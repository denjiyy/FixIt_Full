@page "/admin/issues"
@model FixIt.Areas.Admin.Pages.Issues.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = "Issues Management";
    var resolvedVisible = Model.Issues.Count(i => i.Status == IssueStatus.Fixed);
    var activeVisible = Model.Issues.Count(i => i.Status != IssueStatus.Fixed);
}

<div class="admin-page py-4">
    <section class="admin-hero">
        <div class="admin-hero__row">
            <div>
                <p class="admin-hero__eyebrow"><i class="bi bi-exclamation-triangle"></i> Moderation workspace</p>
                <h1 class="admin-hero__title">Issues Management</h1>
                <p class="admin-hero__subtitle">@Localizer["ReviewAndManageReportedIssues"] Triage reports, resolve stale items, and act on AI-generated recommendations without leaving the queue.</p>
            </div>
            <div class="admin-hero__actions">
                <a href="/admin/dashboard" class="btn btn-outline">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
                <a href="/issues" class="btn btn-primary">
                    <i class="bi bi-box-arrow-up-right"></i> Open public feed
                </a>
            </div>
        </div>
        <div class="admin-hero__stats">
            <div class="admin-hero-stat">
                <strong>@Model.TotalIssues</strong>
                <span>Total issues</span>
            </div>
            <div class="admin-hero-stat">
                <strong>@Model.Issues.Count</strong>
                <span>Visible in view</span>
            </div>
            <div class="admin-hero-stat">
                <strong>@activeVisible</strong>
                <span>Action needed</span>
            </div>
            <div class="admin-hero-stat">
                <strong>@resolvedVisible</strong>
                <span>Resolved here</span>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrEmpty(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }

    <form method="get" class="admin-toolbar">
        <div class="admin-toolbar__row">
            <div class="admin-toolbar__search">
                <input type="text" id="searchInput" name="SearchTerm" value="@Model.SearchTerm" placeholder="@Localizer["SearchByTitle"]" class="form-control">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search"></i> Search
                </button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a href="/admin/issues" class="btn btn-outline">
                        <i class="bi bi-x"></i> Clear
                    </a>
                }
            </div>
        </div>
        <div class="admin-toolbar__meta">
            Found <strong>@Model.Issues.Count</strong> of <strong>@Model.TotalIssues</strong> issues
        </div>
    </form>

    <section class="admin-section-shell">
        <div class="admin-section-shell__head">
            <div>
                <h2 class="section-title mb-0">
                    <i class="bi bi-list-task"></i> Moderation Queue
                </h2>
                <p class="admin-section-shell__copy">Each issue surfaces status, age, and AI context before you decide what happens next.</p>
            </div>
        </div>
        <div class="admin-section-shell__body">
            @if (Model.Issues.Any())
            {
                <div>
                    @foreach (var issue in Model.Issues)
                    {
                        <article class="issue-card">
                            <div class="issue-header">
                                <div>
                                    <h3 class="issue-title">@issue.Title</h3>
                                    <p class="issue-description mb-0">
                                        @(issue.Description.Length > 170 ? issue.Description.Substring(0, 170) + "..." : issue.Description)
                                    </p>
                                </div>
                                <span class="badge-status badge-@issue.Status.ToString().ToLower()">
                                    @issue.Status.ToString().Replace("Inprogress", "In Progress")
                                </span>
                            </div>

                            <div class="issue-meta">
                                <div class="meta-item">
                                    <span class="meta-label">@Localizer["CreatedLabel"]</span>
                                    <span class="meta-value">@issue.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-label">@Localizer["AgeLabel"]</span>
                                    <span class="meta-value">@((DateTime.UtcNow - issue.CreatedAt).Days) days</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-label">@Localizer["StatusLabel"]</span>
                                    <span class="meta-value">@issue.Status</span>
                                </div>
                            </div>

                            <div id="issue-suggestions-@issue.Id" class="mb-3">
                            </div>

                            <details id="issue-summary-@issue.Id" class="ai-summary-details d-none">
                                <summary>
                                    <span>Issue summary</span>
                                    <span class="ai-summary-badge">AI-generated</span>
                                </summary>
                                <div class="ai-summary-details__body"></div>
                            </details>

                            <div class="issue-actions">
                                <button type="button"
                                        class="btn btn-sm btn-outline-primary"
                                        data-summary-trigger
                                        data-summary-type="issue"
                                        data-summary-id="@issue.Id">
                                    <i class="bi bi-stars"></i> Summarize
                                </button>
                                @if (issue.Status != IssueStatus.Fixed)
                                {
                                    <form method="post" asp-page-handler="Resolve" class="admin-inline-form">
                                        <input type="hidden" name="issueId" value="@issue.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success" data-confirm-message="Mark this issue as resolved?">
                                            <i class="bi bi-check-circle"></i> Resolve
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Reopen" class="admin-inline-form">
                                        <input type="hidden" name="issueId" value="@issue.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning" data-confirm-message="Reopen this issue?">
                                            <i class="bi bi-arrow-counterclockwise"></i> Reopen
                                        </button>
                                    </form>
                                }

                                <a href="/issues/@issue.Id" class="btn btn-sm btn-outline">
                                    <i class="bi bi-eye"></i> View
                                </a>

                                @if (User.IsInRole("Admin"))
                                {
                                    <form method="post" asp-page-handler="Delete" class="admin-inline-form">
                                        <input type="hidden" name="issueId" value="@issue.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" data-confirm-message="@Localizer["ConfirmDeleteIssue"]">
                                            <i class="bi bi-trash"></i> @Localizer["Delete"]
                                        </button>
                                    </form>
                                }
                            </div>
                        </article>
                    }
                </div>

                @if (Model.TotalPages > 1)
                {
                    <div class="pagination">
                        @if (Model.PageNumber > 1)
                        {
                            <a href="/admin/issues?pageNumber=1&amp;SearchTerm=@Model.SearchTerm">@Localizer["FirstPage"]</a>
                            <a href="/admin/issues?pageNumber=@(Model.PageNumber - 1)&amp;SearchTerm=@Model.SearchTerm">Previous</a>
                        }

                        @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                        {
                            if (i == Model.PageNumber)
                            {
                                <span class="active">@i</span>
                            }
                            else
                            {
                                <a href="/admin/issues?pageNumber=@i&amp;SearchTerm=@Model.SearchTerm">@i</a>
                            }
                        }

                        @if (Model.PageNumber < Model.TotalPages)
                        {
                            <a href="/admin/issues?pageNumber=@(Model.PageNumber + 1)&amp;SearchTerm=@Model.SearchTerm">Next</a>
                            <a href="/admin/issues?pageNumber=@Model.TotalPages&amp;SearchTerm=@Model.SearchTerm">@Localizer["LastPage"]</a>
                        }
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-exclamation-triangle"></i></div>
                    <h3>@Localizer["NoIssuesReportedYet"]</h3>
                    <p>@(string.IsNullOrEmpty(Model.SearchTerm) ? Localizer["NoIssuesInTheSystem"] : $"{Localizer["FilterResults"]} \"{Model.SearchTerm}\"")</p>
                </div>
            }
        </div>
    </section>
</div>

@section PageScripts {
    <script src="~/js/modules/admin-suggestions.js" defer></script>
    <script src="~/js/pages/admin-issues.js" asp-append-version="true" defer></script>
}
