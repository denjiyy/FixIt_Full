@page "/admin/issues"
@model FixIt.Areas.Admin.Pages.Issues.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = "Issues Management";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
<link rel="stylesheet" href="~/css/admin/admin-issues.css" />

<div class="container-fluid my-4">
    <!-- Header -->
    <div class="admin-header">
        <div class="admin-header-content">
            <div>
                <h1><i class="bi bi-exclamation-triangle"></i> Issues Management</h1>
                <p class="admin-header-subtitle">@Localizer["ReviewAndManageReportedIssues"]</p>
            </div>
            <a href="/admin/dashboard" class="btn btn-outline">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- Messages -->
    @if (!string.IsNullOrEmpty(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }

    <!-- Search -->
    <div class="search-section">
        <div class="search-bar">
            <input type="text" id="searchInput" placeholder="@Localizer["SearchByTitle"]" class="form-control">
            <button class="btn btn-primary" onclick="filterIssues()">
                <i class="bi bi-search"></i> Search
            </button>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <button class="btn btn-outline" onclick="window.location='/admin/issues'">
                    <i class="bi bi-x"></i> Clear
                </button>
            }
        </div>
        <div class="search-results mt-2">
            Found <strong>@Model.Issues.Count</strong> of <strong>@Model.TotalIssues</strong> issues
        </div>
    </div>

    <!-- Issues List -->
    <div class="data-container">
        @if (Model.Issues.Any())
        {
            <div style="padding: 1.5rem;">
                @foreach (var issue in Model.Issues)
                {
                    <div class="issue-card">
                        <div class="issue-header">
                            <h3 class="issue-title">@issue.Title</h3>
                            <span class="badge-status badge-@issue.Status.ToString().ToLower()">
                                @issue.Status.ToString().Replace("Inprogress", "In Progress")
                            </span>
                        </div>

                        <p class="issue-description">
                            @(issue.Description.Length > 150 ? issue.Description.Substring(0, 150) + "..." : issue.Description)
                        </p>

                        <div class="issue-meta">
                            <div class="meta-item">
                                <span class="meta-label">@Localizer["CreatedLabel"]</span>
                                <span class="meta-value">@issue.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                            @if (issue.Status != IssueStatus.Fixed)
                            {
                                <div class="meta-item">
                                    <span class="meta-label">@Localizer["AgeLabel"]</span>
                                    <span class="meta-value">@((DateTime.UtcNow - issue.CreatedAt).Days) days</span>
                                </div>
                            }
                            <div class="meta-item">
                                <span class="meta-label">@Localizer["ReportsLabel"]</span>
                                <span class="meta-value">-</span>
                            </div>
                        </div>

                        <!-- AI Suggestions -->
                        <div id="issue-suggestions-@issue.Id" class="mb-3">
                            <!-- Suggestions will be loaded here -->
                        </div>

                        <div class="issue-actions">
                            @if (issue.Status != IssueStatus.Fixed)
                            {
                                <form method="post" asp-page-handler="Resolve" style="display: inline;">
                                    <input type="hidden" name="issueId" value="@issue.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline" style="color: #10b981;" onclick="return confirm('Mark as resolved?');">
                                        <i class="bi bi-check-circle"></i> Resolve
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="Reopen" style="display: inline;">
                                    <input type="hidden" name="issueId" value="@issue.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline" onclick="return confirm('Reopen this issue?');">
                                        <i class="bi bi-arrow-counterclockwise"></i> Reopen
                                    </button>
                                </form>
                            }

                            <a href="#" class="btn btn-sm btn-outline">
                                <i class="bi bi-eye"></i> View
                            </a>

                            @if (User.IsInRole("Admin"))
                            {
                                <form method="post" asp-page-handler="Delete" style="display: inline;">
                                    <input type="hidden" name="issueId" value="@issue.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick='return confirm("@Localizer["ConfirmDeleteIssue"]");'>
                                        <i class="bi bi-trash"></i> @Localizer["Delete"]
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="pagination">
                    @if (Model.PageNumber > 1)
                    {
                        <a href="/admin/issues?pageNumber=1">@Localizer["FirstPage"]</a>
                        <a href="/admin/issues?pageNumber=@(Model.PageNumber - 1)">Previous</a>
                    }

                    @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                    {
                        if (i == Model.PageNumber)
                        {
                            <span class="active">@i</span>
                        }
                        else
                        {
                            <a href="/admin/issues?pageNumber=@i">@i</a>
                        }
                    }

                    @if (Model.PageNumber < Model.TotalPages)
                    {
                        <a href="/admin/issues?pageNumber=@(Model.PageNumber + 1)">Next</a>
                        <a href="/admin/issues?pageNumber=@Model.TotalPages">@Localizer["LastPage"]</a>
                    }
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state-icon"><i class="bi bi-exclamation-triangle"></i></div>
                <h3>@Localizer["NoIssuesReportedYet"]</h3>
                <p>@(string.IsNullOrEmpty(Model.SearchTerm) ? Localizer["NoIssuesInTheSystem"] : $"{Localizer["FilterResults"]} \"{Model.SearchTerm}\"")</p>
            </div>
        }
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/modules/admin-suggestions.js" defer></script>
<script>
    function filterIssues() {
        const search = document.getElementById('searchInput').value;
        if (search.trim()) {
            window.location = `/admin/issues?SearchTerm=${encodeURIComponent(search)}`;
        }
    }

    // Load suggestions for each issue
    document.addEventListener('DOMContentLoaded', async () => {
        const issueCards = document.querySelectorAll('[id^="issue-suggestions-"]');
        for (const card of issueCards) {
            const issueId = card.id.replace('issue-suggestions-', '');
            try {
                const suggestions = await AdminSuggestions.generateIssueSuggestions(issueId);
                if (suggestions && suggestions.length > 0) {
                    AdminSuggestions.displaySuggestionList(suggestions, card.id);
                }
            } catch (err) {
                console.error(`Error loading suggestions for issue ${issueId}:`, err);
            }
        }
    });
</script>
