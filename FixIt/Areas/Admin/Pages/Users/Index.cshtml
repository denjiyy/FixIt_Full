@page "/admin/users"
@model FixIt.Areas.Admin.Pages.Users.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = "Users Management";
    var bannedVisible = Model.Users.Count(u => u.IsBanned);
    var restrictedVisible = Model.Users.Count(u => u.IsRestricted && u.RestrictedUntil > DateTime.UtcNow);
    var activeVisible = Model.Users.Count - bannedVisible - restrictedVisible;
}

<div class="admin-page py-4">
    <section class="admin-hero">
        <div class="admin-hero__row">
            <div>
                <p class="admin-hero__eyebrow"><i class="bi bi-people"></i> Community governance</p>
                <h1 class="admin-hero__title">Users Management</h1>
                <p class="admin-hero__subtitle">Review trust signals, moderate harmful behavior, and manage roles without losing the broader account context.</p>
            </div>
            <div class="admin-hero__actions">
                <a href="/admin/dashboard" class="btn btn-outline">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
                <a href="/admin/reports" class="btn btn-primary">
                    <i class="bi bi-shield-exclamation"></i> Trust and safety
                </a>
            </div>
        </div>
        <div class="admin-hero__stats">
            <div class="admin-hero-stat">
                <strong>@Model.TotalUsers</strong>
                <span>Total users</span>
            </div>
            <div class="admin-hero-stat">
                <strong>@activeVisible</strong>
                <span>Active</span>
            </div>
            <div class="admin-hero-stat">
                <strong>@restrictedVisible</strong>
                <span>Restricted</span>
            </div>
            <div class="admin-hero-stat">
                <strong>@bannedVisible</strong>
                <span>Banned</span>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrEmpty(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (!string.IsNullOrEmpty(TempData["ErrorMessage"]?.ToString()))
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-circle"></i> @TempData["ErrorMessage"]
        </div>
    }

    <form method="get" class="admin-toolbar">
        <div class="admin-toolbar__row">
            <div class="admin-toolbar__search">
                <input type="text" id="searchInput" name="SearchTerm" value="@Model.SearchTerm" placeholder="@Localizer["SearchByEmailUsernameOrName"]" class="form-control">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search"></i> Search
                </button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a href="/admin/users" class="btn btn-outline">
                        <i class="bi bi-x"></i> Clear
                    </a>
                }
            </div>
        </div>
        <div class="admin-toolbar__meta">
            Found <strong>@Model.Users.Count</strong> of <strong>@Model.TotalUsers</strong> users
        </div>
    </form>

    <section class="admin-section-shell">
        <div class="admin-section-shell__head">
            <div>
                <h2 class="section-title mb-0">
                    <i class="bi bi-person-gear"></i> Member Directory
                </h2>
                <p class="admin-section-shell__copy">Each member card shows role, verification, moderation state, and the fastest available actions.</p>
            </div>
        </div>
        <div class="admin-section-shell__body">
            @if (Model.Users.Any())
            {
                <div>
                    @foreach (var user in Model.Users)
                    {
                        <article class="user-card">
                            <div class="user-header">
                                <div class="user-avatar">
                                    @(user.DisplayName?.FirstOrDefault().ToString().ToUpper() ?? "U")
                                </div>
                                <div class="user-info flex-grow-1">
                                    <h3>@user.DisplayName</h3>
                                    <p>@user.Email</p>
                                </div>
                            </div>

                            <div class="mb-3">
                                <span class="badge-status badge-role-@user.Role.ToString().ToLower()">
                                    @user.Role.ToString()
                                </span>
                                @if (user.EmailConfirmed)
                                {
                                    <span class="badge-status badge-verified">
                                        <i class="bi bi-check-circle"></i> Verified
                                    </span>
                                }
                                @if (user.IsBanned)
                                {
                                    <span class="badge-status badge-banned">
                                        <i class="bi bi-ban"></i> Banned
                                    </span>
                                }
                                else if (user.IsRestricted && user.RestrictedUntil > DateTime.UtcNow)
                                {
                                    <span class="badge-status badge-restricted">
                                        <i class="bi bi-exclamation-circle"></i> Restricted
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-status badge-active">
                                        <i class="bi bi-check-circle"></i> Active
                                    </span>
                                }
                            </div>

                            <div class="user-meta">
                                <div class="meta-item">
                                    <span class="meta-label">@Localizer["ReputationLabel"]</span>
                                    <span class="meta-value">@user.ReputationScore pts</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-label">@Localizer["JoinedLabel"]</span>
                                    <span class="meta-value">@user.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-label">@Localizer["StatusLabel"]</span>
                                    <span class="meta-value">@(user.EmailConfirmed ? "Verified" : "Unverified")</span>
                                </div>
                            </div>

                            <div class="user-actions">
                                <a href="/user/@user.Id" class="btn btn-sm btn-outline" title="View Profile">
                                    <i class="bi bi-eye"></i> View
                                </a>

                                @if (user.IsBanned)
                                {
                                    <form method="post" asp-page-handler="Unban" class="admin-inline-form">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline" data-confirm-message="@Localizer["ConfirmUnbanUser"]">
                                            <i class="bi bi-unlock"></i> Unban
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Ban" class="admin-inline-form">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm-message="@Localizer["ConfirmBanUser"]">
                                            <i class="bi bi-ban"></i> Ban
                                        </button>
                                    </form>
                                }

                                @if (user.IsRestricted && user.RestrictedUntil > DateTime.UtcNow)
                                {
                                    <form method="post" asp-page-handler="Unrestrict" class="admin-inline-form">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline" data-confirm-message="@Localizer["ConfirmRemoveRestrictions"]">
                                            <i class="bi bi-check-circle"></i> Unrestrict
                                        </button>
                                    </form>
                                }
                                else if (!user.IsBanned)
                                {
                                    <form method="post" asp-page-handler="Restrict" class="admin-inline-form">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning" data-confirm-message="@Localizer["ConfirmRestrictUser"]">
                                            <i class="bi bi-pause-circle"></i> Restrict
                                        </button>
                                    </form>
                                }

                                <button type="button" class="btn btn-sm btn-outline" data-bs-toggle="modal"
                                        data-bs-target="#roleModal" data-user-id="@user.Id" data-user-email="@user.Email">
                                    <i class="bi bi-pencil"></i> Role
                                </button>

                                <form method="post" asp-page-handler="Delete" class="admin-inline-form">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger" data-confirm-message="@Localizer["ConfirmDeleteUser"]">
                                        <i class="bi bi-trash"></i> @Localizer["Delete"]
                                    </button>
                                </form>
                            </div>
                        </article>
                    }
                </div>

                @if (Model.TotalPages > 1)
                {
                    <div class="pagination">
                        @if (Model.PageNumber > 1)
                        {
                            <a href="/admin/users?pageNumber=1&amp;SearchTerm=@Model.SearchTerm">@Localizer["FirstPage"]</a>
                            <a href="/admin/users?pageNumber=@(Model.PageNumber - 1)&amp;SearchTerm=@Model.SearchTerm">Previous</a>
                        }

                        @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                        {
                            if (i == Model.PageNumber)
                            {
                                <span class="active">@i</span>
                            }
                            else
                            {
                                <a href="/admin/users?pageNumber=@i&amp;SearchTerm=@Model.SearchTerm">@i</a>
                            }
                        }

                        @if (Model.PageNumber < Model.TotalPages)
                        {
                            <a href="/admin/users?pageNumber=@(Model.PageNumber + 1)&amp;SearchTerm=@Model.SearchTerm">Next</a>
                            <a href="/admin/users?pageNumber=@Model.TotalPages&amp;SearchTerm=@Model.SearchTerm">@Localizer["LastPage"]</a>
                        }
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-people"></i></div>
                    <h3>@Localizer["NoUsersFound"]</h3>
                    <p>@(string.IsNullOrEmpty(Model.SearchTerm) ? Localizer["NoUsersInTheSystem"] : $"{Localizer["FilterResults"]} \"{Model.SearchTerm}\"")</p>
                </div>
            }
        </div>
    </section>
</div>

<div class="modal fade" id="roleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Localizer["ChangeUserRoleModal"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="roleForm" method="post" asp-page-handler="ChangeRole">
                    <input type="hidden" id="userId" name="userId" />
                    <div class="mb-3">
                        <label for="userEmail" class="form-label">@Localizer["UserEmailLabel"]</label>
                        <input type="text" class="form-control" id="userEmail" disabled />
                    </div>
                    <div class="mb-3">
                        <label for="newRole" class="form-label">New Role</label>
                        <select class="form-select" id="newRole" name="role" required>
                            <option value="">Select a role</option>
                            <option value="User">Regular User</option>
                            <option value="Moderator">Moderator</option>
                            <option value="Admin">Administrator</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">@Localizer["UpdateRoleBtn"]</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
    <script src="~/js/pages/admin-users.js" asp-append-version="true" defer></script>
}
