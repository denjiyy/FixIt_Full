@page "/admin/reports"
@model FixIt.Areas.Admin.Pages.Reports.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = "Reports Management";
    var pendingVisible = Model.Reports.Count(r => r.Status == ReportStatus.Pending);
    var reviewedVisible = Model.Reports.Count(r => r.Status != ReportStatus.Pending);
}

<div class="admin-page py-4">
    <section class="admin-hero">
        <div class="admin-hero__row">
            <div>
                <p class="admin-hero__eyebrow"><i class="bi bi-flag"></i> Trust and safety</p>
                <h1 class="admin-hero__title">Reports Management</h1>
                <p class="admin-hero__subtitle">@Localizer["ReviewAndManageUserReports"] Review abuse signals, uphold valid reports, and dismiss noise with clearer operational context.</p>
            </div>
            <div class="admin-hero__actions">
                <a href="/admin/dashboard" class="btn btn-outline">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
                <a href="/admin/users" class="btn btn-primary">
                    <i class="bi bi-people"></i> Review users
                </a>
            </div>
        </div>
        <div class="admin-hero__stats">
            <div class="admin-hero-stat">
                <strong>@Model.TotalReports</strong>
                <span>Total reports</span>
            </div>
            <div class="admin-hero-stat">
                <strong>@Model.Reports.Count</strong>
                <span>Visible in view</span>
            </div>
            <div class="admin-hero-stat">
                <strong>@pendingVisible</strong>
                <span>Pending review</span>
            </div>
            <div class="admin-hero-stat">
                <strong>@reviewedVisible</strong>
                <span>Reviewed here</span>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrEmpty(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }

    <form method="get" class="admin-toolbar">
        <div class="admin-toolbar__row">
            <div class="admin-toolbar__search">
                <input type="text" id="searchInput" name="SearchTerm" value="@Model.SearchTerm" placeholder="@Localizer["SearchByReason"]" class="form-control">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search"></i> Search
                </button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a href="/admin/reports" class="btn btn-outline">
                        <i class="bi bi-x"></i> Clear
                    </a>
                }
            </div>
        </div>
        <div class="admin-toolbar__meta">
            Found <strong>@Model.Reports.Count</strong> of <strong>@Model.TotalReports</strong> reports
        </div>
    </form>

    <section class="admin-section-shell">
        <div class="admin-section-shell__head">
            <div>
                <h2 class="section-title mb-0">
                    <i class="bi bi-list-check"></i> Review Queue
                </h2>
                <p class="admin-section-shell__copy">Each report includes its target, current status, and AI guidance before you act.</p>
            </div>
        </div>
        <div class="admin-section-shell__body">
            @if (Model.Reports.Any())
            {
                <div>
                    @foreach (var report in Model.Reports)
                    {
                        var targetUrl = report.TargetType switch
                        {
                            FixIt.Models.Enums.ModerationTargetType.Issue => $"/issues/{report.TargetId}",
                            FixIt.Models.Enums.ModerationTargetType.User => $"/user/{report.TargetId}",
                            _ => string.Empty
                        };

                        <article class="report-card">
                            <div class="report-header">
                                <div>
                                    <h3 class="report-reason">@(report.Reason.ToString()) reported</h3>
                                    <p class="report-details mb-0">
                                        @(string.IsNullOrEmpty(report.Details) ? "No details provided" : (report.Details.Length > 170 ? report.Details.Substring(0, 170) + "..." : report.Details))
                                    </p>
                                </div>
                                <span class="badge-status badge-@report.Status.ToString().ToLower()">
                                    @report.Status.ToString().Replace("Underreview", "Under Review")
                                </span>
                            </div>

                            <div class="report-meta">
                                <div class="meta-item">
                                    <span class="meta-label">@Localizer["TargetLabel"]</span>
                                    <span class="meta-value">@report.TargetType</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-label">@Localizer["CreatedLabel"]</span>
                                    <span class="meta-value">@report.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-label">@Localizer["StatusLabel"]</span>
                                    <span class="meta-value">@report.Status</span>
                                </div>
                            </div>

                            <div id="suggestions-@report.Id" class="mb-3 d-none">
                                <div class="alert alert-info" role="alert">
                                    <small class="text-muted">
                                        <i class="bi bi-lightbulb"></i> AI Suggestion
                                    </small>
                                    <div class="suggestion-spacer"></div>
                                </div>
                            </div>

                            <details id="report-summary-@report.Id" class="ai-summary-details d-none">
                                <summary>
                                    <span>Report summary</span>
                                    <span class="ai-summary-badge">AI-generated</span>
                                </summary>
                                <div class="ai-summary-details__body"></div>
                            </details>

                            <div class="report-actions">
                                <button type="button"
                                        class="btn btn-sm btn-outline-primary"
                                        data-summary-trigger
                                        data-summary-type="report"
                                        data-summary-id="@report.Id">
                                    <i class="bi bi-stars"></i> Summarize
                                </button>
                                @if (report.Status == ReportStatus.Pending)
                                {
                                    <form method="post" asp-page-handler="Approve" class="admin-inline-form">
                                        <input type="hidden" name="reportId" value="@report.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success" data-confirm-message="@Localizer["ConfirmApproveReport"]">
                                            <i class="bi bi-check-circle"></i> Uphold
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="Reject" class="admin-inline-form">
                                        <input type="hidden" name="reportId" value="@report.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm-message="@Localizer["ConfirmDismissReport"]">
                                            <i class="bi bi-x-circle"></i> Dismiss
                                        </button>
                                    </form>
                                }

                                @if (!string.IsNullOrEmpty(targetUrl))
                                {
                                    <a href="@targetUrl" class="btn btn-sm btn-outline">
                                        <i class="bi bi-eye"></i> View target
                                    </a>
                                }

                                @if (User.IsInRole("Admin"))
                                {
                                    <form method="post" asp-page-handler="Delete" class="admin-inline-form">
                                        <input type="hidden" name="reportId" value="@report.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" data-confirm-message="@Localizer["ConfirmDeleteReport"]">
                                            <i class="bi bi-trash"></i> @Localizer["Delete"]
                                        </button>
                                    </form>
                                }
                            </div>
                        </article>
                    }
                </div>

                @if (Model.TotalPages > 1)
                {
                    <div class="pagination">
                        @if (Model.PageNumber > 1)
                        {
                            <a href="/admin/reports?pageNumber=1&amp;SearchTerm=@Model.SearchTerm">@Localizer["FirstPage"]</a>
                            <a href="/admin/reports?pageNumber=@(Model.PageNumber - 1)&amp;SearchTerm=@Model.SearchTerm">Previous</a>
                        }

                        @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                        {
                            if (i == Model.PageNumber)
                            {
                                <span class="active">@i</span>
                            }
                            else
                            {
                                <a href="/admin/reports?pageNumber=@i&amp;SearchTerm=@Model.SearchTerm">@i</a>
                            }
                        }

                        @if (Model.PageNumber < Model.TotalPages)
                        {
                            <a href="/admin/reports?pageNumber=@(Model.PageNumber + 1)&amp;SearchTerm=@Model.SearchTerm">Next</a>
                            <a href="/admin/reports?pageNumber=@Model.TotalPages&amp;SearchTerm=@Model.SearchTerm">@Localizer["LastPage"]</a>
                        }
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-flag"></i></div>
                    <h3>@Localizer["NoReportsFound"]</h3>
                    <p>@(string.IsNullOrEmpty(Model.SearchTerm) ? Localizer["NoReportsInTheSystem"] : $"{Localizer["FilterResults"]} \"{Model.SearchTerm}\"")</p>
                </div>
            }
        </div>
    </section>
</div>

@section PageScripts {
    <script src="~/js/modules/admin-suggestions.js" defer></script>
    <script src="~/js/pages/admin-reports.js" asp-append-version="true" defer></script>
}
