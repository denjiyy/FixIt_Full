@page "/admin/login"
@model FixIt.Areas.Admin.Pages.LoginModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = "Admin & Moderator Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/design-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
</head>
<body class="admin-login">
    <main class="admin-login-shell">
        <section class="admin-login-panel">
            <div class="admin-login-mark mb-4">
                <i class="bi bi-shield-lock"></i>
            </div>
            <span class="admin-topbar__eyebrow text-white-50">Restricted access</span>
            <h1 class="display-5 fw-bold text-white mb-3">@Localizer["AdminPanel"]</h1>
            <p class="fs-5 text-white-50 mb-0">@Localizer["ManagementPortalForFixIt"]</p>

            <div class="admin-login-stats">
                <div class="admin-login-stat">
                    <span>Moderation</span>
                    <strong>Live queues</strong>
                </div>
                <div class="admin-login-stat">
                    <span>Security</span>
                    <strong>Role-gated access</strong>
                </div>
                <div class="admin-login-stat">
                    <span>Coverage</span>
                    <strong>Users, issues, reports</strong>
                </div>
            </div>

            <div class="admin-login-points">
                <div class="admin-login-point">
                    <i class="bi bi-people"></i>
                    <div>
                        <strong>Moderation workflows</strong>
                        <div class="text-white-50">Review users, issues, reports, and city coverage from one secure workspace.</div>
                    </div>
                </div>
                <div class="admin-login-point">
                    <i class="bi bi-lightning-charge"></i>
                    <div>
                        <strong>Fast response tools</strong>
                        <div class="text-white-50">Take action quickly with focused search, moderation controls, and AI-assisted review surfaces.</div>
                    </div>
                </div>
                <div class="admin-login-point">
                    <i class="bi bi-shield-check"></i>
                    <div>
                        <strong>Role-based access</strong>
                        <div class="text-white-50">Only administrators and moderators can enter this interface.</div>
                    </div>
                </div>
            </div>

            <div class="admin-login-footer">
                <div class="admin-login-footer__note">
                    <i class="bi bi-shield-check"></i>
                    <span>Only administrator and moderator accounts can authenticate into this workspace.</span>
                </div>
                <small><i class="bi bi-house-door me-1"></i><a href="/" class="link-light">Return to the public app</a></small>
            </div>
        </section>

        <section class="admin-login-card">
            <div class="admin-login-card__body">
                <span class="admin-login-card__eyebrow">Operator sign in</span>
                <h2 class="h3 fw-bold mb-2">Sign in to continue</h2>
                <p class="text-muted mb-4">Use your moderator or administrator account credentials.</p>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-circle me-2"></i>@Model.ErrorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form method="post" novalidate>
                    <div class="form-group">
                        <label for="username" class="form-label">Username</label>
                        <input type="text"
                               class="form-control @(ModelState.ContainsKey("Input.Username") && ModelState["Input.Username"]?.Errors.Any() == true ? "is-invalid" : "")"
                               id="username"
                               asp-for="Input.Username"
                               autocomplete="username"
                               required
                               placeholder="@Localizer["EnterYourUsername"]">
                        <span asp-validation-for="Input.Username" class="text-danger small"></span>
                    </div>

                    <div class="form-group">
                        <label for="password" class="form-label">Password</label>
                        <input type="password"
                               class="form-control @(ModelState.ContainsKey("Input.Password") && ModelState["Input.Password"]?.Errors.Any() == true ? "is-invalid" : "")"
                               id="password"
                               asp-for="Input.Password"
                               autocomplete="current-password"
                               required
                               placeholder="@Localizer["EnterYourPassword"]">
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="remember" asp-for="Input.RememberMe">
                            <label class="form-check-label" for="remember">Remember me for 30 days</label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3" id="loginBtn">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign in
                    </button>
                </form>

                <div class="admin-login-card__foot">
                    <div class="admin-login-card__support">
                        <i class="bi bi-life-preserver"></i>
                        <span>Having trouble getting in? Confirm your role assignment and current credentials before retrying.</span>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/pages/admin-login.js" asp-append-version="true" defer></script>
</body>
</html>
