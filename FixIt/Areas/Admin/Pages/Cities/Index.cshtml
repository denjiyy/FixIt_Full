@page "/admin/cities"
@model FixIt.Areas.Admin.Pages.Cities.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = "Cities Management";
    ViewData["RequiresMap"] = true;
    var visibleCount = Model.Cities.Count;
    var countries = new[] { "Afghanistan", "Albania", "Algeria", "Andorra", "Angola", "Argentina", "Armenia", "Austria", "Azerbaijan", "Bahamas", "Bahrain", "Bangladesh", "Barbados", "Belarus", "Belgium", "Belize", "Benin", "Bhutan", "Bolivia", "Bosnia and Herzegovina", "Botswana", "Brazil", "Brunei", "Bulgaria", "Burkina Faso", "Burundi", "Cambodia", "Cameroon", "Canada", "Cape Verde", "Central African Republic", "Chad", "Chile", "China", "Colombia", "Comoros", "Congo", "Costa Rica", "Croatia", "Cuba", "Cyprus", "Czech Republic", "Czechia", "Democratic Republic of the Congo", "Denmark", "Djibouti", "Dominica", "Dominican Republic", "East Timor", "Ecuador", "Egypt", "El Salvador", "Equatorial Guinea", "Eritrea", "Estonia", "Ethiopia", "Fiji", "Finland", "France", "Gabon", "Gambia", "Georgia", "Germany", "Ghana", "Greece", "Grenada", "Guatemala", "Guinea", "Guinea-Bissau", "Guyana", "Haiti", "Honduras", "Hong Kong", "Hungary", "Iceland", "India", "Indonesia", "Iran", "Iraq", "Ireland", "Israel", "Italy", "Ivory Coast", "Jamaica", "Japan", "Jordan", "Kazakhstan", "Kenya", "Kiribati", "Kosovo", "Kuwait", "Kyrgyzstan", "Laos", "Latvia", "Lebanon", "Lesotho", "Liberia", "Libya", "Liechtenstein", "Lithuania", "Luxembourg", "Macao", "Madagascar", "Malawi", "Malaysia", "Maldives", "Mali", "Malta", "Marshall Islands", "Mauritania", "Mauritius", "Mexico", "Micronesia", "Moldova", "Monaco", "Mongolia", "Montenegro", "Morocco", "Mozambique", "Myanmar", "Namibia", "Nauru", "Nepal", "Netherlands", "New Zealand", "Nicaragua", "Niger", "Nigeria", "North Korea", "North Macedonia", "Norway", "Oman", "Pakistan", "Palau", "Palestine", "Panama", "Papua New Guinea", "Paraguay", "Peru", "Philippines", "Poland", "Portugal", "Qatar", "Republic of the Congo", "Romania", "Russia", "Rwanda", "Samoa", "San Marino", "Sao Tome and Principe", "Saudi Arabia", "Senegal", "Serbia", "Seychelles", "Sierra Leone", "Singapore", "Slovakia", "Slovenia", "Solomon Islands", "Somalia", "South Africa", "South Korea", "South Sudan", "Spain", "Sri Lanka", "Sudan", "Suriname", "Sweden", "Switzerland", "Syria", "Taiwan", "Tajikistan", "Tanzania", "Thailand", "Togo", "Tonga", "Trinidad and Tobago", "Tunisia", "Turkey", "Turkmenistan", "Tuvalu", "Uganda", "Ukraine", "United Arab Emirates", "United Kingdom", "United States", "Uruguay", "Uzbekistan", "Vanuatu", "Vatican City", "Venezuela", "Vietnam", "Yemen", "Zambia", "Zimbabwe" };
}

<div class="admin-page py-4">
    <section class="admin-hero">
        <div class="admin-hero__row">
            <div>
                <p class="admin-hero__eyebrow"><i class="bi bi-globe"></i> Coverage Management</p>
                <h1 class="admin-hero__title">Cities Management</h1>
                <p class="admin-hero__subtitle">@Localizer["AddAndManageCitiesWorldwide"] Expand regional coverage, maintain metadata quality, and place cities precisely on the map.</p>
            </div>
            <div class="admin-hero__actions">
                <a href="/admin/dashboard" class="btn btn-outline">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
                <a href="/cities" class="btn btn-primary">
                    <i class="bi bi-box-arrow-up-right"></i> Open Public Explorer
                </a>
            </div>
        </div>
        <div class="admin-hero__stats">
            <div class="admin-hero-stat">
                <strong>@Model.TotalCities</strong>
                <span>Total Cities</span>
            </div>
            <div class="admin-hero-stat">
                <strong>@visibleCount</strong>
                <span>Visible In View</span>
            </div>
            <div class="admin-hero-stat">
                <strong>@countries.Length</strong>
                <span>Countries Available</span>
            </div>
            <div class="admin-hero-stat">
                <strong>@Model.PageNumber</strong>
                <span>Current Page</span>
            </div>
        </div>
    </section>

    <!-- Messages -->
    @if (!string.IsNullOrEmpty(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (!string.IsNullOrEmpty(TempData["ErrorMessage"]?.ToString()))
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-circle"></i> @TempData["ErrorMessage"]
        </div>
    }

    <!-- Add City Form -->
    <section class="admin-section-shell">
        <div class="admin-section-shell__head">
            <div>
                <h2 class="section-title mb-0"><i class="bi bi-plus-circle"></i> Add New City</h2>
                <p class="admin-section-shell__copy">Create a new city record with validated coordinates and optional presentation details.</p>
            </div>
        </div>
        <div class="admin-section-shell__body">
        <form method="post" asp-page-handler="AddCity">
            <div class="form-row">
                <div class="form-group">
                    <label for="CityName">City Name *</label>
                    <input type="text" class="form-control" id="CityName" name="CityName" required placeholder="@Localizer["ExampleNewYork"]">
                </div>
                <div class="form-group">
                    <label for="Country">Country *</label>
                    <select class="form-control" id="Country" name="Country" required>
                        <option value="">Select a country...</option>
                        @foreach (var country in countries.OrderBy(c => c))
                        {
                            <option value="@country">@country</option>
                        }
                    </select>
                </div>
            </div>

            <div class="form-group mb-3">
                <label>Coordinates *</label>
                <div id="coordinatesMap"></div>
                <div class="map-info">
                    <i class="bi bi-info-circle"></i> @Localizer["ClickOnTheMapToSelectCoordinates"]. @Localizer["CurrentCoordinates"]: <strong><span id="coordsDisplay">@Localizer["NotSelected"]</span></strong>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="Latitude">@Localizer["Latitude"]</label>
                    <input type="number" class="form-control" id="Latitude" name="Latitude" step="0.0001" readonly>
                </div>
                <div class="form-group">
                    <label for="Longitude">@Localizer["Longitude"]</label>
                    <input type="number" class="form-control" id="Longitude" name="Longitude" step="0.0001" readonly>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="Description">Description (Optional)</label>
                    <textarea class="form-control" id="Description" name="Description" placeholder="@Localizer["AdditionalInformationAboutThisCity"]"></textarea>
                </div>
                <div class="form-group">
                    <label for="PhotoUrl">City Image URL (Optional)</label>
                    <input type="url" class="form-control" id="PhotoUrl" name="PhotoUrl" placeholder="@Localizer["CityImageUrl"]">
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus"></i> Add City
                </button>
                <button type="reset" class="btn btn-outline">@Localizer["ClearFilters"]</button>
            </div>
        </form>
        </div>
    </section>

    <form method="get" class="admin-toolbar">
        <div class="admin-toolbar__row">
            <div class="admin-toolbar__search">
                <input type="text" id="searchInput" name="SearchTerm" value="@Model.SearchTerm" placeholder="@Localizer["SearchByCityOrCountry"]" class="form-control">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search"></i> Search
                </button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a href="/admin/cities" class="btn btn-outline">
                        <i class="bi bi-x"></i> Clear
                    </a>
                }
            </div>
        </div>
        <div class="admin-toolbar__meta">
            Found <strong>@Model.Cities.Count</strong> of <strong>@Model.TotalCities</strong> cities
        </div>
    </form>

    <!-- Cities List -->
    <section class="admin-section-shell">
        <div class="admin-section-shell__head">
            <div>
                <h2 class="section-title mb-0"><i class="bi bi-building"></i> City Directory</h2>
                <p class="admin-section-shell__copy">Browse existing city records, confirm coordinates, and remove outdated entries.</p>
            </div>
        </div>
        <div class="admin-section-shell__body">
        @if (Model.Cities.Any())
        {
            <div>
                @foreach (var city in Model.Cities)
                {
                    <div class="city-card">
                        @if (!string.IsNullOrEmpty(city.PhotoUrl))
                        {
                            <div class="city-photo-frame">
                                <img src="@city.PhotoUrl" alt="@city.Name" class="city-photo" loading="lazy">
                            </div>
                        }
                        <div>
                            <h3 class="city-title">@city.Name</h3>
                            <p class="city-summary">
                                <i class="bi bi-geo-alt"></i> @city.Country
                            </p>
                            @if (!string.IsNullOrEmpty(city.Description))
                            {
                                <p class="city-description">@city.Description</p>
                            }
                            <div class="city-meta">
                                <div class="meta-item">
                                    <span class="meta-label">@Localizer["Latitude"]</span>
                                    <span class="meta-value">@city.Latitude.ToString("F4")</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-label">@Localizer["Longitude"]</span>
                                    <span class="meta-value">@city.Longitude.ToString("F4")</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-label">@Localizer["CreatedLabel"]</span>
                                    <span class="meta-value">@city.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>
                        </div>
                        <div class="city-actions-row">
                            <form method="post" asp-page-handler="Delete" class="admin-inline-form">
                                <input type="hidden" name="cityId" value="@city.Id" />
                                <button type="submit" class="btn btn-danger btn-sm" data-confirm-message="@Localizer["ConfirmDeleteCity"]">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="pagination">
                    @if (Model.PageNumber > 1)
                    {
                        <a href="/admin/cities?pageNumber=1">@Localizer["FirstPage"]</a>
                        <a href="/admin/cities?pageNumber=@(Model.PageNumber - 1)">Previous</a>
                    }

                    @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                    {
                        if (i == Model.PageNumber)
                        {
                            <span class="active">@i</span>
                        }
                        else
                        {
                            <a href="/admin/cities?pageNumber=@i">@i</a>
                        }
                    }

                    @if (Model.PageNumber < Model.TotalPages)
                    {
                        <a href="/admin/cities?pageNumber=@(Model.PageNumber + 1)">Next</a>
                        <a href="/admin/cities?pageNumber=@Model.TotalPages">@Localizer["LastPage"]</a>
                    }
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state-icon"><i class="bi bi-globe"></i></div>
                <h3>No cities found</h3>
                <p>@(string.IsNullOrEmpty(Model.SearchTerm) ? Localizer["AddYourFirstCityToGetStarted"] : $"No results for \"{Model.SearchTerm}\"")</p>
            </div>
        }
        </div>
    </section>
</div>

@section PageScripts {
    <script src="~/js/pages/admin-cities.js" asp-append-version="true" defer></script>
}
