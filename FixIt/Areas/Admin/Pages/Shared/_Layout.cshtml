@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    var showMapAssets = ViewData["RequiresMap"] as bool? == true;
    var bodyClass = ViewData["BodyClass"]?.ToString() ?? string.Empty;
    var currentPath = Context.Request.Path.Value ?? "/admin/dashboard";

    bool IsActive(string path) => currentPath.StartsWith(path, System.StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Admin Panel") - FixIt</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/design-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    @if (showMapAssets)
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />
    }

    @await RenderSectionAsync("PageCss", required: false)
</head>
<body class="admin-shell @bodyClass" data-current-path="@currentPath">
    <div class="admin-shell__frame">
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="admin-sidebar__brand">
                <a href="/admin/dashboard" class="admin-brand">
                    <span class="admin-brand__mark" aria-hidden="true"><i class="bi bi-shield-lock"></i></span>
                    <span>
                        <strong>FixIt Admin</strong>
                        <small>@Localizer["ManagementPortalForFixIt"]</small>
                    </span>
                </a>
                <button class="admin-sidebar__close btn btn-link d-xl-none" type="button" data-admin-close aria-label="Close menu">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <nav class="admin-nav" aria-label="Admin navigation">
                <a href="/admin/dashboard" class="admin-nav__link @(IsActive("/admin/dashboard") ? "is-active" : "")">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a href="/admin/users" class="admin-nav__link @(IsActive("/admin/users") ? "is-active" : "")">
                        <i class="bi bi-people"></i>
                        <span>Users</span>
                    </a>
                }
                <a href="/admin/issues" class="admin-nav__link @(IsActive("/admin/issues") ? "is-active" : "")">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>Issues</span>
                </a>
                <a href="/admin/reports" class="admin-nav__link @(IsActive("/admin/reports") ? "is-active" : "")">
                    <i class="bi bi-flag"></i>
                    <span>Reports</span>
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a href="/admin/cities" class="admin-nav__link @(IsActive("/admin/cities") ? "is-active" : "")">
                        <i class="bi bi-globe2"></i>
                        <span>Cities</span>
                    </a>
                }
            </nav>

            <div class="admin-sidebar__footer">
                <a href="/" class="admin-utility-link">
                    <i class="bi bi-arrow-up-right-square"></i>
                    <span>Open public app</span>
                </a>
                <a href="/settings" class="admin-utility-link">
                    <i class="bi bi-sliders"></i>
                    <span>Settings</span>
                </a>
                <form id="adminLogoutForm" method="post" asp-area="Identity" asp-page="/Account/Logout">
                    <button type="submit" class="admin-logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>@Localizer["SignOut"]</span>
                    </button>
                </form>
            </div>
        </aside>

        <div class="admin-main">
            <header class="admin-topbar">
                <button class="admin-sidebar-toggle" type="button" data-admin-toggle aria-controls="adminSidebar" aria-expanded="false">
                    <i class="bi bi-list"></i>
                </button>
                <div>
                    <p class="admin-topbar__eyebrow">Operations</p>
                    <h1 class="admin-topbar__title">@(ViewData["Title"] ?? "Admin Panel")</h1>
                </div>
                <div class="admin-topbar__meta">
                    <span class="admin-pill">
                        <i class="bi bi-person-circle"></i>
                        <span>@User?.Identity?.Name</span>
                    </span>
                </div>
            </header>

            <main class="admin-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <div class="admin-overlay" data-admin-close hidden></div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @if (showMapAssets)
    {
        <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
    }
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("PageScripts", required: false)
</body>
</html>
