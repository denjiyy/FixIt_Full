@page
@model FixIt.Areas.Identity.Pages.Account.LockoutModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["AccountLockedOut"];
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<section class="account-page account-page--narrow py-4">
    <div class="card auth-card border-0" style="max-width: 520px; margin: 0 auto;">
        <div class="card-body text-center">
            <div class="auth-card__icon" style="background: linear-gradient(135deg, rgba(239,68,68,0.16), rgba(239,68,68,0.05));">
                <i class="bi bi-shield-lock" style="color: var(--danger-dark);"></i>
            </div>
            <h1 class="h2 mb-3 fw-bold">@Localizer["AccountLockedOut"]</h1>
            <p class="text-muted mb-4">@Localizer["AccountLockedOutDescription"]</p>

            <a asp-page="./Login" class="btn btn-primary">
                <i class="bi bi-arrow-left me-2"></i>@Localizer["BackToSignIn"]
            </a>
        </div>
    </div>
</section>
