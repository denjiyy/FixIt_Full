@page
@model FixIt.Areas.Identity.Pages.Account.ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Resend confirmation";
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<section class="account-page account-page--narrow py-4">
    <div class="card auth-card border-0" style="max-width: 520px; margin: 0 auto;">
        <div class="card-body">
            <div class="text-center mb-4">
                <div class="auth-card__icon">
                    <i class="bi bi-envelope-arrow-up"></i>
                </div>
                <h1 class="h2 mb-2 fw-bold">Resend confirmation</h1>
                <p class="text-muted mb-0">Enter your email and we'll send a fresh confirmation link.</p>
            </div>

            @if (Model.Sent)
            {
                <div class="alert alert-success d-flex align-items-start" role="alert">
                    <i class="bi bi-check-circle me-2"></i>
                    <div>If an unconfirmed account exists for that email, a new confirmation link is on its way.</div>
                </div>
                <div class="d-grid mt-3">
                    <a asp-page="./Login" class="btn btn-outline-primary">Back to sign in</a>
                </div>
            }
            else
            {
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label">Email address</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small d-block mt-2"></span>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-send me-2"></i>Send confirmation link
                        </button>
                    </div>
                </form>
            }
        </div>
    </div>
</section>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
}
