@page
@model FixIt.Areas.Identity.Pages.Account.ExternalLoginModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["CompleteYourRegistration"];
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<section class="account-page account-page--narrow">
    <div class="auth-shell">
        <div class="card auth-card border-0">
            <div class="card-body">
                <div class="text-center mb-4">
                    <div class="auth-card__icon">
                        <i class="bi bi-person-vcard"></i>
                    </div>
                    <h1 class="h3 mb-2">@Localizer["CompleteYourRegistration"]</h1>
                    <p class="text-muted mb-0">@Localizer["SigningInWith"] <strong>@Model.LoginProvider</strong></p>
                </div>

                <form method="post" asp-page-handler="Confirmation">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email address</label>
                        <input asp-for="Input.Email" class="form-control" readonly />
                        <span asp-validation-for="Input.Email" class="text-danger small d-block mt-2"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.DisplayName" class="form-label">@Localizer["DisplayNameField"]</label>
                        <input asp-for="Input.DisplayName" class="form-control" aria-required="true" placeholder='@Localizer["HowShouldWeCallYouPlaceholder"]' />
                        <span asp-validation-for="Input.DisplayName" class="text-danger small d-block mt-2"></span>
                        <small class="text-muted">@Localizer["ThisIsHowOtherUsersWillSeeYou"]</small>
                    </div>

                    <div class="d-grid gap-3 mb-4">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check2-circle me-2"></i>@Localizer["CreateAccount"]
                        </button>
                    </div>
                </form>

                <div class="auth-divider">
                <span>Already have an account?</span>
                </div>

                <a asp-page="./Login" class="btn btn-outline-primary w-100">
                    <i class="bi bi-box-arrow-in-right me-2"></i>@Localizer["LogIn"]
                </a>
            </div>
        </div>

        <aside class="auth-glance-card p-4">
            <span class="page-heading__eyebrow mb-3">@Model.LoginProvider</span>
            <h2 class="h4 mb-3">Finish setup in one step</h2>
            <p class="text-muted mb-4">We already trust the identity from your external provider. We only need the public display name you want residents to see.</p>

            <div class="auth-benefits">
                <div class="auth-benefit">
                    <span class="auth-benefit__icon auth-benefit__icon--blue"><i class="bi bi-shield-check"></i></span>
                    <div>
                        <h6 class="mb-1">Protected by your provider</h6>
                        <p class="small mb-0">Your email comes directly from @Model.LoginProvider and stays linked to that account.</p>
                    </div>
                </div>
                <div class="auth-benefit">
                    <span class="auth-benefit__icon auth-benefit__icon--green"><i class="bi bi-person-badge"></i></span>
                    <div>
                        <h6 class="mb-1">Choose how you appear publicly</h6>
                        <p class="small mb-0">Your display name can stay civic and professional while your underlying account remains secure.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
}
