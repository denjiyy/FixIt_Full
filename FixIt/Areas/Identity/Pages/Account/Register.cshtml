@page
@model FixIt.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card" style="border: none; box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="mb-3">
                            <i class="bi bi-tools text-gradient" style="font-size: 3rem;"></i>
                        </div>
                        <h1 class="h3 mb-2">Create Account</h1>
                        <p class="text-muted">Join the community and start making a difference</p>
                    </div>

                    <section>
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                            
                            <div class="mb-3">
                                <label asp-for="Input.Email" class="form-label">Email</label>
                                <input asp-for="Input.Email" class="form-control form-control-lg" 
                                       autocomplete="username" aria-required="true" 
                                       placeholder="your@email.com" />
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.DisplayName" class="form-label">Display Name</label>
                                <input asp-for="Input.DisplayName" class="form-control form-control-lg" 
                                       aria-required="true" placeholder="How should we call you?" />
                                <span asp-validation-for="Input.DisplayName" class="text-danger small"></span>
                                <small class="text-muted">This is how other users will see you</small>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.Password" class="form-label">Password</label>
                                <input asp-for="Input.Password" type="password" class="form-control form-control-lg" 
                                       autocomplete="new-password" aria-required="true" 
                                       placeholder="••••••••" />
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                <small class="text-muted">At least 8 characters with uppercase and numbers</small>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                                <input asp-for="Input.ConfirmPassword" type="password" class="form-control form-control-lg" 
                                       autocomplete="new-password" aria-required="true" 
                                       placeholder="••••••••" />
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="bi bi-person-plus"></i> Create Account
                                </button>
                            </div>
                            
                            <div class="text-center">
                                <small class="text-muted">
                                    By creating an account, you agree to our Terms of Service
                                </small>
                            </div>
                        </form>
                    </section>

                    <hr class="my-4">

                    <div class="text-center">
                        <p class="mb-2 text-muted small">Already have an account?</p>
                        <a asp-page="./Login" class="btn btn-outline-primary w-100">
                            <i class="bi bi-box-arrow-in-right"></i> Log In
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
