@page
@model FixIt.Areas.Identity.Pages.Account.ConfirmEmailModel
@{
    ViewData["Title"] = "Confirm email";
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<section class="account-page account-page--narrow py-4">
    <div class="card auth-card border-0" style="max-width: 520px; margin: 0 auto;">
        <div class="card-body text-center">
            <div class="auth-card__icon">
                <i class="bi @(Model.Confirmed ? "bi-envelope-check" : "bi-envelope-exclamation")"></i>
            </div>
            <h1 class="h2 mb-3 fw-bold">@(Model.Confirmed ? "Email confirmed" : "Confirmation failed")</h1>
            <p class="text-muted mb-4">@Model.StatusMessage</p>

            @if (Model.Confirmed)
            {
                <a asp-page="./Login" class="btn btn-primary">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign in
                </a>
            }
            else
            {
                <a asp-page="./ResendEmailConfirmation" class="btn btn-primary">
                    <i class="bi bi-arrow-repeat me-2"></i>Resend confirmation link
                </a>
            }
        </div>
    </div>
</section>
