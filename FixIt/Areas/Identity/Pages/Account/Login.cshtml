@page
@model FixIt.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card" style="border: none; box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="mb-3">
                            <i class="bi bi-tools text-gradient" style="font-size: 3rem;"></i>
                        </div>
                        <h1 class="h3 mb-2">Welcome Back</h1>
                        <p class="text-muted">Log in to continue reporting issues</p>
                    </div>
                    
                    <section>
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                            
                            <div class="mb-3">
                                <label asp-for="Input.Email" class="form-label">Email</label>
                                <input asp-for="Input.Email" class="form-control form-control-lg" 
                                       autocomplete="username" aria-required="true" 
                                       placeholder="your@email.com" />
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.Password" class="form-label">Password</label>
                                <input asp-for="Input.Password" type="password" class="form-control form-control-lg" 
                                       autocomplete="current-password" aria-required="true" 
                                       placeholder="••••••••" />
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-4 form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label class="form-check-label" asp-for="Input.RememberMe">Remember me</label>
                            </div>

                            <div class="d-grid mb-3">
                                <button id="login-submit" type="submit" class="btn btn-primary btn-lg">
                                    <i class="bi bi-box-arrow-in-right"></i> Log in
                                </button>
                            </div>
                            
                            <div class="text-center">
                                <a asp-page="./ForgotPassword" class="text-muted small">Forgot your password?</a>
                            </div>
                        </form>
                    </section>

                    <hr class="my-4">

                    <div class="text-center">
                        <p class="mb-2 text-muted small">Don't have an account?</p>
                        <a asp-page="./Register" class="btn btn-outline-primary w-100">
                            <i class="bi bi-person-plus"></i> Create an Account
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
