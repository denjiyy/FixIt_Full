@page
@model FixIt.Areas.Identity.Pages.Account.LoginModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["LogIn"];
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<section class="account-page account-page--compact">
    <div class="auth-shell auth-shell--split">
        <div class="card auth-card border-0">
            <div class="card-body">
                <div class="text-center mb-5">
                    <div class="auth-card__icon">
                        <i class="bi bi-tools"></i>
                    </div>
                    <h1 class="h2 mb-2 fw-bold">@Localizer["WelcomeBack"]</h1>
                    <p class="text-muted mb-0">@Localizer["SignInToContinueMakingYourCommunityBetter"]</p>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-start mb-4" role="alert">
                        <i class="bi bi-exclamation-circle me-2"></i>
                        <div>@Model.ErrorMessage</div>
                    </div>
                }

                @if (Model.ExternalLogins.Any())
                {
                    <div class="mb-4">
                        <div class="text-center mb-3">
                            <small class="text-uppercase fw-semibold text-muted">@Localizer["QuickSignInText"]</small>
                        </div>
                        <div class="auth-provider-list">
                            @foreach (var provider in Model.ExternalLogins)
                            {
                                var iconClass = provider.Name switch
                                {
                                    "Google" => "bi-google",
                                    "Microsoft" => "bi-microsoft",
                                    "Facebook" => "bi-facebook",
                                    "GitHub" => "bi-github",
                                    _ => "bi-box-arrow-in-right"
                                };

                                <form method="post" action="@Url.Page("/Account/ExternalLogin", new { area = "Identity", returnUrl = Model.ReturnUrl })">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="provider" value="@provider.Name" />
                                    <button type="submit" class="btn btn-outline-secondary auth-provider-button">
                                        <i class="bi @iconClass"></i>
                                        <span>@provider.DisplayName</span>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>

                    <div class="auth-divider">
                        <span>@Localizer["OrSignInWithEmail"]</span>
                    </div>
                }

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label">@Localizer["Account_EmailAddressLabel"]</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder='@Localizer["EmailPlaceholder"]' />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small d-block mt-2"></span>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label asp-for="Input.Password" class="form-label mb-0">@Localizer["PasswordLabel"]</label>
                            <a asp-page="./ForgotPassword" class="text-decoration-none small fw-semibold">@Localizer["ForgotPassword"]</a>
                        </div>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Input.Password" type="password" class="form-control" autocomplete="current-password" aria-required="true" placeholder='@Localizer["PasswordPlaceholder"]' />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small d-block mt-2"></span>
                    </div>

                    <div class="mb-4 form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" type="checkbox" id="rememberMe" />
                        <label class="form-check-label" for="rememberMe">@Localizer["KeepMeSignedIn"]</label>
                    </div>

                    <div class="d-grid gap-3">
                        <button id="login-submit" type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-box-arrow-in-right me-2"></i>@Localizer["SignIn"]
                        </button>
                    </div>
                </form>

                <div class="auth-divider mt-5">
                    <span>@Localizer["DontHaveAnAccount"]</span>
                </div>

                <a asp-page="./Register" class="btn btn-outline-primary w-100">
                    <i class="bi bi-person-plus me-2"></i>@Localizer["CreateOneNow"]
                </a>
            </div>
        </div>

        <div class="d-none d-lg-block">
            <div class="settings-hero mb-4">
                <p class="page-heading__eyebrow mb-3">@Localizer["CommunityPoweredPlatform"]</p>
                <h2 class="mb-3">@Localizer["JoinThousandsMakingADifference"]</h2>
                <p class="mb-0 text-white-70">@Localizer["JoinThousands"]</p>
            </div>

            <div class="auth-benefits">
                <div class="auth-benefit">
                    <span class="auth-benefit__icon auth-benefit__icon--blue"><i class="bi bi-flag"></i></span>
                    <div>
                        <h6 class="mb-1">@Localizer["ReportIssuesEasily"]</h6>
                        <p class="small mb-0">@Localizer["TakePhotoAddLocation"]</p>
                    </div>
                </div>
                <div class="auth-benefit">
                    <span class="auth-benefit__icon auth-benefit__icon--green"><i class="bi bi-graph-up-arrow"></i></span>
                    <div>
                        <h6 class="mb-1">@Localizer["TrackProgressLabel"]</h6>
                        <p class="small mb-0">@Localizer["SeeRealTimeUpdates"]</p>
                    </div>
                </div>
                <div class="auth-benefit">
                    <span class="auth-benefit__icon auth-benefit__icon--amber"><i class="bi bi-people"></i></span>
                    <div>
                        <h6 class="mb-1">@Localizer["CommunityImpactLabel"]</h6>
                        <p class="small mb-0">@Localizer["WorkTogetherToImproveYourNeighborhood"]</p>
                    </div>
                </div>
            </div>

            <div class="account-status-strip">
                <div class="alert alert-info mb-0">
                    <i class="bi bi-shield-check me-2"></i>@Localizer["YourDataIsSecureAndEncrypted"]
                </div>
            </div>
        </div>
    </div>
</section>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
}
