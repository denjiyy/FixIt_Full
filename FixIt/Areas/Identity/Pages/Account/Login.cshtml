@page
@model FixIt.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card" style="border: none; box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="mb-3">
                            <i class="bi bi-tools text-gradient" style="font-size: 3rem;"></i>
                        </div>
                        <h1 class="h3 mb-2">Welcome Back</h1>
                        <p class="text-muted">Log in to continue reporting issues</p>
                    </div>
                    
                    <!-- OAuth Providers Section -->
                    @if (Model.ExternalLogins.Any())
                    {
                        <section class="mb-4">
                            <h5 class="text-center text-muted mb-3">Sign in with</h5>
                            <div class="d-grid gap-2">
                                @foreach (var provider in Model.ExternalLogins)
                                {
                                    <form id="@provider.Name" method="post" action="@Url.Page("./ExternalLogin", new { handler = "Callback", returnUrl = Model.ReturnUrl })" style="display: none;">
                                        <input type="hidden" name="provider" value="@provider.Name" />
                                    </form>
                                    <button type="button" class="btn btn-outline-secondary" 
                                            onclick="document.getElementById('@provider.Name').submit();">
                                        @{
                                            var providerName = provider.Name;
                                            if (providerName == "Google")
                                            {
                                                <text><i class="fab fa-google text-danger"></i> Continue with Google</text>
                                            }
                                            else if (providerName == "Microsoft")
                                            {
                                                <text><i class="fab fa-microsoft text-primary"></i> Continue with Microsoft</text>
                                            }
                                            else
                                            {
                                                <text><i class="bi bi-box-arrow-up-right"></i> @provider.DisplayName</text>
                                            }
                                        }
                                    </button>
                                }
                            </div>
                        </section>

                        <div class="text-center mb-4">
                            <div class="divider">
                                <span class="divider-text">or</span>
                            </div>
                        </div>
                    }

                    <section>
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                            
                            <div class="mb-3">
                                <label asp-for="Input.Email" class="form-label">Email</label>
                                <input asp-for="Input.Email" class="form-control form-control-lg" 
                                       autocomplete="username" aria-required="true" 
                                       placeholder="your@email.com" />
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.Password" class="form-label">Password</label>
                                <input asp-for="Input.Password" type="password" class="form-control form-control-lg" 
                                       autocomplete="current-password" aria-required="true" 
                                       placeholder="••••••••" />
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-4 form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label class="form-check-label" asp-for="Input.RememberMe">Remember me</label>
                            </div>

                            <div class="d-grid mb-3">
                                <button id="login-submit" type="submit" class="btn btn-primary btn-lg">
                                    <i class="bi bi-box-arrow-in-right"></i> Log in
                                </button>
                            </div>
                            
                            <div class="text-center">
                                <a asp-page="./ForgotPassword" class="text-muted small">Forgot your password?</a>
                            </div>
                        </form>
                    </section>

                    <hr class="my-4">

                    <div class="text-center">
                        <p class="mb-2 text-muted small">Don't have an account?</p>
                        <a asp-page="./Register" class="btn btn-outline-primary w-100">
                            <i class="bi bi-person-plus"></i> Create an Account
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
.divider {
    display: flex;
    align-items: center;
    margin: 20px 0;
}

.divider-text {
    flex: 1;
    text-align: center;
    color: #6c757d;
    font-size: 0.875rem;
}

.divider::before,
.divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background-color: #e9ecef;
}

.divider::before {
    margin-right: 10px;
}

.divider::after {
    margin-left: 10px;
}
</style>
