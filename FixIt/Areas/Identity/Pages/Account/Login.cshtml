@page
@model FixIt.Areas.Identity.Pages.Account.LoginModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["LogIn"];
}

<!-- Font Awesome for OAuth icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fortawesome/fontawesome-free@@6.5.1/css/all.min.css" />

<div class="container py-5" style="min-height: 80vh;">
    <div class="row align-items-center justify-content-center">
        <div class="col-lg-5 col-md-7">
            <!-- Login Card -->
            <div class="card border-0" style="box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);">
                <div class="card-body p-5">
                    <!-- Header -->
                    <div class="text-center mb-5">
                        <div class="mb-4" style="display: inline-block; padding: 1.25rem; background: linear-gradient(135deg, #e0f2fe, #f0f9ff); border-radius: 1rem;">
                            <i class="bi bi-tools" style="font-size: 3rem; background: linear-gradient(135deg, #0ea5e9, #0284c7); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
                        </div>
                        <h1 class="h2 mb-2 fw-bold">@Localizer["WelcomeBack"]</h1>
                        <p class="text-muted mb-0">@Localizer["SignInToContinueMakingYourCommunityBetter"]</p>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-start mb-4" role="alert">
                            <i class="bi bi-exclamation-circle me-2" style="font-size: 1.25rem;"></i>
                            <div>@Model.ErrorMessage</div>
                        </div>
                    }

                    <!-- OAuth Providers -->
                    @if (Model.ExternalLogins.Any())
                    {
                        <div class="mb-4">
                            <div class="text-center mb-3">
                                <small class="text-uppercase fw-semibold text-muted" style="letter-spacing: 0.05em;">@Localizer["QuickSignInText"]</small>
                            </div>
                            <div class="d-grid gap-2">
                                @foreach (var provider in Model.ExternalLogins)
                                {
                                    <form method="post" action="@Url.Page("/Account/ExternalLogin", new { area = "Identity", returnUrl = Model.ReturnUrl })" style="display: contents;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="provider" value="@provider.Name" />
                                        <button type="submit" class="btn btn-outline-secondary d-flex align-items-center justify-content-center gap-2 py-3" 
                                                style="border-width: 2px; font-weight: 500;">
                                            <i class="fab fa-google text-danger" style="font-size: 1.25rem;"></i>
                                            <span>@Localizer["ContinueWithGoogle"]</span>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        <!-- Divider -->
                        <div class="position-relative my-4">
                            <hr class="my-0" style="border-color: #e5e7eb;">
                            <span class="position-absolute top-50 start-50 translate-middle px-3 bg-white text-muted" 
                                  style="font-size: 0.875rem;">@Localizer["OrSignInWithEmail"]</span>
                        </div>
                    }

                    <!-- Login Form -->
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-flex align-items-start" role="alert" style="display: none !important;">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <div></div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Input.Email" class="form-label fw-semibold">@Localizer["EmailAddress"]</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0" style="border: 2px solid #d1d5db; border-right: none; border-radius: 0.75rem 0 0 0.75rem;">
                                    <i class="bi bi-envelope text-muted"></i>
                                </span>
                                <input asp-for="Input.Email" class="form-control border-start-0" 
                                       style="border: 2px solid #d1d5db; border-left: none; border-radius: 0 0.75rem 0.75rem 0;"
                                       autocomplete="username" aria-required="true" 
                                       placeholder='@Localizer["EmailPlaceholder"]' />
                            </div>
                            <span asp-validation-for="Input.Email" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label asp-for="Input.Password" class="form-label fw-semibold mb-0">@Localizer["PasswordLabel"]</label>
                                <a asp-page="./ForgotPassword" class="text-decoration-none small" style="font-weight: 500;">
                                    @Localizer["ForgotPassword"]
                                </a>
                            </div>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0" style="border: 2px solid #d1d5db; border-right: none; border-radius: 0.75rem 0 0 0.75rem;">
                                    <i class="bi bi-lock text-muted"></i>
                                </span>
                                <input asp-for="Input.Password" type="password" class="form-control border-start-0" 
                                       style="border: 2px solid #d1d5db; border-left: none; border-radius: 0 0.75rem 0.75rem 0;"
                                       autocomplete="current-password" aria-required="true" 
                                       placeholder='@Localizer["PasswordPlaceholder"]' />
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="mb-4">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" type="checkbox" id="rememberMe" />
                                <label class="form-check-label" for="rememberMe" style="font-size: 0.875rem; cursor: pointer;">
                                    @Localizer["KeepMeSignedIn"]
                                </label>
                            </div>
                        </div>

                        <div class="d-grid mb-4">
                            <button id="login-submit" type="submit" class="btn btn-primary btn-lg py-3" style="font-weight: 600;">
                                <i class="bi bi-box-arrow-in-right me-2"></i>@Localizer["SignIn"]
                            </button>
                        </div>
                    </form>

                    <!-- Register Link -->
                    <div class="text-center pt-3" style="border-top: 1px solid #e5e7eb;">
                        <p class="mb-0 text-muted">
                            @Localizer["DontHaveAnAccount"]
                            <a asp-page="./Register" class="text-decoration-none fw-semibold ms-1" style="color: #0ea5e9;">
                                @Localizer["CreateOneNow"]
                            </a>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Security Notice -->
            <div class="text-center mt-4">
                <small class="text-muted d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-shield-check"></i>
                    <span>@Localizer["YourDataIsSecureAndEncrypted"]</span>
                </small>
            </div>
        </div>

        <!-- Optional: Side panel with benefits -->
        <div class="col-lg-5 d-none d-lg-block ps-5">
            <div class="p-5">
                <h2 class="h3 fw-bold mb-4">@Localizer["JoinThousandsMakingADifference"]</h2>
                <div class="d-flex flex-column gap-4">
                    <div class="d-flex align-items-start gap-3">
                        <div class="flex-shrink-0" style="width: 48px; height: 48px; background: #e0f2fe; border-radius: 0.75rem; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-flag" style="font-size: 1.5rem; color: #0ea5e9;"></i>
                        </div>
                        <div>
                            <h6 class="fw-semibold mb-1">@Localizer["ReportIssuesEasily"]</h6>
                            <p class="text-muted small mb-0">@Localizer["TakePhotoAddLocation"]</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start gap-3">
                        <div class="flex-shrink-0" style="width: 48px; height: 48px; background: #d1fae5; border-radius: 0.75rem; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-graph-up" style="font-size: 1.5rem; color: #10b981;"></i>
                        </div>
                        <div>
                            <h6 class="fw-semibold mb-1">@Localizer["TrackProgressLabel"]</h6>
                            <p class="text-muted small mb-0">@Localizer["SeeRealTimeUpdates"]</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start gap-3">
                        <div class="flex-shrink-0" style="width: 48px; height: 48px; background: #fef3c7; border-radius: 0.75rem; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-people" style="font-size: 1.5rem; color: #f59e0b;"></i>
                        </div>
                        <div>
                            <h6 class="fw-semibold mb-1">@Localizer["CommunityImpactLabel"]</h6>
                            <p class="text-muted small mb-0">@Localizer["WorkTogetherToImproveYourNeighborhood"]</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    /* Input focus enhancement */
    .form-control:focus {
        border-color: #0ea5e9 !important;
        box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.1) !important;
    }
    
    .input-group:focus-within .input-group-text {
        border-color: #0ea5e9 !important;
    }
    
    /* Button hover effect */
    .btn-outline-secondary:hover {
        background: #f9fafb;
        border-color: #9ca3af;
        transform: translateY(-1px);
    }
    
    /* Card entrance animation */
    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .card {
        animation: slideUp 0.5s ease-out;
    }
</style>
