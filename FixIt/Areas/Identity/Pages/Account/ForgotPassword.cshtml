@page
@model FixIt.Areas.Identity.Pages.Account.ForgotPasswordModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["ForgotPassword"];
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<section class="account-page account-page--narrow py-4">
    <div class="card auth-card border-0" style="max-width: 520px; margin: 0 auto;">
        <div class="card-body">
            <div class="text-center mb-5">
                <div class="auth-card__icon">
                    <i class="bi bi-envelope-paper"></i>
                </div>
                <h1 class="h2 mb-2 fw-bold">@Localizer["ForgotPasswordTitle"]</h1>
                <p class="text-muted mb-0">@Localizer["ForgotPasswordDescription"]</p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                <div class="mb-4">
                    <label asp-for="Input.Email" class="form-label">@Localizer["Account_EmailAddressLabel"]</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder='@Localizer["EmailPlaceholder"]' />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger small d-block mt-2"></span>
                </div>

                <div class="d-grid gap-3">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-send me-2"></i>@Localizer["SendResetLink"]
                    </button>
                </div>
            </form>

            <div class="text-center mt-4">
                <a asp-page="./Login" class="text-decoration-none fw-semibold">
                    <i class="bi bi-arrow-left me-1"></i>@Localizer["BackToSignIn"]
                </a>
            </div>
        </div>
    </div>
</section>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
}
