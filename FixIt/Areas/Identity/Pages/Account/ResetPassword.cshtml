@page
@model FixIt.Areas.Identity.Pages.Account.ResetPasswordModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["ResetPassword"];
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<section class="account-page account-page--narrow py-4">
    <div class="card auth-card border-0" style="max-width: 520px; margin: 0 auto;">
        <div class="card-body">
            <div class="text-center mb-5">
                <div class="auth-card__icon">
                    <i class="bi bi-key"></i>
                </div>
                <h1 class="h2 mb-2 fw-bold">@Localizer["ResetPassword"]</h1>
                <p class="text-muted mb-0">@Localizer["ResetPasswordDescription"]</p>
            </div>

            @if (Model.Success)
            {
                <div class="alert alert-success text-center" role="alert">
                    <i class="bi bi-check-circle me-2"></i>
                    @Localizer["PasswordHasBeenReset"]
                </div>
                <div class="text-center mt-3">
                    <a asp-page="./Login" class="btn btn-primary">
                        <i class="bi bi-box-arrow-in-right me-2"></i>@Localizer["SignIn"]
                    </a>
                </div>
            }
            else
            {
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>
                    <input asp-for="Input.Code" type="hidden" />

                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label">@Localizer["Account_EmailAddressLabel"]</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Input.Email" class="form-control" autocomplete="email" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small d-block mt-2"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.Password" class="form-label">@Localizer["NewPassword"]</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small d-block mt-2"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label">@Localizer["ConfirmNewPassword"]</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small d-block mt-2"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-lg me-2"></i>@Localizer["ResetPassword"]
                        </button>
                    </div>
                </form>
            }
        </div>
    </div>
</section>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
}
