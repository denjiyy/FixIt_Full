@page
@model FixIt.Areas.Identity.Pages.Account.LoginWith2faModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["TwoFactorAuthentication"];
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<section class="account-page account-page--narrow py-4">
    <div class="card auth-card border-0" style="max-width: 520px; margin: 0 auto;">
        <div class="card-body">
            <div class="text-center mb-5">
                <div class="auth-card__icon">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h1 class="h2 mb-2 fw-bold">@Localizer["TwoFactorAuthentication"]</h1>
                <p class="text-muted mb-0">@Localizer["TwoFactorAuthDescription"]</p>
            </div>

            <form method="post">
                <input type="hidden" asp-for="RememberMe" />
                <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                <div class="mb-4">
                    <label asp-for="Input.TwoFactorCode" class="form-label">@Localizer["AuthenticatorCode"]</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-key"></i></span>
                        <input asp-for="Input.TwoFactorCode" class="form-control" autocomplete="off" placeholder="000000" />
                    </div>
                    <span asp-validation-for="Input.TwoFactorCode" class="text-danger small d-block mt-2"></span>
                </div>

                <div class="mb-4 form-check">
                    <input class="form-check-input" asp-for="Input.RememberMachine" type="checkbox" />
                    <label class="form-check-label" asp-for="Input.RememberMachine">@Localizer["RememberThisMachine"]</label>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-in-right me-2"></i>@Localizer["SignIn"]
                    </button>
                </div>
            </form>

            <div class="text-center mt-4">
                <a asp-page="./Login" class="text-decoration-none fw-semibold">
                    <i class="bi bi-arrow-left me-1"></i>@Localizer["BackToSignIn"]
                </a>
            </div>
        </div>
    </div>
</section>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
}
