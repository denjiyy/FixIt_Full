@page
@model FixIt.Areas.Identity.Pages.Account.ChangePasswordModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["ChangePassword"];
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<section class="account-page account-page--narrow py-4">
    <div class="settings-panel">
        <div class="settings-panel__head">
            <div>
                <span class="settings-panel__eyebrow"><i class="bi bi-key"></i> @Localizer["ChangePassword"]</span>
                <h2 class="settings-panel__title">
                    @(Model.HasPassword ? Localizer["UpdateYourPassword"] : Localizer["SetAPassword"])
                </h2>
                <p class="settings-panel__copy">
                    @(Model.HasPassword
                        ? Localizer["ChangePasswordDescription"]
                        : Localizer["SetPasswordDescription"])
                </p>
            </div>
        </div>
        <div class="settings-panel__body">
            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="alert alert-success d-flex align-items-center" role="alert">
                    <i class="bi bi-check-circle me-2"></i>
                    @Model.StatusMessage
                </div>
            }

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                @if (Model.HasPassword)
                {
                    <div class="mb-4">
                        <label asp-for="Input.OldPassword" class="form-label">@Localizer["CurrentPassword"]</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" />
                        </div>
                        <span asp-validation-for="Input.OldPassword" class="text-danger small d-block mt-2"></span>
                    </div>
                }

                <div class="mb-4">
                    <label asp-for="Input.NewPassword" class="form-label">@Localizer["NewPassword"]</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                        <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="Input.NewPassword" class="text-danger small d-block mt-2"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="form-label">@Localizer["ConfirmNewPassword"]</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small d-block mt-2"></span>
                </div>

                <div class="settings-inline-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-2"></i>@(Model.HasPassword ? Localizer["UpdatePassword"] : Localizer["SetPassword"])
                    </button>
                    <a asp-area="Identity" asp-page="/Account/Manage" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>@Localizer["BackToAccount"]
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
}
