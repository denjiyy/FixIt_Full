@page
@model FixIt.Areas.Identity.Pages.Account.RegisterConfirmationModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["RegisterConfirmation"];
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<section class="account-page account-page--narrow py-4">
    <div class="card auth-card border-0" style="max-width: 520px; margin: 0 auto;">
        <div class="card-body text-center">
            <div class="auth-card__icon">
                <i class="bi bi-envelope-check"></i>
            </div>
            <h1 class="h2 mb-3 fw-bold">@Localizer["RegisterConfirmation"]</h1>
            <p class="text-muted mb-4">@Localizer["RegisterConfirmationDescription"]</p>

            <a asp-page="./Login" class="btn btn-primary">
                <i class="bi bi-box-arrow-in-right me-2"></i>@Localizer["SignIn"]
            </a>
        </div>
    </div>
</section>
