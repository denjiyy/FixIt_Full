@page
@model FixIt.Pages.Settings.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = "Settings";
    var emailState = Model.User?.EmailNotificationsEnabled == true ? "Enabled" : "Disabled";
    var cityConfigured = !string.IsNullOrEmpty(Model.SelectedCityId);
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<section class="account-page account-page--compact py-4">
    <section class="account-surface-hero mb-4">
        <div class="account-surface-hero__row">
            <div class="account-surface-hero__copy">
                <span class="account-surface-hero__eyebrow">
                    <i class="bi bi-sliders"></i>
                    Preferences hub
                </span>
                <h1 class="account-surface-hero__title">@Localizer["Settings"]</h1>
                <p class="account-surface-hero__subtitle">
                    Control your city context, privacy choices, linked sign-in methods, and communication preferences from one calm, focused workspace.
                </p>
            </div>
            <div class="account-surface-hero__meta">
                <div class="account-surface-hero__meta-card">
                    <span>City context</span>
                    <strong>@(cityConfigured ? "Set" : "Open")</strong>
                    <small>@(cityConfigured ? "Used to personalize reporting and alerts" : "Choose a preferred city to personalize content")</small>
                </div>
                <div class="account-surface-hero__meta-card">
                    <span>Email updates</span>
                    <strong>@emailState</strong>
                    <small>Digest and alert delivery preference</small>
                </div>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success mb-4">
            <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger mb-4">
            <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
        </div>
    }

    <section class="settings-dashboard-grid mb-4" aria-label="Settings summary">
        <article class="settings-dashboard-card">
            <span class="settings-dashboard-card__icon settings-dashboard-card__icon--blue"><i class="bi bi-geo-alt"></i></span>
            <span class="settings-dashboard-card__label">Preferred city</span>
            <strong class="settings-dashboard-card__value">@(cityConfigured ? "1" : "0")</strong>
            <p class="settings-dashboard-card__copy">Set a city to tailor issue feeds, health reports, and alerts to your area.</p>
        </article>
        <article class="settings-dashboard-card">
            <span class="settings-dashboard-card__icon settings-dashboard-card__icon--green"><i class="bi bi-envelope-check"></i></span>
            <span class="settings-dashboard-card__label">Inbox status</span>
            <strong class="settings-dashboard-card__value">@emailState</strong>
            <p class="settings-dashboard-card__copy">Weekly reports and urgent hazard notices follow the preferences you choose below.</p>
        </article>
        <article class="settings-dashboard-card">
            <span class="settings-dashboard-card__icon settings-dashboard-card__icon--amber"><i class="bi bi-shield-lock"></i></span>
            <span class="settings-dashboard-card__label">Privacy controls</span>
            <strong class="settings-dashboard-card__value">3</strong>
            <p class="settings-dashboard-card__copy">Anonymous reporting, visibility, and safety alerts all live under one privacy surface.</p>
        </article>
    </section>

    <section class="settings-panel mb-4">
        <div class="settings-panel__head">
            <div>
                <span class="settings-panel__eyebrow"><i class="bi bi-pin-map"></i> Local context</span>
                <h2 class="settings-panel__title">@Localizer["CityPreference"]</h2>
                <p class="settings-panel__copy">@Localizer["SelectYourCityToPersonalizeFeatureContent"]</p>
            </div>
        </div>
        <div class="settings-panel__body">
            <form method="post" asp-page-handler="SetCity" class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label for="cityId" class="form-label">@Localizer["CityOrCities"]</label>
                    <select class="form-select" id="cityId" name="cityId" required>
                        <option value="">@Localizer["SelectACity"]</option>
                        @foreach (var city in Model.AvailableCities)
                        {
                            <option value="@city.Id" selected="@(Model.SelectedCityId == city.Id)">
                                @city.Name
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-save me-2"></i>Save city
                    </button>
                </div>
            </form>

            <div class="settings-note-panel">
                <h6 class="mb-2"><i class="bi bi-info-circle me-2"></i>Why this matters</h6>
                <p class="mb-0">
                    @(cityConfigured
                        ? Localizer["CityPreferenceInfo"]
                        : "A preferred city lets FixIt show more relevant issue activity, analytics, and notification defaults.")
                </p>
            </div>
        </div>
    </section>

    <section class="settings-hub-grid">
        <a href="/settings/connected-accounts" class="settings-hub-card">
            <span class="settings-hub-card__icon settings-hub-card__icon--blue"><i class="bi bi-link-45deg"></i></span>
            <div>
                <div class="settings-hub-card__title">@Localizer["ConnectedAccounts"]</div>
                <p class="settings-hub-card__copy">@Localizer["LinkOAuthProvidersAndManageAuthenticationMethods"]</p>
            </div>
            <div class="settings-hub-card__foot">
                <i class="bi bi-arrow-right"></i>
                Review sign-in methods
            </div>
        </a>

        <a href="/settings/email-preferences" class="settings-hub-card">
            <span class="settings-hub-card__icon settings-hub-card__icon--green"><i class="bi bi-envelope"></i></span>
            <div>
                <div class="settings-hub-card__title">@Localizer["EmailPreferencesPage"]</div>
                <p class="settings-hub-card__copy">@Localizer["ControlWhichEmailsAndNotificationsYouReceive"]</p>
            </div>
            <div class="settings-hub-card__foot">
                <i class="bi bi-arrow-right"></i>
                Tune inbox delivery
            </div>
        </a>

        <a href="/settings/privacy" class="settings-hub-card">
            <span class="settings-hub-card__icon settings-hub-card__icon--amber"><i class="bi bi-shield-lock"></i></span>
            <div>
                <div class="settings-hub-card__title">@Localizer["PrivacyAndSafety"]</div>
                <p class="settings-hub-card__copy">@Localizer["AnonymousReportingHazardAlertsAndProfileVisibility"]</p>
            </div>
            <div class="settings-hub-card__foot">
                <i class="bi bi-arrow-right"></i>
                Manage safety controls
            </div>
        </a>

        <a href="/Account/Manage" class="settings-hub-card">
            <span class="settings-hub-card__icon settings-hub-card__icon--blue"><i class="bi bi-person-circle"></i></span>
            <div>
                <div class="settings-hub-card__title">@Localizer["MyAccount"]</div>
                <p class="settings-hub-card__copy">@Localizer["ChangePasswordManageProfileAndAccountSecurity"]</p>
            </div>
            <div class="settings-hub-card__foot">
                <i class="bi bi-arrow-right"></i>
                Open account management
            </div>
        </a>
    </section>
</section>
