@page "/user/{userId}"
@model FixIt.Pages.User.ProfileModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["ViewProfile"];
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<div class="account-page py-4">
    @if (Model.UserProfile != null)
    {
        <section class="account-surface-hero mb-4">
            <div class="account-surface-hero__row">
                <div class="profile-main">
                    <div class="profile-avatar">
                        @Model.UserProfile.UserName?.Substring(0, 1).ToUpper()
                    </div>
                    <div class="profile-info">
                        <span class="account-surface-hero__eyebrow">
                            <i class="bi bi-person-badge"></i>
                            @Localizer["ViewProfile"]
                        </span>
                        <h1 class="profile-username">@Model.UserProfile.UserName</h1>

                        @if (Model.UserReputation != null)
                        {
                            <span class="trust-badge level-@Model.UserReputation.TrustLevel mb-3">
                                <i class="bi bi-award"></i>
                                @GetTrustLevelLabel(Model.UserReputation.TrustLevel)
                            </span>
                        }
                        else
                        {
                            <span class="trust-badge level-0 mb-3">
                                <i class="bi bi-award"></i>
                                @Localizer["NewMember"]
                            </span>
                        }
                    </div>
                </div>

                <div class="account-surface-hero__meta">
                    <div class="account-surface-hero__meta-card">
                        <span>Total points</span>
                        <strong>@(Model.UserReputation?.TotalPoints ?? 0)</strong>
                        <small>Community reputation earned so far</small>
                    </div>
                    <div class="account-surface-hero__meta-card">
                        <span>Achievements</span>
                        <strong>@(Model.UserReputation?.Achievements.Count ?? 0)</strong>
                        <small>Milestones unlocked through participation</small>
                    </div>
                </div>
            </div>
        </section>

        @if (Model.UserReputation != null)
        {
            var (currentMin, nextThreshold) = Model.UserReputation.TrustLevel switch
            {
                0 => (0, 11),
                1 => (11, 51),
                2 => (51, 151),
                _ => (151, int.MaxValue)
            };
            var progress = Model.UserReputation.TotalPoints - currentMin;
            var levelSize = nextThreshold - currentMin;
            var progressPercent = Model.UserReputation.TrustLevel >= 3
                ? 100
                : Math.Min(100, Math.Max(0, (progress / (double)levelSize) * 100));
            var pointsNeeded = Math.Max(0, nextThreshold - Model.UserReputation.TotalPoints);

            <div class="settings-stack">
                <section class="settings-panel">
                    <div class="settings-panel__head">
                        <div>
                            <span class="settings-panel__eyebrow"><i class="bi bi-graph-up"></i> Reputation</span>
                            <h2 class="settings-panel__title">@Localizer["ReputationProgressLabel"]</h2>
                            <p class="settings-panel__copy">Track progress toward the next trust milestone and see how close this citizen is to the next credibility tier.</p>
                        </div>
                    </div>
                    <div class="settings-panel__body">
                        <div class="profile-progress">
                            <div class="progress-header">
                                <span class="progress-title">@Localizer["LevelProgressLabel"]</span>
                                <span class="progress-stats">@Math.Max(0, progress) / @levelSize @Localizer["Points"]</span>
                            </div>
                            <div class="profile-progress__bar" role="progressbar" aria-valuenow="@((int)progressPercent)" aria-valuemin="0" aria-valuemax="100">
                                <div class="profile-progress__fill" data-progress-width="@progressPercent"></div>
                            </div>
                            <div class="progress-info">
                                @if (Model.UserReputation.TrustLevel < 3)
                                {
                                    <span>@Localizer["PointsUntilNextLevel", pointsNeeded, GetTrustLevelLabel(Model.UserReputation.TrustLevel + 1)]</span>
                                }
                                else
                                {
                                    <span>@Localizer["MaxTrustLevelAchieved"]</span>
                                }
                            </div>
                        </div>
                    </div>
                </section>

                <div class="profile-grid">
                    <section class="settings-panel">
                        <div class="settings-panel__head">
                            <div>
                                <span class="settings-panel__eyebrow"><i class="bi bi-trophy"></i> Milestones</span>
                                <h2 class="settings-panel__title">@Localizer["AchievementsLabel"] (@Model.UserReputation.Achievements.Count)</h2>
                                <p class="settings-panel__copy">Milestones earned through consistent and constructive civic participation.</p>
                            </div>
                        </div>
                        <div class="settings-panel__body">
                            @if (Model.UserReputation.Achievements.Any())
                            {
                                <div class="achievements-grid">
                                    @foreach (var achievement in Model.UserReputation.Achievements)
                                    {
                                        <div class="achievement-badge" title="@GetAchievementDescription(achievement.Type.ToString())">
                                            <span class="badge-icon"><i class="bi @GetAchievementIcon(achievement.Type.ToString())"></i></span>
                                            <div class="badge-name">@GetAchievementName(achievement.Type.ToString())</div>
                                            <div class="badge-date">@achievement.EarnedAt.ToString("MMM yyyy")</div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="empty-achievements">
                                    <i class="bi bi-trophy"></i>
                                    <p>@Localizer["NoAchievementsYetMessage"]</p>
                                </div>
                            }
                        </div>
                    </section>

                    <section class="settings-panel">
                        <div class="settings-panel__head">
                            <div>
                                <span class="settings-panel__eyebrow"><i class="bi bi-activity"></i> Activity</span>
                                <h2 class="settings-panel__title">@Localizer["CommunityActivityLabel"]</h2>
                                <p class="settings-panel__copy">A snapshot of how this citizen contributes across reporting, discussion, and resolution.</p>
                            </div>
                        </div>
                        <div class="settings-panel__body">
                            <div class="activity-list mb-4">
                                <div class="activity-item">
                                    <span class="activity-label"><i class="bi bi-flag"></i>@Localizer["IssuesReported"]</span>
                                    <span class="activity-value">@Model.UserReputation.IssuesReported</span>
                                </div>
                                <div class="activity-item">
                                    <span class="activity-label"><i class="bi bi-chat-left-text"></i>@Localizer["CommentsPosted"]</span>
                                    <span class="activity-value">@Model.UserReputation.CommentsPosted</span>
                                </div>
                                <div class="activity-item">
                                    <span class="activity-label"><i class="bi bi-check-circle"></i>@Localizer["IssuesResolved"]</span>
                                    <span class="activity-value">@Model.UserReputation.IssuesResolved</span>
                                </div>
                            </div>

                            <div class="settings-note-panel">
                                <h6 class="mb-3"><i class="bi bi-star me-2 text-warning"></i>@Localizer["PointBreakdownLabel"]</h6>
                                <div class="points-list">
                                    <div class="points-item">
                                        <span class="points-label"><i class="bi bi-flag"></i>@Localizer["IssueReports"]</span>
                                        <span class="points-value">+@(Model.UserReputation.IssuesReported * 5)</span>
                                    </div>
                                    <div class="points-item">
                                        <span class="points-label"><i class="bi bi-chat-left-text"></i>@Localizer["Comments"]</span>
                                        <span class="points-value">+@(Model.UserReputation.CommentsPosted * 2)</span>
                                    </div>
                                    <div class="points-item">
                                        <span class="points-label"><i class="bi bi-check-circle"></i>@Localizer["ResolvedIssues"]</span>
                                        <span class="points-value">+@(Model.UserReputation.IssuesResolved * 10)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        }
    }
    else
    {
        <div class="not-found-container">
            <div class="not-found-icon">
                <i class="bi bi-person-x"></i>
            </div>
            <div class="alert alert-info d-inline-block">
                <h4><i class="bi bi-info-circle me-2"></i>@Localizer["UserNotFoundTitle"]</h4>
                <p class="mb-0">@Localizer["UserNotFoundMessage"]</p>
            </div>
        </div>
    }
</div>

@functions {
    private string GetTrustLevelLabel(int level) => level switch
    {
        0 => Localizer["TrustLevel_NewMember"],
        1 => Localizer["TrustLevel_ActiveCitizen"],
        2 => Localizer["TrustLevel_TrustedMember"],
        3 => Localizer["TrustLevel_CommunityLeader"],
        _ => Localizer["TrustLevel_Unknown"]
    };

    private string GetAchievementName(string type)
    {
        var key = $"AchievementName_{type}";
        var localized = Localizer[key];
        return localized.ResourceNotFound ? Localizer["Achievement"] : localized;
    }

    // Bootstrap Icons (the product's icon system) — never emoji.
    private string GetAchievementIcon(string type) => type switch
    {
        "FirstReporter" => "bi-megaphone-fill",
        "HelpfulCommenteer" => "bi-chat-heart-fill",
        "CommunityHelper" => "bi-people-fill",
        "IssueSolver" => "bi-check2-circle",
        "CivicContributor" => "bi-building-fill",
        "CommunityChampion" => "bi-trophy-fill",
        "CivicLeader" => "bi-award-fill",
        "VerifiedCitizen" => "bi-patch-check-fill",
        "ConsistentParticipant" => "bi-calendar2-check-fill",
        "ImpactMaker" => "bi-star-fill",
        "TopContributor" => "bi-1-circle-fill",
        _ => "bi-rosette"
    };

    private string GetAchievementDescription(string type)
    {
        var key = $"AchievementDescription_{type}";
        var localized = Localizer[key];
        return localized.ResourceNotFound ? Localizer["AchievementUnlocked"] : localized;
    }
}
