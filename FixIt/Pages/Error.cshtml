@page
@model ErrorModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Error"];
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<div class="account-page py-5">
    <div class="error-shell">
        <section class="card error-card">
            <div class="card-body text-center">
                <div class="auth-card__icon">
                    <i class="bi bi-exclamation-octagon"></i>
                </div>
                <span class="eyebrow text-primary">@Localizer["Error"]</span>
                <h1 class="mt-3 mb-3">Something interrupted this request</h1>
                <p class="page-copy mx-auto mb-4">
                    The page could not be completed right now. Try refreshing, heading back home, or retrying the action in a moment.
                </p>

                @if (Model.ShowRequestId)
                {
                    <div class="mb-4">
                        <p class="text-muted mb-2">Request ID</p>
                        <div class="error-id">@Model.RequestId</div>
                    </div>
                }

                <div class="d-flex flex-wrap justify-content-center gap-3 mb-4">
                    <a class="btn btn-primary" asp-page="/Index">
                        <i class="bi bi-house-door me-2"></i>Go to homepage
                    </a>
                    <button type="button" class="btn btn-outline-secondary" data-history-back>
                        <i class="bi bi-arrow-left me-2"></i>Go back
                    </button>
                </div>

                <div class="alert alert-info text-start mb-0">
                    <h2 class="h6 mb-2">Development mode note</h2>
                    <p class="mb-2">Detailed exception information is only shown when the app runs in the Development environment.</p>
                    <p class="mb-0">Do not enable Development in production because it can expose sensitive diagnostic details to end users.</p>
                </div>
            </div>
        </section>
    </div>
</div>
