@page
@model ErrorModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = Localizer["Error"];
    var errorCode = HttpContext.Request.Query["code"].ToString();
    var isProduction = !WebHostEnvironment.IsDevelopment();
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<div class="account-page py-5">
    <div class="error-shell">
        <section class="card error-card">
            <div class="card-body text-center">
                <div class="auth-card__icon">
                    <i class="bi bi-exclamation-octagon"></i>
                </div>
                @if (!string.IsNullOrEmpty(errorCode))
                {
                    <span class="eyebrow text-primary">@Localizer["Error"] - @errorCode</span>
                }
                else
                {
                    <span class="eyebrow text-primary">@Localizer["Error"]</span>
                }
                <h1 class="mt-3 mb-3">
                    @if (errorCode == "403")
                    {
                        <span>Access Denied</span>
                    }
                    else if (errorCode == "404")
                    {
                        <span>Page Not Found</span>
                    }
                    else if (errorCode == "400")
                    {
                        <span>Bad Request</span>
                    }
                    else
                    {
                        <span>Something interrupted this request</span>
                    }
                </h1>
                <p class="page-copy mx-auto mb-4">
                    @if (errorCode == "403")
                    {
                        <span>You don't have permission to access this resource. If you believe this is an error, please contact support.</span>
                    }
                    else if (errorCode == "404")
                    {
                        <span>The page you're looking for could not be found. It may have been moved or deleted.</span>
                    }
                    else if (errorCode == "400")
                    {
                        <span>The request could not be understood by the server. Please check your input and try again.</span>
                    }
                    else
                    {
                        <span>The page could not be completed right now. Try refreshing, heading back home, or retrying the action in a moment.</span>
                    }
                </p>

                @if (Model.ShowRequestId && !isProduction)
                {
                    <div class="mb-4">
                        <p class="text-muted mb-2">Request ID</p>
                        <div class="error-id">@Model.RequestId</div>
                    </div>
                }

                <div class="d-flex flex-wrap justify-content-center gap-3 mb-4">
                    <a class="btn btn-primary" asp-page="/Index">
                        <i class="bi bi-house-door me-2"></i>Go to homepage
                    </a>
                    <button type="button" class="btn btn-outline-secondary" data-history-back>
                        <i class="bi bi-arrow-left me-2"></i>Go back
                    </button>
                </div>

                @if (!isProduction)
                {
                    <div class="alert alert-info text-start mb-0">
                        <h2 class="h6 mb-2">Development mode note</h2>
                        <p class="mb-2">Detailed exception information is only shown when the app runs in the Development environment.</p>
                        <p class="mb-0">Do not enable Development in production because it can expose sensitive diagnostic details to end users.</p>
                    </div>
                }
            </div>
        </section>
    </div>
</div>
