@page
@model IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["ReportAndFix"] + " - FixIt";
    ViewData["BodyClass"] = "page-home-index";
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/issues-shared.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/home-index.css" asp-append-version="true" />
}

<div class="home-index-page">
    <section class="home-hero">
        <div class="home-hero__grid">
            <div class="home-hero__content">
                <span class="home-hero__eyebrow">
                    <i class="bi bi-shield-check"></i>
                    @Localizer["CommunityPoweredPlatform"]
                </span>
                <h1 class="home-hero__title">
                    @Localizer["ReportAndFix"]
                    <span>@Localizer["CommunityIssues"]</span>
                </h1>
                <p class="home-hero__copy">@Localizer["HomeHeroDescription"]</p>

                <div class="home-hero__actions">
                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <a asp-page="/Issues/Create" class="nav-report-btn">
                            <i class="bi bi-plus-circle-fill"></i>
                            <span>@Localizer["ReportNewIssue"]</span>
                        </a>
                        <a asp-page="/Issues/Index" class="app-link-btn">
                            <i class="bi bi-list-check"></i>
                            <span>@Localizer["BrowseIssues"]</span>
                        </a>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Register" class="nav-report-btn">
                            <i class="bi bi-person-plus-fill"></i>
                            <span>@Localizer["GetStartedFree"]</span>
                        </a>
                        <a asp-area="Identity" asp-page="/Account/Login" class="app-link-btn">
                            <i class="bi bi-box-arrow-in-right"></i>
                            <span>@Localizer["SignIn"]</span>
                        </a>
                    }
                </div>

                <div class="home-hero__highlights">
                    <div class="home-highlight">
                        <strong>@Model.Overview.ResolutionRatePercentage%</strong>
                        <span>@Localizer["ResolutionRate"]</span>
                    </div>
                    <div class="home-highlight">
                        <strong>@Model.Overview.CitiesCovered</strong>
                        <span>@Localizer["CitiesCovered"]</span>
                    </div>
                    <div class="home-highlight">
                        <strong>@Model.Overview.ActiveIssues</strong>
                        <span>@Localizer["ActiveIssues"]</span>
                    </div>
                </div>
            </div>

            <aside class="home-hero__panel home-hero__panel--inset">
                <div class="home-hero__panel-head">
                    <span class="home-panel-kicker">@Localizer["LivePlatformPulse"]</span>
                    <h2>@Model.Overview.ActiveIssues @Localizer["ActiveIssues"]</h2>
                    <p>@Localizer["FeaturedCommunityActivityCopy"]</p>
                </div>

                <div class="home-hero__panel-metrics">
                    <article class="home-mini-metric">
                        <span>@Localizer["TotalIssues"]</span>
                        <strong>@Model.Overview.TotalIssues</strong>
                    </article>
                    <article class="home-mini-metric">
                        <span>@Localizer["Resolved"]</span>
                        <strong>@Model.Overview.FixedIssues</strong>
                    </article>
                    <article class="home-mini-metric">
                        <span>@Localizer["InProgress"]</span>
                        <strong>@Model.Overview.InProgressIssues</strong>
                    </article>
                    <article class="home-mini-metric">
                        <span>@Localizer["Critical"]</span>
                        <strong>@Model.Overview.CriticalIssues</strong>
                    </article>
                </div>

                <div class="home-hero__feed">
                    <div class="home-hero__feed-heading">
                        <i class="bi bi-activity"></i>
                        <span>@Localizer["FeaturedIssueUpdates"]</span>
                    </div>

                    @if (Model.Overview.FeaturedIssues.Any())
                    {
                        foreach (var issue in Model.Overview.FeaturedIssues.Take(3))
                        {
                            <a href="/issues/@issue.Id" class="home-hero__feed-item">
                                <div class="home-hero__feed-copy">
                                    <strong>@issue.Title</strong>
                                    <span>@(string.IsNullOrWhiteSpace(issue.Address) ? Localizer["CommunityIssues"] : issue.Address)</span>
                                </div>
                                <div class="home-hero__feed-meta">
                                    <partial name="_BadgeStatus" model="issue.Status" />
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="home-hero__feed-empty">
                            @Localizer["NoIssuesReportedYet"]
                        </div>
                    }
                </div>
            </aside>
        </div>
    </section>

    <section class="issue-page">
        <div class="issue-section-heading">
            <div>
                <span class="issue-page-header__eyebrow">
                    <i class="bi bi-stars"></i>
                    @Localizer["FeaturedCommunityActivity"]
                </span>
                <h2 class="issue-section-heading__title">@Localizer["FeaturedCommunityActivity"]</h2>
                <p class="issue-section-heading__copy">@Localizer["FeaturedCommunityActivityCopy"]</p>
            </div>
            <a asp-page="/Issues/Index" class="app-link-btn">
                <i class="bi bi-arrow-right-circle"></i>
                <span>@Localizer["BrowseIssues"]</span>
            </a>
        </div>

        @if (Model.Overview.FeaturedIssues.Any())
        {
            <div class="issue-card-grid home-featured-grid">
                @foreach (var issue in Model.Overview.FeaturedIssues.Take(3))
                {
                    <partial name="_IssueCard" model="issue" />
                }
            </div>
        }
        else
        {
            <div class="issue-surface issue-empty-state">
                <div class="issue-empty-state__icon">
                    <i class="bi bi-inbox"></i>
                </div>
                <h2 class="issue-empty-state__title">@Localizer["NoIssuesReportedYet"]</h2>
                <p class="issue-empty-state__copy">@Localizer["BeTheFirstToMakeYourCommunityBetter"]</p>
            </div>
        }
    </section>

    <section class="issue-page home-process">
        <div class="home-section-intro">
            <span class="issue-page-header__eyebrow">
                <i class="bi bi-diagram-3"></i>
                @Localizer["HowItWorks"]
            </span>
            <h2>@Localizer["SimpleTransparentEffective"]</h2>
            <p>@Localizer["HomeProcessCopy"]</p>
        </div>

        <div class="home-process__grid">
            <article class="home-process__card issue-surface">
                <span class="home-process__number">1</span>
                <div class="home-process__icon home-process__icon--blue">
                    <i class="bi bi-camera"></i>
                </div>
                <h3>@Localizer["ReportIssues"]</h3>
                <p>@Localizer["TakePhotoPin"]</p>
            </article>

            <article class="home-process__card issue-surface">
                <span class="home-process__number">2</span>
                <div class="home-process__icon home-process__icon--green">
                    <i class="bi bi-geo-alt"></i>
                </div>
                <h3>@Localizer["Location"]</h3>
                <p>@Localizer["PinTheExactSpotOnTheMapDescription"]</p>
            </article>

            <article class="home-process__card issue-surface">
                <span class="home-process__number">3</span>
                <div class="home-process__icon home-process__icon--gold">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <h3>@Localizer["RealTimeTracking"]</h3>
                <p>@Localizer["WatchIssuesProgress"]</p>
            </article>

            <article class="home-process__card issue-surface">
                <span class="home-process__number">4</span>
                <div class="home-process__icon home-process__icon--red">
                    <i class="bi bi-people"></i>
                </div>
                <h3>@Localizer["CommunityEngagement"]</h3>
                <p>@Localizer["UpvoteIssuesComment"]</p>
            </article>
        </div>
    </section>

    <section class="issue-page home-trust">
        <div class="home-trust__layout">
            <div class="home-trust__content">
                <span class="issue-page-header__eyebrow">
                    <i class="bi bi-buildings"></i>
                    @Localizer["WhyItMatters"]
                </span>
                <h2>@Localizer["BuildingStrongerCommunities"]</h2>
                <p class="home-trust__copy">@Localizer["HomeTrustCopy"]</p>

                <div class="home-trust__list">
                    <article class="home-trust__item">
                        <div class="home-trust__item-icon">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <div>
                            <h3>@Localizer["FullTransparency"]</h3>
                            <p>@Localizer["EveryReportStatusVisible"]</p>
                        </div>
                    </article>

                    <article class="home-trust__item">
                        <div class="home-trust__item-icon home-trust__item-icon--green">
                            <i class="bi bi-lightning-charge"></i>
                        </div>
                        <div>
                            <h3>@Localizer["FasterResolution"]</h3>
                            <p>@Localizer["CommunityReportingAccelerates"]</p>
                        </div>
                    </article>

                    <article class="home-trust__item">
                        <div class="home-trust__item-icon home-trust__item-icon--gold">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div>
                            <h3>@Localizer["CommunityPower"]</h3>
                            <p>@Localizer["YourVoiceMatters"]</p>
                        </div>
                    </article>

                    <article class="home-trust__item">
                        <div class="home-trust__item-icon home-trust__item-icon--red">
                            <i class="bi bi-bar-chart-line"></i>
                        </div>
                        <div>
                            <h3>@Localizer["DataDrivenImpact"]</h3>
                            <p>@Localizer["InfrastructureDecisionsBackedBy"]</p>
                        </div>
                    </article>
                </div>
            </div>

            <aside class="home-trust__panel issue-surface">
                <div class="home-trust__panel-copy">
                    <span class="home-panel-kicker">@Localizer["LiveCommunityImpact"]</span>
                    <h3>@Localizer["FeaturedCommunityActivity"]</h3>
                    <p>@Localizer["FeaturedCommunityActivityCopy"]</p>
                </div>

                <div class="issue-kpi-grid home-trust__metrics">
                    <div class="issue-kpi-card">
                        <div class="issue-kpi-card__label">
                            <i class="bi bi-check2-circle"></i>
                            @Localizer["Resolved"]
                        </div>
                        <div class="issue-kpi-card__value">@Model.Overview.FixedIssues</div>
                        <div class="issue-kpi-card__meta">@Localizer["IssuesResolved"]</div>
                    </div>

                    <div class="issue-kpi-card">
                        <div class="issue-kpi-card__label">
                            <i class="bi bi-exclamation-circle"></i>
                            @Localizer["New"]
                        </div>
                        <div class="issue-kpi-card__value">@Model.Overview.NewIssues</div>
                        <div class="issue-kpi-card__meta">@Localizer["ReportIssues"]</div>
                    </div>
                </div>
            </aside>
        </div>
    </section>

    <section class="issue-page home-cta">
        <div class="home-cta__card issue-surface issue-surface--glass">
            <span class="issue-page-header__eyebrow">
                <i class="bi bi-megaphone"></i>
                @Localizer["ReadyToMakeADifference"]
            </span>
            <h2>@Localizer["ReadyToMakeADifference"]</h2>
            <p>@Localizer["ReadyToMakeADifferenceCopy"]</p>

            <div class="home-cta__actions">
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <a asp-page="/Issues/Create" class="nav-report-btn">
                        <i class="bi bi-send-plus"></i>
                        <span>@Localizer["SubmitReport"]</span>
                    </a>
                    <a asp-page="/Issues/Index" class="app-link-btn">
                        <i class="bi bi-graph-up-arrow"></i>
                        <span>@Localizer["BrowseIssues"]</span>
                    </a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Register" class="nav-report-btn">
                        <i class="bi bi-person-plus-fill"></i>
                        <span>@Localizer["CreateAccount"]</span>
                    </a>
                    <a asp-area="Identity" asp-page="/Account/Login" class="app-link-btn">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>@Localizer["SignIn"]</span>
                    </a>
                }
            </div>
        </div>
    </section>
</div>
