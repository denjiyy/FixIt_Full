@page
@using FixIt.Models.Enums
@using FixIt.Models.Issues
@model IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["ReportAndFix"] + " - FixIt";
    ViewData["BodyClass"] = "page-home-index";

    var isAuthed = User?.Identity?.IsAuthenticated ?? false;
    var featured = Model.Overview.FeaturedIssues.Take(3).ToList();
    var stories = Model.ResolvedStories.Take(3).ToList();
    var topStory = stories.FirstOrDefault();
    var topFeatured = featured.FirstOrDefault();

    var grads = new[] { "grad-a", "grad-b", "grad-c", "grad-d" };
    var avatarColors = new[] { "var(--sky-600)", "var(--violet-500)", "var(--emerald-600)", "var(--amber-500)", "var(--sky-500)" };

    string GradFor(int i) => grads[i % grads.Length];
    string AvatarColor(int i) => avatarColors[i % avatarColors.Length];
    string GlyphFor(IssueStatus s) => s switch
    {
        IssueStatus.Fixed => "bi-check2-circle",
        IssueStatus.InProgress => "bi-tools",
        IssueStatus.Confirmed => "bi-hand-thumbs-up",
        IssueStatus.Rejected => "bi-x-circle",
        IssueStatus.Duplicate => "bi-files",
        _ => "bi-exclamation-circle"
    };
    string ReporterName(Issue it) => it.IsAnonymous
        ? Localizer["AnonymousReporter"].Value
        : (string.IsNullOrWhiteSpace(it.Reporter?.DisplayName) ? Localizer["CommunityMember"].Value : it.Reporter!.DisplayName);
    string InitialOf(Issue it)
    {
        if (it.IsAnonymous) { return "?"; }
        var name = ReporterName(it).Trim();
        return name.Length > 0 ? name[0].ToString().ToUpperInvariant() : "?";
    }
    string AddressOf(Issue it) => string.IsNullOrWhiteSpace(it.Address) ? Localizer["CommunityIssues"].Value : it.Address!;

    // Resident "your town" home data + helpers.
    var greetingName = string.IsNullOrWhiteSpace(Model.DisplayName) ? Localizer["Neighbor"].Value : Model.DisplayName;
    var myReports = Model.MyReports;
    var nearYou = featured;
    string TownStep(IssueStatus s) => s switch
    {
        IssueStatus.New => Localizer["TownStepNew"].Value,
        IssueStatus.Confirmed => Localizer["TownStepConfirmed"].Value,
        IssueStatus.InProgress => Localizer["TownStepInProgress"].Value,
        IssueStatus.Fixed => Localizer["TownStepFixed"].Value,
        _ => Localizer["TownStepClosed"].Value
    };
    int TownPct(IssueStatus s) => s switch
    {
        IssueStatus.New => 25,
        IssueStatus.Confirmed => 55,
        IssueStatus.InProgress => 80,
        IssueStatus.Fixed => 100,
        _ => 100
    };
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/issues-shared.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/home-index.css" asp-append-version="true" />
}

<div class="home-index-page">

@if (Model.IsResident)
{
    <section class="section--tight townhome">
        <div class="wrap">
            <div class="greet">
                <div>
                    <span class="kicker"><i class="bi bi-sunrise"></i>@Localizer["TownGreeting"]</span>
                    <h1>@Localizer["WelcomeBack"], @greetingName</h1>
                </div>
            </div>

            <div class="report-card">
                <div class="report-card__copy">
                    <h2>@Localizer["TownReportTitle"]</h2>
                    <p>@Localizer["TownReportCopy"]</p>
                    <a class="app-link-btn home-cta-btn btn-onblue" asp-area="" asp-page="/Issues/Create">
                        <i class="bi bi-plus-circle-fill"></i>
                        <span>@Localizer["LandingReportCta"]</span>
                    </a>
                    <div class="report-card__steps">
                        <span class="rc-step"><i class="bi bi-camera"></i>@Localizer["TownStepSnap"]</span>
                        <span class="rc-step"><i class="bi bi-geo-alt"></i>@Localizer["TownStepPin"]</span>
                        <span class="rc-step"><i class="bi bi-send"></i>@Localizer["TownStepDone"]</span>
                    </div>
                </div>
                <div class="report-card__visual" aria-hidden="true">
                    <div class="report-card__photo grad-a"><i class="bi bi-buildings"></i></div>
                </div>
            </div>

            @if (myReports.Any())
            {
                <div class="sec-row">
                    <div class="sec-row__copy">
                        <span class="kicker"><i class="bi bi-bookmark-heart"></i>@Localizer["TownYourReports"]</span>
                        <h2 class="h-section townhome__h2">@Localizer["TownWatching"] @myReports.Count</h2>
                    </div>
                    <a class="linkmore" asp-area="" asp-page="/Issues/Index">@Localizer["LandingBrowseAll"]<i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="your-reports">
                    @foreach (var it in myReports)
                    {
                        <a href="/issues/@it.Id" class="yr-card">
                            <div class="yr-card__top">
                                <partial name="_BadgeStatus" model="it.Status" />
                                <span class="gcard__confirm"><i class="bi bi-hand-thumbs-up-fill"></i>@it.Upvotes</span>
                            </div>
                            <h4>@it.Title</h4>
                            <div class="yr-bar"><i class="@(it.Status == IssueStatus.Fixed ? "is-done" : "")" style="width:@(TownPct(it.Status))%"></i></div>
                            <div class="yr-card__step">@TownStep(it.Status)</div>
                        </a>
                    }
                </div>
            }

            @if (nearYou.Any())
            {
                <div class="sec-row townhome__near">
                    <div class="sec-row__copy">
                        <span class="kicker"><i class="bi bi-pin-map"></i>@Localizer["TownNearYou"]</span>
                        <h2 class="h-section townhome__h2">@Localizer["TownHappeningAround"]</h2>
                    </div>
                    <a class="linkmore" asp-area="" asp-page="/Issues/Index">@Localizer["LandingBrowseAll"]<i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="gallery">
                    @foreach (var it in nearYou)
                    {
                        <partial name="_GalleryCard" model="it" />
                    }
                </div>
            }
        </div>
    </section>
}
else
{
    @* ---------- Hero ---------- *@
    <section class="lhero">
        <div class="wrap">
            <div class="lhero__grid">
                <div class="lhero__copy">
                    <span class="kicker"><i class="bi bi-people-fill"></i>@Localizer["LandingKicker"]</span>
                    <h1 class="lhero__title">
                        @Localizer["LandingTitleLine1"]<br />
                        <span class="soft-accent">@Localizer["LandingTitleLine2"]</span>
                    </h1>
                    <p class="lede">@Localizer["LandingLede"]</p>

                    <div class="lhero__actions">
                        @if (isAuthed)
                        {
                            <a class="nav-report-btn home-cta-btn" asp-area="" asp-page="/Issues/Create">
                                <i class="bi bi-plus-circle-fill"></i>
                                <span>@Localizer["LandingReportCta"]</span>
                            </a>
                        }
                        else
                        {
                            <a class="nav-report-btn home-cta-btn" asp-area="Identity" asp-page="/Account/Register">
                                <i class="bi bi-plus-circle-fill"></i>
                                <span>@Localizer["LandingReportCta"]</span>
                            </a>
                        }
                        <a class="app-link-btn home-cta-btn" asp-area="" asp-page="/Issues/Index">
                            <i class="bi bi-images"></i>
                            <span>@Localizer["LandingSeeHappening"]</span>
                        </a>
                    </div>

                    <div class="lhero__trust">
                        <div class="trust-item">
                            <b>@Model.Overview.FixedIssues.ToString("N0")</b>
                            <span>@Localizer["LandingStatResolved"]</span>
                        </div>
                        <div class="trust-item">
                            <b>@Model.Overview.CitiesCovered</b>
                            <span>@Localizer["LandingStatTowns"]</span>
                        </div>
                        <div class="trust-item">
                            <b>@Model.Overview.ResolutionRatePercentage%</b>
                            <span>@Localizer["LandingStatFixed"]</span>
                        </div>
                    </div>
                </div>

                <div class="lhero__visual" aria-hidden="true">
                    <div class="lhero__photo grad-a">
                        <i class="bi bi-buildings"></i>
                    </div>

                    @if (topStory is not null)
                    {
                        <div class="float-card float-card--tl">
                            <span class="float-card__ic" style="background: var(--emerald-500)"><i class="bi bi-check2"></i></span>
                            <div class="float-card__text">
                                <div class="float-card__t">@Localizer["Fixed"]</div>
                                <div class="float-card__s">@AddressOf(topStory)</div>
                            </div>
                        </div>
                    }

                    @if (topFeatured is not null)
                    {
                        <div class="float-card float-card--br">
                            <span class="float-card__ic" style="background: var(--sky-500)"><i class="bi bi-hand-thumbs-up-fill"></i></span>
                            <div class="float-card__text">
                                <div class="float-card__t">@topFeatured.Upvotes @Localizer["LandingConfirmed"]</div>
                                <div class="float-card__s">@topFeatured.Title</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    @* ---------- How it works ---------- *@
    <section class="section band">
        <div class="wrap center steps-band">
            <span class="kicker">@Localizer["HowItWorks"]</span>
            <h2 class="h-section steps-band__title">@Localizer["LandingStepsTitle"]</h2>
            <p class="lede center steps-band__lede">@Localizer["LandingStepsLede"]</p>

            <div class="steps">
                <div class="step">
                    <span class="step__num step__num--a"><i class="bi bi-camera-fill"></i></span>
                    <h3>@Localizer["LandingStep1Title"]</h3>
                    <p>@Localizer["LandingStep1Copy"]</p>
                </div>
                <div class="step">
                    <span class="step__num step__num--b"><i class="bi bi-people-fill"></i></span>
                    <h3>@Localizer["LandingStep2Title"]</h3>
                    <p>@Localizer["LandingStep2Copy"]</p>
                </div>
                <div class="step">
                    <span class="step__num step__num--c"><i class="bi bi-flag-fill"></i></span>
                    <h3>@Localizer["LandingStep3Title"]</h3>
                    <p>@Localizer["LandingStep3Copy"]</p>
                </div>
            </div>
        </div>
    </section>

    @* ---------- Happening now ---------- *@
    <section class="section">
        <div class="wrap">
            <div class="sec-row">
                <div class="sec-row__copy">
                    <span class="kicker"><i class="bi bi-broadcast"></i>@Localizer["LandingHappeningKicker"]</span>
                    <h2 class="h-section">@Localizer["LandingHappeningTitle"]</h2>
                </div>
                <a class="linkmore" asp-area="" asp-page="/Issues/Index">
                    @Localizer["LandingBrowseAll"]<i class="bi bi-arrow-right"></i>
                </a>
            </div>

            @if (featured.Any())
            {
                <div class="gallery">
                    @for (var i = 0; i < featured.Count; i++)
                    {
                        var it = featured[i];
                        <a href="/issues/@it.Id" class="gcard">
                            <div class="gcard__photo @GradFor(i)">
                                <span class="gcard__glyph"><i class="bi @GlyphFor(it.Status)"></i></span>
                                <span class="gcard__status"><partial name="_BadgeStatus" model="it.Status" /></span>
                            </div>
                            <div class="gcard__body">
                                <h3 class="gcard__title">@it.Title</h3>
                                <span class="gcard__loc"><i class="bi bi-geo-alt-fill"></i>@AddressOf(it)</span>
                                <div class="gcard__foot">
                                    <span class="gcard__reporter">
                                        <span class="gcard__avatar" style="background:@AvatarColor(i)">@InitialOf(it)</span>
                                        @ReporterName(it)
                                    </span>
                                    <span class="gcard__confirm">
                                        <i class="bi bi-hand-thumbs-up-fill"></i>@it.Upvotes @Localizer["LandingConfirmed"]
                                    </span>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="home-empty">
                    <div class="home-empty__icon"><i class="bi bi-inbox"></i></div>
                    <h3>@Localizer["NoIssuesReportedYet"]</h3>
                    <p>@Localizer["BeTheFirstToMakeYourCommunityBetter"]</p>
                </div>
            }
        </div>
    </section>

    @* ---------- Real outcomes / stories ---------- *@
    @if (stories.Any())
    {
        <section class="section band">
            <div class="wrap">
                <div class="center">
                    <span class="kicker"><i class="bi bi-stars"></i>@Localizer["LandingStoriesKicker"]</span>
                    <h2 class="h-section steps-band__title">@Localizer["LandingStoriesTitle"]</h2>
                    <p class="lede center steps-band__lede">@Localizer["LandingStoriesLede"]</p>
                </div>

                <div class="gallery gallery--stories">
                    @for (var i = 0; i < stories.Count; i++)
                    {
                        var s = stories[i];
                        <a href="/issues/@s.Id" class="gcard">
                            <div class="gcard__photo @GradFor(i + 1)">
                                <span class="gcard__glyph"><i class="bi bi-check2-circle"></i></span>
                                <span class="gcard__status"><partial name="_BadgeStatus" model="IssueStatus.Fixed" /></span>
                            </div>
                            <div class="gcard__body">
                                <h3 class="gcard__title">@s.Title</h3>
                                <span class="gcard__loc"><i class="bi bi-geo-alt-fill"></i>@AddressOf(s)</span>
                                <div class="gcard__foot">
                                    <span class="gcard__reporter">
                                        <span class="gcard__avatar" style="background:@AvatarColor(i + 2)">@InitialOf(s)</span>
                                        @ReporterName(s)
                                    </span>
                                    <span class="gcard__confirm gcard__confirm--muted">
                                        <i class="bi bi-calendar2-check"></i>@Localizer["LandingResolvedLabel"] @s.LastActivityAt.ToString("MMM d")
                                    </span>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </section>
    }

    @* ---------- Closing CTA ---------- *@
    <section class="section--tight">
        <div class="wrap">
            <div class="cta-band">
                <h2>@Localizer["LandingCtaTitle"]</h2>
                <p>@Localizer["LandingCtaCopy"]</p>
                <div class="cta-band__actions">
                    @if (isAuthed)
                    {
                        <a class="app-link-btn home-cta-btn btn-onblue" asp-area="" asp-page="/Issues/Create">
                            <i class="bi bi-plus-circle-fill"></i>
                            <span>@Localizer["LandingReportCta"]</span>
                        </a>
                        <a class="app-link-btn home-cta-btn btn-onblue-ghost" asp-area="" asp-page="/Issues/Index">
                            <i class="bi bi-images"></i>
                            <span>@Localizer["BrowseIssues"]</span>
                        </a>
                    }
                    else
                    {
                        <a class="app-link-btn home-cta-btn btn-onblue" asp-area="Identity" asp-page="/Account/Register">
                            <i class="bi bi-person-plus-fill"></i>
                            <span>@Localizer["CreateAccount"]</span>
                        </a>
                        <a class="app-link-btn home-cta-btn btn-onblue-ghost" asp-area="Identity" asp-page="/Account/Login">
                            <i class="bi bi-box-arrow-in-right"></i>
                            <span>@Localizer["SignIn"]</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </section>
}
</div>
