@page "/safety/hazard-mode"
@model FixIt.Pages.Safety.HazardModeModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["SafetyHazardMap"];
}

<div class="container-fluid" style="height: 100vh; padding: 0;">
    <!-- Header -->
    <div class="hazard-header">
        <div class="header-content">
            <h5 class="mb-0">
                <i class="bi bi-exclamation-triangle-fill text-danger"></i> Hazard Mode
            </h5>
            <small class="text-muted">Real-time safety alerts for your area</small>
        </div>
        <div class="header-controls">
            <button class="btn btn-sm btn-outline-primary" id="myLocationBtn">
                <i class="bi bi-geo-alt-fill"></i> My Location
            </button>
            <small class="text-muted ms-2"><i class="bi bi-info-circle"></i> Click on map to report a hazard</small>
        </div>
    </div>

    <div class="hazard-container">
        <!-- Map -->
        <div id="hazardMap" class="hazard-map"></div>

        <!-- Sidebar - Hazard List -->
        <div class="hazard-sidebar">
            <div class="sidebar-header">
                <h6 class="mb-3">Nearby Hazards</h6>
                <div class="filter-controls">
                    <input type="text" class="form-control form-control-sm mb-2" 
                           id="hazardFilter" placeholder='@Localizer["FilterHazards"]'
                           onkeyup="filterHazards(this.value)">
                    <select class="form-select form-select-sm mb-2" id="severityFilter" 
                            onchange="filterBySeverity(this.value)">
                        <option value="">All Severities</option>
                        <option value="Critical">Critical</option>
                        <option value="High">High</option>
                        <option value="Medium">Medium</option>
                        <option value="Low">Low</option>
                    </select>
                    <select class="form-select form-select-sm" id="typeFilter" 
                            onchange="filterByType(this.value)">
                        <option value="">All Types</option>
                        <option value="Crime">Crime</option>
                        <option value="Accident">Accident</option>
                        <option value="Construction">Construction</option>
                        <option value="Pothole">Pothole</option>
                        <option value="Flooding">Flooding</option>
                        <option value="DamagedInfrastructure">Infrastructure Damage</option>
                        <option value="StreetLight">Street Light</option>
                        <option value="Debris">Debris</option>
                        <option value="TrafficCongestion">Traffic</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
            </div>

            <div class="sidebar-stats mb-3">
                <div class="stat-pill">
                    <span class="stat-value" id="totalHazardsCount">0</span>
                    <span class="stat-label">Total</span>
                </div>
                <div class="stat-pill critical">
                    <span class="stat-value" id="criticalCount">0</span>
                    <span class="stat-label">Critical</span>
                </div>
                <div class="stat-pill high">
                    <span class="stat-value" id="highCount">0</span>
                    <span class="stat-label">High</span>
                </div>
            </div>

            <div class="hazards-list" id="hazardsList">
                <div class="text-center text-muted py-4">
                    <i class="bi bi-hourglass-split"></i> @Localizer["LoadingHazards"]
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Hazard Detail Modal -->
<div class="modal fade" id="hazardDetailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title" id="hazardModalTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="hazard-detail-content" id="hazardDetailContent">
                    <!-- Dynamic content -->
                </div>
            </div>
            <div class="modal-footer border-top-0" id="hazardDetailFooter">
                <button type="button" class="btn btn-outline-primary" id="confirmBtn" onclick="confirmHazard()">
                    <i class="bi bi-check-circle"></i> Confirm
                </button>
                <button type="button" class="btn btn-warning d-none" id="editBtn" onclick="openEditModal()">
                    <i class="bi bi-pencil-square"></i> Edit
                </button>
                <button type="button" class="btn btn-danger d-none" id="deleteBtn" onclick="deleteHazard()">
                    <i class="bi bi-trash"></i> Delete
                </button>
                <button type="button" class="btn btn-success d-none" id="restoreBtn" onclick="restoreHazard()">
                    <i class="bi bi-arrow-counterclockwise"></i> Restore
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>

            <!-- Edit Hazard Modal -->
            <div class="modal fade" id="editHazardModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Edit Hazard</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <form id="editHazardForm">
                                <input type="hidden" id="editHazardId" />
                                <div class="mb-2">
                                    <label class="form-label">Type</label>
                                    <select id="editType" class="form-select">
                                        <option value="">-- Select type --</option>
                                        <option value="Crime">Crime</option>
                                        <option value="Accident">Accident</option>
                                        <option value="Construction">Construction</option>
                                        <option value="Pothole">Pothole</option>
                                        <option value="Flooding">Flooding</option>
                                        <option value="DamagedInfrastructure">Infrastructure Damage</option>
                                        <option value="StreetLight">Street Light</option>
                                        <option value="Debris">Debris</option>
                                        <option value="TrafficCongestion">Traffic</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label">Severity</label>
                                    <select id="editSeverity" class="form-select">
                                        <option value="">-- Select severity --</option>
                                        <option value="Critical">Critical</option>
                                        <option value="High">High</option>
                                        <option value="Medium">Medium</option>
                                        <option value="Low">Low</option>
                                    </select>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label">Title</label>
                                    <input id="editTitle" class="form-control" />
                                </div>
                                <div class="mb-2">
                                    <label class="form-label">Description</label>
                                    <textarea id="editDescription" class="form-control" rows="3"></textarea>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label">Address</label>
                                    <input id="editAddress" class="form-control" />
                                </div>
                                <div class="row">
                                    <div class="col-6 mb-2">
                                        <label class="form-label">Latitude</label>
                                        <input id="editLatitude" class="form-control" />
                                    </div>
                                    <div class="col-6 mb-2">
                                        <label class="form-label">Longitude</label>
                                        <input id="editLongitude" class="form-control" />
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="button" class="btn btn-primary" onclick="submitHazardUpdate()">@Localizer["SaveChanges"]</button>
                        </div>
                    </div>
                </div>
            </div>
</div>

<!-- Report Hazard Modal -->
<div class="modal fade" id="reportHazardModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-flag"></i> Report Hazard</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="quickReportForm">
                    <div class="alert alert-info mb-3">
                        <strong>Location Selected:</strong><br>
                        <small id="reportLocationDisplay">Click on map to select location</small>
                    </div>

                    <div class="mb-3">
                        <label for="reportType" class="form-label">Hazard Type <span class="text-danger">*</span></label>
                        <select class="form-select" id="reportType" required>
                            <option value="">-- Select type --</option>
                            <option value="Crime">Crime</option>
                            <option value="Accident">Accident</option>
                            <option value="Construction">Construction</option>
                            <option value="Pothole">Pothole</option>
                            <option value="Flooding">Flooding</option>
                            <option value="DamagedInfrastructure">Infrastructure Damage</option>
                            <option value="StreetLight">Street Light</option>
                            <option value="Debris">Debris</option>
                            <option value="TrafficCongestion">Traffic</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="reportSeverity" class="form-label">Severity <span class="text-danger">*</span></label>
                        <select class="form-select" id="reportSeverity" required>
                            <option value="">-- Select severity --</option>
                            <option value="Critical">🔴 Critical</option>
                            <option value="High">🟠 High</option>
                            <option value="Medium">🟡 Medium</option>
                            <option value="Low">🟢 Low</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="reportTitle" class="form-label">Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="reportTitle" required placeholder="Brief description of the hazard">
                    </div>

                    <div class="mb-3">
                        <label for="reportDescription" class="form-label">Details <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="reportDescription" rows="3" required placeholder="Additional details that would help others..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label for="reportLocationInput" class="form-label">Location <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="reportLocationInput" readonly placeholder="Click on map to select location">
                        <small class="form-text text-muted">Selected from map: Click anywhere on the map to update</small>
                    </div>


                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="submitQuickReport()">
                    <i class="bi bi-check-circle"></i> Submit Report
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Hazard Detail Modal -->
<div class="modal fade" id="hazardDetailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title" id="hazardModalTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="hazard-detail-content" id="hazardDetailContent">
                    <!-- Dynamic content -->
                </div>
            </div>
            <div class="modal-footer border-top-0" id="hazardDetailFooter">
                <button type="button" class="btn btn-outline-primary" id="confirmBtn" onclick="confirmHazard()">
                    <i class="bi bi-check-circle"></i> Confirm
                </button>
                <button type="button" class="btn btn-warning d-none" id="editBtn" onclick="openEditModal()">
                    <i class="bi bi-pencil-square"></i> Edit
                </button>
                <button type="button" class="btn btn-danger d-none" id="deleteBtn" onclick="deleteHazard()">
                    <i class="bi bi-trash"></i> Delete
                </button>
                <button type="button" class="btn btn-success d-none" id="restoreBtn" onclick="restoreHazard()">
                    <i class="bi bi-arrow-counterclockwise"></i> Restore
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>

<script>
    let map;
    let userMarker;
    let hazardMarkers = {};
    let currentCity = '@Model.CityId';
    let selectedHazardId = null;
    let reportLocationLat = null;
    let reportLocationLng = null;
    let reportLocationAddress = '';
    let userLocation = { lat: 42.7339, lng: 25.4858 }; // Default Sofia
    
    // Geocoding state and caching
    let geocodingCache = {};
    let lastGeocodingRequest = 0;
    let geocodingTimeout = null;
    const GEOCODING_DEBOUNCE_MS = 300;
    const GEOCODING_REQUEST_THROTTLE_MS = 500;

    // Real-time hazard updates - poll for new/updated hazards every 5 seconds
    let hazardRefreshInterval = null;
    const HAZARD_REFRESH_INTERVAL_MS = 5000;

    const severityColors = {
        'Critical': '#dc3545',
        'High': '#fd7e14',
        'Medium': '#ffc107',
        'Low': '#198754'
    };

    const severityIcons = {
        'Critical': '🚨',
        'High': '⚠️',
        'Medium': '⚡',
        'Low': 'ℹ️'
    };

    document.addEventListener('DOMContentLoaded', function () {
        initializeMap();
        loadNearbyHazards();
        
        // Start a refresh interval to check for new hazards every 5 seconds
        if (hazardRefreshInterval) clearInterval(hazardRefreshInterval);
        hazardRefreshInterval = setInterval(loadNearbyHazards, HAZARD_REFRESH_INTERVAL_MS);
        
        // Request user location
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(function (position) {
                userLocation = {
                    lat: position.coords.latitude,
                    lng: position.coords.longitude
                };
                updateMapCenter();
                loadNearbyHazards();
            });
        }
    });

    function initializeMap() {
        map = L.map('hazardMap').setView([userLocation.lat, userLocation.lng], 13);
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
            maxZoom: 19
        }).addTo(map);

        // User location marker
        userMarker = L.circleMarker([userLocation.lat, userLocation.lng], {
            radius: 8,
            fillColor: '#007bff',
            color: '#0056b3',
            weight: 2,
            opacity: 1,
            fillOpacity: 0.8
        }).addTo(map);
        userMarker.bindPopup('Your Location');

        // Map click handler for reporting hazards
        map.on('click', function (e) {
            reportLocationLat = e.latlng.lat;
            reportLocationLng = e.latlng.lng;
            
            // Show loading state
            const coordDisplay = `Latitude: ${reportLocationLat.toFixed(6)}, Longitude: ${reportLocationLng.toFixed(6)}`;
            document.getElementById('reportLocationDisplay').textContent = coordDisplay;
                            document.getElementById('reportLocationInput').value = '@Localizer["LoadingAddress"]';
            document.getElementById('reportLocationInput').style.color = '#999';
            
            // Debounce geocoding requests
            clearTimeout(geocodingTimeout);
            geocodingTimeout = setTimeout(function() {
                reverseGeocode(reportLocationLat, reportLocationLng);
            }, GEOCODING_DEBOUNCE_MS);
            
            const modal = new bootstrap.Modal(document.getElementById('reportHazardModal'));
            modal.show();
        });
    }

    function updateMapCenter() {
        if (map && userMarker) {
            map.setView([userLocation.lat, userLocation.lng], 13);
            userMarker.setLatLng([userLocation.lat, userLocation.lng]);
        }
    }

    /**
     * Reverse geocode coordinates to address
     */
    async function reverseGeocode(lat, lng) {
        const cacheKey = `${lat.toFixed(4)},${lng.toFixed(4)}`;
        
        // Check local cache first
        if (geocodingCache[cacheKey]) {
            console.log('Using local cache:', geocodingCache[cacheKey]);
            updateLocationField(geocodingCache[cacheKey]);
            reportLocationAddress = geocodingCache[cacheKey];
            return;
        }
        
        // Throttle requests to avoid overloading
        const now = Date.now();
        if (now - lastGeocodingRequest < GEOCODING_REQUEST_THROTTLE_MS) {
            console.log('Throttling geocoding request');
            return;
        }
        
        lastGeocodingRequest = now;
        
        try {
            console.log(`Fetching address for: ${lat}, ${lng}`);
            
            const response = await fetch(
                `/api/geocoding/reverse?latitude=${lat}&longitude=${lng}`,
                {
                    method: 'GET',
                    headers: {
                        'Accept': 'application/json'
                    }
                }
            );
            
            console.log('Backend geocoding response status:', response.status);
            
            if (!response.ok) {
                throw new Error(`Geocoding API error: ${response.status}`);
            }
            
            const data = await response.json();
            console.log('Geocoding response:', data);
            
            if (data && data.address) {
                console.log('Address received:', data.address);
                
                // Cache the result
                geocodingCache[cacheKey] = data.address;
                
                // Update the field
                reportLocationAddress = data.address;
                updateLocationField(data.address);
            } else {
                console.warn('No address in response');
                const fallback = `Latitude: ${lat.toFixed(6)}, Longitude: ${lng.toFixed(6)}`;
                reportLocationAddress = fallback;
                updateLocationField(fallback);
            }
        } catch (error) {
            console.error('Geocoding error:', error);
            
            // Fallback to coordinates on error
            const fallback = `Latitude: ${lat.toFixed(6)}, Longitude: ${lng.toFixed(6)}`;
            reportLocationAddress = fallback;
            updateLocationField(fallback);
        }
    }
    
    function buildAddressString(addressObj) {
        // Priority order for address components
        const parts = [];
        
        // Add street address with house number
        if (addressObj.road) {
            let street = addressObj.road;
            if (addressObj.house_number) {
                street += ` ${addressObj.house_number}`;
            }
            parts.push(street);
        } else if (addressObj.street) {
            let street = addressObj.street;
            if (addressObj.house_number) {
                street += ` ${addressObj.house_number}`;
            }
            parts.push(street);
        }
        
        // Add suburb or neighborhood
        if (addressObj.suburb) {
            if (!parts.some(p => p.includes(addressObj.suburb))) {
                parts.push(addressObj.suburb);
            }
        } else if (addressObj.neighbourhood) {
            if (!parts.some(p => p.includes(addressObj.neighbourhood))) {
                parts.push(addressObj.neighbourhood);
            }
        }
        
        // Add postcode if available
        if (addressObj.postcode) {
            parts.push(addressObj.postcode);
        }
        
        // Add city/town/village - use the most specific
        let city = addressObj.city || addressObj.town || addressObj.village || addressObj.municipality;
        if (city) {
            if (!parts.some(p => p.includes(city))) {
                parts.push(city);
            }
        }
        
        // Add state/province if different from city
        if (addressObj.state && addressObj.state !== city) {
            if (!parts.some(p => p.includes(addressObj.state))) {
                parts.push(addressObj.state);
            }
        }
        
        // Add country as last component
        if (addressObj.country) {
            if (!parts.some(p => p.includes(addressObj.country))) {
                parts.push(addressObj.country);
            }
        }
        
        if (parts.length === 0) {
            return 'Location selected';
        }
        
        return parts.join(', ');
    }
    
    function updateLocationField(address) {
        const input = document.getElementById('reportLocationInput');
        if (input) {
            input.value = address;
            input.style.color = '#333';
        }
    }

    async function loadNearbyHazards() {
        try {
            const response = await fetch(
                `/api/safety/nearby-hazards?cityId=${currentCity}&latitude=${userLocation.lat}&longitude=${userLocation.lng}&radiusKm=10`
            );
            
            if (!response.ok) {
                const errorText = await response.text();
                console.error(`HTTP error! status: ${response.status}, body: ${errorText}`);
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            const data = await response.json();
            console.log('Hazards loaded:', data);

            if (data.success && Array.isArray(data.data)) {
                displayHazards(data.data);
                updateStatistics(data.data);
            } else {
                console.error('Failed to load hazards:', data.message || 'Invalid response format');
                document.getElementById('hazardsList').innerHTML = '<div class="alert alert-warning p-2"><small>No hazards in your area</small></div>';
            }
        } catch (error) {
            console.error('Error loading hazards:', error);
            document.getElementById('hazardsList').innerHTML = '<div class="alert alert-danger p-2"><small>Failed to load hazards. Please try again.</small></div>';
        }
    }

    function displayHazards(hazards) {
        // Clear existing markers
        Object.values(hazardMarkers).forEach(marker => map.removeLayer(marker));
        hazardMarkers = {};

        // Update sidebar
        const hazardsList = document.getElementById('hazardsList');
        if (hazards.length === 0) {
            hazardsList.innerHTML = '<div class="text-center text-muted py-4"><i class="bi bi-check-circle"></i> No hazards nearby</div>';
            return;
        }

        hazardsList.innerHTML = hazards.map(hazard => `
            <div class="hazard-item severity-${hazard.severity.toLowerCase()}" onclick="selectHazard('${hazard.id}')">
                <div class="hazard-item-header">
                    <span class="hazard-icon">${severityIcons[hazard.severity]}</span>
                    <div class="hazard-info">
                        <h6 class="mb-0">${hazard.title}</h6>
                        <small class="text-muted">${hazard.type} • ${hazard.distance.toFixed(1)} km away</small>
                    </div>
                </div>
                <div class="hazard-item-footer">
                    <span class="badge bg-${getSeverityBadgeClass(hazard.severity)}">${hazard.severity}</span>
                    <span class="badge bg-light text-dark">${hazard.confirmations} confirmations</span>
                </div>
            </div>
        `).join('');

        // Add markers to map
        hazards.forEach(hazard => {
            const marker = L.circleMarker([hazard.latitude, hazard.longitude], {
                radius: 10,
                fillColor: severityColors[hazard.severity],
                color: '#000',
                weight: 2,
                opacity: 1,
                fillOpacity: 0.8
            }).addTo(map);

            marker.bindPopup(`
                <strong>${hazard.title}</strong><br/>
                ${hazard.severity} • ${hazard.confirmations} confirmations<br/>
                <button class="btn btn-sm btn-primary mt-2" onclick="showHazardDetail('${hazard.id}')">
                    View Details
                </button>
            `);

            hazardMarkers[hazard.id] = marker;

            marker.on('click', function () {
                selectHazard(hazard.id);
            });
        });
    }

    function updateStatistics(hazards) {
        document.getElementById('totalHazardsCount').textContent = hazards.length;
        document.getElementById('criticalCount').textContent = hazards.filter(h => h.severity === 'Critical').length;
        document.getElementById('highCount').textContent = hazards.filter(h => h.severity === 'High').length;
    }

    function selectHazard(hazardId) {
        selectedHazardId = hazardId;
        if (hazardMarkers[hazardId]) {
            hazardMarkers[hazardId].openPopup();
        }
    }

    async function showHazardDetail(hazardId) {
        try {
            const response = await fetch(`/api/safety/${hazardId}`);
            const data = await response.json();

            if (data.success) {
                const hazard = data.data;
                // store for editing
                window._currentHazard = hazard;

                document.getElementById('hazardModalTitle').textContent = hazard.title;
                document.getElementById('hazardDetailContent').innerHTML = `
                    <div class="hazard-detail">
                        <div class="detail-row">
                            <label>Type:</label>
                            <span>${hazard.type}</span>
                        </div>
                        <div class="detail-row">
                            <label>Severity:</label>
                            <span class="badge bg-${getSeverityBadgeClass(hazard.severity)}">${hazard.severity}</span>
                        </div>
                        <div class="detail-row">
                            <label>Description:</label>
                            <p>${hazard.description}</p>
                        </div>
                        <div class="detail-row">
                            <label>Location:</label>
                            <span>${hazard.address}</span>
                        </div>
                        <div class="detail-row">
                            <label>Confirmations:</label>
                            <span>${hazard.confirmations}</span>
                        </div>
                        <div class="detail-row">
                            <label>Reported:</label>
                            <span>${new Date(hazard.createdAt).toLocaleString()}</span>
                        </div>
                    </div>
                `;

                selectedHazardId = hazardId;

                // toggle CRUD buttons based on API-provided flags
                const canEdit = hazard.canEdit || hazard.canEdit === true;
                const canDelete = hazard.canDelete || hazard.canDelete === true;
                const canRestore = hazard.canRestore || hazard.canRestore === true;

                document.getElementById('editBtn').classList.toggle('d-none', !canEdit);
                document.getElementById('deleteBtn').classList.toggle('d-none', !canDelete);
                document.getElementById('restoreBtn').classList.toggle('d-none', !canRestore);

                const modal = new bootstrap.Modal(document.getElementById('hazardDetailModal'));
                modal.show();
            }
        } catch (error) {
            console.error('Error loading hazard detail:', error);
        }
    }

    async function confirmHazard() {
        if (!selectedHazardId) return;

        try {
            const response = await fetch(`/api/safety/${selectedHazardId}/confirm`, {
                method: 'POST'
            });

            if (response.ok) {
                alert('Hazard confirmed! Thank you for helping keep your community safe.');
                
                // Close the modal first
                const modalInstance = bootstrap.Modal.getInstance(document.getElementById('hazardDetailModal'));
                if (modalInstance) {
                    modalInstance.hide();
                }
                
                // Refresh all hazard data to show updated confirmation count in real-time
                await loadNearbyHazards();
            }
        } catch (error) {
            console.error('Error confirming hazard:', error);
        }
    }

    async function submitQuickReport() {
        const type = document.getElementById('reportType').value;
        const severity = document.getElementById('reportSeverity').value;
        const title = document.getElementById('reportTitle').value;
        const description = document.getElementById('reportDescription').value;

        if (!type || !severity || !title || !description) {
            alert('Please fill in all required fields');
            return;
        }

        if (reportLocationLat === null || reportLocationLng === null) {
            alert('Please click on the map to select a location');
            return;
        }

        // Map severity string to enum value
        const severityMap = { 'Low': 0, 'Medium': 1, 'High': 2, 'Critical': 3 };
        const severityValue = severityMap[severity];

        try {
            const response = await fetch('/api/safety/report', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    cityId: currentCity,
                    type: type,
                    severity: severity,
                    title: title,
                    description: description,
                    latitude: reportLocationLat,
                    longitude: reportLocationLng,
                    address: reportLocationAddress
                })
            });

            const responseData = await response.json();

            if (response.ok || response.status === 201) {
                alert('Thank you! Your report has been submitted and helps keep the community safe.');
                bootstrap.Modal.getInstance(document.getElementById('reportHazardModal')).hide();
                document.getElementById('quickReportForm').reset();
                reportLocationLat = null;
                reportLocationLng = null;
                reportLocationAddress = '';
                document.getElementById('reportLocationDisplay').textContent = 'Click on map to select location';
                const locationInput = document.getElementById('reportLocationInput');
                locationInput.value = '';
                locationInput.style.color = '#333';
                loadNearbyHazards();
            } else {
                const errorMsg = responseData?.message || 'Failed to submit report';
                console.error('Report submission failed:', {
                    status: response.status,
                    error: errorMsg,
                    fullResponse: responseData
                });
                alert('Error: ' + errorMsg);
            }
        } catch (error) {
            console.error('Error submitting report:', error);
            alert('Error submitting report: ' + error.message);
        }
    }

    function filterHazards(searchTerm) {
        const items = document.querySelectorAll('.hazard-item');
        items.forEach(item => {
            const text = item.textContent.toLowerCase();
            item.style.display = text.includes(searchTerm.toLowerCase()) ? 'block' : 'none';
        });
    }

    function filterBySeverity(severity) {
        const items = document.querySelectorAll('.hazard-item');
        items.forEach(item => {
            if (!severity) {
                item.style.display = 'block';
            } else {
                item.style.display = item.classList.contains(`severity-${severity.toLowerCase()}`) ? 'block' : 'none';
            }
        });
    }

    function filterByType(type) {
        // Implementation for type filtering
        const items = document.querySelectorAll('.hazard-item');
        items.forEach(item => {
            if (!type) {
                item.style.display = 'block';
            } else {
                item.style.display = item.textContent.includes(type) ? 'block' : 'none';
            }
        });
    }

    function getSeverityBadgeClass(severity) {
        const classes = {
            'Critical': 'danger',
            'High': 'warning',
            'Medium': 'info',
            'Low': 'success'
        };
        return classes[severity] || 'secondary';
    }

    document.getElementById('myLocationBtn').addEventListener('click', function () {
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(function (position) {
                userLocation = {
                    lat: position.coords.latitude,
                    lng: position.coords.longitude
                };
                updateMapCenter();
                loadNearbyHazards();
            });
        }
    });

    // Open edit modal and prefill fields
    function openEditModal() {
        const hazard = window._currentHazard;
        if (!hazard) return;

        document.getElementById('editHazardId').value = hazard.id;
        document.getElementById('editType').value = hazard.type || '';
        document.getElementById('editSeverity').value = hazard.severity || '';
        document.getElementById('editTitle').value = hazard.title || '';
        document.getElementById('editDescription').value = hazard.description || '';
        document.getElementById('editAddress').value = hazard.address || '';
        document.getElementById('editLatitude').value = hazard.latitude || '';
        document.getElementById('editLongitude').value = hazard.longitude || '';

        const modal = new bootstrap.Modal(document.getElementById('editHazardModal'));
        modal.show();
    }

    async function submitHazardUpdate() {
        const id = document.getElementById('editHazardId').value;
        const payload = {
            type: document.getElementById('editType').value || null,
            severity: document.getElementById('editSeverity').value || null,
            title: document.getElementById('editTitle').value || null,
            description: document.getElementById('editDescription').value || null,
            address: document.getElementById('editAddress').value || null,
            latitude: parseFloat(document.getElementById('editLatitude').value) || null,
            longitude: parseFloat(document.getElementById('editLongitude').value) || null
        };

        try {
            const response = await fetch(`/api/safety/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            const res = await response.json();
            if (response.ok) {
                alert('Hazard updated');
                bootstrap.Modal.getInstance(document.getElementById('editHazardModal')).hide();
                bootstrap.Modal.getInstance(document.getElementById('hazardDetailModal'))?.hide();
                loadNearbyHazards();
            } else {
                console.error('Update failed', res);
                alert(res?.message || 'Failed to update hazard');
            }
        } catch (err) {
            console.error('Error updating hazard', err);
            alert('Error updating hazard');
        }
    }

    async function deleteHazard() {
        if (!selectedHazardId) return;
        if (!confirm('Are you sure you want to delete this hazard?')) return;

        try {
            const response = await fetch(`/api/safety/${selectedHazardId}`, { method: 'DELETE' });
            const res = await response.json();
            if (response.ok) {
                alert('Hazard deleted');
                bootstrap.Modal.getInstance(document.getElementById('hazardDetailModal')).hide();
                loadNearbyHazards();
            } else {
                console.error('Delete failed', res);
                alert(res?.message || 'Failed to delete hazard');
            }
        } catch (err) {
            console.error('Error deleting hazard', err);
            alert('Error deleting hazard');
        }
    }

    async function restoreHazard() {
        if (!selectedHazardId) return;
        if (!confirm('Restore this hazard?')) return;

        try {
            const response = await fetch(`/api/safety/${selectedHazardId}/restore`, { method: 'POST' });
            const res = await response.json();
            if (response.ok) {
                alert('Hazard restored');
                bootstrap.Modal.getInstance(document.getElementById('hazardDetailModal')).hide();
                loadNearbyHazards();
            } else {
                console.error('Restore failed', res);
                alert(res?.message || 'Failed to restore hazard');
            }
        } catch (err) {
            console.error('Error restoring hazard', err);
            alert('Error restoring hazard');
        }
    }
</script>

