@page "/safety/hazard-mode"
@model FixIt.Pages.Safety.HazardModeModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@inject Microsoft.AspNetCore.Mvc.Rendering.IJsonHelper Json
@{
    ViewData["Title"] = Localizer["SafetyHazardMap"];
    ViewData["RequiresMap"] = true;
    var coverageArea = Model.City?.Name ?? "your area";
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/maps.css" asp-append-version="true" />
}

<div class="map-page py-4">
    <section class="hazard-mode-hero">
        <div class="hazard-mode-hero__copy">
            <span class="eyebrow">@Localizer["HazardMode"]</span>
            <h1 class="page-title mb-2">@Localizer["HazardMode"]</h1>
            <p class="page-copy mb-0">
                Monitor live reports across @coverageArea, verify incidents quickly, and capture new hazards directly from the map.
            </p>
        </div>
        <div class="hazard-mode-hero__actions">
            <button type="button" class="btn btn-primary" id="myLocationBtn">
                <i class="bi bi-geo-alt-fill me-2"></i>My location
            </button>
        </div>
        <div class="hazard-mode-hero__metrics">
            <div class="hazard-mode-hero__metric">
                <span>Coverage area</span>
                <strong>@coverageArea</strong>
                <small>Live map radius of 10 km around the active position.</small>
            </div>
            <div class="hazard-mode-hero__metric">
                <span>Workflow</span>
                <strong>Report, verify, coordinate</strong>
                <small>Tap the map to report. Open any card to inspect or moderate.</small>
            </div>
        </div>
    </section>

    <div class="hazard-mode-layout">
        <section class="card hazard-mode-stage">
            <div class="hazard-mode-stage__head">
                <div>
                    <span class="eyebrow">@Localizer["SafetyHazardMap"]</span>
                    <h2 class="h3 mb-2">Tap the map to report a hazard</h2>
                    <p class="text-muted mb-0">Select any point on the map to open the rapid-report flow. Existing hazards stay visible so teams can avoid duplicates.</p>
                </div>
                <div class="hazard-mode-stage__legend">
                    <span class="hazard-severity-pill hazard-severity-pill--critical">@Localizer["Critical"]</span>
                    <span class="hazard-severity-pill hazard-severity-pill--high">@Localizer["High"]</span>
                    <span class="hazard-severity-pill hazard-severity-pill--medium">@Localizer["Medium"]</span>
                    <span class="hazard-severity-pill hazard-severity-pill--low">@Localizer["Low"]</span>
                </div>
            </div>
            <div class="hazard-mode-stage__map-wrap">
                <div id="hazardMap" class="hazard-map"></div>
                <div class="hazard-map-hint">
                    <i class="bi bi-cursor-fill"></i>
                    <div>
                        <strong>Quick report</strong>
                        <span>Click anywhere on the map to start a field report with the selected coordinates.</span>
                    </div>
                </div>
            </div>
        </section>

        <aside class="card hazard-mode-sidebar">
            <div class="hazard-mode-sidebar__head">
                <div>
                    <span class="eyebrow">Nearby hazards</span>
                    <h2 class="h4 mb-2">Nearby hazards</h2>
                    <p class="text-muted mb-0">Filter by keyword, severity, or type to focus on the incidents that need attention first.</p>
                </div>
            </div>

            <div class="hazard-mode-filter-grid">
                <div class="hazard-filter-field hazard-filter-field--wide">
                    <label for="hazardFilter">@Localizer["FilterHazards"]</label>
                    <div class="hazard-search-input">
                        <i class="bi bi-search"></i>
                        <input type="search" class="form-control" id="hazardFilter" placeholder='@Localizer["FilterHazards"]' />
                    </div>
                </div>

                <div class="hazard-filter-field">
                    <label for="severityFilter">Severity</label>
                    <select class="form-select" id="severityFilter">
                        <option value="">All severities</option>
                        <option value="Critical">@Localizer["Critical"]</option>
                        <option value="High">@Localizer["High"]</option>
                        <option value="Medium">@Localizer["Medium"]</option>
                        <option value="Low">@Localizer["Low"]</option>
                    </select>
                </div>

                <div class="hazard-filter-field">
                    <label for="typeFilter">Type</label>
                    <select class="form-select" id="typeFilter">
                        <option value="">All types</option>
                        <option value="Crime">Crime</option>
                        <option value="Accident">Accident</option>
                        <option value="Construction">Construction</option>
                        <option value="Pothole">Pothole</option>
                        <option value="Flooding">Flooding</option>
                        <option value="DamagedInfrastructure">Damaged infrastructure</option>
                        <option value="StreetLight">Street light</option>
                        <option value="Debris">Debris</option>
                        <option value="TrafficCongestion">Traffic congestion</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
            </div>

            <div class="sidebar-stats mb-0">
                <div class="stat-pill">
                    <span class="stat-value" id="totalHazardsCount">0</span>
                    <span class="stat-label">Total hazards</span>
                </div>
                <div class="stat-pill critical">
                    <span class="stat-value" id="criticalCount">0</span>
                    <span class="stat-label">@Localizer["Critical"]</span>
                </div>
                <div class="stat-pill high">
                    <span class="stat-value" id="highCount">0</span>
                    <span class="stat-label">@Localizer["High"]</span>
                </div>
            </div>

            <section id="hazardInsightCard" class="hazard-insight-card" aria-live="polite">
                <div class="hazard-insight-card__header">
                    <h3 class="h6 mb-0">Hazard trend insight</h3>
                    <span class="hazard-insight-card__badge">AI-generated</span>
                </div>
                <div id="hazardInsightContent" class="hazard-insight-card__content">
                    Select a hazard to generate a cluster insight.
                </div>
            </section>

            <div class="hazards-list" id="hazardsList">
                <div class="hazard-list-placeholder">
                    <i class="bi bi-hourglass-split"></i>
                    <h3>@Localizer["LoadingHazards"]</h3>
                    <p class="mb-0">Fetching the latest safety reports for the active coverage area.</p>
                </div>
            </div>
        </aside>
    </div>
</div>

<div class="toast-container position-fixed top-0 end-0 p-3 hazard-toast-stack">
        <div id="hazardToast" class="toast hazard-toast" role="status" aria-live="polite" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body" id="hazardToastBody"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
</div>

<div class="modal fade" id="hazardDetailModal" tabindex="-1" aria-labelledby="hazardModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom-0">
                <div>
                    <span class="eyebrow">Nearby hazards</span>
                    <h2 class="modal-title h4 mt-2" id="hazardModalTitle"></h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="hazard-detail-content" id="hazardDetailContent"></div>
            </div>
            <div class="modal-footer border-top-0 hazard-modal-actions">
                <button type="button" class="btn btn-outline-primary" id="confirmBtn">
                    <i class="bi bi-check-circle me-2"></i>Confirm
                </button>
                <button type="button" class="btn btn-warning d-none" id="editBtn">
                    <i class="bi bi-pencil-square me-2"></i>@Localizer["Edit"]
                </button>
                <button type="button" class="btn btn-danger d-none" id="deleteBtn">
                    <i class="bi bi-trash me-2"></i>@Localizer["Delete"]
                </button>
                <button type="button" class="btn btn-success d-none" id="restoreBtn">
                    <i class="bi bi-arrow-counterclockwise me-2"></i>Restore
                </button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editHazardModal" tabindex="-1" aria-labelledby="editHazardModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <span class="eyebrow">Edit hazard</span>
                    <h2 class="modal-title h5 mt-2" id="editHazardModalTitle">Edit hazard</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="editHazardForm" class="hazard-form-stack">
                    <input type="hidden" id="editHazardId" />

                    <div class="hazard-form-grid">
                        <div>
                            <label class="form-label" for="editType">Type</label>
                            <select id="editType" class="form-select">
                                <option value="">Select type</option>
                                <option value="Crime">Crime</option>
                                <option value="Accident">Accident</option>
                                <option value="Construction">Construction</option>
                                <option value="Pothole">Pothole</option>
                                <option value="Flooding">Flooding</option>
                                <option value="DamagedInfrastructure">Damaged infrastructure</option>
                                <option value="StreetLight">Street light</option>
                                <option value="Debris">Debris</option>
                                <option value="TrafficCongestion">Traffic congestion</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div>
                            <label class="form-label" for="editSeverity">Severity</label>
                            <select id="editSeverity" class="form-select">
                                <option value="">Select severity</option>
                                <option value="Critical">@Localizer["Critical"]</option>
                                <option value="High">@Localizer["High"]</option>
                                <option value="Medium">@Localizer["Medium"]</option>
                                <option value="Low">@Localizer["Low"]</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="form-label" for="editTitle">@Localizer["Title"]</label>
                        <input id="editTitle" class="form-control" />
                    </div>

                    <div>
                        <label class="form-label" for="editDescription">@Localizer["Description"]</label>
                        <textarea id="editDescription" class="form-control" rows="4"></textarea>
                    </div>

                    <div>
                        <label class="form-label" for="editAddress">@Localizer["Address"]</label>
                        <input id="editAddress" class="form-control" />
                    </div>

                    <div class="hazard-form-grid">
                        <div>
                            <label class="form-label" for="editLatitude">@Localizer["Latitude"]</label>
                            <input id="editLatitude" class="form-control" />
                        </div>
                        <div>
                            <label class="form-label" for="editLongitude">@Localizer["Longitude"]</label>
                            <input id="editLongitude" class="form-control" />
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveHazardUpdateBtn">
                    <i class="bi bi-check-circle me-2"></i>@Localizer["SaveChanges"]
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="reportHazardModal" tabindex="-1" aria-labelledby="reportHazardModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <span class="eyebrow">Quick report</span>
                    <h2 class="modal-title h5 mt-2" id="reportHazardModalTitle">Report hazard</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="quickReportForm" class="hazard-form-stack">
                    <div class="hazard-report-location">
                        <strong>Location selected</strong>
                        <small id="reportLocationDisplay">Click on the map to select a location</small>
                    </div>

                    <div class="hazard-form-grid">
                        <div>
                            <label for="reportType" class="form-label">Hazard type <span class="text-danger">*</span></label>
                            <select class="form-select" id="reportType" required>
                                <option value="">Select type</option>
                                <option value="Crime">Crime</option>
                                <option value="Accident">Accident</option>
                                <option value="Construction">Construction</option>
                                <option value="Pothole">Pothole</option>
                                <option value="Flooding">Flooding</option>
                                <option value="DamagedInfrastructure">Damaged infrastructure</option>
                                <option value="StreetLight">Street light</option>
                                <option value="Debris">Debris</option>
                                <option value="TrafficCongestion">Traffic congestion</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div>
                            <label for="reportSeverity" class="form-label">Severity <span class="text-danger">*</span></label>
                            <select class="form-select" id="reportSeverity" required>
                                <option value="">Select severity</option>
                                <option value="Critical">@Localizer["Critical"]</option>
                                <option value="High">@Localizer["High"]</option>
                                <option value="Medium">@Localizer["Medium"]</option>
                                <option value="Low">@Localizer["Low"]</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label for="reportTitle" class="form-label">@Localizer["Title"] <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="reportTitle" required placeholder="Summarize the hazard in one clear line" />
                    </div>

                    <div>
                        <label for="reportDescription" class="form-label">@Localizer["Details"] <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="reportDescription" rows="4" required placeholder="Describe what happened, how severe it is, and anything responders should know."></textarea>
                    </div>

                    <div>
                        <label for="reportLocationInput" class="form-label">@Localizer["Location"] <span class="text-danger">*</span></label>
                        <input type="text" class="form-control location-field" id="reportLocationInput" readonly placeholder="Click on the map to select a location" />
                        <small class="form-text text-muted">The location is filled automatically from the point you selected on the map.</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="submitQuickReportBtn">
                    <i class="bi bi-send-check me-2"></i>Submit report
                </button>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
    <script id="hazardModeConfig" type="application/json">
        @Json.Serialize(new
        {
            currentCity = Model.CityId,
            localized = new
            {
                yourLocation = "Your location",
                latitudeLabel = Localizer["Latitude"].Value,
                longitudeLabel = Localizer["Longitude"].Value,
                locationSelected = "Location selected",
                noHazardsNearby = "No hazards nearby",
                failedToLoadHazards = "Unable to load nearby hazards right now.",
                viewDetails = Localizer["ViewDetails"].Value,
                typeLabel = "Type",
                severityLabel = "Severity",
                descriptionLabel = Localizer["Description"].Value,
                locationLabel = "Location",
                confirmationsLabel = Localizer["Confirmations"].Value,
                reportedLabel = "Reported",
                hazardConfirmed = "Hazard confirmed.",
                fillAllRequiredFields = "Fill in all required fields before submitting.",
                clickOnMapToSelectLocation = "Click on the map to select a location",
                reportSubmitted = "Report submitted.",
                errorSubmittingReport = "We couldn't submit the report.",
                hazardUpdated = "Hazard updated.",
                errorUpdatingHazard = "We couldn't update the hazard.",
                hazardDeleted = "Hazard deleted.",
                errorDeletingHazard = "We couldn't delete the hazard.",
                hazardRestored = "Hazard restored.",
                errorRestoringHazard = "We couldn't restore the hazard.",
                confirmDeleteHazard = "Are you sure you want to delete this hazard?",
                confirmRestoreHazard = "Restore this hazard?",
                loadingAddress = Localizer["LoadingAddress"].Value,
                loadingHazards = Localizer["LoadingHazards"].Value,
                quickReportThanks = "Thank you! Your report has been submitted and helps keep the community safe.",
                pleaseSelectLocation = "Please click on the map to select a location.",
                noHazardsArea = "No hazards in your area",
                hazardUpdatedShort = "Hazard updated",
                hazardDeletedShort = "Hazard deleted",
                hazardRestoredShort = "Hazard restored",
                insightLoadingLabel = "Generating AI trend insight...",
                insightErrorLabel = "Could not generate AI insight. Showing fallback insight.",
                insightFallbackLabel = "Rule-based insight",
                insightAiLabel = "AI-generated",
                locating = "Locating...",
                locationDenied = "Location access is blocked. Allow location for this site in your browser, then tap My location again.",
                locationUnavailable = "We could not determine your location. Showing the default coverage area.",
                locationTimeout = "Locating timed out. Check your connection or device location settings and try again.",
                locationInsecure = "Location needs a secure (HTTPS) connection. Open the site over HTTPS to use My location.",
                locationUnsupported = "Your browser does not support location. Showing the default coverage area."
            }
        })
    </script>
    <script src="~/js/pages/hazard-mode.js" asp-append-version="true" defer></script>
}
