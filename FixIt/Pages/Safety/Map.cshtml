@page "/safety/map"
@model FixIt.Pages.Safety.MapModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@inject Microsoft.AspNetCore.Mvc.Rendering.IJsonHelper Json
@{
    ViewData["Title"] = Localizer["SafetyHazardMap"];
    ViewData["RequiresMap"] = true;
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/maps.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/analytics.css" asp-append-version="true" />
}

<div class="map-page py-4">
    <div class="d-flex flex-column flex-lg-row align-items-start justify-content-between gap-3 mb-4">
        <div>
            <span class="eyebrow">@Localizer["SafetyHazardMap"]</span>
            <h1 class="page-title mb-2">@Localizer["SafetyHazardMap"]</h1>
            <p class="page-copy mb-0">Monitor reported hazards in real time, inspect the map, and open the immersive reporting mode for faster field updates.</p>
        </div>
        <a href="/safety/hazard-mode" class="btn btn-danger">
            <i class="bi bi-radar me-2"></i>@Localizer["GoToHazardMode"]
        </a>
    </div>

    <div class="map-page__grid">
        <section class="card map-container">
            <div class="card-body">
                <div class="section-header">
                    <div>
                        <h2 class="map-title h3 mb-2">@Localizer["ActiveHazards"]</h2>
                        <p class="mb-0 text-muted">Select any marker to inspect severity, confirmation count, and reporting context.</p>
                    </div>
                </div>
                <div id="map" class="map-canvas"></div>
            </div>
        </section>

        <aside class="card map-sidebar-card">
            <div class="card-header">
                <h2 class="h5 mb-1">@Localizer["ActiveHazards"]</h2>
                <p class="mb-0 text-muted small">Tap a hazard to focus it on the map.</p>
            </div>
            <div class="card-body">
                <div id="hazardList">
                    @foreach (var hazard in Model.Hazards)
                    {
                        <button type="button"
                                class="hazard-item severity-@hazard.Severity.ToString().ToLowerInvariant()"
                                data-hazard-focus
                                data-id="@hazard.Id"
                                data-lat="@hazard.Location.Coordinates.Latitude"
                                data-lng="@hazard.Location.Coordinates.Longitude"
                                aria-label="Focus @hazard.Title on map">
                            <div class="hazard-item-header">
                                <div class="hazard-icon">
                                    <i class="@GetSeverityIcon(hazard.Severity)"></i>
                                </div>
                                <div class="hazard-info">
                                    <h6 class="mb-1">@hazard.Title</h6>
                                    <div class="text-muted small">@hazard.Type</div>
                                </div>
                                <span class="badge text-bg-@GetSeverityClass(hazard.Severity)">@hazard.Severity</span>
                            </div>
                            <div class="text-muted small mb-2"><i class="bi bi-geo-alt me-1"></i>@hazard.Address</div>
                            <div class="hazard-item-footer">
                                <span class="badge text-bg-light border text-dark"><i class="bi bi-check-circle me-1"></i>@hazard.Confirmations @Localizer["Confirmations"]</span>
                            </div>
                        </button>
                    }
                </div>

                <section id="hazardInsightCard" class="hazard-insight-card" aria-live="polite">
                    <div class="hazard-insight-card__header">
                        <h3 class="h6 mb-0">Hazard trend insight</h3>
                        <span class="hazard-insight-card__badge">AI-generated</span>
                    </div>
                    <div id="hazardInsightContent" class="hazard-insight-card__content">
                        Select a hazard to generate a cluster insight.
                    </div>
                </section>
            </div>
        </aside>
    </div>

    <section class="card map-container mt-4">
        <div class="card-body">
            <div class="section-header">
                <div>
                    <h2 class="h4 mb-2">@Localizer["SeverityLevels"]</h2>
                    <p class="mb-0 text-muted">Use severity to prioritize your response and understand risk at a glance.</p>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-sm-6 col-lg-3"><div class="priority-tile priority-tile--low"><strong>@Localizer["Low"]</strong><span>@Localizer["MinorIssues"]</span></div></div>
                <div class="col-sm-6 col-lg-3"><div class="priority-tile priority-tile--medium"><strong>@Localizer["Medium"]</strong><span>@Localizer["RequiresAttention"]</span></div></div>
                <div class="col-sm-6 col-lg-3"><div class="priority-tile priority-tile--high"><strong>@Localizer["High"]</strong><span>@Localizer["SignificantHazard"]</span></div></div>
                <div class="col-sm-6 col-lg-3"><div class="priority-tile priority-tile--critical"><strong>@Localizer["Critical"]</strong><span>@Localizer["ImmediateDanger"]</span></div></div>
            </div>
        </div>
    </section>
</div>

@section PageScripts {
    <script id="safetyMapConfig" type="application/json">
        @Json.Serialize(new
        {
            confirmationLabel = Localizer["Confirmations"].Value,
            viewDetailsLabel = Localizer["ViewDetails"].Value,
            untitledHazardLabel = Localizer["UntitledHazard"].Value,
            unknownLabel = Localizer["Unknown"].Value,
            insightLoadingLabel = "Generating AI trend insight...",
            insightErrorLabel = "Could not generate AI insight. Showing fallback insight.",
            insightFallbackLabel = "Rule-based insight",
            insightAiLabel = "AI-generated",
            hazards = Model.HazardMapData
        })
    </script>
    <script src="~/js/pages/safety-map.js" asp-append-version="true" defer></script>
}

@functions {
    private static string GetSeverityClass(FixIt.Models.Safety.HazardSeverity severity) => severity switch
    {
        FixIt.Models.Safety.HazardSeverity.Low => "success",
        FixIt.Models.Safety.HazardSeverity.Medium => "warning",
        FixIt.Models.Safety.HazardSeverity.High => "danger",
        FixIt.Models.Safety.HazardSeverity.Critical => "dark",
        _ => "secondary"
    };

    private static string GetSeverityIcon(FixIt.Models.Safety.HazardSeverity severity) => severity switch
    {
        FixIt.Models.Safety.HazardSeverity.Low => "bi bi-info-circle",
        FixIt.Models.Safety.HazardSeverity.Medium => "bi bi-exclamation-circle",
        FixIt.Models.Safety.HazardSeverity.High => "bi bi-exclamation-triangle",
        FixIt.Models.Safety.HazardSeverity.Critical => "bi bi-exclamation-octagon",
        _ => "bi bi-dot"
    };
}
