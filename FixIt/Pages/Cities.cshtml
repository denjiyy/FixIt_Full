@page
@using FixIt.Models.Issues
@model CitiesModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["ExploreCities"] + " - FixIt";

    var selectedCountry = Model.SelectedCountry ?? "Bulgaria";
    var selectedCity = Model.SelectedCity?.Trim() ?? string.Empty;
    var hasSelectedCity = !string.IsNullOrWhiteSpace(selectedCity);
    var visibleCities = Model.Cities?.Count ?? 0;
    var issuePreview = Model.CityIssues.Take(6).ToList();
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/cities.css" asp-append-version="true" />
}

<div class="cities-page py-4">
    <section class="cities-hero">
        <div class="cities-hero__copy">
            <span class="cities-hero__eyebrow">
                <i class="bi bi-globe2"></i>
                @Localizer["Cities_Eyebrow"]
            </span>
            <h1 class="cities-hero__title">@Localizer["Cities_HeroTitle"]</h1>
            <p class="cities-hero__subtitle">@Localizer["Cities_HeroSubtitle"]</p>
            <div class="cities-hero__actions">
                <a href="/issues" class="btn btn-primary">
                    <i class="bi bi-list-ul"></i>
                    @Localizer["Cities_BrowseAllIssues"]
                </a>
                <a href="/issues/create" class="btn btn-outline-primary">
                    <i class="bi bi-plus-circle"></i>
                    @Localizer["Cities_ReportNewIssue"]
                </a>
            </div>
        </div>

        <div class="cities-hero__stats">
            <article class="cities-hero-stat">
                <span>@Localizer["Cities_Stat_SelectedCountry"]</span>
                <strong>@selectedCountry</strong>
                <small>@Localizer["Cities_Stat_SelectedCountryDesc"]</small>
            </article>
            <article class="cities-hero-stat">
                <span>@Localizer["Cities_Stat_AvailableCities"]</span>
                <strong>@Model.TotalCities</strong>
                <small>@string.Format(Localizer["Cities_Stat_VisibleOnPage"].Value, visibleCities)</small>
            </article>
            <article class="cities-hero-stat">
                <span>@Localizer["Cities_Stat_ExplorerCoverage"]</span>
                <strong>@Model.Countries.Count</strong>
                <small>@Localizer["Cities_Stat_CountriesSupported"]</small>
            </article>
            <article class="cities-hero-stat">
                <span>@Localizer["Cities_Stat_PageProgress"]</span>
                <strong>@Model.CurrentPage / @Math.Max(1, Model.TotalPages)</strong>
                <small>@Localizer["Cities_Stat_PaginationCopy"]</small>
            </article>
        </div>
    </section>

    <section class="cities-toolbar">
        <div>
            <p class="cities-toolbar__eyebrow">@Localizer["Cities_FilterByCountry"]</p>
            <h2 class="cities-toolbar__title">@string.Format(Localizer["Cities_CountryCoverage"].Value, selectedCountry)</h2>
            <p class="cities-toolbar__copy">@Localizer["Cities_ToolbarCopy"]</p>
        </div>

        @if (hasSelectedCity)
        {
            <div class="cities-toolbar__selected">
                <span class="cities-toolbar__selected-label">@Localizer["Cities_FocusedCityLabel"]</span>
                <strong>@selectedCity</strong>
                <a asp-page="/Cities"
                   asp-route-selectedCountry="@selectedCountry"
                   asp-route-selectedCity=""
                   asp-route-currentPage="@Model.CurrentPage">
                    @Localizer["Cities_ClearCityFocus"]
                </a>
            </div>
        }
    </section>

    <section class="cities-country-shell">
        <div class="cities-country-shell__chips">
            @foreach (var country in Model.Countries)
            {
                <a asp-page="/Cities"
                   asp-route-selectedCountry="@country"
                   asp-route-selectedCity=""
                   asp-route-currentPage="1"
                   class="country-chip @(selectedCountry == country ? "is-active" : string.Empty)">
                    <i class="bi bi-flag"></i>
                    @country
                </a>
            }
        </div>
    </section>

    <section class="cities-directory">
        <div class="cities-directory__head">
            <div>
                <p class="cities-directory__eyebrow">@Localizer["Cities_DirectoryEyebrow"]</p>
                <h2 class="cities-directory__title">@selectedCountry</h2>
                <p class="cities-directory__copy">@Localizer["Cities_DirectoryCopy"]</p>
            </div>
            <div class="cities-directory__meta">
                <span><i class="bi bi-buildings"></i> @string.Format(Localizer["Cities_TotalCities"].Value, Model.TotalCities)</span>
                <span><i class="bi bi-grid"></i> @string.Format(Localizer["Cities_ShownOnPage"].Value, visibleCities)</span>
            </div>
        </div>

        @if (Model.Cities?.Any() == true)
        {
            <div class="cities-grid">
                @foreach (var city in Model.Cities)
                {
                    var isSelected = string.Equals(selectedCity, city.Name, StringComparison.OrdinalIgnoreCase);
                    <article class="city-card @(isSelected ? "city-card--selected" : string.Empty)">
                        <div class="city-card__media @(string.IsNullOrEmpty(city.PhotoUrl) ? "is-fallback" : string.Empty)" data-city-image-container>
                            @if (!string.IsNullOrEmpty(city.PhotoUrl))
                            {
                                <img src="@city.PhotoUrl"
                                     alt="@city.Name"
                                     class="city-card__image"
                                     loading="lazy"
                                     decoding="async"
                                     crossorigin="anonymous" />
                            }
                            <div class="city-card__placeholder" aria-hidden="@(string.IsNullOrEmpty(city.PhotoUrl) ? "false" : "true")">
                                <i class="bi bi-building"></i>
                            </div>
                            <div class="city-card__badge">
                                <i class="bi bi-pin-map"></i>
                                @(isSelected ? Localizer["Cities_BadgeFocused"].Value : Localizer["Cities_BadgeExplore"].Value)
                            </div>
                        </div>

                        <div class="city-card__body">
                            <div class="city-card__heading">
                                <h3>@city.Name</h3>
                                <span>@selectedCountry</span>
                            </div>

                            <p class="city-card__description">
                                @if (!string.IsNullOrWhiteSpace(city.Description))
                                {
                                    @city.Description
                                }
                                else
                                {
                                    <text>@Localizer["ExploreInfrastructureIssuesInCity", city.Name]</text>
                                }
                            </p>

                            <div class="city-card__actions">
                                <a asp-page="/Cities"
                                   asp-page-handler="SelectCity"
                                   asp-route-country="@selectedCountry"
                                   asp-route-city="@city.Name"
                                   class="btn btn-primary">
                                    <i class="bi bi-list-stars"></i>
                                    @(isSelected ? Localizer["Cities_ActionViewing"].Value : Localizer["Cities_ActionViewRecent"].Value)
                                </a>
                                <a href="/Heatmaps/@city.Id" class="btn btn-outline-primary">
                                    <i class="bi bi-map"></i>
                                    @Localizer["Cities_ActionHeatmap"]
                                </a>
                                <a href="/HealthReports/@city.Id" class="btn btn-outline-primary">
                                    <i class="bi bi-heart-pulse"></i>
                                    @Localizer["Cities_ActionHealthReport"]
                                </a>
                            </div>
                        </div>
                    </article>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="cities-pagination" aria-label="Cities pagination">
                    @if (Model.CurrentPage > 1)
                    {
                        <a asp-page="/Cities"
                           asp-route-selectedCountry="@selectedCountry"
                           asp-route-selectedCity="@selectedCity"
                           asp-route-currentPage="@(Model.CurrentPage - 1)"
                           class="cities-pagination__link">
                            <i class="bi bi-arrow-left"></i>
                            @Localizer["Cities_PaginationPrev"]
                        </a>
                    }

                    <div class="cities-pagination__numbers">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            if (i == Model.CurrentPage)
                            {
                                <span class="cities-pagination__link is-active">@i</span>
                            }
                            else
                            {
                                <a asp-page="/Cities"
                                   asp-route-selectedCountry="@selectedCountry"
                                   asp-route-selectedCity="@selectedCity"
                                   asp-route-currentPage="@i"
                                   class="cities-pagination__link">@i</a>
                            }
                        }
                    </div>

                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a asp-page="/Cities"
                           asp-route-selectedCountry="@selectedCountry"
                           asp-route-selectedCity="@selectedCity"
                           asp-route-currentPage="@(Model.CurrentPage + 1)"
                           class="cities-pagination__link">
                            @Localizer["Cities_PaginationNext"]
                            <i class="bi bi-arrow-right"></i>
                        </a>
                    }
                </nav>
            }
        }
        else
        {
            <div class="cities-empty">
                <div class="cities-empty__icon">
                    <i class="bi bi-inbox"></i>
                </div>
                <h3>@Localizer["Cities_EmptyTitle"]</h3>
                <p>@string.Format(Localizer["Cities_EmptyCopy"].Value, selectedCountry)</p>
                <a asp-page="/Cities" asp-route-selectedCountry="Bulgaria" class="btn btn-primary">
                    <i class="bi bi-arrow-left"></i>
                    @Localizer["Cities_BackToBulgaria"]
                </a>
            </div>
        }
    </section>

    @if (hasSelectedCity)
    {
        <section class="city-focus">
            <div class="city-focus__head">
                <div>
                    <p class="city-focus__eyebrow">@Localizer["Cities_FocusEyebrow"]</p>
                    <h2 class="city-focus__title">@selectedCity</h2>
                    <p class="city-focus__copy">
                        @(Model.CityIssues.Any()
                            ? string.Format(Localizer["Cities_FocusActiveCopy"].Value, selectedCity)
                            : string.Format(Localizer["Cities_FocusEmptyCopy"].Value, selectedCity))
                    </p>
                </div>
                <div class="city-focus__actions">
                    <a href="/issues/create" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i>
                        @Localizer["Cities_FocusReportHere"]
                    </a>
                    @if (Model.Cities?.Any(c => c.Name == selectedCity) == true)
                    {
                        var selectedCityObject = Model.Cities?.FirstOrDefault(c => c.Name == selectedCity);
                        if (selectedCityObject != null)
                        {
                            <a href="/Heatmaps/@selectedCityObject.Id" class="btn btn-outline-primary">
                                <i class="bi bi-map"></i>
                                @Localizer["Cities_FocusOpenHeatmap"]
                            </a>
                        }
                    }
                </div>
            </div>

            @if (issuePreview.Any())
            {
                <div class="city-focus__grid">
                    @foreach (var issue in issuePreview)
                    {
                        <a href="/issues/@issue.Id" class="city-issue-card">
                            <div class="city-issue-card__top">
                                <partial name="_BadgeStatus" model="issue.Status" />
                                <partial name="_BadgePriority" model="issue.Priority" />
                            </div>
                            <h3>@issue.Title</h3>
                            <p>@issue.Description</p>
                            <div class="city-issue-card__meta">
                                <span><i class="bi bi-calendar3"></i> @issue.CreatedAt.ToString("MMM dd, yyyy")</span>
                                <span><i class="bi bi-hand-thumbs-up"></i> @issue.Upvotes</span>
                                <span><i class="bi bi-chat-left-text"></i> @issue.CommentCount</span>
                            </div>
                        </a>
                    }
                </div>

                @if (Model.CityIssues.Count > issuePreview.Count)
                {
                    <div class="city-focus__footer">
                        <p>@string.Format(Localizer["Cities_FocusFooter"].Value, issuePreview.Count, Model.CityIssues.Count, selectedCity)</p>
                    </div>
                }
            }
            else
            {
                <div class="cities-empty cities-empty--compact">
                    <div class="cities-empty__icon cities-empty__icon--success">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <h3>@string.Format(Localizer["Cities_AllClearTitle"].Value, selectedCity)</h3>
                    <p>@Localizer["Cities_AllClearCopy"]</p>
                </div>
            }
        </section>
    }
</div>

@section PageScripts {
    <script src="~/js/pages/cities-page.js" asp-append-version="true" defer></script>
}
