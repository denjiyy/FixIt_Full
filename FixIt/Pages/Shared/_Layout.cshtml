@using System.Globalization
@using Microsoft.AspNetCore.Identity
@using FixIt.Models.Users
@inject UserManager<ApplicationUser> UserManager
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    var showMapAssets = ViewData["RequiresMap"] as bool? == true;
    var bodyClass = ViewData["BodyClass"]?.ToString() ?? string.Empty;
    var currentPath = Context.Request.Path.Value ?? "/";
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;

    ApplicationUser? currentUser = null;
    var displayText = User?.Identity?.Name ?? "Guest";
    var avatarChar = displayText.Length > 0 ? displayText[0].ToString().ToUpperInvariant() : "?";

    if (isAuthenticated)
    {
        currentUser = await UserManager.GetUserAsync(User!);
        displayText = currentUser?.DisplayName ?? User?.Identity?.Name ?? "User";
        avatarChar = displayText.Length > 0 ? displayText[0].ToString().ToUpperInvariant() : "?";
    }
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FixIt - Civic issue reporting and tracking platform. Report infrastructure problems, confirm hazards, and track resolutions in your city." />
    <meta name="keywords" content="civic issues, reporting, infrastructure, hazard, community" />
    <meta name="theme-color" content="#0ea5e9" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@(Context.Request.Scheme)://@(Context.Request.Host)" />
    <meta property="og:title" content="@(ViewData["Title"] ?? "FixIt") - Community Infrastructure Solutions" />
    <meta property="og:description" content="Report, track, and resolve civic infrastructure issues in your city." />
    <meta property="og:image" content="@(Context.Request.Scheme)://@(Context.Request.Host)/images/og-image.png" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="@(Context.Request.Scheme)://@(Context.Request.Host)" />
    <meta property="twitter:title" content="@(ViewData["Title"] ?? "FixIt") - Community Infrastructure Solutions" />
    <meta property="twitter:description" content="Report, track, and resolve civic infrastructure issues in your city." />
    <meta property="twitter:image" content="@(Context.Request.Scheme)://@(Context.Request.Host)/images/og-image.png" />
    
    <title>@ViewData["Title"] - FixIt</title>
    <link rel="canonical" href="@(Context.Request.Scheme)://@(Context.Request.Host)@(Context.Request.Path)" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="apple-touch-icon" href="~/images/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/design-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />

    @if (showMapAssets)
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />
    }

    @await RenderSectionAsync("PageCss", required: false)
</head>
<body class="app-shell @bodyClass" data-current-path="@currentPath">
    <a class="skip-link" href="#mainContent">Skip to main content</a>
    <div class="shell-backdrop" aria-hidden="true"></div>

    <header class="app-header" id="shellHeader">
        <nav class="navbar navbar-expand-xl app-navbar" aria-label="Main navigation">
            <div class="container-fluid app-navbar__inner">
                <a class="navbar-brand app-brand" asp-area="" asp-page="/Index" aria-label="FixIt home">
                    <span class="app-brand__mark" aria-hidden="true">
                        <i class="bi bi-tools"></i>
                    </span>
                    <span class="app-brand__text">FixIt</span>
                </a>

                <button class="navbar-toggler app-navbar__toggle" type="button" data-bs-toggle="collapse" data-bs-target="#navMain" aria-controls="navMain" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list"></i>
                </button>

                <div class="collapse navbar-collapse app-navbar__collapse" id="navMain">
                    <ul class="navbar-nav app-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="" asp-page="/Index">
                                <i class="bi bi-house-door"></i>
                                <span>@Localizer["Home"]</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="" asp-page="/Issues/Index">
                                <i class="bi bi-list-check"></i>
                                <span>@Localizer["Issues"]</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="" asp-page="/Cities">
                                <i class="bi bi-geo-alt"></i>
                                <span>@Localizer["Cities"]</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="" asp-page="/Leaderboards/Index">
                                <i class="bi bi-trophy"></i>
                                <span>@Localizer["Leaderboards"]</span>
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <button class="nav-link app-nav-link app-nav-link--button dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-shield-check"></i>
                                <span>@Localizer["Safety"]</span>
                            </button>
                            <ul class="dropdown-menu app-menu">
                                <li><span class="dropdown-header">@Localizer["HazardTools"]</span></li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Safety/HazardMode">
                                        <i class="bi bi-broadcast-pin"></i>
                                        <span>@Localizer["HazardMode"]</span>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Safety/Map">
                                        <i class="bi bi-map"></i>
                                        <span>@Localizer["HazardMap"]</span>
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Settings/Privacy">
                                        <i class="bi bi-incognito"></i>
                                        <span>@Localizer["PrivacySettings"]</span>
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <button class="nav-link app-nav-link app-nav-link--button dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-graph-up-arrow"></i>
                                <span>@Localizer["AnalyticsDropdown"]</span>
                            </button>
                            <ul class="dropdown-menu app-menu">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/HealthReports/Index">
                                        <i class="bi bi-heart-pulse"></i>
                                        <span>@Localizer["HealthReports"]</span>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Cities">
                                        <i class="bi bi-thermometer-half"></i>
                                        <span>@Localizer["ViewHeatmaps"]</span>
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>

                    <div class="app-actions ms-auto">
                        @if (isAuthenticated)
                        {
                            <a class="nav-report-btn" asp-area="" asp-page="/Issues/Create">
                                <i class="bi bi-plus-circle-fill"></i>
                                <span>@Localizer["ReportIssue"]</span>
                            </a>

                            <div class="dropdown">
                                <button class="nav-link user-chip dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Account menu for @displayText">
                                    <span class="user-avatar" aria-hidden="true">@avatarChar</span>
                                    <span class="user-chip__meta">
                                        <strong>@displayText</strong>
                                        <small>@Localizer["MyAccount"]</small>
                                    </span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end app-menu user-menu">
                                    <li><span class="dropdown-header">@Localizer["QuickActions"]</span></li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/User/Profile" asp-route-userId="@User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value">
                                            <i class="bi bi-person-circle"></i>
                                            <span>@Localizer["ViewProfile"]</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/Settings/Index">
                                            <i class="bi bi-sliders"></i>
                                            <span>@Localizer["Settings"]</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/Issues/Create">
                                            <i class="bi bi-send-plus"></i>
                                            <span>@Localizer["ReportAnIssue"]</span>
                                        </a>
                                    </li>
                                    @if (User?.IsInRole("Admin") == true || User?.IsInRole("Moderator") == true)
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <a class="dropdown-item" href="/admin/dashboard">
                                                <i class="bi bi-shield-lock"></i>
                                                <span>@Localizer["AdminPanel"]</span>
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
                                            <button type="submit" class="dropdown-item dropdown-item-danger">
                                                <i class="bi bi-box-arrow-right"></i>
                                                <span>@Localizer["SignOut"]</span>
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="app-link-btn" asp-area="Identity" asp-page="/Account/Login">
                                <i class="bi bi-box-arrow-in-right"></i>
                                <span>@Localizer["SignIn"]</span>
                            </a>
                            <a class="nav-report-btn nav-report-btn--secondary" asp-area="Identity" asp-page="/Account/Register">
                                <i class="bi bi-person-plus-fill"></i>
                                <span>@Localizer["GetStarted"]</span>
                            </a>
                            <a class="app-link-btn app-link-btn--quiet" href="/admin/login" title="@Localizer["AdminLoginTooltip"]">
                                <i class="bi bi-shield-lock"></i>
                                <span>@Localizer["Admin"]</span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main id="mainContent" class="app-main">
        @RenderBody()
    </main>

    <footer class="app-footer" role="contentinfo">
        <div class="container app-footer__grid">
            <div class="app-footer__brand">
                <a asp-area="" asp-page="/Index" class="footer-brand">
                    <span class="app-brand__mark" aria-hidden="true"><i class="bi bi-tools"></i></span>
                    <span>FixIt</span>
                </a>
                <p class="footer-copy">@Localizer["FooterTagline"]</p>
                <div class="footer-stats" aria-label="Platform highlights">
                    <div>
                        <strong>10K+</strong>
                        <span>@Localizer["IssuesReported"]</span>
                    </div>
                    <div>
                        <strong>50+</strong>
                        <span>@Localizer["Cities"]</span>
                    </div>
                    <div>
                        <strong>75%</strong>
                        <span>@Localizer["Resolved"]</span>
                    </div>
                </div>
            </div>

            <div>
                <h6>@Localizer["Platform"]</h6>
                <nav class="footer-links" aria-label="Platform links">
                    <a asp-area="" asp-page="/Index">@Localizer["Home"]</a>
                    <a asp-area="" asp-page="/Issues/Index">@Localizer["BrowseIssues"]</a>
                    <a asp-area="" asp-page="/Cities">@Localizer["Cities"]</a>
                    <a asp-area="" asp-page="/Leaderboards/Index">@Localizer["Leaderboards"]</a>
                </nav>
            </div>

            <div>
                <h6>@Localizer["Insights"]</h6>
                <nav class="footer-links" aria-label="Insights links">
                    <a asp-area="" asp-page="/HealthReports/Index">@Localizer["HealthReports"]</a>
                    <a asp-area="" asp-page="/Safety/HazardMode">@Localizer["HazardMode"]</a>
                    <a asp-area="" asp-page="/Cities">@Localizer["Heatmaps"]</a>
                </nav>
            </div>

            <div>
                <h6>@Localizer["Support"]</h6>
                <nav class="footer-links" aria-label="Support links">
                    <a asp-area="" asp-page="/Privacy">@Localizer["PrivacyPolicy"]</a>
                    <a href="mailto:support@fixit.local">@Localizer["ContactUs"]</a>
                    <a asp-area="" asp-page="/Settings/Privacy">@Localizer["PrivacySettings"]</a>
                </nav>
            </div>

            <div>
                <h6>@Localizer["Account"]</h6>
                <nav class="footer-links" aria-label="Account links">
                    @if (isAuthenticated)
                    {
                        <a asp-area="" asp-page="/User/Profile" asp-route-userId="@User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value">@Localizer["MyProfile"]</a>
                        <a asp-area="" asp-page="/Settings/Index">@Localizer["Settings"]</a>
                        <a asp-area="" asp-page="/Issues/Create">@Localizer["ReportIssue"]</a>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login">@Localizer["SignIn"]</a>
                        <a asp-area="Identity" asp-page="/Account/Register">@Localizer["CreateAccount"]</a>
                    }
                </nav>
            </div>
        </div>

        <div class="conbootstrap/dist/js/bootstrap.bundle.min.js" defer></script>
    @if (showMapAssets)
    {
        <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js" defer></script>
    }
    <script src="~/js/site.js" asp-append-version="true" deferan>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end app-menu">
                        <li><a class="dropdown-item" href="/SetLanguage?culture=en-US&returnUrl=@Context.Request.Path">English</a></li>
                        <li><a class="dropdown-item" href="/SetLanguage?culture=bg-BG&returnUrl=@Context.Request.Path">Български</a></li>
                    </ul>
                </div>
                <span class="footer-made-with">
                    @Localizer["MadeWithLove"]
                    <i class="bi bi-heart-fill" aria-hidden="true"></i>
                </span>
            </div>
        </div>
    </footer>

    <button id="scrollTopBtn" class="scroll-top-btn" type="button" aria-label="Back to top" title="Back to top">
        <i class="bi bi-arrow-up"></i>
    </button>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @if (showMapAssets)
    {
        <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
    }
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("PageScripts", required: false)
</body>
</html>
