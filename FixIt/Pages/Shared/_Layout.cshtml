<!DOCTYPE html>
<html lang="en">
@using Microsoft.AspNetCore.Identity
@using FixIt.Models.Users
@inject UserManager<ApplicationUser> UserManager
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0284c7" />
    <title>@ViewData["Title"] - FixIt</title>

    <!-- Icons & Fonts loaded by site.css @@import -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Admin Dashboard CSS -->
    @if (ViewContext.RouteData.Values["area"]?.ToString() == "Admin")
    {
        <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
    }
    <!-- Leaflet map library CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />

    <style>
        /* ── Navbar active-link detection ─────────── */
        .nav-link.active {
            color: var(--primary-600) !important;
            background: var(--primary-100);
            font-weight: var(--font-semibold);
        }

        /* ── Notification dot (future use) ────────── */
        .nav-dot {
            width: 7px; height: 7px;
            background: var(--accent);
            border-radius: 50%;
            position: absolute;
            top: 4px; right: 4px;
            border: 1.5px solid var(--white);
        }

        /* ── Report Issue CTA in nav ───────────────── */
        .nav-report-btn {
            background: linear-gradient(135deg, var(--primary-500), var(--primary-600));
            color: var(--white) !important;
            border: none;
            border-radius: var(--radius-lg);
            padding: var(--space-2) var(--space-4);
            font-size: var(--text-sm);
            font-weight: var(--font-semibold);
            display: inline-flex;
            align-items: center;
            gap: var(--space-2);
            transition: all var(--transition-base);
            box-shadow: 0 2px 8px rgba(14,165,233,.25);
            text-decoration: none;
        }
        .nav-report-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(14,165,233,.3);
            color: var(--white) !important;
        }

        /* ── Main wrapper ──────────────────────────── */
        .main-content {
            min-height: calc(100vh - 380px);
            padding-top: var(--space-8);
            padding-bottom: var(--space-8);
        }

        /* ── Footer link columns ───────────────────── */
        .footer-links a {
            display: inline-flex;
            align-items: center;
            gap: var(--space-2);
            padding: var(--space-1) 0;
            color: var(--gray-500);
            font-size: var(--text-sm);
            transition: color var(--transition-fast);
        }
        .footer-links a:hover { color: var(--primary-600); }
        .footer-links a i { color: var(--gray-400); font-size: var(--text-base); }

        /* ── Footer bottom strip ───────────────────── */
        .footer-bottom {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: var(--space-2);
            font-size: var(--text-sm);
            color: var(--gray-400);
        }

        /* ── Flash toast container ─────────────────── */
        .toast-stack {
            position: fixed;
            bottom: var(--space-6);
            right: var(--space-6);
            z-index: var(--z-tooltip);
            display: flex;
            flex-direction: column;
            gap: var(--space-3);
            pointer-events: none;
        }

        /* ── Scroll-to-top button ──────────────────── */
        #scrollTopBtn {
            position: fixed;
            bottom: var(--space-6);
            left: var(--space-6);
            width: 42px; height: 42px;
            background: var(--white);
            border: 1.5px solid var(--gray-200);
            border-radius: var(--radius-full);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--gray-500);
            box-shadow: var(--shadow-md);
            opacity: 0;
            transform: translateY(12px);
            transition: all var(--transition-base);
            pointer-events: none;
            z-index: var(--z-fixed);
        }
        #scrollTopBtn.visible {
            opacity: 1;
            transform: translateY(0);
            pointer-events: all;
        }
        #scrollTopBtn:hover {
            background: var(--primary-500);
            color: var(--white);
            border-color: var(--primary-500);
        }
    </style>
</head>
<body>

    <!-- ══ NAVBAR ════════════════════════════════════════ -->
    <header>
        <nav class="navbar navbar-expand-lg" id="mainNav">
            <div class="container-fluid px-4">

                <!-- Brand -->
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <i class="bi bi-tools"></i>
                    FixIt
                </a>

                <!-- Mobile toggler -->
                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navMain"
                        aria-controls="navMain" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list" style="font-size: 1.5rem; color: var(--gray-600);"></i>
                </button>

                <div class="navbar-collapse collapse" id="navMain">

                    <!-- Primary nav -->
                    <ul class="navbar-nav me-auto gap-1">

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">
                                <i class="bi bi-house-door"></i> Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Issues/Index">
                                <i class="bi bi-list-check"></i> Issues
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Cities">
                                <i class="bi bi-geo-alt"></i> Cities
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Leaderboards/Index">
                                <i class="bi bi-trophy"></i> Leaderboards
                            </a>
                        </li>

                        <!-- Safety dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-shield-check"></i> Safety
                            </a>
                            <ul class="dropdown-menu">
                                <li class="dropdown-header"><i class="bi bi-exclamation-triangle me-1"></i> Hazard Tools</li>
                                <li>
                                    <a class="dropdown-item" href="/safety/hazard-mode">
                                        <i class="bi bi-map"></i> Hazard Map
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li class="dropdown-header"><i class="bi bi-lock me-1"></i> Privacy</li>
                                <li>
                                    <a class="dropdown-item" href="/settings/privacy">
                                        <i class="bi bi-incognito"></i> Privacy Settings
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- Analytics dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-graph-up"></i> Analytics
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" href="/HealthReports">
                                        <i class="bi bi-heart-pulse"></i> Health Reports
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/Cities">
                                        <i class="bi bi-map"></i> View Heatmaps
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>

                    <!-- Auth / user section -->
                    <ul class="navbar-nav ms-auto align-items-center gap-2">

                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <!-- Report issue CTA -->
                            <li class="nav-item d-none d-lg-flex">
                                <a class="nav-report-btn" asp-area="" asp-page="/Issues/Create">
                                    <i class="bi bi-plus-circle-fill"></i> Report Issue
                                </a>
                            </li>

                            <!-- User dropdown -->
                            <li class="nav-item dropdown">
                                @{
                                    var currentUser = await UserManager.GetUserAsync(User);
                                    var displayText = currentUser?.DisplayName ?? User.Identity?.Name ?? "User";
                                    var avatarChar = displayText.FirstOrDefault().ToString().ToUpper() ?? "?";
                                }
                                <a class="nav-link p-0 dropdown-toggle user-chip text-decoration-none"
                                   href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="user-avatar">
                                        @avatarChar
                                    </div>
                                    <span class="user-name">
                                        @displayText
                                    </span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li class="dropdown-header">My Account</li>
                                    <li>
                                        <a class="dropdown-item"
                                           asp-area="" asp-page="/User/Profile"
                                           asp-route-userId="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value">
                                            <i class="bi bi-person-circle"></i> View Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/Settings/ConnectedAccounts">
                                            <i class="bi bi-link-45deg"></i> Connected Accounts
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/Settings/Privacy">
                                            <i class="bi bi-shield-lock"></i> Privacy & Safety
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/Settings/Index">
                                            <i class="bi bi-gear"></i> Settings
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li class="dropdown-header">Quick Actions</li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/Issues/Create">
                                            <i class="bi bi-plus-circle"></i> Report an Issue
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Moderator"))
                                    {
                                        <li>
                                            <a class="dropdown-item" href="/admin/dashboard">
                                                <i class="bi bi-shield-lock text-danger"></i> <strong>Admin Panel</strong>
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    <li>
                                        <form method="post"
                                              asp-area="Identity"
                                              asp-page="/Account/Logout"
                                              asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
                                            <button type="submit"
                                                    class="dropdown-item text-danger w-100 text-start border-0 bg-transparent">
                                                <i class="bi bi-box-arrow-right"></i> Sign Out
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Sign In
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-report-btn" asp-area="Identity" asp-page="/Account/Register">
                                    <i class="bi bi-person-plus-fill"></i> Get Started
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/login" title="Admin and Moderator Login">
                                    <i class="bi bi-shield-lock"></i> Admin
                                </a>
                            </li>
                        }
                    </ul>
                </div><!-- /collapse -->
            </div><!-- /container -->
        </nav>
    </header>

    <!-- ══ MAIN ══════════════════════════════════════════ -->
    <div class="container main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- ══ FOOTER ════════════════════════════════════════ -->
    <footer>
        <div class="container">
            <div class="row g-5 mb-4">

                <!-- Brand column -->
                <div class="col-lg-4">
                    <a href="/" class="footer-brand">
                        <i class="bi bi-tools"></i>
                        FixIt
                    </a>
                    <p style="font-size: var(--text-sm); color: var(--gray-500); line-height: var(--leading-relaxed); max-width: 300px;">
                        Empowering communities to report, track, and resolve infrastructure issues together.
                    </p>

                    <!-- Mini stats -->
                    <div class="d-flex gap-4 mt-4">
                        <div>
                            <div style="font-size: var(--text-xl); font-weight: var(--font-extrabold); color: var(--gray-800); letter-spacing: -0.03em;">10K+</div>
                            <div style="font-size: var(--text-xs); color: var(--gray-400); font-weight: var(--font-medium);">Issues Reported</div>
                        </div>
                        <div>
                            <div style="font-size: var(--text-xl); font-weight: var(--font-extrabold); color: var(--gray-800); letter-spacing: -0.03em;">50+</div>
                            <div style="font-size: var(--text-xs); color: var(--gray-400); font-weight: var(--font-medium);">Cities</div>
                        </div>
                        <div>
                            <div style="font-size: var(--text-xl); font-weight: var(--font-extrabold); color: var(--gray-800); letter-spacing: -0.03em;">75%</div>
                            <div style="font-size: var(--text-xs); color: var(--gray-400); font-weight: var(--font-medium);">Resolved</div>
                        </div>
                    </div>
                </div>

                <!-- Platform links -->
                <div class="col-6 col-lg-2">
                    <h6>Platform</h6>
                    <nav class="footer-links d-flex flex-column gap-1">
                        <a asp-area="" asp-page="/Index">
                            <i class="bi bi-house-door"></i> Home
                        </a>
                        <a asp-area="" asp-page="/Issues/Index">
                            <i class="bi bi-list-check"></i> Browse Issues
                        </a>
                        <a asp-area="" asp-page="/Cities">
                            <i class="bi bi-geo-alt"></i> Cities
                        </a>
                        <a asp-area="" asp-page="/Leaderboards/Index">
                            <i class="bi bi-trophy"></i> Leaderboards
                        </a>
                    </nav>
                </div>

                <!-- Insights links -->
                <div class="col-6 col-lg-2">
                    <h6>Insights</h6>
                    <nav class="footer-links d-flex flex-column gap-1">
                        <a href="/HealthReports">
                            <i class="bi bi-heart-pulse"></i> Health Reports
                        </a>
                        <a href="/Cities">
                            <i class="bi bi-map"></i> Heatmaps
                        </a>
                        <a href="/safety/hazard-mode">
                            <i class="bi bi-exclamation-triangle"></i> Hazard Mode
                        </a>
                    </nav>
                </div>

                <!-- Support links -->
                <div class="col-6 col-lg-2">
                    <h6>Support</h6>
                    <nav class="footer-links d-flex flex-column gap-1">
                        <a asp-area="" asp-page="/Privacy">
                            <i class="bi bi-shield-check"></i> Privacy Policy
                        </a>
                        <a href="mailto:support@fixit.local">
                            <i class="bi bi-envelope"></i> Contact Us
                        </a>
                        <a href="#">
                            <i class="bi bi-question-circle"></i> Help Center
                        </a>
                    </nav>
                </div>

                <!-- Account links -->
                <div class="col-6 col-lg-2">
                    <h6>Account</h6>
                    <nav class="footer-links d-flex flex-column gap-1">
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <a asp-area="" asp-page="/User/Profile"
                               asp-route-userId="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value">
                                <i class="bi bi-person-circle"></i> My Profile
                            </a>
                            <a asp-area="" asp-page="/Issues/Create">
                                <i class="bi bi-plus-circle"></i> Report Issue
                            </a>
                            <a asp-area="" asp-page="/Settings/Index">
                                <i class="bi bi-gear"></i> Settings
                            </a>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login">
                                <i class="bi bi-box-arrow-in-right"></i> Sign In
                            </a>
                            <a asp-area="Identity" asp-page="/Account/Register">
                                <i class="bi bi-person-plus"></i> Create Account
                            </a>
                        }
                    </nav>
                </div>

            </div><!-- /row -->

            <hr>

            <div class="footer-bottom">
                <span>&copy; 2026 FixIt — Community Infrastructure Solutions</span>
                <span style="display: flex; align-items: center; gap: var(--space-1);">
                    Made with <i class="bi bi-heart-fill" style="color: var(--danger); font-size: 11px;"></i> for better communities
                </span>
            </div>
        </div>
    </footer>

    <!-- ══ SCROLL-TO-TOP ═════════════════════════════════ -->
    <button id="scrollTopBtn" aria-label="Back to top">
        <i class="bi bi-arrow-up" style="font-size: var(--text-base);"></i>
    </button>

    <!-- ══ SCRIPTS ═══════════════════════════════════════ -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        /* ── Navbar scroll shadow ────────────────────── */
        const nav = document.getElementById('mainNav');
        const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 12);
        window.addEventListener('scroll', onScroll, { passive: true });

        /* ── Active nav link ─────────────────────────── */
        const currentPath = window.location.pathname.toLowerCase();
        document.querySelectorAll('.navbar-nav .nav-link').forEach(link => {
            const href = link.getAttribute('href') || link.getAttribute('asp-page') || '';
            const norm = href.toLowerCase().replace(/\/+$/, '');
            if (norm && currentPath.startsWith(norm) && norm !== '/') {
                link.classList.add('active');
            }
        });

        /* ── Scroll-to-top button ────────────────────── */
        const scrollBtn = document.getElementById('scrollTopBtn');
        window.addEventListener('scroll', () => {
            scrollBtn.classList.toggle('visible', window.scrollY > 320);
        }, { passive: true });
        scrollBtn.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
