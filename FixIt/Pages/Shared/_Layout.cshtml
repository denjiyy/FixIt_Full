<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FixIt</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg sticky-top">
            <div class="container-fluid px-md-4">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <i class="bi bi-tools"></i>
                    <span>FixIt</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" 
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">
                                <i class="bi bi-house-door"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Issues/Index">
                                <i class="bi bi-list-check"></i> Issues
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Leaderboards/Index">
                                <i class="bi bi-trophy"></i> Leaderboards
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" 
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg" aria-labelledby="userDropdown" 
                                    style="border: none; border-radius: 0.75rem;">
                                    <li class="dropdown-header">
                                        <i class="bi bi-person-fill"></i> Account
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/User/Profile" asp-route-userId="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value">
                                            <i class="bi bi-file-person"></i> View Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/Settings/ConnectedAccounts">
                                            <i class="bi bi-link-45deg"></i> Connected Accounts
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                                            <i class="bi bi-gear"></i> Settings
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li class="dropdown-header">
                                        <i class="bi bi-plus-circle"></i> Actions
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-page="/Issues/Create">
                                            <i class="bi bi-plus-circle"></i> Report Issue
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-area="Identity" asp-page="/Account/Logout" 
                                              asp-route-returnUrl="@Url.Page("/Index", new { area = "" })" class="d-inline">
                                            <button type="submit" class="dropdown-item text-danger" 
                                                    style="border: none; cursor: pointer; background: none; width: 100%; text-align: left;">
                                                <i class="bi bi-box-arrow-right"></i> Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Login
                                </a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-primary btn-sm" asp-area="Identity" asp-page="/Account/Register">
                                    <i class="bi bi-person-plus"></i> Sign Up
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container" style="margin-top: 2rem; min-height: calc(100vh - 300px);">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container py-4">
            <div class="row mb-3">
                <div class="col-md-6">
                    <h6 class="fw-bold mb-2" style="color: #1a1a1a;">
                        <i class="bi bi-tools text-gradient"></i> FixIt
                    </h6>
                    <p class="mb-0 text-muted" style="font-size: 0.9rem;">
                        Making communities better, one report at a time.
                    </p>
                </div>
                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <a asp-area="" asp-page="/Privacy" style="margin-right: 1.5rem;">Privacy Policy</a>
                    <a href="mailto:support@fixit.local">Contact Support</a>
                </div>
            </div>
            <hr style="margin: 1.5rem 0; border-color: var(--gray-300);">
            <div class="text-center text-muted" style="font-size: 0.9rem;">
                <p class="mb-0">&copy; 2026 FixIt - Community Infrastructure Solutions</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
