@using FixIt.Models.Issues
@model Issue
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer

@{
    var priorityStr = Model.Priority switch
    {
        FixIt.Models.Enums.IssuePriority.Critical => "critical",
        FixIt.Models.Enums.IssuePriority.High     => "high",
        FixIt.Models.Enums.IssuePriority.Medium   => "medium",
        FixIt.Models.Enums.IssuePriority.Low      => "low",
        _ => "low"
    };

    var reporterName = Model.IsAnonymous
        ? Localizer["AnonymousReporter"]
        : string.IsNullOrWhiteSpace(Model.Reporter?.DisplayName)
            ? Localizer["CommunityMember"]
            : Model.Reporter.DisplayName;

    var score = Model.Upvotes - Model.Downvotes;
    var lastActivityLabel = Model.LastActivityAt > Model.CreatedAt
        ? Model.LastActivityAt.ToString("MMM d")
        : Model.CreatedAt.ToString("MMM d");
}

<a href="/issues/@Model.Id" class="issue-card-link">
    <article class="issue-card" data-priority="@priorityStr">
        <div class="issue-card-head">
            <div class="issue-badges">
                <partial name="_BadgeStatus" model="Model.Status" />
            </div>
            <partial name="_BadgePriority" model="Model.Priority" />
        </div>

        <div class="issue-card-body">
            <div class="issue-card-meta-row">
                <span class="issue-card-meta-pill">
                    <i class="bi bi-person-circle"></i>
                    <span>@reporterName</span>
                </span>
                <span class="issue-card-meta-pill">
                    <i class="bi bi-clock-history"></i>
                    <span>@Localizer["UpdatedShortLabel"] @lastActivityLabel</span>
                </span>
            </div>

            <h3 class="issue-card-title">@Model.Title</h3>

            @if (!string.IsNullOrEmpty(Model.Address))
            {
                <div class="issue-location">
                    <i class="bi bi-geo-alt-fill"></i>
                    @Model.Address
                </div>
            }

            <p class="issue-card-desc">@Model.Description</p>
        </div>

        <div class="issue-card-foot">
            <div class="issue-card-stats">
                <span class="issue-stat">
                    <i class="bi bi-eye"></i>@Model.ViewCount
                </span>
                <span class="issue-stat">
                    <i class="bi bi-chat"></i>@Model.CommentCount
                </span>
                <span class="issue-stat votes @(score < 0 ? "is-negative" : "")">
                    <i class="bi bi-activity"></i>@score
                </span>
            </div>
            <span class="issue-card-cta">
                <span class="issue-date">@Model.CreatedAt.ToString("MMM d, yyyy")</span>
                <strong>@Localizer["OpenIssue"] <i class="bi bi-arrow-up-right"></i></strong>
            </span>
        </div>
    </article>
</a>
