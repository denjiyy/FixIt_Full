@using FixIt.Models.Enums
@model IssuePriority
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer

@{
    var badgeClass = Model switch
    {
        IssuePriority.Critical => "priority-badge--critical",
        IssuePriority.High     => "priority-badge--high",
        IssuePriority.Medium   => "priority-badge--medium",
        IssuePriority.Low      => "priority-badge--low",
        _                      => "priority-badge--low"
    };

    var label = Model switch
    {
        IssuePriority.Low => Localizer["Low"],
        IssuePriority.Medium => Localizer["Medium"],
        IssuePriority.High => Localizer["High"],
        IssuePriority.Critical => Localizer["Critical"],
        _ => Model.ToString()
    };
}

<span class="priority-badge @badgeClass">
    <span class="priority-dot" aria-hidden="true"></span>
    <span class="priority-label">@label</span>
</span>
