@using FixIt.Models.Enums
@model IssuePriority

@{
    var dotClass = Model switch
    {
        IssuePriority.Critical => "critical",
        IssuePriority.High     => "high",
        IssuePriority.Medium   => "medium",
        IssuePriority.Low      => "low",
        _                      => "low"
    };
}

<div class="d-flex align-items-center gap-2">
    <span class="priority-dot @dotClass" title="@Model Priority"></span>
    <span style="font-size: var(--text-xs); color: var(--gray-400); font-weight: var(--font-semibold);">@Model</span>
</div>
