@using FixIt.ViewModels
@model PaginationViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer

@if (Model.TotalPages > 1)
{
    var startPage = Math.Max(1, Model.CurrentPage - 2);
    var endPage   = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
    
    <nav aria-label="@Localizer["PaginationLabel"]" class="pagination-wrap">

        <!-- Prev button -->
        @if (Model.CurrentPage > 1)
        {
            <a class="page-link" href="@Model.BuildPageUrl(Model.CurrentPage - 1)" aria-label="@Localizer["PreviousPage"]">
                <i class="bi bi-chevron-left"></i>
            </a>
        }
        else
        {
            <span class="page-link disabled" aria-disabled="true"><i class="bi bi-chevron-left"></i></span>
        }

        <!-- First page + ellipsis -->
        @if (startPage > 1)
        {
            <a class="page-link" href="@Model.BuildPageUrl(1)">1</a>
            @if (startPage > 2) { <span class="page-ellipsis">…</span> }
        }

        <!-- Page range -->
        @for (int i = startPage; i <= endPage; i++)
        {
            @if (i == Model.CurrentPage)
            {
                <span class="page-link active" aria-current="page">@i</span>
            }
            else
            {
                <a class="page-link" href="@Model.BuildPageUrl(i)">@i</a>
            }
        }

        <!-- Last page + ellipsis -->
        @if (endPage < Model.TotalPages)
        {
            @if (endPage < Model.TotalPages - 1) { <span class="page-ellipsis">…</span> }
            <a class="page-link" href="@Model.BuildPageUrl(Model.TotalPages)">@Model.TotalPages</a>
        }

        <!-- Next button -->
        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a class="page-link" href="@Model.BuildPageUrl(Model.CurrentPage + 1)" aria-label="@Localizer["NextPage"]">
                <i class="bi bi-chevron-right"></i>
            </a>
        }
        else
        {
            <span class="page-link disabled" aria-disabled="true"><i class="bi bi-chevron-right"></i></span>
        }

    </nav>
}
