@page "/Heatmaps/{cityId}"
@using FixIt.Services.Analytics
@model HeatmapsModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@inject Microsoft.AspNetCore.Mvc.Rendering.IJsonHelper Json
@{
    ViewData["Title"] = Model.CityName + " - " + Localizer["ViewHeatmaps"];
    ViewData["RequiresMap"] = true;
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/maps.css" asp-append-version="true" />
}

<div class="map-page py-4">
    <div class="d-flex flex-column flex-lg-row align-items-start justify-content-between gap-3 mb-4">
        <div>
            <span class="eyebrow">@Model.CityName</span>
            <h1 class="page-title mb-2">@Localizer["ViewHeatmaps"]</h1>
            <p class="page-copy mb-0">@Localizer["MapClick"]</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <span class="badge rounded-pill text-bg-light border"><i class="bi bi-geo-alt me-1"></i>@Model.CityName</span>
            <span class="badge rounded-pill text-bg-light border"><i class="bi bi-diagram-3 me-1"></i>@Model.TotalIssues @Localizer["TotalIssues"]</span>
        </div>
    </div>

    <section class="card map-container">
        <div class="card-body">
            <div class="section-header">
                <div>
                    <h2 class="map-title h3 mb-2">@Localizer["ActiveIssues"]</h2>
                    <p class="mb-0 text-muted">Explore the live issue footprint across the city and open any marker for more detail.</p>
                </div>
            </div>

            <div id="map" class="map-canvas"></div>

            <div class="map-legend">
                <div class="legend-title">@Localizer["MapLegend"]</div>
                <div class="legend-item"><div class="legend-color legend-color--critical"></div><span>@Localizer["CriticalPriority"]</span></div>
                <div class="legend-item"><div class="legend-color legend-color--high"></div><span>@Localizer["HighPriority"]</span></div>
                <div class="legend-item"><div class="legend-color legend-color--medium"></div><span>@Localizer["MediumPriority"]</span></div>
                <div class="legend-item"><div class="legend-color legend-color--low"></div><span>@Localizer["LowPriority"]</span></div>
            </div>
        </div>
    </section>

    <div class="stats-grid">
        <div class="map-stat-card is-open">
            <div class="stat-label">@Localizer["OpenIssues"]</div>
            <div class="stat-value" id="openCount">0</div>
        </div>
        <div class="map-stat-card is-resolved">
            <div class="stat-label">@Localizer["ResolvedIssues"]</div>
            <div class="stat-value" id="resolvedCount">0</div>
        </div>
        <div class="map-stat-card is-total">
            <div class="stat-label">@Localizer["TotalIssues"]</div>
            <div class="stat-value" id="totalCount">0</div>
        </div>
    </div>
</div>

@section PageScripts {
    <script id="heatmapsConfig" type="application/json">
        @Json.Serialize(new
        {
            cityLat = Model.CityLatitude,
            cityLng = Model.CityLongitude,
            statusLabelText = Localizer["Status"].Value,
            priorityLabelText = Localizer["Priority"].Value,
            viewDetailsText = Localizer["ViewDetails"].Value,
            untitledIssueText = Localizer["UntitledIssue"].Value,
            unknownText = Localizer["Unknown"].Value,
            markersData = Model.IssueMarkers
        })
    </script>
    <script src="~/js/pages/heatmaps.js" asp-append-version="true" defer></script>
}
