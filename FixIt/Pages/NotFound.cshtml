@page "/404"
@model NotFoundModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = "Page Not Found";
    Response.StatusCode = 404;
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

<div class="account-page py-5">
    <div class="error-shell">
        <section class="card error-card">
            <div class="card-body text-center">
                <div class="auth-card__icon" style="font-size: 4rem; color: var(--color-primary);">
                    <i class="bi bi-search"></i>
                </div>
                <span class="eyebrow text-primary">404 - Not Found</span>
                <h1 class="mt-3 mb-3">This page doesn't exist</h1>
                <p class="page-copy mx-auto mb-4">
                    We couldn't find the page you're looking for. It may have been moved or deleted. 
                    Let's get you back on track.
                </p>

                <div class="mb-4" style="max-width: 400px; margin: 0 auto;">
                    <div class="list-group list-group-flush">
                        <a href="/" class="list-group-item list-group-item-action d-flex align-items-center">
                            <i class="bi bi-house-door me-3 text-primary"></i>
                            <span>Go to homepage</span>
                        </a>
                        <a href="/Search" class="list-group-item list-group-item-action d-flex align-items-center">
                            <i class="bi bi-search me-3 text-primary"></i>
                            <span>Search for issues</span>
                        </a>
                        <a href="/HealthReports" class="list-group-item list-group-item-action d-flex align-items-center">
                            <i class="bi bi-bar-chart me-3 text-primary"></i>
                            <span>View city reports</span>
                        </a>
                        <button type="button" class="list-group-item list-group-item-action d-flex align-items-center" data-history-back>
                            <i class="bi bi-arrow-left me-3 text-primary"></i>
                            <span>Go back</span>
                        </button>
                    </div>
                </div>

                <div class="alert alert-light text-muted mt-4 mb-0">
                    <p class="mb-0 small">If you believe this is an error, please <a href="mailto:support@fixit.local" class="link-primary">contact support</a>.</p>
                </div>
            </div>
        </section>
    </div>
</div>

<style>
.error-shell {
    max-width: 600px;
    margin: 0 auto;
}

.error-card {
    border: none;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
}

.auth-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    border-radius: 12px;
    background: var(--color-primary-light, #f0f4ff);
    color: var(--color-primary);
}

.eyebrow {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
}

.page-copy {
    font-size: 1rem;
    color: #666;
    line-height: 1.6;
}

.list-group-item {
    border: 1px solid #e9ecef;
    background: #f9f9f9;
    transition: all 0.2s ease;
}

.list-group-item:hover {
    background: #f0f4ff;
    border-color: #d4d8ff;
    transform: translateX(4px);
}

.list-group-item i {
    flex-shrink: 0;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const backButton = document.querySelector('[data-history-back]');
    if (backButton) {
        backButton.addEventListener('click', function () {
            if (window.history.length > 1) {
                window.history.back();
            } else {
                window.location.href = '/';
            }
        });
    }
});
</script>
