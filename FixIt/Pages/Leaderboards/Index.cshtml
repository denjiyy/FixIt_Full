@page
@model FixIt.Pages.Leaderboards.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Leaderboards"] + " - FixIt";
}

<div class="container py-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="text-center mb-4">
                <h1 class="display-5 fw-bold mb-3">
                    <i class="bi bi-trophy text-gradient" style="font-size: 3.5rem;"></i>
                </h1>
                <h1 class="h2 mb-2">Community Leaderboards</h1>
                <p class="text-muted">@Localizer["CelebratateTopContributors"]</p>
            </div>
        </div>
    </div>

    <!-- Period Tabs -->
    <ul class="nav nav-pills justify-content-center mb-5 gap-2" id="leaderboardTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active px-4 py-2" id="weekly-tab" data-bs-toggle="tab" data-bs-target="#weekly" 
                    type="button" role="tab" style="border-radius: 2rem; font-weight: 600;">
                <i class="bi bi-calendar-week"></i> Weekly
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link px-4 py-2" id="monthly-tab" data-bs-toggle="tab" data-bs-target="#monthly" 
                    type="button" role="tab" style="border-radius: 2rem; font-weight: 600;">
                <i class="bi bi-calendar-month"></i> Monthly
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link px-4 py-2" id="alltime-tab" data-bs-toggle="tab" data-bs-target="#alltime" 
                    type="button" role="tab" style="border-radius: 2rem; font-weight: 600;">
                <i class="bi bi-infinity"></i> @Localizer["AllTimeTab"]
            </button>
        </li>
    </ul>

    <!-- Leaderboard Content -->
    <div class="tab-content" id="leaderboardContent">
        <!-- Weekly Leaderboard -->
        <div class="tab-pane fade show active" id="weekly" role="tabpanel">
            @RenderLeaderboard(Model.WeeklyLeaderboard, Localizer["ThisWeeksChampions"])
        </div>

        <!-- Monthly Leaderboard -->
        <div class="tab-pane fade" id="monthly" role="tabpanel">
            @RenderLeaderboard(Model.MonthlyLeaderboard, Localizer["ThisMonthsTopContributors"])
        </div>

        <!-- All Time Leaderboard -->
        <div class="tab-pane fade" id="alltime" role="tabpanel">
            @RenderLeaderboard(Model.AllTimeLeaderboard, "Hall of Fame")
        </div>
    </div>
</div>

@{
    object RenderLeaderboard(List<FixIt.Models.Gamification.LeaderboardEntry> entries, string title)
    {
        if (!entries.Any())
        {
            <div class="text-center py-5">
                <div class="mb-4" style="font-size: 4rem; opacity: 0.3;">
                    <i class="bi bi-inbox"></i>
                </div>
                <h5 class="text-muted">@Localizer["NoEntriesYet"]</h5>
                <p class="text-muted">@Localizer["BeTheFirstToContributeAndClaimYourSpot"]</p>
            </div>
        }

        <div class="row mb-4">
            <div class="col-12">
                <h4 class="text-center mb-4">@title</h4>
            </div>
        </div>

        <!-- Top 3 Podium -->
        if (entries.Count >= 3)
        {
            var top3 = entries.Take(3).ToList();
            <div class="row mb-5 g-3">
                <!-- 2nd Place -->
                <div class="col-md-4 d-flex align-items-end">
                    <div class="card w-100 text-center" style="border: none; background: linear-gradient(135deg, rgba(192, 192, 192, 0.2), rgba(169, 169, 169, 0.2)); transform: translateY(20px);">
                        <div class="card-body p-4">
                            <div class="mb-3" style="font-size: 4rem;">🥈</div>
                            <h5 class="mb-2">@top3[1].UserDisplayName</h5>
                            <div class="display-6 fw-bold text-secondary mb-3">@top3[1].Points</div>
                            <small class="text-muted d-block">Points</small>
                            <div class="mt-3">
                                <span class="badge bg-@GetTrustLevelColor(top3[1].TrustLevel)">
                                    @GetTrustLevelLabel(top3[1].TrustLevel)
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 1st Place -->
                <div class="col-md-4 order-md-first order-last">
                    <div class="card w-100 text-center" style="border: none; background: linear-gradient(135deg, rgba(255, 215, 0, 0.3), rgba(255, 193, 7, 0.3)); box-shadow: 0 8px 32px rgba(255, 215, 0, 0.3);">
                        <div class="card-body p-4">
                            <div class="mb-3" style="font-size: 5rem;">👑</div>
                            <h4 class="mb-2 fw-bold">@top3[0].UserDisplayName</h4>
                            <div class="display-4 fw-bold mb-3" style="color: #fbbf24;">@top3[0].Points</div>
                            <small class="text-muted d-block">Points</small>
                            <div class="mt-3">
                                <span class="badge bg-@GetTrustLevelColor(top3[0].TrustLevel) px-3 py-2">
                                    @GetTrustLevelLabel(top3[0].TrustLevel)
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 3rd Place -->
                <div class="col-md-4 d-flex align-items-end">
                    <div class="card w-100 text-center" style="border: none; background: linear-gradient(135deg, rgba(205, 127, 50, 0.2), rgba(184, 115, 51, 0.2)); transform: translateY(40px);">
                        <div class="card-body p-4">
                            <div class="mb-3" style="font-size: 3.5rem;">🥉</div>
                            <h6 class="mb-2">@top3[2].UserDisplayName</h6>
                            <div class="h4 fw-bold mb-3" style="color: #cd7f32;">@top3[2].Points</div>
                            <small class="text-muted d-block">Points</small>
                            <div class="mt-3">
                                <span class="badge bg-@GetTrustLevelColor(top3[2].TrustLevel)">
                                    @GetTrustLevelLabel(top3[2].TrustLevel)
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Rest of Leaderboard -->
        <div class="row">
            <div class="col-12">
                <div class="card" style="border: none;">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead style="background: var(--gray-100); position: sticky; top: 0; z-index: 10;">
                                    <tr>
                                        <th class="border-0 py-3 ps-4" style="width: 80px;">@Localizer["RankHeader"]</th>
                                        <th class="border-0 py-3">@Localizer["UserHeader"]</th>
                                        <th class="border-0 py-3 text-center">@Localizer["PointsHeader"]</th>
                                        <th class="border-0 py-3 text-end pe-4">@Localizer["TrustLevelHeader"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in entries.Skip(3).Take(20))
                                    {
                                        <tr class="leaderboard-row">
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <div class="rank-circle">@entry.Rank</div>
                                                </div>
                                            </td>
                                            <td class="py-3">
                                                <a href="/user/@entry.UserId" class="text-decoration-none d-flex align-items-center">
                                                    <div class="avatar-circle me-2">
                                                        @entry.UserDisplayName.Substring(0, 1).ToUpper()
                                                    </div>
                                                    <span class="fw-bold">@entry.UserDisplayName</span>
                                                </a>
                                            </td>
                                            <td class="py-3 text-center">
                                                <span class="badge" style="background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; padding: 0.5rem 1rem; font-size: 0.9rem;">
                                                    @entry.Points pts
                                                </span>
                                            </td>
                                            <td class="py-3 text-end pe-4">
                                                <span class="badge bg-@GetTrustLevelColor(entry.TrustLevel) px-3 py-2">
                                                    @GetTrustLevelLabel(entry.TrustLevel)
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        return string.Empty;
    }
}

@functions {
    private string GetTrustLevelLabel(int level) => level switch
    {
        0 => "New",
        1 => "Active",
        2 => "Trusted",
        3 => "Leader",
        _ => "Unknown"
    };

    private string GetTrustLevelColor(int level) => level switch
    {
        0 => "secondary",
        1 => "info",
        2 => "success",
        3 => "warning",
        _ => "secondary"
    };
}

<style>
    .nav-pills .nav-link {
        background: white;
        color: var(--gray-700);
        border: 2px solid var(--gray-300);
        transition: all 0.3s;
    }

    .nav-pills .nav-link:hover {
        background: var(--primary-light);
        border-color: var(--primary);
        color: var(--primary);
    }

    .nav-pills .nav-link.active {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        border-color: var(--primary);
        color: white;
    }

    .leaderboard-row {
        transition: all 0.2s;
    }

    .leaderboard-row:hover {
        background: var(--gray-100);
        transform: translateX(4px);
    }

    .rank-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--gray-300), var(--gray-400));
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: var(--dark);
    }

    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: white;
    }

    .table-hover tbody tr:hover {
        background: var(--gray-100);
    }
</style>
