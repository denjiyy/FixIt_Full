@page
@model FixIt.Pages.Leaderboards.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Leaderboards"] + " - FixIt";
    var weeklyChampion = Model.WeeklyLeaderboard.FirstOrDefault()?.UserDisplayName ?? Localizer["NoEntriesYet"];
    var monthlyChampion = Model.MonthlyLeaderboard.FirstOrDefault()?.UserDisplayName ?? Localizer["NoEntriesYet"];
    var allTimeChampion = Model.AllTimeLeaderboard.FirstOrDefault()?.UserDisplayName ?? Localizer["NoEntriesYet"];
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/leaderboards.css" asp-append-version="true" />
}

<section class="leaderboards-page py-4">
    <div class="container">
        <section class="leaderboards-hero">
            <div class="leaderboards-hero__copy">
                <span class="leaderboards-hero__eyebrow">
                    <i class="bi bi-trophy"></i>
                    Community champions
                </span>
                <h1 class="leaderboards-hero__title">@Localizer["CommunityLeaderboards"]</h1>
                <p class="leaderboards-hero__subtitle">@Localizer["CelebratateTopContributors"]</p>
            </div>
            <div class="leaderboards-hero__stats">
                <div class="leaderboards-hero__stat">
                    <span>Weekly leader</span>
                    <strong>@weeklyChampion</strong>
                </div>
                <div class="leaderboards-hero__stat">
                    <span>Monthly leader</span>
                    <strong>@monthlyChampion</strong>
                </div>
                <div class="leaderboards-hero__stat">
                    <span>All-time leader</span>
                    <strong>@allTimeChampion</strong>
                </div>
            </div>
        </section>

        <ul class="nav nav-pills leaderboards-tabs justify-content-center mb-5 gap-2" id="leaderboardTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active px-4 py-2" id="weekly-tab" data-bs-toggle="tab" data-bs-target="#weekly"
                        type="button" role="tab">
                    <i class="bi bi-calendar-week"></i> @Localizer["Weekly"]
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link px-4 py-2" id="monthly-tab" data-bs-toggle="tab" data-bs-target="#monthly"
                        type="button" role="tab">
                    <i class="bi bi-calendar-month"></i> @Localizer["Monthly"]
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link px-4 py-2" id="alltime-tab" data-bs-toggle="tab" data-bs-target="#alltime"
                        type="button" role="tab">
                    <i class="bi bi-infinity"></i> @Localizer["AllTimeTab"]
                </button>
            </li>
        </ul>

        <div class="tab-content" id="leaderboardContent">
            <div class="tab-pane fade show active" id="weekly" role="tabpanel">
                @RenderLeaderboard(Model.WeeklyLeaderboard, Localizer["ThisWeeksChampions"])
            </div>

            <div class="tab-pane fade" id="monthly" role="tabpanel">
                @RenderLeaderboard(Model.MonthlyLeaderboard, Localizer["ThisMonthsTopContributors"])
            </div>

            <div class="tab-pane fade" id="alltime" role="tabpanel">
                @RenderLeaderboard(Model.AllTimeLeaderboard, Localizer["HallOfFame"])
            </div>
        </div>
    </div>
</section>

@{
    object RenderLeaderboard(List<FixIt.Models.Gamification.LeaderboardEntry> entries, string title)
    {
        if (!entries.Any())
        {
            <section class="leaderboards-section-shell">
                <div class="leaderboards-section-shell__head">
                    <div>
                        <p class="leaderboards-section-shell__eyebrow">Leaderboard</p>
                        <h2 class="leaderboards-section-shell__title">@title</h2>
                    </div>
                </div>
                <div class="leaderboards-empty">
                    <div class="leaderboards-empty-icon">
                        <i class="bi bi-inbox"></i>
                    </div>
                    <h3>@Localizer["NoEntriesYet"]</h3>
                    <p>@Localizer["BeTheFirstToContributeAndClaimYourSpot"]</p>
                </div>
            </section>
        }
        else
        {
            <section class="leaderboards-section-shell">
                <div class="leaderboards-section-shell__head">
                    <div>
                        <p class="leaderboards-section-shell__eyebrow">Leaderboard</p>
                        <h2 class="leaderboards-section-shell__title">@title</h2>
                    </div>
                    <div class="leaderboards-section-shell__meta">
                        <span><i class="bi bi-people"></i> @entries.Count contributors ranked</span>
                    </div>
                </div>

                @if (entries.Count >= 3)
                {
                    var top3 = entries.Take(3).ToList();
                    <div class="leaderboards-podium-grid">
                        <article class="leaderboards-podium-card leaderboards-podium-card--silver">
                            <div class="leaderboards-podium-card__medal">🥈</div>
                            <h3>@top3[1].UserDisplayName</h3>
                            <strong>@top3[1].Points</strong>
                            <span>@Localizer["Points"]</span>
                            <div class="mt-3">
                                <span class="badge leaderboards-badge bg-@GetTrustLevelColor(top3[1].TrustLevel)">
                                    @GetTrustLevelLabel(top3[1].TrustLevel)
                                </span>
                            </div>
                        </article>

                        <article class="leaderboards-podium-card leaderboards-podium-card--gold">
                            <div class="leaderboards-podium-card__medal leaderboards-podium-card__medal--large">👑</div>
                            <h3>@top3[0].UserDisplayName</h3>
                            <strong>@top3[0].Points</strong>
                            <span>@Localizer["Points"]</span>
                            <div class="mt-3">
                                <span class="badge leaderboards-badge bg-@GetTrustLevelColor(top3[0].TrustLevel)">
                                    @GetTrustLevelLabel(top3[0].TrustLevel)
                                </span>
                            </div>
                        </article>

                        <article class="leaderboards-podium-card leaderboards-podium-card--bronze">
                            <div class="leaderboards-podium-card__medal">🥉</div>
                            <h3>@top3[2].UserDisplayName</h3>
                            <strong>@top3[2].Points</strong>
                            <span>@Localizer["Points"]</span>
                            <div class="mt-3">
                                <span class="badge leaderboards-badge bg-@GetTrustLevelColor(top3[2].TrustLevel)">
                                    @GetTrustLevelLabel(top3[2].TrustLevel)
                                </span>
                            </div>
                        </article>
                    </div>
                }

                <div class="leaderboards-table-shell">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 leaderboard-table">
                            <thead>
                                <tr>
                                    <th class="border-0 py-3 ps-4 leaderboards-rank-col">@Localizer["RankHeader"]</th>
                                    <th class="border-0 py-3">@Localizer["UserHeader"]</th>
                                    <th class="border-0 py-3 text-center">@Localizer["PointsHeader"]</th>
                                    <th class="border-0 py-3 text-end pe-4">@Localizer["TrustLevelHeader"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in entries.Skip(3).Take(20))
                                {
                                    <tr class="leaderboard-row">
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                <div class="rank-circle">@entry.Rank</div>
                                            </div>
                                        </td>
                                        <td class="py-3">
                                            <a href="/user/@entry.UserId" class="text-decoration-none d-flex align-items-center">
                                                <div class="avatar-circle me-2">
                                                    @entry.UserDisplayName.Substring(0, 1).ToUpper()
                                                </div>
                                                <span class="fw-bold">@entry.UserDisplayName</span>
                                            </a>
                                        </td>
                                        <td class="py-3 text-center">
                                            <span class="badge points-badge">
                                                @entry.Points @Localizer["Points"]
                                            </span>
                                        </td>
                                        <td class="py-3 text-end pe-4">
                                            <span class="badge bg-@GetTrustLevelColor(entry.TrustLevel) px-3 py-2">
                                                @GetTrustLevelLabel(entry.TrustLevel)
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        }

        return string.Empty;
    }
}

@functions {
    private string GetTrustLevelLabel(int level) => level switch
    {
        0 => Localizer["TrustLevel_NewMember"],
        1 => Localizer["TrustLevel_ActiveCitizen"],
        2 => Localizer["TrustLevel_TrustedMember"],
        3 => Localizer["TrustLevel_CommunityLeader"],
        _ => Localizer["TrustLevel_Unknown"]
    };

    private string GetTrustLevelColor(int level) => level switch
    {
        0 => "secondary",
        1 => "info",
        2 => "success",
        3 => "warning",
        _ => "secondary"
    };
}
