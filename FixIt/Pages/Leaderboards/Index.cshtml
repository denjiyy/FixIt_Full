@page
@using FixIt.Models.Gamification
@model FixIt.Pages.Leaderboards.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Leaderboards"] + " - FixIt";
    ViewData["BodyClass"] = "page-leaderboards";

    var rep = Model.CurrentUserReputation;
    var isAuthed = User?.Identity?.IsAuthenticated ?? false;

    // Trust-level ladder — thresholds mirror ReputationService exactly.
    var levels = new[]
    {
        new { Idx = 0, Name = Localizer["TrustLevel_NewMember"].Value, Range = "0–10", Color = "var(--slate-400)", Icon = "bi-egg" },
        new { Idx = 1, Name = Localizer["TrustLevel_ActiveCitizen"].Value, Range = "11–50", Color = "var(--sky-500)", Icon = "bi-lightning-charge-fill" },
        new { Idx = 2, Name = Localizer["TrustLevel_TrustedMember"].Value, Range = "51–150", Color = "var(--amber-500)", Icon = "bi-patch-check-fill" },
        new { Idx = 3, Name = Localizer["TrustLevel_CommunityLeader"].Value, Range = "150+", Color = "var(--amber-700)", Icon = "bi-trophy-fill" }
    };

    // Progress toward the next trust level for the "Your standing" card.
    var curPts = rep?.TotalPoints ?? 0;
    var curLvl = rep?.TrustLevel ?? 0;
    var lvlFloor = new[] { 0, 11, 51, 151 };
    var prevFloor = curLvl <= 0 ? 0 : lvlFloor[curLvl];
    var nextFloor = curLvl >= 3 ? 0 : lvlFloor[curLvl + 1];
    var progressPct = curLvl >= 3 ? 100 : (nextFloor - prevFloor <= 0 ? 0 : (int)Math.Clamp((double)(curPts - prevFloor) / (nextFloor - prevFloor) * 100, 0, 100));
    var nextLevelName = curLvl >= 3 ? string.Empty : levels[curLvl + 1].Name;
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/community.css" asp-append-version="true" />
}

@functions {
    private string GetTrustLevelLabel(int level) => level switch
    {
        0 => Localizer["TrustLevel_NewMember"],
        1 => Localizer["TrustLevel_ActiveCitizen"],
        2 => Localizer["TrustLevel_TrustedMember"],
        3 => Localizer["TrustLevel_CommunityLeader"],
        _ => Localizer["TrustLevel_Unknown"]
    };

    private static string Initial(string? name)
        => string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[..1].ToUpperInvariant();

    private static string AvatarGradient(string? seed)
    {
        var grads = new[]
        {
            "linear-gradient(135deg,var(--sky-500),var(--sky-700))",
            "linear-gradient(135deg,var(--violet-500),var(--sky-600))",
            "linear-gradient(135deg,var(--emerald-500),var(--emerald-700))",
            "linear-gradient(135deg,var(--amber-500),var(--amber-700))",
            "linear-gradient(135deg,var(--slate-400),var(--slate-600))"
        };
        var h = 0;
        foreach (var ch in seed ?? string.Empty) { h = (h + ch) % 9973; }
        return grads[h % grads.Length];
    }
}

@{
    void RenderBoard(string period, List<LeaderboardEntry> entries, bool active)
    {
        <div class="board__panel" data-period="@period" hidden="@(active ? null : "hidden")">
            @if (entries.Any())
            {
                <div class="board__rows">
                    @foreach (var entry in entries.Take(20))
                    {
                        var top3 = entry.Rank <= 3;
                        <a href="/user/@entry.UserId" class="lrow @(top3 ? "top3" : "")">
                            <span class="lrow__rank @(top3 ? "r" + entry.Rank : "")">
                                @if (top3)
                                {
                                    <i class="bi bi-trophy-fill"></i>
                                }
                                else
                                {
                                    @entry.Rank
                                }
                            </span>
                            <span class="lb-avatar" style="background:@AvatarGradient(entry.UserId)">@Initial(entry.UserDisplayName)</span>
                            <span class="lrow__id">
                                <strong>@entry.UserDisplayName</strong>
                                <span class="lrow__lvl"><i class="bi bi-patch-check-fill"></i>@GetTrustLevelLabel(entry.TrustLevel)</span>
                            </span>
                            <span class="lrow__pts">
                                <b>@entry.Points.ToString("N0")</b>
                                <small>@Localizer["Points"]</small>
                            </span>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="board__empty">
                    <i class="bi bi-people"></i>
                    <strong>@Localizer["NoEntriesYet"]</strong>
                    <span>@Localizer["BeTheFirstToContributeAndClaimYourSpot"]</span>
                </div>
            }
        </div>
    }
}

<div class="community-page calm" id="communityRoot">
    <div class="community">
        <div class="community__head">
            <span class="community__eyebrow"><i class="bi bi-trophy-fill"></i>@Localizer["Community"]</span>
            <h1 class="community__title">@Localizer["CommunityLeaderboards"]</h1>
            <p class="community__sub">@Localizer["CelebratateTopContributors"]</p>
        </div>

        <div class="community__grid">
            <section class="lb-card community__board">
                <div class="board__top">
                    <h3>@Localizer["TopContributors"]</h3>
                    <div class="seg seg--sm" role="group" aria-label="@Localizer["LeaderboardPeriodLabel"]" id="communityPeriod">
                        <button type="button" data-period="weekly"><i class="bi bi-calendar-week"></i>@Localizer["Weekly"]</button>
                        <button type="button" class="on" data-period="monthly"><i class="bi bi-calendar-month"></i>@Localizer["Monthly"]</button>
                        <button type="button" data-period="alltime"><i class="bi bi-infinity"></i>@Localizer["AllTimeTab"]</button>
                    </div>
                </div>

                @{ RenderBoard("weekly", Model.WeeklyLeaderboard, false); }
                @{ RenderBoard("monthly", Model.MonthlyLeaderboard, true); }
                @{ RenderBoard("alltime", Model.AllTimeLeaderboard, false); }
            </section>

            <aside class="community__side">
                @if (isAuthed && rep is not null)
                {
                    <section class="lb-card youcard">
                        <div class="youcard__top">
                            <span class="lb-avatar" style="width:3.25rem;height:3.25rem;font-size:var(--text-base);background:linear-gradient(135deg,var(--sky-500),var(--sky-700))">@Initial(Model.CurrentUserName)</span>
                            <div>
                                <strong>@Localizer["YourStanding"]</strong>
                                <div class="youcard__rank">
                                    @(Model.CurrentUserRank.HasValue ? $"{Localizer["RankHeader"]} #{Model.CurrentUserRank}" : Localizer["Unranked"].Value) · @GetTrustLevelLabel(curLvl)
                                </div>
                            </div>
                        </div>
                        <div class="youcard__bar">
                            <div class="youcard__fill" style="width:@progressPct%"></div>
                        </div>
                        <div class="youcard__prog">
                            <span>@curPts.ToString("N0") @Localizer["Points"]</span>
                            @if (curLvl >= 3)
                            {
                                <span>@Localizer["MaxLevelReached"]</span>
                            }
                            else
                            {
                                <span>@nextLevelName @Localizer["AtPointsSuffix"] @nextFloor</span>
                            }
                        </div>
                        @if (rep.Achievements?.Any() == true)
                        {
                            var achColors = new[] { "var(--sky-500)", "var(--emerald-500)", "var(--amber-500)", "var(--violet-500)" };
                            <div class="youcard__ach">
                                @{ var ai = 0; }
                                @foreach (var ach in rep.Achievements.Take(4))
                                {
                                    var icon = !string.IsNullOrWhiteSpace(ach.Icon) && ach.Icon!.StartsWith("bi-") ? ach.Icon : "bi-award-fill";
                                    var chipColor = achColors[ai % achColors.Length];
                                    <span class="achip" style="--c:@chipColor"><i class="bi @icon"></i>@ach.Name</span>
                                    ai++;
                                }
                            </div>
                        }
                    </section>
                }
                else
                {
                    <section class="lb-card youcard">
                        <div class="youcard__top">
                            <span class="lb-avatar" style="width:3.25rem;height:3.25rem;font-size:var(--text-base);background:linear-gradient(135deg,var(--slate-400),var(--slate-600))"><i class="bi bi-person"></i></span>
                            <div>
                                <strong>@Localizer["YourStanding"]</strong>
                                <div class="youcard__rank">@Localizer["Unranked"]</div>
                            </div>
                        </div>
                        <p class="community__sub" style="margin:0">
                            <a asp-area="Identity" asp-page="/Account/Login">@Localizer["SignIn"]</a> @Localizer["SignInToEarnReputation"]
                        </p>
                    </section>
                }

                <section class="lb-card">
                    <div class="sec-head"><i class="bi bi-bar-chart-line-fill"></i><h3>@Localizer["TrustLevels"]</h3></div>
                    <div class="levels">
                        @foreach (var lv in levels)
                        {
                            var isCur = isAuthed && rep is not null && lv.Idx == curLvl;
                            <div class="lvrow @(isCur ? "cur" : "")">
                                <span class="lvrow__ic" style="background:@lv.Color"><i class="bi @lv.Icon"></i></span>
                                <strong>@lv.Name</strong>
                                <span class="lvrow__r">@lv.Range</span>
                                @if (isCur)
                                {
                                    <span class="lvrow__you">@Localizer["YouLabel"]</span>
                                }
                            </div>
                        }
                    </div>
                </section>
            </aside>
        </div>
    </div>
</div>

@section PageScripts {
    <script src="~/js/pages/community.js" asp-append-version="true" defer></script>
}
