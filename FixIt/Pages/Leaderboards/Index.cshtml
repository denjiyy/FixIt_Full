@page
@model FixIt.Pages.Leaderboards.IndexModel
@{
    ViewData["Title"] = "Community Leaderboards";
}

<div class="container py-4">
    <h1 class="mb-4">Community Leaderboards</h1>

    <!-- Leaderboard Tabs -->
    <ul class="nav nav-tabs mb-4" id="leaderboardTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="weekly-tab" data-bs-toggle="tab" data-bs-target="#weekly" 
                    type="button" role="tab" aria-controls="weekly" aria-selected="true">
                Weekly
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="monthly-tab" data-bs-toggle="tab" data-bs-target="#monthly" 
                    type="button" role="tab" aria-controls="monthly" aria-selected="false">
                Monthly
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="alltime-tab" data-bs-toggle="tab" data-bs-target="#alltime" 
                    type="button" role="tab" aria-controls="alltime" aria-selected="false">
                All Time
            </button>
        </li>
    </ul>

    <!-- Leaderboard Content -->
    <div class="tab-content" id="leaderboardContent">
        <!-- Weekly Leaderboard -->
        <div class="tab-pane fade show active" id="weekly" role="tabpanel" aria-labelledby="weekly-tab">
            @RenderLeaderboard(Model.WeeklyLeaderboard, "Weekly")
        </div>

        <!-- Monthly Leaderboard -->
        <div class="tab-pane fade" id="monthly" role="tabpanel" aria-labelledby="monthly-tab">
            @RenderLeaderboard(Model.MonthlyLeaderboard, "Monthly")
        </div>

        <!-- All Time Leaderboard -->
        <div class="tab-pane fade" id="alltime" role="tabpanel" aria-labelledby="alltime-tab">
            @RenderLeaderboard(Model.AllTimeLeaderboard, "All Time")
        </div>
    </div>
</div>

@{
    object RenderLeaderboard(List<FixIt.Models.Gamification.LeaderboardEntry> entries, string period)
    {
        <div class="card">
            <div class="card-body p-0">
                @if (entries.Any())
                {
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>User</th>
                                <th>Points</th>
                                <th class="text-end">Trust Level</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in entries.Take(20))
                            {
                                <tr class="leaderboard-row">
                                    <td class="rank-cell">
                                        @if (entry.Rank == 1)
                                        {
                                            <span class="badge bg-warning text-dark">🥇 @entry.Rank</span>
                                        }
                                        else if (entry.Rank == 2)
                                        {
                                            <span class="badge bg-secondary">🥈 @entry.Rank</span>
                                        }
                                        else if (entry.Rank == 3)
                                        {
                                            <span class="badge bg-danger">🥉 @entry.Rank</span>
                                        }
                                        else
                                        {
                                            <span>@entry.Rank</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="/user/@entry.UserId" class="text-decoration-none">@entry.UserDisplayName</a>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary">@entry.Points pts</span>
                                    </td>
                                    <td class="text-end">
                                        <span class="badge bg-@GetTrustLevelColor(entry.TrustLevel)">@GetTrustLevelLabel(entry.TrustLevel)</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-info m-0">
                        <p class="mb-0">No entries for @period leaderboard yet.</p>
                    </div>
                }
            </div>
        </div>
        return null;
    }
}

@functions {
    private string GetTrustLevelLabel(int level) => level switch
    {
        0 => "New",
        1 => "Active",
        2 => "Trusted",
        3 => "Leader",
        _ => "Unknown"
    };

    private string GetTrustLevelColor(int level) => level switch
    {
        0 => "secondary",
        1 => "info",
        2 => "success",
        3 => "warning",
        _ => "secondary"
    };
}

<style>
    .leaderboard-row {
        transition: background-color 0.2s;
    }

    .leaderboard-row:hover {
        background-color: #f5f5f5;
    }

    .rank-cell {
        font-weight: bold;
        min-width: 60px;
    }

    .nav-tabs .nav-link {
        color: #6c757d;
        border: none;
        border-bottom: 3px solid transparent;
    }

    .nav-tabs .nav-link:hover {
        color: #0d6efd;
        border-bottom-color: #0d6efd;
    }

    .nav-tabs .nav-link.active {
        color: #0d6efd;
        background-color: transparent;
        border-bottom-color: #0d6efd;
    }
</style>
