@page
@model PrivacyModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["PrivacyPolicy"];
}

<link rel="stylesheet" href="~/css/pages/privacy.css" />

<div class="container my-5">
    <!-- Hero Section -->
    <div class="policy-hero">
        <h1><i class="bi bi-shield-lock"></i> @ViewData["Title"]</h1>
        <p>Your privacy is important to us. This page explains how FixIt collects, uses, and protects your personal information.</p>
    </div>

    <div class="policy-container">
        <!-- Table of Contents -->
        <div class="policy-toc">
            <h2><i class="bi bi-list-ul"></i> Quick Navigation</h2>
            <ul>
                <li><a href="#information-collection">Information Collection</a></li>
                <li><a href="#information-use">How We Use Information</a></li>
                <li><a href="#data-security">Data Security</a></li>
                <li><a href="#user-rights">Your Rights</a></li>
                <li><a href="#cookies">Cookies & Tracking</a></li>
                <li><a href="#third-parties">Third-Party Services</a></li>
                <li><a href="#contact">Contact Us</a></li>
            </ul>
        </div>

        <!-- Information Collection Section -->
        <div class="policy-section" id="information-collection">
            <h2><i class="bi bi-info-circle"></i> Information We Collect</h2>
            
            <h3>Account Information</h3>
            <p>When you create a FixIt account, we collect:</p>
            <ul>
                <li>Email address and username</li>
                <li>Password (encrypted and never stored in plain text)</li>
                <li>Profile information (optional: name, preferences, location)</li>
            </ul>

            <h3>Issue Reports & Content</h3>
            <p>When you report infrastructure issues, we collect:</p>
            <ul>
                <li>Issue title and description</li>
                <li>Location coordinates and GPS data</li>
                <li>Photos and media uploads</li>
                <li>Issue status and priority information</li>
                <li>Timestamps and device information</li>
            </ul>

            <h3>Usage Information</h3>
            <p>We automatically collect information about how you interact with our platform:</p>
            <ul>
                <li>Pages and features you visit</li>
                <li>Time spent on each page</li>
                <li>Clicks and interactions</li>
                <li>Device type and operating system</li>
                <li>IP address and approximate location</li>
            </ul>

            <div class="policy-highlight">
                <strong>Privacy First:</strong> We never sell your personal data to third parties. Your privacy is under your control.
            </div>
        </div>

        <!-- Information Use Section -->
        <div class="policy-section" id="information-use">
            <h2><i class="bi bi-gear"></i> How We Use Your Information</h2>
            
            <h3>Service Improvement</h3>
            <p>Your information helps us improve FixIt by:</p>
            <ul>
                <li>Understanding how our platform is used</li>
                <li>Identifying and fixing bugs and issues</li>
                <li>Developing new features that benefit the community</li>
                <li>Improving our infrastructure reports and analytics</li>
            </ul>

            <h3>Communication</h3>
            <p>We may contact you to:</p>
            <ul>
                <li>Send important account or service notifications</li>
                <li>Respond to your inquiries and support requests</li>
                <li>Provide updates on issues you've reported (if opted in)</li>
                <li>Share community highlights (optional)</li>
            </ul>

            <h3>Safety & Legal Compliance</h3>
            <p>We use information to:</p>
            <ul>
                <li>Detect and prevent fraud and abuse</li>
                <li>Enforce our Terms of Service</li>
                <li>Comply with legal obligations</li>
                <li>Protect the rights and safety of our community</li>
            </ul>
        </div>

        <!-- Data Security Section -->
        <div class="policy-section" id="data-security">
            <h2><i class="bi bi-lock"></i> Data Security</h2>
            
            <p>We implement industry-standard security measures to protect your information:</p>
            <ul>
                <li>End-to-end encryption for sensitive data</li>
                <li>Secure HTTPS connections for all traffic</li>
                <li>Regular security audits and penetration testing</li>
                <li>Encrypted password storage with strong hashing</li>
                <li>Limited access to personal data (need-to-know basis)</li>
                <li>Automatic backups and disaster recovery systems</li>
            </ul>

            <h3>Data Retention</h3>
            <p>We retain your data only for as long as necessary to provide our services. You can request data deletion at any time, and we'll remove your personal information within 30 days (unless legally required to retain it).</p>
        </div>

        <!-- User Rights Section -->
        <div class="policy-section" id="user-rights">
            <h2><i class="bi bi-person-check"></i> Your Privacy Rights</h2>
            
            <h3>Access & Portability</h3>
            <p>You have the right to:</p>
            <ul>
                <li>Access all your personal data we hold</li>
                <li>Download your data in a portable format</li>
                <li>Understand how your data is being used</li>
            </ul>

            <h3>Correction & Deletion</h3>
            <p>You can:</p>
            <ul>
                <li>Update or correct your account information anytime</li>
                <li>Delete your account and associated data</li>
                <li>Remove specific pieces of information</li>
            </ul>

            <h3>Opt-Out Options</h3>
            <p>You can opt out of:</p>
            <ul>
                <li>Marketing emails and newsletters</li>
                <li>Location tracking (with reduced functionality)</li>
                <li>Analytics and usage tracking</li>
                <li>Cookie-based personalization</li>
            </ul>

            <div class="policy-highlight">
                <strong>GDPR & CCPA Compliant:</strong> We respect and comply with international privacy regulations including GDPR, CCPA, and other local laws.
            </div>
        </div>

        <!-- Cookies Section -->
        <div class="policy-section" id="cookies">
            <h2><i class="bi bi-cookie"></i> Cookies & Tracking</h2>
            
            <p>FixIt uses cookies to enhance your experience:</p>
            <ul>
                <li><strong>Essential Cookies:</strong> Required for authentication and security</li>
                <li><strong>Performance Cookies:</strong> Help us understand how you use FixIt</li>
                <li><strong>Preference Cookies:</strong> Remember your settings and language choice</li>
                <li><strong>Marketing Cookies:</strong> (optional) Track campaigns and improvements</li>
            </ul>

            <h3>Managing Cookies</h3>
            <p>You can manage cookie preferences through your browser settings. Most browsers allow you to refuse cookies or alert you when cookies are being sent. Note that disabling certain cookies may affect platform functionality.</p>
        </div>

        <!-- Third-Party Services Section -->
        <div class="policy-section" id="third-parties">
            <h2><i class="bi bi-diagram-3"></i> Third-Party Services</h2>
            
            <h3>Services We Use</h3>
            <p>FixIt integrates with third-party services:</p>
            <ul>
                <li><strong>Maps & Geocoding:</strong> For location services</li>
                <li><strong>Analytics:</strong> To understand aggregate usage patterns</li>
                <li><strong>Cloud Storage:</strong> Secure hosting of media uploads</li>
                <li><strong>Email Delivery:</strong> For transactional notifications</li>
            </ul>

            <h3>Your Data with Third Parties</h3>
            <p>When using third-party services, only necessary data is shared, and we ensure they comply with privacy standards. You can contact us for specific information about any third-party processor.</p>
        </div>

        <!-- Contact Section -->
        <div class="policy-section" id="contact">
            <h2><i class="bi bi-envelope"></i> Contact Us</h2>
            
            <p>If you have questions about our privacy practices or want to exercise your privacy rights:</p>
            <ul>
                <li><strong>Email:</strong> <a href="mailto:privacy@fixitapp.local">privacy@fixitapp.local</a></li>
                <li><strong>Submit a Request:</strong> Use the privacy request form in your account settings</li>
                <li><strong>Response Time:</strong> We aim to respond within 10 business days</li>
            </ul>

            <h3>Data Protection Officer</h3>
            <p>For GDPR-related inquiries, contact our Data Protection Officer at <a href="mailto:dpo@fixitapp.local">dpo@fixitapp.local</a></p>
        </div>

        <!-- Footer -->
        <div class="policy-footer">
            <p><strong>Privacy Policy Last Updated:</strong> <span class="policy-last-updated">@DateTime.Now.ToString("MMMM d, yyyy")</span></p>
            <p>We may update this privacy policy from time to time. We will notify you of material changes via email.</p>
        </div>
    </div>
</div>
