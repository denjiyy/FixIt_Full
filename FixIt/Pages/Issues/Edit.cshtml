@page "/issues/{id}/edit"
@model EditIssueModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["EditIssue"];
    ViewData["BodyClass"] = "page-issue-edit";
    ViewData["RequiresMap"] = true;
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/issues-shared.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/issue-manage.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/issue-edit-extended.css" asp-append-version="true" />
}

<div class="issue-page issue-page--compact issue-edit-page" id="issueEditRoot">
    <header class="issue-page-header">
        <div class="issue-page-header__content">
            <span class="issue-page-header__eyebrow">
                <i class="bi bi-pencil-square"></i>
                @Localizer["EditIssue"]
            </span>
            <h1 class="issue-page-header__title">@Localizer["EditIssue"]</h1>
            <p class="issue-page-header__copy">@Localizer["EditIssueCopy"]</p>
        </div>

        <div class="issue-page-actions">
            <a href="/issues/@Model.Id" class="app-link-btn">
                <i class="bi bi-arrow-left"></i>
                <span>@Localizer["BackToIssue"]</span>
            </a>
        </div>
    </header>

    @if (Model.Issue != null)
    {
        <div class="issue-manage-layout">
            <section class="issue-surface issue-manage-card">
                <div class="issue-manage-card__header">
                    <div>
                        <span class="issue-manage-card__eyebrow">01</span>
                        <h2 class="issue-manage-card__title">@Localizer["BasicInformation"]</h2>
                        <p class="issue-manage-card__copy">@Localizer["EditIssueFormCopy"]</p>
                    </div>
                </div>

                <div class="issue-manage-card__body">
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
                    {
                        <div asp-validation-summary="All" class="alert alert-danger rounded-4 mb-4" role="alert">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                        </div>
                    }

                    <form method="post" class="issue-manage-form" novalidate>
                        <div class="issue-manage-field">
                            <label for="Input_Title" class="issue-manage-label">@Localizer["IssueTitle"]</label>
                            <input asp-for="Input.Title"
                                   class="issue-manage-input @(ModelState.IsValid ? "" : "is-invalid")"
                                   id="Input_Title"
                                   maxlength="200"
                                   placeholder="@Localizer["BriefTitleOfTheIssueEdit"]" />
                            <div class="issue-manage-support">
                                <span>@Localizer["SpecificAndDescriptive"]</span>
                                <span class="issue-manage-counter"><span id="charCount">@Model.Input.Title?.Length ?? 0</span>/200</span>
                            </div>
                            <span asp-validation-for="Input.Title" class="invalid-feedback"></span>
                        </div>

                        <div class="issue-manage-field">
                            <label for="Input_Description" class="issue-manage-label">@Localizer["Description"]</label>
                            <textarea asp-for="Input.Description"
                                      class="issue-manage-textarea @(ModelState.IsValid ? "" : "is-invalid")"
                                      id="Input_Description"
                                      rows="7"
                                      maxlength="5000"
                                      placeholder="@Localizer["DetailedDescriptionOfTheIssueEdit"]"></textarea>
                            <div class="issue-manage-support">
                                <span>@Localizer["DescribeTheIssueInDetail"]</span>
                                <span class="issue-manage-counter"><span id="descCharCount">@Model.Input.Description?.Length ?? 0</span>/5000</span>
                            </div>
                            <span asp-validation-for="Input.Description" class="invalid-feedback"></span>
                        </div>

                        <div class="issue-manage-field">
                            <label for="Input_Address" class="issue-manage-label">@Localizer["AddressLabel"]</label>
                            <input asp-for="Input.Address"
                                   class="issue-manage-input"
                                   id="Input_Address"
                                   maxlength="300"
                                   placeholder="@Localizer["LocationOrStreetAddress"]" />
                        </div>

                        <div class="issue-manage-field">
                            <label for="Input_Priority" class="issue-manage-label">@Localizer["Priority"]</label>
                            <select asp-for="Input.Priority"
                                    asp-items="@Model.Priorities"
                                    class="issue-manage-input"
                                    id="Input_Priority">
                            </select>
                            <span asp-validation-for="Input.Priority" class="invalid-feedback"></span>
                        </div>

                        <div class="issue-manage-field">
                            <label for="Input_Status" class="issue-manage-label">@Localizer["Status"]</label>
                            <select asp-for="Input.Status"
                                    asp-items="@Model.Statuses"
                                    class="issue-manage-input"
                                    id="Input_Status">
                            </select>
                            <span asp-validation-for="Input.Status" class="invalid-feedback"></span>
                        </div>

                        @* Location Picker *@
                        <div class="issue-manage-field">
                            <label class="issue-manage-label">@Localizer["LocationCoordinates"]</label>
                            <div class="location-inputs">
                                <div class="location-input-group">
                                    <label for="Input_Latitude">@Localizer["Latitude"]</label>
                                    <input asp-for="Input.Latitude"
                                           type="number"
                                           step="0.000001"
                                           min="-90"
                                           max="90"
                                           class="issue-manage-input"
                                           id="Input_Latitude"
                                           placeholder="Latitude" />
                                </div>
                                <div class="location-input-group">
                                    <label for="Input_Longitude">@Localizer["Longitude"]</label>
                                    <input asp-for="Input.Longitude"
                                           type="number"
                                           step="0.000001"
                                           min="-180"
                                           max="180"
                                           class="issue-manage-input"
                                           id="Input_Longitude"
                                           placeholder="Longitude" />
                                </div>
                            </div>
                            <small class="form-text text-muted">@Localizer["ClickTheMapBelowToUpdateLocation"]</small>
                        </div>

                        @* Media Management *@
                        <div class="issue-manage-field">
                            <label class="issue-manage-label">@Localizer["Media"]</label>
                            
                            @if (Model.ExistingMedia.Any())
                            {
                                <div class="media-gallery">
                                    <h4 class="media-gallery-title">@Localizer["ExistingMedia"]</h4>
                                    <div class="media-grid">
                                        @foreach (var media in Model.ExistingMedia)
                                        {
                                            <div class="media-item" data-media-id="@media.Id">
                                                @if (!string.IsNullOrEmpty(media.Item2))
                                                {
                                                    <img src="@media.Item2" alt="@media.Item3" class="media-thumbnail" />
                                                }
                                                else
                                                {
                                                    <div class="media-placeholder">
                                                        <i class="bi bi-image"></i>
                                                    </div>
                                                }
                                                <button type="button" class="media-remove-btn" 
                                                        data-media-id="@media.Id"
                                                        title="@Localizer["RemoveMedia"]"
                                                        aria-label="@Localizer["RemoveMedia"]">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="media-upload-section">
                                <h4 class="media-upload-title">@Localizer["AddNewMedia"]</h4>
                                <div class="upload-zone" id="editUploadZone" role="button" tabindex="0" aria-controls="NewMediaFiles">
                                    <div class="upload-zone-icon">
                                        <i class="bi bi-cloud-arrow-up"></i>
                                    </div>
                                    <h5>@Localizer["DropFilesOrBrowse"]</h5>
                                    <p>@Localizer["UploadFileInfo"]</p>
                                </div>
                                <input type="file" 
                                       asp-for="NewMediaFiles"
                                       id="NewMediaFiles"
                                       multiple 
                                       accept="image/jpeg,image/png,video/mp4,video/webm"
                                       style="display: none;" />
                                <div id="selectedFilesPreview" class="selected-files-preview"></div>
                            </div>
                        </div>

                        <div class="issue-manage-note">
                            <strong>@Localizer["EditGuidanceTitle"]</strong>
                            <p>@Localizer["EditGuidanceCopy"]</p>
                        </div>

                        <div class="issue-manage-actions">
                            <button type="submit" class="nav-report-btn">
                                <i class="bi bi-check-circle"></i>
                                <span>@Localizer["SaveChanges"]</span>
                            </button>
                            <a href="/issues/@Model.Id" class="app-link-btn">
                                <i class="bi bi-x-circle"></i>
                                <span>@Localizer["Cancel"]</span>
                            </a>
                            <a href="/issues/@Model.Id/delete" class="app-link-btn issue-manage-danger">
                                <i class="bi bi-trash3"></i>
                                <span>@Localizer["DeleteIssue"]</span>
                            </a>
                        </div>
                    </form>
                </div>
            </section>

            <aside class="issue-manage-sidebar">
                <section class="issue-surface issue-manage-sidebar-card map-container">
                    <div class="map-header">
                        <i class="bi bi-geo-alt-fill"></i>
                        <div>
                            <strong>@Localizer["LocationCoordinates"]</strong>
                            <small id="coordsDisplay">@if (Model.Input.Latitude.HasValue && Model.Input.Longitude.HasValue) { <text>@Model.Input.Latitude.Value.ToString("F6"), @Model.Input.Longitude.Value.ToString("F6")</text> } else { @Localizer["ClickTheMapToPlacePin"] }</small>
                        </div>
                    </div>
                    <div id="map" class="issue-edit-map" aria-label="@Localizer["PinOnMap"]"
                         data-default-lat="@(Model.Input.Latitude?.ToString("F6") ?? "42.6977")"
                         data-default-lng="@(Model.Input.Longitude?.ToString("F6") ?? "23.3219")"></div>
                </section>

                <section class="issue-surface issue-manage-sidebar-card">
                    <h2>@Localizer["ReportSnapshot"]</h2>
                    <dl class="issue-manage-summary">
                        <div>
                            <dt>@Localizer["Status"]</dt>
                            <dd><partial name="_BadgeStatus" model="Model.Input.Status" /></dd>
                        </div>
                        <div>
                            <dt>@Localizer["Priority"]</dt>
                            <dd><partial name="_BadgePriority" model="Model.Input.Priority" /></dd>
                        </div>
                        <div>
                            <dt>@Localizer["CreatedBy"]</dt>
                            <dd>@(Model.Issue.Reporter?.DisplayName ?? Localizer["AnonymousUser"])</dd>
                        </div>
                        <div>
                            <dt>@Localizer["CreatedAtLabel"]</dt>
                            <dd>@Model.Issue.CreatedAt.ToString("MMMM d, yyyy")</dd>
                        </div>
                    </dl>
                </section>

                <section class="issue-surface issue-manage-sidebar-card">
                    <h2>@Localizer["BeforeYouSubmit"]</h2>
                    <ul class="issue-manage-checklist">
                        <li>@Localizer["SpecificAndDescriptive"]</li>
                        <li>@Localizer["EditChecklistDescription"]</li>
                        <li>@Localizer["EditChecklistAddress"]</li>
                    </ul>
                </section>
            </aside>
        </div>
    }
    else
    {
        <section class="issue-surface issue-empty-state">
            <div class="issue-empty-state__icon">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <h2 class="issue-empty-state__title">@Localizer["IssueNotFoundMessage"]</h2>
            <p class="issue-empty-state__copy">@Localizer["IssueNotFoundMessage"]</p>
            <a href="/issues" class="app-link-btn">
                <i class="bi bi-arrow-left"></i>
                <span>@Localizer["GoToIssuesList"]</span>
            </a>
        </section>
    }
</div>

@section PageScripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script src="~/js/modules/issue-edit.js" asp-append-version="true" defer></script>
}
