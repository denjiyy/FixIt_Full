                                <div style="font-size: 2.5rem; margin-bottom: var(--space-3); opacity: .4;">
                                    <i class="bi bi-chat-square-dots"></i>
                                </div>
                                <div style="font-weight: var(--font-semibold); color: var(--gray-500);">@Localizer["NoCommentsYet"]</div>
                                <div style="font-size: var(--text-sm);">@Localizer["BeTheFirstToShareYourThoughts"]</div>
                            </div>
                        }
                    </div>
                </div>

            </div><!-- /col-lg-8 -->

            <!-- ══ SIDEBAR ════════════════════════════════ -->
            <div class="col-lg-4">
                <div class="sticky-top" style="top: 90px;">

                    <!-- ── Vote Card ───────────────────────── -->
                    <div class="vote-card anim-2">
                        <div class="vote-header">
                            <i class="bi bi-hand-thumbs-up"></i> Community Vote
