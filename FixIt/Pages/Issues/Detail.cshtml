                        {
                            <select id="commentSortDropdown" class="form-select form-select-sm" style="width: 160px; margin-left: auto;">
                                <option value="newest">@Localizer["NewestFirstOption"]</option>
                                <option value="oldest">@Localizer["OldestFirstOption"]</option>
                                <option value="mostLiked">@Localizer["MostLikedOption"]</option>
                            </select>
                        }
                    </div>
                    <div class="detail-card-body">
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <form method="post" class="mb-5">
                                <div class="comment-form-area">
                                    <div class="comment-avatar-sm">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                    <div class="comment-input-wrap">
                                        <textarea id="commentText"
                                                  name="commentText"
                                                  class="comment-textarea"
                                                  rows="3"
                                                  placeholder="Share your thoughts or additional information…"></textarea>
                                        <div class="comment-actions">
                                            <button type="submit" asp-page-handler="AddComment" class="btn btn-primary btn-sm">
                                                <i class="bi bi-send-fill me-1"></i>Post Comment
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        }

                        @if (Model.Comments?.Any() == true)
                        {
                            <div id="commentsList">
                                @foreach (var comment in Model.Comments)
                                {
                                    <div class="comment-item" data-comment-id="@comment.Id" data-author-id="@comment.AuthorId" data-date="@comment.CreatedAt.ToString("O")" data-likes="@(comment.LikedBy?.Count ?? 0)" data-dislikes="@(comment.DislikedBy?.Count ?? 0)">
                                        <div class="comment-user-avatar">
                                            @if (comment.IsAnonymous)
