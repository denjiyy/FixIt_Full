@page "/issues/{id}"
@model IssueDetailModel
@{
    ViewData["Title"] = Model.Issue?.Title ?? "Issue";
}

<div class="container-fluid mt-4 mb-5">
    @if (Model.Issue != null)
    {
        <div class="row">
            <!-- Main Content -->
            <div class="col-lg-8">
                <!-- Issue Header -->
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h1 class="h3 mb-1">@Model.Issue.Title</h1>
                                <small class="text-muted">
                                    Reported by <strong>@Model.Issue.Reporter?.DisplayName ?? "Anonymous"</strong>
                                    on <time datetime="@Model.Issue.CreatedAt.ToString("O")">@Model.Issue.CreatedAt.ToString("MMMM d, yyyy")</time>
                                </small>
                            </div>
                            @if (User?.Identity?.IsAuthenticated ?? false)
                            {
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" href="/issues/@Model.Issue.Id/edit">Edit</a></li>
                                        <li><a class="dropdown-item text-danger" href="/issues/@Model.Issue.Id/delete">Delete</a></li>
                                    </ul>
                                </div>
                            }
                        </div>

                        <!-- Status & Priority Badges -->
                        <div class="mb-3">
                            @{
                                var statusColor = Model.Issue.Status switch
                                {
                                    FixIt.Models.Enums.IssueStatus.New => "warning",
                                    FixIt.Models.Enums.IssueStatus.Confirmed => "info",
                                    FixIt.Models.Enums.IssueStatus.InProgress => "primary",
                                    FixIt.Models.Enums.IssueStatus.Fixed => "success",
                                    _ => "secondary"
                                };
                                var priorityColor = Model.Issue.Priority switch
                                {
                                    FixIt.Models.Enums.IssuePriority.Low => "success",
                                    FixIt.Models.Enums.IssuePriority.Medium => "warning",
                                    FixIt.Models.Enums.IssuePriority.High => "danger",
                                    FixIt.Models.Enums.IssuePriority.Critical => "danger",
                                    _ => "secondary"
                                };
                            }
                            <span class="badge bg-@statusColor me-2">@Model.Issue.Status</span>
                            <span class="badge bg-@priorityColor">@Model.Issue.Priority Priority</span>
                        </div>

                        <!-- Location -->
                        <div class="mb-3">
                            <i class="bi bi-geo-alt-fill text-danger"></i>
                            <strong>@(Model.Issue.Address ?? "Location not specified")</strong>
                        </div>

                        <!-- Tags -->
                        @if (Model.Issue.TagIds?.Any() == true)
                        {
                            <div class="mb-3">
                                @foreach (var tagId in Model.Issue.TagIds)
                                {
                                    <span class="badge bg-light text-dark me-1">#category</span>
                                }
                            </div>
                        }

                        <!-- Stats -->
                        <div class="row text-center border-top border-bottom py-3 my-3">
                            <div class="col">
                                <div><i class="bi bi-eye"></i></div>
                                <small class="text-muted">@Model.Issue.ViewCount Views</small>
                            </div>
                            <div class="col">
                                <div><i class="bi bi-chat-dots"></i></div>
                                <small class="text-muted">@Model.Issue.CommentCount Comments</small>
                            </div>
                            <div class="col">
                                <div><i class="bi bi-hand-thumbs-up"></i></div>
                                <small class="text-muted">@(Model.Issue.Upvotes - Model.Issue.Downvotes) Score</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Issue Description -->
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Description</h5>
                        <p class="card-text lh-lg">@Model.Issue.Description</p>
                    </div>
                </div>

                <!-- Photos -->
                @if (Model.Issue.MediaIds?.Any() == true)
                {
                    <div class="card mb-4">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="bi bi-image"></i> Photos</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-2">
                                @foreach (var mediaId in Model.Issue.MediaIds)
                                {
                                    <div class="col-md-6">
                                        <img src="/api/media/@mediaId" alt="Issue photo" class="img-fluid rounded" 
                                             style="max-height: 300px; object-fit: cover;">
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- Comments Section -->
                <div class="card">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-chat-dots"></i> Comments (@Model.Issue.CommentCount)</h6>
                    </div>
                    <div class="card-body">
                        <!-- Add Comment Form -->
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <form method="post" class="mb-4">
                                <div class="mb-3">
                                    <label for="commentText" class="form-label">Add a Comment</label>
                                    <textarea id="commentText" name="commentText" class="form-control" 
                                              rows="3" placeholder="Share your thoughts..."></textarea>
                                </div>
                                <button type="submit" asp-page-handler="AddComment" class="btn btn-sm btn-primary">
                                    <i class="bi bi-send"></i> Post Comment
                                </button>
                            </form>
                        }

                        <!-- Comments List -->
                        @if (Model.Comments?.Any() == true)
                        {
                            <div class="comments-list">
                                @foreach (var comment in Model.Comments)
                                {
                                    <div class="card mb-3">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <div>
                                                    <strong>User</strong>
                                                    <br/>
                                                    <small class="text-muted">@comment.CreatedAt.ToString("MMMM d, yyyy 'at' h:mm tt")</small>
                                                </div>
                                                @if (User?.Identity?.IsAuthenticated ?? false)
                                                {
                                                    <button class="btn btn-sm btn-link text-danger" title="Delete">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                }
                                            </div>
                                            <p class="mb-0">@comment.Text</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else if (!((User?.Identity?.IsAuthenticated ?? false)))
                        {
                            <div class="alert alert-info">
                                <a href="/Identity/Account/Login">Login</a> to add comments
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">No comments yet. Be the first!</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Voting Card -->
                <div class="card mb-4 sticky-top" style="top: 20px;">
                    <div class="card-body text-center">
                        <h6 class="card-title mb-4">Is this helpful?</h6>
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <div class="btn-group d-grid gap-2" role="group">
                                <button type="button" class="btn btn-outline-success btn-lg" 
                                        onclick="vote(1)" title="Upvote">
                                    <i class="bi bi-hand-thumbs-up"></i><br/>
                                    <small>@Model.Issue.Upvotes</small>
                                </button>
                                <button type="button" class="btn btn-outline-danger btn-lg" 
                                        onclick="vote(-1)" title="Downvote">
                                    <i class="bi bi-hand-thumbs-down"></i><br/>
                                    <small>@Model.Issue.Downvotes</small>
                                </button>
                            </div>
                            <div id="voteMessage" class="mt-3"></div>
                        }
                        else
                        {
                            <p class="text-muted mb-3">
                                <a href="/Identity/Account/Login">Login</a> to vote
                            </p>
                            <div class="d-flex justify-content-center gap-3">
                                <div class="text-center">
                                    <div style="font-size: 1.5rem;"><i class="bi bi-hand-thumbs-up text-success"></i></div>
                                    <small class="text-muted">@Model.Issue.Upvotes</small>
                                </div>
                                <div class="text-center">
                                    <div style="font-size: 1.5rem;"><i class="bi bi-hand-thumbs-down text-danger"></i></div>
                                    <small class="text-muted">@Model.Issue.Downvotes</small>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Reporter Info -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">Reported By</h6>
                    </div>
                    <div class="card-body text-center">
                        @if (!string.IsNullOrEmpty(Model.Issue.Reporter?.AvatarUrl))
                        {
                            <img src="@Model.Issue.Reporter.AvatarUrl" alt="Avatar" class="rounded-circle mb-2" 
                                 style="width: 60px; height: 60px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center mb-2" 
                                 style="width: 60px; height: 60px;">
                                <i class="bi bi-person" style="font-size: 1.5rem;"></i>
                            </div>
                        }
                        <h6>@Model.Issue.Reporter?.DisplayName</h6>
                        <p class="text-muted small mb-0">@(Model.IssueCount ?? 0) issues reported</p>
                    </div>
                </div>

                <!-- Status History -->
                @if (Model.Issue.StatusHistory?.Any() == true)
                {
                    <div class="card">
                        <div class="card-header bg-light">
                            <h6 class="mb-0">Status History</h6>
                        </div>
                        <div class="card-body">
                            <div class="timeline">
                                @foreach (var history in Model.SortedStatusHistory)
                                {
                                    <div class="mb-3">
                                        <small class="text-muted d-block">@history.ChangedAt.ToString("MMM d, yyyy")</small>
                                        <strong>@history.From → @history.To</strong>
                                        @if (!string.IsNullOrEmpty(history.Comment))
                                        {
                                            <p class="mb-0 small text-muted">@history.Comment</p>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger text-center py-5">
            <h5>Issue not found</h5>
            <p>The issue you're looking for doesn't exist or has been deleted.</p>
            <a href="/issues" class="btn btn-primary">Back to Issues</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        async function vote(voteType) {
            try {
                const response = await fetch('@("/api/issues/" + Model.Issue?.Id + "/vote")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ voteType: voteType })
                });

                if (response.ok) {
                    const message = document.getElementById('voteMessage');
                    message.innerHTML = '<small class="text-success">Vote recorded!</small>';
                    setTimeout(() => {
                        location.reload();
                    }, 1500);
                } else {
                    alert('Failed to record vote');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred');
            }
        }
    </script>
}
