@page "/issues/{id}"
@using System.Globalization
@model IssueDetailModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Model.Issue?.Title ?? Localizer["Issue"];
    ViewData["RequiresMap"] = Model.Issue?.Location?.Coordinates != null;
    ViewData["BodyClass"] = "page-issue-detail";
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/issues-shared.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/issue-detail.css" asp-append-version="true" />
}

@if (Model.Issue != null)
{
    var totalVotes = Model.Issue.Upvotes + Model.Issue.Downvotes;
    var upvotePct = totalVotes > 0 ? (int)Math.Round((double)Model.Issue.Upvotes / totalVotes * 100) : 50;
    var reporterName = Model.Issue.IsAnonymous
        ? Localizer["AnonymousUser"].Value
        : (Model.Issue.Reporter?.DisplayName ?? Localizer["CommunityMember"].Value);
    var imageList = Model.MediaList.Where(m => m.Type == FixIt.Models.Enums.MediaType.Image).ToList();
    var videoList = Model.MediaList.Where(m => m.Type == FixIt.Models.Enums.MediaType.Video).ToList();

    <div class="issue-page issue-detail-page"
         id="issueDetailRoot"
         data-issue-id="@Model.Id"
         data-current-user="@(User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty)"
         data-locale="@CultureInfo.CurrentUICulture.Name"
         data-vote-success="@Localizer["VoteRecorded"]"
         data-vote-failure="@Localizer["VoteFailed"]"
         data-vote-error="@Localizer["UnexpectedError"]"
         data-positive-label="@Localizer["PositiveVotesLabel"]"
         data-total-label="@Localizer["VotesTotalLabel"]"
         data-delete-comment-confirm="@Localizer["DeleteCommentConfirm"]"
         data-delete-own-only="@Localizer["DeleteOwnCommentsOnly"]"
         data-delete-comment-failed="@Localizer["DeleteCommentFailed"]"
         data-delete-comment-error="@Localizer["DeleteCommentError"]"
         data-sign-in-like="@Localizer["SignInToLikeComments"]"
         data-sign-in-dislike="@Localizer["SignInToDislikeComments"]"
         data-lightbox-label="@Localizer["ImageViewer"]"
         data-close-label="@Localizer["CloseLabel"]"
         data-previous-label="@Localizer["PreviousLabel"]"
         data-next-label="@Localizer["NextLabel"]"
         data-photo-label="@Localizer["IssuePhotoLabel"]"
         data-analysis-title="@Localizer["AiAnalysisLabel"]"
         data-analysis-pending="@Localizer["PendingLabel"]"
         data-analysis-complete="@Localizer["CompleteLabel"]"
         data-analysis-unavailable="@Localizer["AnalysisUnavailable"]"
         data-analysis-error-copy="@Localizer["AnalysisUnavailableCopy"]"
         data-analysis-retry="@Localizer["Retry"]"
         data-analysis-generating-title="@Localizer["GeneratingAiAnalysisTitle"]"
         data-analysis-generating-copy="@Localizer["GeneratingAiAnalysisCopy"]"
         data-analysis-category-label="@Localizer["CategoryLabel"]"
         data-analysis-severity-label="@Localizer["SeverityLabel"]"
         data-analysis-keywords-label="@Localizer["KeywordsLabel"]"
         data-analysis-suggested-tags-label="@Localizer["SuggestedTagsLabel"]"
         data-analysis-notes-label="@Localizer["AnalysisNotesLabel"]"
         data-analysis-similar-issues-label="@Localizer["SimilarIssuesDetectedLabel"]"
         data-analysis-more-label="@Localizer["MoreLabel"]"
         data-analysis-confidence-suffix="@Localizer["ConfidenceSuffix"]"
         data-analysis-analyzed-label="@Localizer["AnalyzedAtLabel"]"
         data-video-preview-unavailable="@Localizer["VideoPreviewUnavailable"]">
        <input type="hidden" id="issueId" value="@Model.Id" />

        <nav class="detail-breadcrumb" aria-label="@Localizer["BreadcrumbLabel"]">
            <a href="/"><i class="bi bi-house-door"></i></a>
            <span>/</span>
            <a href="/issues">@Localizer["Issues"]</a>
            <span>/</span>
            <span>@Model.Issue.Title</span>
        </nav>

        <section class="issue-surface issue-surface--glass detail-hero">
            <div class="detail-hero__main">
                <div class="issue-badges">
                    <partial name="_BadgeStatus" model="Model.Issue.Status" />
                    <partial name="_BadgePriority" model="Model.Issue.Priority" />
                </div>

                <h1 class="detail-hero__title">@Model.Issue.Title</h1>

                <div class="detail-hero__meta">
                    <span>
                        <i class="bi bi-person-circle"></i>
                        <strong>@reporterName</strong>
                    </span>
                    <span>
                        <i class="bi bi-calendar3"></i>
                        @Model.Issue.CreatedAt.ToString("MMMM d, yyyy")
                    </span>
                    <span>
                        <i class="bi bi-clock-history"></i>
                        @Localizer["LastUpdatedLabel"] @Model.Issue.LastActivityAt.ToString("MMM d, yyyy")
                    </span>
                    @if (!string.IsNullOrWhiteSpace(Model.Issue.Address))
                    {
                        <span>
                            <i class="bi bi-geo-alt-fill"></i>
                            @Model.Issue.Address
                        </span>
                    }
                </div>
            </div>

            <div class="detail-hero__side">
                @if (Model.CanManageIssue)
                {
                    <div class="detail-hero__actions">
                        <a href="/issues/@Model.Issue.Id/edit" class="app-link-btn">
                            <i class="bi bi-pencil-square"></i>
                            <span>@Localizer["EditIssue"]</span>
                        </a>
                        <a href="/issues/@Model.Issue.Id/delete" class="app-link-btn detail-hero__danger">
                            <i class="bi bi-trash3"></i>
                            <span>@Localizer["DeleteIssue"]</span>
                        </a>
                    </div>
                }

                <div class="detail-stats">
                    <article class="detail-stat">
                        <span>@Localizer["ViewsLabel"]</span>
                        <strong id="statViews">@Model.Issue.ViewCount</strong>
                    </article>
                    <article class="detail-stat">
                        <span>@Localizer["CommentsLabel"]</span>
                        <strong>@Model.Issue.CommentCount</strong>
                    </article>
                    <article class="detail-stat">
                        <span>@Localizer["ScoreLabel"]</span>
                        <strong id="statScore">@(Model.Issue.Upvotes - Model.Issue.Downvotes)</strong>
                    </article>
                </div>
            </div>
        </section>

        <div class="detail-layout">
            <main class="detail-main">
                <section class="issue-surface detail-card">
                    <div class="detail-card__header">
                        <h2>@Localizer["DescriptionLabel"]</h2>
                    </div>
                    <div class="detail-card__body">
                        <p class="detail-description">@Model.Issue.Description</p>
                    </div>
                </section>

                @if (Model.MediaList.Any())
                {
                    <section class="issue-surface detail-card">
                        <div class="detail-card__header detail-card__header--split">
                            <h2>@Localizer["MediaLabel"]</h2>
                            <span class="detail-card__caption">
                                @if (imageList.Any())
                                {
                                    <text>@imageList.Count @Localizer["PhotosLabel"]</text>
                                }
                                @if (imageList.Any() && videoList.Any())
                                {
                                    <text> · </text>
                                }
                                @if (videoList.Any())
                                {
                                    <text>@videoList.Count @Localizer["VideosLabel"]</text>
                                }
                            </span>
                        </div>
                        <div class="detail-card__body">
                            @if (imageList.Any())
                            {
                                <div class="detail-media-grid" id="mediaGrid">
                                    @for (int idx = 0; idx < imageList.Count; idx++)
                                    {
                                        var media = imageList[idx];
                                        <button type="button"
                                                class="detail-media-thumb"
                                                data-media-index="@idx"
                                                data-media-src="/api/media/@media.Id"
                                                data-lightbox-index="@idx">
                                            <img src="/api/media/@media.Id"
                                                 alt="@Localizer["IssuePhotoLabel"] @(idx + 1)"
                                                 loading="lazy"
                                                 decoding="async" />
                                            <span class="detail-media-thumb__overlay">
                                                <i class="bi bi-arrows-fullscreen"></i>
                                            </span>
                                        </button>
                                    }
                                </div>
                            }

                            @if (videoList.Any())
                            {
                                <div class="detail-video-list @(imageList.Any() ? "detail-video-list--spaced" : string.Empty)">
                                    @foreach (var media in videoList)
                                    {
                                        <div class="detail-video-card">
                                            <div class="video-wrapper">
                                                <video controls controlsList="nodownload" preload="metadata" data-video-preview>
                                                    <source src="/api/media/@media.Id" type="@media.MimeType" />
                                                </video>
                                            </div>
                                            <div class="detail-video-meta">
                                                <i class="bi bi-file-play"></i>
                                                <span>@Localizer["VideosLabel"] · @(media.SizeBytes / (1024 * 1024)) MB</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </section>
                }

                @if (Model.Issue.Location?.Coordinates?.Values?.Count >= 2)
                {
                    <section class="issue-surface detail-card">
                        <div class="detail-card__header">
                            <h2>@Localizer["LocationLabel"]</h2>
                        </div>
                        <div class="detail-card__body">
                            <div id="detailMap"
                                 data-latitude="@Model.Issue.Location.Coordinates.Values[1]"
                                 data-longitude="@Model.Issue.Location.Coordinates.Values[0]"
                                 class="detail-map"></div>
                            <div class="detail-map__meta">
                                <strong>@Localizer["Coordinates"]</strong>
                                <span>@Model.Issue.Location.Coordinates.Values[1].ToString("F5"), @Model.Issue.Location.Coordinates.Values[0].ToString("F5")</span>
                            </div>
                        </div>
                    </section>
                }

                @if (Model.Analysis != null)
                {
                    var severityToneClass = Model.Analysis.EstimatedSeverity >= 8
                        ? "detail-metric__icon--danger"
                        : Model.Analysis.EstimatedSeverity >= 5
                            ? "detail-metric__icon--warning"
                            : "detail-metric__icon--success";
                    var severityFillClass = Model.Analysis.EstimatedSeverity >= 8
                        ? "detail-progress__bar--danger"
                        : Model.Analysis.EstimatedSeverity >= 5
                            ? "detail-progress__bar--warning"
                            : "detail-progress__bar--success";

                    <section class="issue-surface detail-card detail-card--accent">
                        <div class="detail-card__header detail-card__header--split">
                            <h2>@Localizer["AiAnalysisLabel"]</h2>
                            <span class="detail-status detail-status--success">@Localizer["CompleteLabel"]</span>
                        </div>
                        <div class="detail-card__body">
                            <div class="detail-metric-grid">
                                <article class="detail-metric">
                                    <div class="detail-metric__icon">
                                        <i class="bi bi-tag-fill"></i>
                                    </div>
                                    <div>
                                        <span>@Localizer["CategoryLabel"]</span>
                                        <strong>@Model.Analysis.Category</strong>
                                        <small>@Model.Analysis.ConfidenceScore% @Localizer["ConfidenceSuffix"]</small>
                                    </div>
                                </article>
                                <article class="detail-metric">
                                    <div class="detail-metric__icon @severityToneClass">
                                        <i class="bi bi-exclamation-triangle-fill"></i>
                                    </div>
                                    <div>
                                        <span>@Localizer["SeverityLabel"]</span>
                                        <strong>@Model.Analysis.EstimatedSeverity / 10</strong>
                                        <div class="detail-progress">
                                            <div class="detail-progress__bar @severityFillClass severity-fill" data-width="@(Model.Analysis.EstimatedSeverity * 10)"></div>
                                        </div>
                                    </div>
                                </article>
                            </div>

                            @if (Model.Analysis.Keywords?.Any() == true)
                            {
                                <div class="detail-chip-block">
                                    <span class="detail-chip-block__label">@Localizer["KeywordsLabel"]</span>
                                    <div class="detail-chip-list">
                                        @foreach (var keyword in Model.Analysis.Keywords.Take(6))
                                        {
                                            <span class="detail-chip">@keyword</span>
                                        }
                                    </div>
                                </div>
                            }

                            @if (Model.Analysis.SuggestedTags?.Any() == true)
                            {
                                <div class="detail-chip-block">
                                    <span class="detail-chip-block__label">@Localizer["SuggestedTagsLabel"]</span>
                                    <div class="detail-chip-list">
                                        @foreach (var tag in Model.Analysis.SuggestedTags.Take(5))
                                        {
                                            <a href="/tags/@tag" class="detail-chip detail-chip--link">#@tag</a>
                                        }
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(Model.Analysis.Reasoning))
                            {
                                <div class="detail-note">
                                    <strong>@Localizer["AnalysisNotesLabel"]</strong>
                                    <p>@Model.Analysis.Reasoning</p>
                                </div>
                            }

                            @if (Model.Analysis.PotentialDuplicates?.Any() == true)
                            {
                                <div class="detail-duplicates">
                                    <span class="detail-chip-block__label">@Localizer["SimilarIssuesDetectedLabel"]</span>
                                    @foreach (var duplicate in Model.Analysis.PotentialDuplicates.Take(3))
                                    {
                                        <a href="/issues/@duplicate.IssueId" class="detail-duplicate-card">
                                            <div>
                                                <strong>@duplicate.IssueTitle</strong>
                                                <span>@duplicate.Reason</span>
                                            </div>
                                            <em>@duplicate.SimilarityScore%</em>
                                        </a>
                                    }
                                </div>
                            }

                            <div class="detail-analysis-meta">
                                <i class="bi bi-clock-history"></i>
                                <span>@Localizer["AnalyzedAtLabel"] @Model.Analysis.AnalyzedAt.ToString("MMMM d, yyyy '•' HH:mm")</span>
                            </div>
                        </div>
                    </section>
                }
                else
                {
                    <section class="issue-surface detail-card detail-card--accent" id="analysisPlaceholder">
                        <div class="detail-card__header detail-card__header--split">
                            <h2>@Localizer["AiAnalysisLabel"]</h2>
                            <span class="detail-status detail-status--warning">@Localizer["PendingLabel"]</span>
                        </div>
                        <div class="detail-card__body">
                            <div class="detail-analysis-loading">
                                <div class="detail-analysis-loading__icon">
                                    <i class="bi bi-stars"></i>
                                </div>
                                <h3>@Localizer["GeneratingAiAnalysisTitle"]</h3>
                                <p>@Localizer["GeneratingAiAnalysisCopy"]</p>
                            </div>
                        </div>
                    </section>
                }

                <section class="issue-surface detail-card">
                    <div class="detail-card__header detail-card__header--split">
                        <h2>@Localizer["CommentsLabel"]</h2>
                        @if (Model.Comments.Any())
                        {
                            <select id="commentSortDropdown" class="detail-comment-sort">
                                <option value="newest">@Localizer["NewestFirstOption"]</option>
                                <option value="oldest">@Localizer["OldestFirstOption"]</option>
                                <option value="mostLiked">@Localizer["MostLikedOption"]</option>
                            </select>
                        }
                    </div>
                    <div class="detail-card__body">
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <form method="post" class="detail-comment-form">
                                <div class="detail-comment-form__avatar">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                                <div class="detail-comment-form__body">
                                    <textarea id="commentText"
                                              name="commentText"
                                              class="detail-comment-textarea"
                                              rows="4"
                                              placeholder="@Localizer["CommentPlaceholder"]"></textarea>
                                    <div class="detail-comment-form__actions">
                                        <button type="submit" asp-page-handler="AddComment" class="nav-report-btn nav-report-btn--compact">
                                            <i class="bi bi-send-fill"></i>
                                            <span>@Localizer["PostCommentLabel"]</span>
                                        </button>
                                    </div>
                                </div>
                            </form>
                        }

                        @if (Model.Comments.Any())
                        {
                            <div id="commentsList" class="detail-comments">
                                @foreach (var comment in Model.Comments)
                                {
                                    <article class="detail-comment-item comment-item"
                                             data-comment-id="@comment.Id"
                                             data-author-id="@comment.AuthorId"
                                             data-date="@comment.CreatedAt.ToString("O")"
                                             data-likes="@(comment.LikedBy?.Count ?? 0)"
                                             data-dislikes="@(comment.DislikedBy?.Count ?? 0)">
                                        <div class="comment-user-avatar detail-comment-item__avatar">
                                            @if (comment.IsAnonymous)
                                            {
                                                <i class="bi bi-incognito comment-user-avatar-icon-muted"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-person-fill"></i>
                                            }
                                        </div>
                                        <div class="comment-body detail-comment-item__body">
                                            <div class="detail-comment-item__header">
                                                <div>
                                                    <strong class="comment-author">@(comment.IsAnonymous ? Localizer["AnonymousUser"] : comment.Author?.DisplayName ?? Localizer["CommunityMember"])</strong>
                                                    <span class="detail-comment-item__time">@comment.CreatedAt.ToString("MMM d, yyyy '•' HH:mm")</span>
                                                </div>
                                            </div>
                                            <p class="comment-text detail-comment-item__text">@comment.Text</p>
                                            <div class="detail-comment-item__actions comment-actions-row">
                                                <button class="comment-like-btn" type="button" title="@Localizer["UpvoteLabel"]" data-comment-id="@comment.Id">
                                                    <i class="bi bi-hand-thumbs-up"></i>
                                                    <span class="like-count">@(comment.LikedBy?.Count ?? 0)</span>
                                                </button>
                                                <button class="comment-dislike-btn" type="button" title="@Localizer["DownvoteLabel"]" data-comment-id="@comment.Id">
                                                    <i class="bi bi-hand-thumbs-down"></i>
                                                    <span class="dislike-count">@(comment.DislikedBy?.Count ?? 0)</span>
                                                </button>
                                                @if (User?.Identity?.IsAuthenticated ?? false)
                                                {
                                                    <button class="comment-delete-btn" type="button" title="@Localizer["DeleteIssue"]" data-comment-id="@comment.Id" data-author-id="@comment.AuthorId">
                                                        <i class="bi bi-trash3"></i>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                        else if (!(User?.Identity?.IsAuthenticated ?? false))
                        {
                            <div class="detail-empty-inline">
                                <a asp-area="Identity" asp-page="/Account/Login">@Localizer["SignIn"]</a> @Localizer["SignInToJoinTheConversation"].
                            </div>
                        }
                        else
                        {
                            <div class="detail-empty-inline">
                                @Localizer["BeTheFirstToShareYourThoughts"]
                            </div>
                        }
                    </div>
                </section>
            </main>

            <aside class="detail-sidebar">
                <section class="issue-surface detail-sidebar-card vote-card">
                    <h2>@Localizer["CommunityVoteLabel"]</h2>
                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <div class="detail-vote-buttons">
                            <button type="button" class="vote-btn detail-vote-btn" id="upvoteBtn" data-vote-type="1">
                                <i class="bi bi-hand-thumbs-up-fill"></i>
                                <span class="vote-count" id="upvoteCount">@Model.Issue.Upvotes</span>
                                <span class="vote-btn-label">@Localizer["UpvoteLabel"]</span>
                            </button>
                            <button type="button" class="vote-btn detail-vote-btn" id="downvoteBtn" data-vote-type="-1">
                                <i class="bi bi-hand-thumbs-down-fill"></i>
                                <span class="vote-count" id="downvoteCount">@Model.Issue.Downvotes</span>
                                <span class="vote-btn-label">@Localizer["DownvoteLabel"]</span>
                            </button>
                        </div>
                        <div class="detail-vote-progress">
                            <div class="detail-vote-progress__bar" id="scoreBar" data-width="@upvotePct"></div>
                        </div>
                        <div class="detail-vote-summary">
                            <span id="upvotePct">@upvotePct% @Localizer["PositiveVotesLabel"]</span>
                            <span id="totalVoteCount">@totalVotes @Localizer["VotesTotalLabel"]</span>
                        </div>
                        <div id="voteMessage"></div>
                    }
                    else
                    {
                        <div class="detail-vote-guest">
                            <div>
                                <strong>@Model.Issue.Upvotes</strong>
                                <span>@Localizer["UpvoteLabel"]</span>
                            </div>
                            <div>
                                <strong>@Model.Issue.Downvotes</strong>
                                <span>@Localizer["DownvoteLabel"]</span>
                            </div>
                        </div>
                        <p class="detail-sidebar-card__copy">
                            <a asp-area="Identity" asp-page="/Account/Login">@Localizer["SignIn"]</a> @Localizer["SignInToCastYourVote"]
                        </p>
                    }
                </section>

                <section class="issue-surface detail-sidebar-card">
                    <h2>@Localizer["SnapshotLabel"]</h2>
                    <dl class="detail-sidebar-list">
                        <div>
                            <dt>@Localizer["Status"]</dt>
                            <dd><partial name="_BadgeStatus" model="Model.Issue.Status" /></dd>
                        </div>
                        <div>
                            <dt>@Localizer["Priority"]</dt>
                            <dd><partial name="_BadgePriority" model="Model.Issue.Priority" /></dd>
                        </div>
                        <div>
                            <dt>@Localizer["VisibilityLabel"]</dt>
                            <dd>@(Model.Issue.IsAnonymous ? Localizer["AnonymousVisibility"] : Localizer["PublicIssue"])</dd>
                        </div>
                        <div>
                            <dt>@Localizer["CreatedAtLabel"]</dt>
                            <dd>@Model.Issue.CreatedAt.ToString("MMMM d, yyyy")</dd>
                        </div>
                        <div>
                            <dt>@Localizer["LastUpdatedLabel"]</dt>
                            <dd>@Model.Issue.LastActivityAt.ToString("MMMM d, yyyy")</dd>
                        </div>
                    </dl>
                </section>

                <section class="issue-surface detail-sidebar-card">
                    <h2>@Localizer["ReportedByLabel"]</h2>
                    @if (Model.Issue.IsAnonymous)
                    {
                        <div class="detail-reporter detail-reporter--static">
                            <div class="detail-reporter__avatar">
                                <i class="bi bi-incognito"></i>
                            </div>
                            <div>
                                <strong>@Localizer["AnonymousUser"]</strong>
                                <span>@Localizer["IdentityHiddenForPrivacy"]</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a href="/user/@Model.Issue.Reporter?.Id" class="detail-reporter">
                            <div class="detail-reporter__avatar">
                                @if (!string.IsNullOrWhiteSpace(Model.Issue.Reporter?.AvatarUrl))
                                {
                                    <img src="@Model.Issue.Reporter.AvatarUrl" alt="@Model.Issue.Reporter.DisplayName" loading="lazy" decoding="async" />
                                }
                                else
                                {
                                    <i class="bi bi-person-fill"></i>
                                }
                            </div>
                            <div>
                                <strong>@Model.Issue.Reporter?.DisplayName</strong>
                                <span>@(Model.IssueCount ?? 0) @Localizer["IssuesReporterStat"]</span>
                            </div>
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    }
                </section>

                @if (Model.Issue.StatusHistory?.Any() == true)
                {
                    <section class="issue-surface detail-sidebar-card">
                        <h2>@Localizer["StatusHistoryLabel"]</h2>
                        <div class="detail-timeline">
                            @foreach (var history in Model.SortedStatusHistory)
                            {
                                <article class="detail-timeline__item">
                                    <span class="detail-timeline__date">@history.ChangedAt.ToString("MMM d, yyyy")</span>
                                    <div class="detail-timeline__flow">
                                        <partial name="_BadgeStatus" model="history.From" />
                                        <i class="bi bi-arrow-right"></i>
                                        <partial name="_BadgeStatus" model="history.To" />
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(history.Comment))
                                    {
                                        <p>@history.Comment</p>
                                    }
                                </article>
                            }
                        </div>
                    </section>
                }
            </aside>
        </div>
    </div>
}
else
{
    <div class="issue-page issue-page--compact">
        <section class="issue-surface issue-empty-state">
            <div class="issue-empty-state__icon">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <h2 class="issue-empty-state__title">@Localizer["IssueNotFoundMessage"]</h2>
            <p class="issue-empty-state__copy">@Localizer["IssueNotFoundMessage"]</p>
            <a href="/issues" class="app-link-btn">
                <i class="bi bi-arrow-left"></i>
                <span>@Localizer["GoToIssuesList"]</span>
            </a>
        </section>
    </div>
}

@section PageScripts {
    <script src="~/js/modules/media-lightbox.js" asp-append-version="true" defer></script>
    <script src="~/js/modules/ai-analysis.js" asp-append-version="true" defer></script>
    <script src="~/js/modules/voting.js" asp-append-version="true" defer></script>
    <script src="~/js/modules/comments.js" asp-append-version="true" defer></script>
