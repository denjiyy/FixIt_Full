@page "/issues/{id}"
@model IssueDetailModel
@{
    ViewData["Title"] = Model.Issue?.Title ?? "Issue";
}

@if (Model.Issue != null)
{
    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8 mb-4">
            <!-- Issue Header Card -->
            <div class="card mb-4" style="border: none;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="flex-grow-1">
                            <div class="mb-3">
                                @{
                                    var statusBadgeClass = Model.Issue.Status switch
                                    {
                                        FixIt.Models.Enums.IssueStatus.New => "badge-status-new",
                                        FixIt.Models.Enums.IssueStatus.Confirmed => "badge-status-confirmed",
                                        FixIt.Models.Enums.IssueStatus.InProgress => "badge-status-in-progress",
                                        FixIt.Models.Enums.IssueStatus.Fixed => "badge-status-fixed",
                                        _ => "bg-secondary"
                                    };
                                    var priorityBadgeClass = Model.Issue.Priority switch
                                    {
                                        FixIt.Models.Enums.IssuePriority.Low => "badge-priority-low",
                                        FixIt.Models.Enums.IssuePriority.Medium => "badge-priority-medium",
                                        FixIt.Models.Enums.IssuePriority.High => "badge-priority-high",
                                        FixIt.Models.Enums.IssuePriority.Critical => "badge-priority-critical",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @statusBadgeClass me-2">@Model.Issue.Status</span>
                                <span class="badge @priorityBadgeClass">@Model.Issue.Priority Priority</span>
                            </div>
                            <h1 class="h3 mb-2">@Model.Issue.Title</h1>
                            <div class="text-muted small">
                                <i class="bi bi-person-circle"></i> <strong>@(Model.Issue.Reporter?.DisplayName ?? "Anonymous")</strong>
                                <span class="mx-2">•</span>
                                <i class="bi bi-calendar"></i> @Model.Issue.CreatedAt.ToString("MMMM d, yyyy")
                            </div>
                        </div>
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="/issues/@Model.Issue.Id/edit"><i class="bi bi-pencil"></i> Edit</a></li>
                                    <li><a class="dropdown-item text-danger" href="/issues/@Model.Issue.Id/delete"><i class="bi bi-trash"></i> Delete</a></li>
                                </ul>
                            </div>
                        }
                    </div>

                    <!-- Location -->
                    @if (!string.IsNullOrEmpty(Model.Issue.Address))
                    {
                        <div class="mb-3 p-3" style="background: var(--gray-100); border-radius: 0.5rem;">
                            <i class="bi bi-geo-alt-fill text-danger"></i>
                            <strong>@Model.Issue.Address</strong>
                        </div>
                    }

                    <!-- Stats Row -->
                    <div class="row text-center border-top pt-3 mt-3">
                        <div class="col-4">
                            <div class="stat-value" style="font-size: 1.5rem;">@Model.Issue.ViewCount</div>
                            <div class="stat-label" style="font-size: 0.75rem;">Views</div>
                        </div>
                        <div class="col-4">
                            <div class="stat-value" style="font-size: 1.5rem;">@Model.Issue.CommentCount</div>
                            <div class="stat-label" style="font-size: 0.75rem;">Comments</div>
                        </div>
                        <div class="col-4">
                            <div class="stat-value" style="font-size: 1.5rem;">@(Model.Issue.Upvotes - Model.Issue.Downvotes)</div>
                            <div class="stat-label" style="font-size: 0.75rem;">Score</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div class="card mb-4" style="border: none;">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-file-text"></i> Description</h6>
                </div>
                <div class="card-body">
                    <p class="mb-0" style="white-space: pre-wrap;">@Model.Issue.Description</p>
                </div>
            </div>

            <!-- Photos -->
            @if (Model.Issue.MediaIds?.Any() == true)
            {
                <div class="card mb-4" style="border: none;">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-images"></i> Photos</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            @foreach (var mediaId in Model.Issue.MediaIds)
                            {
                                <div class="col-md-6">
                                    <img src="/api/media/@mediaId" alt="Issue photo" class="img-fluid rounded hover-lift" 
                                         style="width: 100%; height: 250px; object-fit: cover; cursor: pointer;">
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Comments -->
            <div class="card" style="border: none;">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-chat-dots"></i> Comments (@Model.Issue.CommentCount)</h6>
                </div>
                <div class="card-body">
                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <form method="post" class="mb-4">
                            <div class="mb-3">
                                <textarea id="commentText" name="commentText" class="form-control" 
                                          rows="3" placeholder="Share your thoughts..."></textarea>
                            </div>
                            <button type="submit" asp-page-handler="AddComment" class="btn btn-primary">
                                <i class="bi bi-send"></i> Post Comment
                            </button>
                        </form>
                    }

                    @if (Model.Comments?.Any() == true)
                    {
                        @foreach (var comment in Model.Comments)
                        {
                            <div class="card mb-3" style="border: 1px solid var(--gray-300);">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <strong>User</strong>
                                            <br/>
                                            <small class="text-muted">@comment.CreatedAt.ToString("MMM d, yyyy 'at' h:mm tt")</small>
                                        </div>
                                        @if (User?.Identity?.IsAuthenticated ?? false)
                                        {
                                            <button class="btn btn-sm btn-link text-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                    <p class="mb-0">@comment.Text</p>
                                </div>
                            </div>
                        }
                    }
                    else if (!((User?.Identity?.IsAuthenticated ?? false)))
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> <a href="/Identity/Account/Login">Login</a> to add comments
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">No comments yet. Be the first!</p>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Voting Card -->
            <div class="card mb-4 sticky-top" style="top: 90px; border: none;">
                <div class="card-header">
                    <h6 class="mb-0 text-center">Community Vote</h6>
                </div>
                <div class="card-body text-center">
                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <button type="button" class="btn btn-outline-success w-100 py-3" onclick="vote(1)">
                                    <i class="bi bi-hand-thumbs-up" style="font-size: 1.5rem;"></i>
                                    <div class="small mt-2">@Model.Issue.Upvotes</div>
                                </button>
                            </div>
                            <div class="col-6">
                                <button type="button" class="btn btn-outline-danger w-100 py-3" onclick="vote(-1)">
                                    <i class="bi bi-hand-thumbs-down" style="font-size: 1.5rem;"></i>
                                    <div class="small mt-2">@Model.Issue.Downvotes</div>
                                </button>
                            </div>
                        </div>
                        <div id="voteMessage"></div>
                    }
                    else
                    {
                        <p class="text-muted mb-3">
                            <a href="/Identity/Account/Login">Login</a> to vote
                        </p>
                        <div class="row text-center">
                            <div class="col-6">
                                <div style="font-size: 2rem;"><i class="bi bi-hand-thumbs-up text-success"></i></div>
                                <strong>@Model.Issue.Upvotes</strong>
                            </div>
                            <div class="col-6">
                                <div style="font-size: 2rem;"><i class="bi bi-hand-thumbs-down text-danger"></i></div>
                                <strong>@Model.Issue.Downvotes</strong>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Reporter Info -->
            <div class="card mb-4" style="border: none;">
                <div class="card-header">
                    <h6 class="mb-0">Reported By</h6>
                </div>
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.Issue.Reporter?.AvatarUrl))
                    {
                        <img src="@Model.Issue.Reporter.AvatarUrl" alt="Avatar" class="rounded-circle mb-2" 
                             style="width: 60px; height: 60px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-2" 
                             style="width: 60px; height: 60px; background: linear-gradient(135deg, var(--primary), var(--primary-dark));">
                            <i class="bi bi-person" style="font-size: 1.5rem; color: white;"></i>
                        </div>
                    }
                    <h6 class="mb-1">@Model.Issue.Reporter?.DisplayName</h6>
                    <p class="text-muted small mb-0">@(Model.IssueCount ?? 0) issues reported</p>
                </div>
            </div>

            <!-- Status History -->
            @if (Model.Issue.StatusHistory?.Any() == true)
            {
                <div class="card" style="border: none;">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-clock-history"></i> Status History</h6>
                    </div>
                    <div class="card-body">
                        <div class="timeline">
                            @foreach (var history in Model.SortedStatusHistory)
                            {
                                <div class="timeline-item">
                                    <small class="text-muted d-block mb-1">@history.ChangedAt.ToString("MMM d, yyyy")</small>
                                    <strong>@history.From → @history.To</strong>
                                    @if (!string.IsNullOrEmpty(history.Comment))
                                    {
                                        <p class="mb-0 small text-muted">@history.Comment</p>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="card text-center py-5" style="border: none; background: var(--gray-100);">
        <div class="card-body">
            <i class="bi bi-exclamation-triangle" style="font-size: 4rem; color: var(--danger);"></i>
            <h5 class="mt-3">Issue not found</h5>
            <p class="text-muted">The issue you're looking for doesn't exist or has been deleted.</p>
            <a href="/issues" class="btn btn-primary mt-3">
                <i class="bi bi-arrow-left"></i> Back to Issues
            </a>
        </div>
    </div>
}

@section Scripts {
    <script>
        async function vote(voteType) {
            try {
                const response = await fetch('@("/api/issues/" + Model.Issue?.Id + "/vote")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ voteType: voteType })
                });

                const message = document.getElementById('voteMessage');
                if (response.ok) {
                    message.innerHTML = '<div class="alert alert-success py-2"><i class="bi bi-check-circle"></i> Vote recorded!</div>';
                    setTimeout(() => location.reload(), 1500);
                } else {
                    message.innerHTML = '<div class="alert alert-danger py-2">Failed to record vote</div>';
                }
            } catch (error) {
                console.error('Error:', error);
                document.getElementById('voteMessage').innerHTML = '<div class="alert alert-danger py-2">An error occurred</div>';
            }
        }
    </script>
}
