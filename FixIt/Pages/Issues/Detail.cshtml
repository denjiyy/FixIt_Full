                                        <i class="bi bi-hand-thumbs-up-fill"></i>
                                        <span class="vote-count" id="upvoteCount">@Model.Issue?.Upvotes</span>
                                        <span style="font-size: var(--text-xs); font-weight: var(--font-medium); opacity: .7; position: relative; z-index: 1;">@Localizer["UpvoteLabel"]</span>
                                    </button>
                                    <button type="button" class="vote-btn downvote" id="downvoteBtn" onclick="vote(-1)">
                                        <i class="bi bi-hand-thumbs-down-fill"></i>
                                        <span class="vote-count" id="downvoteCount">@Model.Issue?.Downvotes</span>
                                        <span style="font-size: var(--text-xs); font-weight: var(--font-medium); opacity: .7; position: relative; z-index: 1;">@Localizer["DownvoteLabel"]</span>
                                    </button>
                                </div>
                                <div class="vote-score-bar">
                                    <div class="vote-score-fill" id="scoreBar" style="width: @upvotePct%;"></div>
                                </div>
                                <div style="display: flex; justify-content: space-between; font-size: var(--text-xs); color: var(--gray-400); margin-top: var(--space-2);">
                                    <span id="upvotePct">@upvotePct% positive</span>
                                    <span id="totalVoteCount">@totalVotes total</span>
                                </div>
                                <div id="voteMessage"></div>
                            }
                            else
                            {
                                <div class="vote-display-guest">
                                    <div class="vote-display-box up-box">
                                        <i class="bi bi-hand-thumbs-up-fill"></i>
                                        <strong>@Model.Issue?.Upvotes</strong>
                                        <small>@Localizer["UpvotesCount"]</small>
                                    </div>
                                    <div class="vote-display-box down-box">
                                        <i class="bi bi-hand-thumbs-down-fill"></i>
                                        <strong>@Model.Issue?.Downvotes</strong>
                                        <small>@Localizer["DownvotesCount"]</small>
