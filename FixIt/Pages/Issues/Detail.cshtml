@page "/issues/{id}"
@model IssueDetailModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Model.Issue?.Title ?? "Issue";
}

<style>
/* ═══════════════════════════════════════════════
   ISSUE DETAIL — Production Design System
   Fully aligned with site.css variables
═══════════════════════════════════════════════ */

/* ── Page Entry Animation ────────────────────── */
@@keyframes slide-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
}

.anim-1 { animation: slide-up .45s cubic-bezier(.22,1,.36,1) both; }
.anim-2 { animation: slide-up .45s cubic-bezier(.22,1,.36,1) .08s both; }
.anim-3 { animation: slide-up .45s cubic-bezier(.22,1,.36,1) .16s both; }
.anim-4 { animation: slide-up .45s cubic-bezier(.22,1,.36,1) .24s both; }

/* ── Breadcrumb ──────────────────────────────── */
.breadcrumb-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
    font-size: var(--text-sm);
    color: var(--gray-400);
}
.breadcrumb-row a {
    color: var(--gray-500);
    font-weight: var(--font-medium);
    text-decoration: none;
    transition: color var(--transition-fast);
}
.breadcrumb-row a:hover { color: var(--primary-600); }
.breadcrumb-row .sep { color: var(--gray-300); }
.breadcrumb-row .current { color: var(--gray-700); font-weight: var(--font-semibold); }

/* ── Issue Header ────────────────────────────── */
.issue-header-card {
    background: var(--white);
    border-radius: var(--radius-2xl);
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    margin-bottom: var(--space-5);
}

.issue-header-top {
    padding: var(--space-8);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--gray-100);
}

.issue-badges {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
}

.issue-title-h1 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: var(--font-extrabold);
    color: var(--gray-900);
    line-height: var(--leading-tight);
    letter-spacing: -0.025em;
    margin-bottom: var(--space-3);
}

.issue-meta-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--gray-500);
}

.issue-meta-row span {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
}

.issue-meta-row strong {
    color: var(--gray-700);
}

.issue-dots-btn {
    background: var(--gray-100);
    border: none;
    border-radius: var(--radius-lg);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--gray-600);
    transition: all var(--transition-fast);
    flex-shrink: 0;
}
.issue-dots-btn:hover {
    background: var(--gray-200);
    color: var(--gray-900);
}

/* ── Stats Bar ───────────────────────────────── */
.stats-bar {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    padding: var(--space-4) var(--space-8);
}

.stat-item {
    text-align: center;
    padding: var(--space-4) 0;
    position: relative;
}

.stat-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 25%;
    height: 50%;
    width: 1px;
    background: var(--gray-200);
}

.stat-num {
    font-size: var(--text-2xl);
    font-weight: var(--font-extrabold);
    color: var(--gray-900);
    line-height: 1;
    letter-spacing: -0.03em;
}

.stat-lbl {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: var(--space-1);
}

/* ── Content Sections ────────────────────────── */
.detail-card {
    background: var(--white);
    border-radius: var(--radius-xl);
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    margin-bottom: var(--space-5);
}

.detail-card-header {
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--gray-100);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--gray-50);
}

.detail-card-header h6 {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--gray-500);
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--space-2);
}

.detail-card-header i {
    font-size: var(--text-sm);
    color: var(--gray-400);
}

.detail-card-body {
    padding: var(--space-6);
}

/* ── Description ─────────────────────────────── */
.description-text {
    font-size: var(--text-base);
    color: var(--gray-700);
    line-height: 1.75;
    white-space: pre-wrap;
    margin: 0;
}

/* ── AI Analysis ─────────────────────────────── */
.ai-card {
    background: var(--white);
    border-radius: var(--radius-xl);
    border: 1px solid var(--primary-200);
    box-shadow: var(--shadow-sm), 0 0 0 4px var(--primary-50);
    overflow: hidden;
    margin-bottom: var(--space-5);
}

.ai-card-header {
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--primary-100);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(135deg, var(--primary-50), #f0f4ff);
}

.ai-card-header-left {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-weight: var(--font-semibold);
    font-size: var(--text-sm);
    color: var(--primary-700);
}

.ai-card-header-left i {
    font-size: var(--text-xl);
    color: var(--primary-500);
}

.ai-card-body {
    padding: var(--space-6);
}

.ai-metric {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--gray-50);
    border-radius: var(--radius-lg);
    border: 1px solid var(--gray-100);
}

.ai-metric-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xl);
    flex-shrink: 0;
}

.ai-metric-label {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-400);
    margin-bottom: var(--space-1);
}

.ai-metric-value {
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--gray-900);
    line-height: 1;
}

.ai-metric-sub {
    font-size: var(--text-xs);
    color: var(--gray-400);
    margin-top: 2px;
}

.severity-track {
    height: 6px;
    background: var(--gray-200);
    border-radius: var(--radius-full);
    margin-top: var(--space-2);
    overflow: hidden;
    width: 80px;
}

.severity-fill {
    height: 100%;
    border-radius: var(--radius-full);
    transition: width .6s cubic-bezier(.22,1,.36,1);
}

.ai-reasoning {
    background: linear-gradient(135deg, var(--primary-50), #f8faff);
    border: 1px solid var(--primary-100);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-5);
    font-size: var(--text-sm);
    color: var(--gray-600);
    line-height: 1.65;
}

.ai-reasoning .label {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--primary-500);
    margin-bottom: var(--space-2);
    display: flex;
    align-items: center;
    gap: var(--space-2);
}

/* duplicate warning */
.duplicate-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--white);
    border: 1px solid #fde68a;
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-fast);
    margin-bottom: var(--space-2);
}
.duplicate-item:hover {
    background: #fffbeb;
    border-color: #f59e0b;
    transform: translateX(3px);
    color: inherit;
}
.dup-match-badge {
    background: #fef3c7;
    color: #92400e;
    border: 1px solid #fde68a;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    padding: 2px var(--space-2);
    white-space: nowrap;
}

/* Analysis loading/error states */
.ai-loading {
    text-align: center;
    padding: var(--space-10);
}

.ai-pulse-ring {
    width: 64px;
    height: 64px;
    background: var(--primary-100);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-4);
    position: relative;
}

.ai-pulse-ring::before {
    content: '';
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 2px solid var(--primary-300);
    animation: pulse-ring 1.5s ease-in-out infinite;
}

@@keyframes pulse-ring {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.08); }
}

.ai-pulse-ring i {
    font-size: 1.75rem;
    color: var(--primary-500);
}

/* ── Media Gallery ───────────────────────────── */
.media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-3);
}

/* IMPORTANT: no transform on .media-thumb to avoid breaking position:fixed in the modal */
.media-thumb {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16/10;
    cursor: pointer;
    position: relative;
    background: var(--gray-100);
    /* Use box-shadow transition instead of transform to avoid fixed-position containment */
    transition: box-shadow var(--transition-base);
}

.media-thumb:hover {
    box-shadow: var(--shadow-lg);
}

.media-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Subtle zoom on hover using img transform (safe — modal is not a child of img) */
    transition: transform 0.35s cubic-bezier(.22,1,.36,1);
}

.media-thumb:hover img {
    transform: scale(1.04);
}

.media-thumb .media-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition-fast);
}

.media-thumb:hover .media-overlay {
    background: rgba(0,0,0,0.25);
}

.media-overlay i {
    color: white;
    font-size: 2rem;
    opacity: 0;
    transition: opacity var(--transition-fast);
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
}

.media-thumb:hover .media-overlay i { opacity: 1; }

/* ── Shared Media Lightbox Modal ─────────────────────── */
/*
 * ROOT-LEVEL MODAL — rendered as a direct child of body via JS.
 * This avoids the CSS containment bug where position:fixed is broken
 * when any ancestor has a transform applied.
 */
#sharedMediaModal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.93);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: var(--space-6);
    cursor: zoom-out;
}

#sharedMediaModal.show {
    display: flex;
}

#sharedMediaModal .modal-img-wrap {
    position: relative;
    cursor: default;
    max-width: min(90vw, 1280px);
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: modal-scale-in .22s cubic-bezier(.22,1,.36,1) both;
}

@@keyframes modal-scale-in {
    from { opacity: 0; transform: scale(0.94); }
    to   { opacity: 1; transform: scale(1); }
}

#sharedMediaModal img {
    display: block;
    max-width: 100%;
    max-height: 90vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: var(--radius-lg);
    box-shadow: 0 32px 80px rgba(0,0,0,0.6);
}

#sharedMediaModal .modal-close-btn {
    position: fixed;
    top: 20px;
    right: 20px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    color: white;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--transition-fast);
    backdrop-filter: blur(4px);
    z-index: 10000;
}

#sharedMediaModal .modal-close-btn:hover {
    background: rgba(255,255,255,0.28);
}

#sharedMediaModal .modal-counter {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.5);
    color: rgba(255,255,255,0.75);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    backdrop-filter: blur(4px);
    letter-spacing: 0.04em;
}

#sharedMediaModal .modal-nav-btn {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--transition-fast);
    backdrop-filter: blur(4px);
    z-index: 10000;
}

#sharedMediaModal .modal-nav-btn:hover { background: rgba(255,255,255,0.25); }
#sharedMediaModal .modal-nav-prev { left: 20px; }
#sharedMediaModal .modal-nav-next { right: 20px; }
#sharedMediaModal .modal-nav-btn.hidden { display: none; }

/* ── Video wrapper ───────────────────────────── */
.video-wrapper {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #000;
    aspect-ratio: 16/9;
}

.video-wrapper video {
    width: 100%;
    height: 100%;
    display: block;
}

.video-meta {
    font-size: var(--text-xs);
    color: var(--gray-400);
    margin-top: var(--space-1);
    display: flex;
    align-items: center;
    gap: var(--space-1);
}

/* ── Comment styles ──────────────────────────── */
.comment-form-area {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
}

.comment-avatar-sm {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary-400), var(--primary-600));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
}

.comment-avatar-sm i { color: white; font-size: var(--text-sm); }

.comment-input-wrap {
    flex: 1;
}

.comment-textarea {
    width: 100%;
    border: 2px solid var(--gray-200);
    border-radius: var(--radius-xl);
    padding: var(--space-3) var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    resize: none;
    transition: all var(--transition-fast);
    background: var(--gray-50);
    color: var(--gray-900);
    min-height: 80px;
}

.comment-textarea:focus {
    outline: none;
    border-color: var(--primary-400);
    background: var(--white);
    box-shadow: 0 0 0 4px var(--primary-100);
}

.comment-textarea::placeholder { color: var(--gray-400); }

.comment-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: var(--space-2);
}

.comment-item {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--gray-100);
}

.comment-item:last-child { border-bottom: none; }

.comment-user-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gray-200), var(--gray-300));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: var(--text-sm);
    color: var(--gray-600);
    font-weight: var(--font-bold);
}

.comment-body { flex: 1; }

.comment-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-1);
    flex-wrap: wrap;
}

.comment-author {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--gray-900);
}

.comment-time {
    font-size: var(--text-xs);
    color: var(--gray-400);
}

.comment-text {
    font-size: var(--text-sm);
    color: var(--gray-600);
    line-height: 1.6;
    margin: 0;
}

.comment-delete-btn {
    background: none;
    border: none;
    color: var(--gray-300);
    cursor: pointer;
    padding: var(--space-1);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    font-size: var(--text-sm);
    margin-left: auto;
}
.comment-delete-btn:hover { color: var(--danger); background: var(--danger-light); }

.comment-like-btn,
.comment-dislike-btn {
    background: none;
    border: none;
    color: var(--gray-400);
    cursor: pointer;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    font-size: var(--text-xs);
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
}
.comment-like-btn:hover,
.comment-like-btn.active {
    color: var(--primary);
    background: var(--primary-light);
}
.comment-dislike-btn:hover,
.comment-dislike-btn.active {
    color: var(--danger);
    background: var(--danger-light);
}

/* ── Sidebar ─────────────────────────────────── */
.sidebar-card {
    background: var(--white);
    border-radius: var(--radius-xl);
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    margin-bottom: var(--space-4);
}

.sidebar-card-header {
    padding: var(--space-3) var(--space-5);
    border-bottom: 1px solid var(--gray-100);
    background: var(--gray-50);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--gray-400);
    display: flex;
    align-items: center;
    gap: var(--space-2);
}

.sidebar-card-body {
    padding: var(--space-5);
}

/* ── Vote Section ────────────────────────────── */
.vote-card {
    background: var(--white);
    border-radius: var(--radius-xl);
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    margin-bottom: var(--space-4);
}

.vote-header {
    padding: var(--space-3) var(--space-5);
    border-bottom: 1px solid var(--gray-100);
    background: var(--gray-50);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--gray-400);
    text-align: center;
}

.vote-body {
    padding: var(--space-5);
}

.vote-buttons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
}

.vote-btn {
    border: 2px solid;
    border-radius: var(--radius-xl);
    background: var(--white);
    padding: var(--space-4) var(--space-3);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
}

.vote-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--transition-fast);
}

.vote-btn:hover::before { opacity: 1; }
.vote-btn:active { transform: scale(0.97); }

.vote-btn.upvote {
    border-color: #bbf7d0;
    color: #166534;
}
.vote-btn.upvote::before { background: linear-gradient(135deg, #f0fdf4, #dcfce7); }
.vote-btn.upvote:hover { border-color: var(--success); box-shadow: 0 4px 16px rgba(16,185,129,.2); }
.vote-btn.upvote.active { background: var(--success); color: white; border-color: var(--success); }

.vote-btn.downvote {
    border-color: #fecaca;
    color: #991b1b;
}
.vote-btn.downvote::before { background: linear-gradient(135deg, #fef2f2, #fee2e2); }
.vote-btn.downvote:hover { border-color: var(--danger); box-shadow: 0 4px 16px rgba(239,68,68,.2); }
.vote-btn.downvote.active { background: var(--danger); color: white; border-color: var(--danger); }

.vote-btn i {
    font-size: 1.6rem;
    position: relative;
    z-index: 1;
    transition: transform var(--transition-base);
}
.vote-btn:hover i { transform: scale(1.15); }

.vote-count {
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    position: relative;
    z-index: 1;
    line-height: 1;
}

.vote-score-bar {
    height: 6px;
    background: var(--gray-100);
    border-radius: var(--radius-full);
    overflow: hidden;
}

.vote-score-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--success), #86efac);
    border-radius: var(--radius-full);
    transition: width .5s ease;
}

#voteMessage .alert {
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    border-radius: var(--radius-lg);
    margin-top: var(--space-3);
    text-align: center;
}

/* ── Reporter Card ───────────────────────────── */
.reporter-link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    text-decoration: none;
    padding: var(--space-3);
    border-radius: var(--radius-lg);
    transition: all var(--transition-fast);
    margin-bottom: var(--space-3);
}
.reporter-link:hover {
    background: var(--gray-50);
    color: inherit;
}

.reporter-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 2px solid var(--primary-100);
    overflow: hidden;
    flex-shrink: 0;
}

.reporter-avatar img { width: 100%; height: 100%; object-fit: cover; display: block; }

.reporter-avatar-default {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary-400), var(--primary-700));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 2px solid var(--primary-100);
}

.reporter-avatar-default i { color: white; font-size: 1.4rem; }

.reporter-name {
    font-size: var(--text-base);
    font-weight: var(--font-bold);
    color: var(--gray-900);
    line-height: 1.2;
}

.reporter-stat {
    font-size: var(--text-xs);
    color: var(--gray-400);
    font-weight: var(--font-medium);
    margin-top: 2px;
}

/* ── Status Timeline ─────────────────────────── */
.timeline {
    position: relative;
    padding-left: var(--space-6);
}

.timeline::before {
    content: '';
    position: absolute;
    left: 11px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(180deg, var(--primary-200) 0%, var(--gray-100) 100%);
    border-radius: var(--radius-full);
}

.timeline-item {
    position: relative;
    padding-bottom: var(--space-5);
}

.timeline-item:last-child { padding-bottom: 0; }

.timeline-item::before {
    content: '';
    position: absolute;
    left: -22px;
    top: 5px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--primary-400);
    border: 2px solid var(--white);
    box-shadow: 0 0 0 2px var(--primary-200);
}

.timeline-item:first-child::before {
    background: var(--primary-500);
    box-shadow: 0 0 0 3px var(--primary-100);
}

.timeline-date {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 2px;
}

.timeline-change {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--gray-800);
}

.timeline-arrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--gray-400);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
}

.timeline-comment {
    font-size: var(--text-xs);
    color: var(--gray-500);
    margin-top: 2px;
    line-height: 1.5;
}

/* ── 404 State ───────────────────────────────── */
.not-found-card {
    background: var(--white);
    border-radius: var(--radius-2xl);
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
    text-align: center;
    padding: var(--space-16) var(--space-8);
}

.not-found-icon {
    width: 96px;
    height: 96px;
    background: var(--danger-light);
    border-radius: var(--radius-2xl);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-6);
    font-size: 2.5rem;
    color: var(--danger);
}

/* ── Guest vote display ──────────────────────── */
.vote-display-guest {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
}

.vote-display-box {
    text-align: center;
    padding: var(--space-4);
    border-radius: var(--radius-xl);
    border: 2px solid;
}

.vote-display-box.up-box {
    background: #f0fdf4;
    border-color: #bbf7d0;
    color: #166534;
}

.vote-display-box.down-box {
    background: #fef2f2;
    border-color: #fecaca;
    color: #991b1b;
}

.vote-display-box i { font-size: 1.5rem; display: block; margin-bottom: var(--space-1); }
.vote-display-box strong { font-size: var(--text-2xl); font-weight: var(--font-extrabold); display: block; }
.vote-display-box small { font-size: var(--text-xs); opacity: 0.7; }

.login-prompt {
    text-align: center;
    padding: var(--space-3) var(--space-4);
    background: var(--gray-50);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    color: var(--gray-500);
    border: 1px dashed var(--gray-200);
    margin-top: var(--space-3);
}

.login-prompt a {
    color: var(--primary-600);
    font-weight: var(--font-semibold);
}

/* ── Responsive ──────────────────────────────── */
@@media (max-width: 768px) {
    .issue-header-top { padding: var(--space-5); }
    .stats-bar { padding: var(--space-2) var(--space-4); }
    .detail-card-body { padding: var(--space-4); }
    .ai-card-body { padding: var(--space-4); }
    .sidebar-card-body { padding: var(--space-4); }
    .vote-body { padding: var(--space-4); }
}
</style>

@if (Model.Issue != null)
{
    var statusBadgeClass = Model.Issue.Status switch
    {
        FixIt.Models.Enums.IssueStatus.New => "badge-status-new",
        FixIt.Models.Enums.IssueStatus.Confirmed => "badge-status-confirmed",
        FixIt.Models.Enums.IssueStatus.InProgress => "badge-status-in-progress",
        FixIt.Models.Enums.IssueStatus.Fixed => "badge-status-fixed",
        _ => "bg-secondary"
    };
    var priorityBadgeClass = Model.Issue.Priority switch
    {
        FixIt.Models.Enums.IssuePriority.Low => "badge-priority-low",
        FixIt.Models.Enums.IssuePriority.Medium => "badge-priority-medium",
        FixIt.Models.Enums.IssuePriority.High => "badge-priority-high",
        FixIt.Models.Enums.IssuePriority.Critical => "badge-priority-critical",
        _ => "bg-secondary"
    };
    var severityColor = Model.Analysis != null ? (
        Model.Analysis.EstimatedSeverity >= 8 ? "#ef4444" :
        Model.Analysis.EstimatedSeverity >= 5 ? "#f59e0b" :
        "#10b981") : "#10b981";
    var severityBgClass = Model.Analysis != null ? (
        Model.Analysis.EstimatedSeverity >= 8 ? "bg-danger" :
        Model.Analysis.EstimatedSeverity >= 5 ? "bg-warning" :
        "bg-success") : "bg-success";
    var totalVotes = Model.Issue.Upvotes + Model.Issue.Downvotes;
    var upvotePct = totalVotes > 0 ? (int)Math.Round((double)Model.Issue.Upvotes / totalVotes * 100) : 50;

    <div class="container mt-4 pb-5">

        <!-- ── Breadcrumb ─────────────────────────────── -->
        <div class="breadcrumb-row anim-1">
            <a href="/"><i class="bi bi-house-fill"></i></a>
            <span class="sep">›</span>
            <a href="/Issues">Issues</a>
            <span class="sep">›</span>
            <span class="current">@Model.Issue.Title</span>
        </div>

        <div class="row g-4">

            <!-- ══ MAIN COLUMN ════════════════════════════ -->
            <div class="col-lg-8">

                <!-- ── Issue Header ───────────────────────── -->
                <div class="issue-header-card anim-1">
                    <div class="issue-header-top">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div class="flex-grow-1">
                                <div class="issue-badges">
                                    <span class="badge @statusBadgeClass">@Model.Issue.Status</span>
                                    <span class="badge @priorityBadgeClass">@Model.Issue.Priority Priority</span>
                                </div>
                                <h1 class="issue-title-h1">@Model.Issue.Title</h1>
                                <div class="issue-meta-row">
                                    <span>
                                        <i class="bi bi-person-circle"></i>
                                        <strong>@(Model.Issue.IsAnonymous ? "Anonymous User" : (Model.Issue.Reporter?.DisplayName ?? "Anonymous"))</strong>
                                    </span>
                                    <span>
                                        <i class="bi bi-calendar3"></i>
                                        @Model.Issue.CreatedAt.ToString("MMMM d, yyyy")
                                    </span>
                                    @if (!string.IsNullOrEmpty(Model.Issue.Address))
                                    {
                                        <span>
                                            <i class="bi bi-geo-alt-fill" style="color: var(--danger);"></i>
                                            @Model.Issue.Address
                                        </span>
                                    }
                                </div>
                            </div>
                            @if (User?.Identity?.IsAuthenticated ?? false)
                            {
                                <div class="dropdown flex-shrink-0">
                                    <button class="issue-dots-btn" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <a class="dropdown-item" href="/issues/@Model.Issue.Id/edit">
                                                <i class="bi bi-pencil"></i> Edit Issue
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item text-danger" href="/issues/@Model.Issue.Id/delete">
                                                <i class="bi bi-trash"></i> Delete Issue
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Stats bar -->
                    <div class="stats-bar">
                        <div class="stat-item">
                            <div class="stat-num" id="statViews">@Model.Issue.ViewCount</div>
                            <div class="stat-lbl"><i class="bi bi-eye"></i> Views</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-num">@Model.Issue.CommentCount</div>
                            <div class="stat-lbl"><i class="bi bi-chat"></i> Comments</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-num" id="statScore">@(Model.Issue.Upvotes - Model.Issue.Downvotes)</div>
                            <div class="stat-lbl"><i class="bi bi-arrow-up-circle"></i> Score</div>
                        </div>
                    </div>
                </div>

                <!-- ── Description ────────────────────────── -->
                <div class="detail-card anim-2">
                    <div class="detail-card-header">
                        <h6><i class="bi bi-file-text"></i> Description</h6>
                    </div>
                    <div class="detail-card-body">
                        <p class="description-text">@Model.Issue.Description</p>
                    </div>
                </div>

                <!-- ── Media Gallery (MOVED ABOVE MAP) ──────── -->
                @if (Model.MediaList?.Any() == true)
                {
                    var imageList = Model.MediaList.Where(m => m.Type == FixIt.Models.Enums.MediaType.Image).ToList();
                    var videoList = Model.MediaList.Where(m => m.Type == FixIt.Models.Enums.MediaType.Video).ToList();

                    <div class="detail-card anim-2">
                        <div class="detail-card-header" style="justify-content: space-between;">
                            <h6>
                                <i class="bi bi-images"></i> Media
                                <span class="badge bg-secondary ms-1" style="font-size: 10px;">@Model.MediaList.Count</span>
                            </h6>
                            @if (imageList.Count > 0 && videoList.Count > 0)
                            {
                                <small class="text-muted" style="font-size: var(--text-xs);">
                                    @imageList.Count photo@(imageList.Count != 1 ? "s" : "") · @videoList.Count video@(videoList.Count != 1 ? "s" : "")
                                </small>
                            }
                        </div>
                        <div class="detail-card-body">
                            @if (imageList.Count > 0)
                            {
                                <div class="media-grid" id="mediaGrid">
                                    @for (int idx = 0; idx < imageList.Count; idx++)
                                    {
                                        var media = imageList[idx];
                                        <div class="media-thumb"
                                             data-media-index="@idx"
                                             data-media-src="/api/media/@media.Id"
                                             onclick="openLightbox(@idx)">
                                            <img src="/api/media/@media.Id" alt="Issue photo @(idx + 1)" loading="lazy">
                                            <div class="media-overlay">
                                                <i class="bi bi-arrows-fullscreen"></i>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            @if (videoList.Count > 0)
                            {
                                <div class="@(imageList.Count > 0 ? "mt-4" : "")">
                                    @if (imageList.Count > 0)
                                    {
                                        <div style="font-size: var(--text-xs); font-weight: var(--font-semibold); text-transform: uppercase; letter-spacing: .06em; color: var(--gray-400); margin-bottom: var(--space-3);">
                                            <i class="bi bi-play-circle me-1"></i>Videos
                                        </div>
                                    }
                                    <div class="row g-3">
                                        @foreach (var media in videoList)
                                        {
                                            <div class="col-12 col-sm-6">
                                                <div class="video-wrapper">
                                                    <video controls
                                                           controlsList="nodownload"
                                                           preload="metadata"
                                                           onerror="handleVideoError(this)">
                                                        <source src="/api/media/@media.Id" type="@media.MimeType" />
                                                    </video>
                                                </div>
                                                <div class="video-meta">
                                                    <i class="bi bi-file-play"></i>
                                                    Video · @(media.SizeBytes / (1024 * 1024)) MB
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- ── Location Map (MOVED BELOW MEDIA) ─────── -->
                @if (Model.Issue?.Location?.Coordinates != null && Model.Issue.Location.Coordinates.Values?.Count >= 2)
                {
                    <div class="detail-card anim-3">
                        <div class="detail-card-header">
                            <h6><i class="bi bi-geo-alt"></i> Location</h6>
                        </div>
                        <div class="detail-card-body">
                            <div id="detailMap" 
                                 data-latitude="@Model.Issue.Location.Coordinates.Values[1]"
                                 data-longitude="@Model.Issue.Location.Coordinates.Values[0]"
                                 style="height: 400px; border: 2px solid var(--gray-300); border-radius: 0.75rem; margin-bottom: var(--space-4);"></div>
                            <div class="mt-3 p-3" style="background: var(--gray-50); border-radius: 0.5rem;">
                                <small class="text-muted">
                                    <i class="bi bi-crosshair"></i> Coordinates: 
                                    <span class="text-primary fw-bold">@Model.Issue.Location.Coordinates.Values[1].ToString("F5"), @Model.Issue.Location.Coordinates.Values[0].ToString("F5")</span>
                                </small>
                            </div>
                        </div>
                    </div>
                }

                <!-- ── AI Analysis ────────────────────────── -->
                @if (Model.Analysis != null)
                {
                    <div class="ai-card anim-3">
                        <div class="ai-card-header">
                            <div class="ai-card-header-left">
                                <i class="bi bi-stars"></i>
                                AI Analysis
                            </div>
                            <span class="badge bg-success" style="font-size: var(--text-xs);">
                                <i class="bi bi-check-circle-fill me-1"></i>Complete
                            </span>
                        </div>
                        <div class="ai-card-body">
                            <!-- Metrics row -->
                            <div class="row g-3 mb-4">
                                <div class="col-sm-6">
                                    <div class="ai-metric">
                                        <div class="ai-metric-icon" style="background: var(--info-light); color: var(--info);">
                                            <i class="bi bi-tag-fill"></i>
                                        </div>
                                        <div>
                                            <div class="ai-metric-label">@Localizer["CategoryLabel"]</div>
                                            <div class="ai-metric-value">@Model.Analysis.Category</div>
                                            <div class="ai-metric-sub">@Model.Analysis.ConfidenceScore% confidence</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="ai-metric">
                                        <div class="ai-metric-icon" style="background: @(Model.Analysis.EstimatedSeverity >= 8 ? "var(--danger-light)" : Model.Analysis.EstimatedSeverity >= 5 ? "var(--warning-light)" : "var(--success-light)"); color: @severityColor;">
                                            <i class="bi bi-exclamation-triangle-fill"></i>
                                        </div>
                                        <div>
                                            <div class="ai-metric-label">@Localizer["SeverityLabel"]</div>
                                            <div class="ai-metric-value">@Model.Analysis.EstimatedSeverity <span style="font-size: var(--text-sm); color: var(--gray-400);">/ 10</span></div>
                                            <div class="severity-track">
                                                <div class="severity-fill @severityBgClass" style="width: @(Model.Analysis.EstimatedSeverity * 10)%;"></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @if (Model.Analysis.Keywords?.Any() == true)
                            {
                                <div class="mb-4">
                                    <div style="font-size: var(--text-xs); font-weight: var(--font-semibold); text-transform: uppercase; letter-spacing: .06em; color: var(--gray-400); margin-bottom: var(--space-2);">
                                        <i class="bi bi-key-fill me-1"></i>Keywords
                                    </div>
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var keyword in Model.Analysis.Keywords.Take(6))
                                        {
                                            <span class="badge" style="background: var(--gray-100); color: var(--gray-700); border: 1px solid var(--gray-200); font-size: var(--text-xs); font-weight: var(--font-medium); text-transform: none; letter-spacing: 0;">@keyword</span>
                                        }
                                        @if (Model.Analysis.Keywords.Count > 6)
                                        {
                                            <span class="badge" style="background: var(--gray-100); color: var(--gray-400); border: 1px solid var(--gray-200);">+@(Model.Analysis.Keywords.Count - 6) more</span>
                                        }
                                    </div>
                                </div>
                            }

                            @if (Model.Analysis.SuggestedTags?.Any() == true)
                            {
                                <div class="mb-4">
                                    <div style="font-size: var(--text-xs); font-weight: var(--font-semibold); text-transform: uppercase; letter-spacing: .06em; color: var(--gray-400); margin-bottom: var(--space-2);">
                                        <i class="bi bi-hash me-1"></i>Suggested Tags
                                    </div>
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var tag in Model.Analysis.SuggestedTags.Take(5))
                                        {
                                            <a href="/tags/@tag" class="badge" style="background: var(--primary-50); color: var(--primary-700); border: 1px solid var(--primary-200); text-decoration: none; font-weight: var(--font-medium); text-transform: none; letter-spacing: 0; font-size: var(--text-xs);">#@tag</a>
                                        }
                                        @if (Model.Analysis.SuggestedTags.Count > 5)
                                        {
                                            <span class="badge" style="background: var(--gray-100); color: var(--gray-400); border: 1px solid var(--gray-200);">+@(Model.Analysis.SuggestedTags.Count - 5) more</span>
                                        }
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(Model.Analysis.Reasoning))
                            {
                                <div class="ai-reasoning mb-4">
                                    <div class="label"><i class="bi bi-chat-right-quote-fill"></i> Analysis Notes</div>
                                    @Model.Analysis.Reasoning
                                </div>
                            }

                            @if (Model.Analysis.PotentialDuplicates?.Any() == true)
                            {
                                <div class="mb-3">
                                    <div style="font-size: var(--text-xs); font-weight: var(--font-semibold); text-transform: uppercase; letter-spacing: .06em; color: var(--warning); margin-bottom: var(--space-3); display: flex; align-items: center; gap: var(--space-2);">
                                        <i class="bi bi-exclamation-circle-fill"></i> Similar Issues Detected
                                    </div>
                                    @foreach (var dup in Model.Analysis.PotentialDuplicates.Take(3))
                                    {
                                        <a href="/issues/@dup.IssueId" class="duplicate-item">
                                            <i class="bi bi-link-45deg" style="color: var(--warning); margin-top: 2px; flex-shrink: 0;"></i>
                                            <div class="flex-grow-1">
                                                <div style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--gray-800);">@dup.IssueTitle</div>
                                                <div style="font-size: var(--text-xs); color: var(--gray-500); margin-top: 2px;">@dup.Reason</div>
                                            </div>
                                            <span class="dup-match-badge">@dup.SimilarityScore% match</span>
                                        </a>
                                    }
                                    @if (Model.Analysis.PotentialDuplicates.Count > 3)
                                    {
                                        <div style="font-size: var(--text-xs); color: var(--gray-400); padding-left: var(--space-1);">
                                            +@(Model.Analysis.PotentialDuplicates.Count - 3) more similar issues
                                        </div>
                                    }
                                </div>
                            }

                            <div style="font-size: var(--text-xs); color: var(--gray-400); border-top: 1px solid var(--gray-100); padding-top: var(--space-3); margin-top: var(--space-2);">
                                <i class="bi bi-clock me-1"></i>
                                Analyzed @Model.Analysis.AnalyzedAt.ToString("MMMM d, yyyy 'at' h:mm tt")
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="ai-card anim-3" id="analysisPlaceholder">
                        <div class="ai-card-header">
                            <div class="ai-card-header-left">
                                <i class="bi bi-stars"></i>
                                AI Analysis
                            </div>
                            <span class="badge" style="background: var(--warning-light); color: var(--warning-dark); border: 1px solid #fde68a; font-size: var(--text-xs);">
                                <i class="bi bi-hourglass-split me-1"></i>Pending
                            </span>
                        </div>
                        <div class="ai-card-body">
                            <div class="ai-loading" id="analysisLoading">
                                <div class="ai-pulse-ring">
                                    <i class="bi bi-stars"></i>
                                </div>
                                <div style="font-weight: var(--font-semibold); color: var(--gray-700); margin-bottom: var(--space-1);">Generating AI Analysis...</div>
                                <div style="font-size: var(--text-sm); color: var(--gray-400);">This may take 15–30 seconds on first load</div>
                            </div>
                            <div id="analysisError" style="display: none; text-align: center; padding: var(--space-8);">
                                <div style="width: 56px; height: 56px; background: var(--warning-light); border-radius: var(--radius-xl); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4); font-size: 1.5rem; color: var(--warning);">
                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                </div>
                                <div style="font-weight: var(--font-semibold); color: var(--gray-700); margin-bottom: var(--space-1);">@Localizer["AnalysisUnavailable"]</div>
                                <div style="font-size: var(--text-sm); color: var(--gray-400); margin-bottom: var(--space-4);">Could not generate AI analysis at this time.</div>
                                <button type="button" class="btn btn-primary btn-sm" onclick="retryAnalysis('@Model.Id')">
                                    <i class="bi bi-arrow-clockwise me-1"></i>Retry
                                </button>
                            </div>
                        </div>
                    </div>
                }

                <!-- ── Comments ───────────────────────────── -->
                <div class="detail-card anim-4">
                    <div class="detail-card-header" style="display: flex; align-items: center; justify-content: space-between;">
                        <h6 style="margin: 0;">
                            <i class="bi bi-chat-dots-fill"></i> Comments
                            <span style="color: var(--gray-700); font-weight: var(--font-bold); text-transform: none; letter-spacing: 0; font-size: var(--text-sm);">(@Model.Issue?.CommentCount)</span>
                        </h6>
