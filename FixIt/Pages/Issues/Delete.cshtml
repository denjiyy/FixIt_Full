@page "/issues/{id}/delete"
@model DeleteIssueModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["DeleteIssue"];
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/issue-manage.css" asp-append-version="true" />
}

<div class="issue-manage-page">
    <section class="issue-manage-hero issue-manage-hero--danger">
        <a href="/issues/@Model.Id" class="issue-manage-back">
            <i class="bi bi-chevron-left"></i> @Localizer["BackToIssue"]
        </a>
        <p class="issue-manage-eyebrow"><i class="bi bi-shield-exclamation"></i> Destructive Action</p>
        <h1 class="issue-manage-title">@Localizer["DeleteIssue"]</h1>
        <p class="issue-manage-copy">@Localizer["ThisActionCannotBeUndone"] Review the issue one last time and confirm only if the report should no longer remain publicly accessible.</p>
    </section>

    @if (Model.Issue != null)
    {
        <div class="issue-manage-layout">
            <section class="issue-manage-card">
                <div class="issue-manage-card__header">
                    <h2 class="issue-manage-card__title"><i class="bi bi-file-earmark-x"></i> @Localizer["IssueToDeleteHeading"]</h2>
                    <p class="issue-manage-card__copy">This summary helps confirm you are deleting the correct report.</p>
                </div>
                <div class="issue-manage-card__body issue-manage-stack">
                    <div class="issue-manage-summary">
                        <div class="issue-manage-meta">
                            <div class="issue-manage-meta-item">
                                <span>@Localizer["Title"]</span>
                                <strong>@Model.Issue.Title</strong>
                            </div>
                            <div class="issue-manage-meta-item">
                                <span>@Localizer["CreatedBy"]</span>
                                <strong>@(Model.Issue.Reporter?.DisplayName ?? Localizer["AnonymousUser"])</strong>
                            </div>
                            <div class="issue-manage-meta-item">
                                <span>@Localizer["OnDate"]</span>
                                <strong>@Model.Issue.CreatedAt.ToString("MMMM d, yyyy h:mm tt")</strong>
                            </div>
                        </div>
                    </div>

                    <div class="issue-manage-highlight issue-manage-highlight--danger">
                        <strong>@Localizer["Warning"]</strong> @Localizer["DeletingThisIssue"]
                    </div>

                    <div class="issue-manage-card">
                        <div class="issue-manage-card__body">
                            <h3 class="h6 fw-bold mb-3">@Localizer["WhenYouDeleteThisIssueColon"]</h3>
                            <ul class="issue-manage-checklist">
                                <li>@Localizer["ItWillNoLongerAppearInIssueListings"]</li>
                                <li>@Localizer["OtherUsersWillNotBeSeeIt"]</li>
                                <li>@Localizer["CommentsAndVotesWillBePreserved"]</li>
                                <li>@Localizer["AdminsCanRestoreDeletedIssues"]</li>
                            </ul>
                        </div>
                    </div>

                    <div class="issue-manage-note">
                        <i class="bi bi-info-circle me-2"></i>
                        @Localizer["Note"] @Localizer["IfYouDeleteThisByMistake"]
                    </div>

                    <form method="post" class="issue-manage-actions">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-2"></i>@Localizer["DeleteIssuePermanently"]
                        </button>
                        <a href="/issues/@Model.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-2"></i>@Localizer["CancelDeletion"]
                        </a>
                    </form>
                </div>
            </section>
        </div>
    }
    else
    {
        <section class="issue-manage-card">
            <div class="issue-manage-card__body">
                <div class="issue-manage-empty">
                    <i class="bi bi-exclamation-triangle"></i>
                    <h2 class="h4 mb-2">@Localizer["IssueNotFoundMessage"]</h2>
                    <p class="mb-4">The issue could not be loaded for deletion.</p>
                    <a href="/issues" class="btn btn-outline-primary">@Localizer["GoToIssuesList"]</a>
                </div>
            </div>
        </section>
    }
</div>
