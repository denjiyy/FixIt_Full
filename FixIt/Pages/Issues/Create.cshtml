@page "/issues/create"
@model CreateIssueModel
@{
    ViewData["Title"] = "Report an Issue";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Header -->
            <div class="mb-4">
                <h1 class="h2">
                    <i class="bi bi-exclamation-circle"></i> Report a New Issue
                </h1>
                <p class="lead text-muted">Help improve your community by reporting civic problems</p>
            </div>

            <!-- Form -->
            <form method="post" enctype="multipart/form-data" class="needs-validation">
                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                <!-- Title -->
                <div class="mb-3">
                    <label asp-for="Input.Title" class="form-label">Issue Title *</label>
                    <input asp-for="Input.Title" class="form-control form-control-lg" 
                           placeholder="e.g., Pothole on Main Street" />
                    <span asp-validation-for="Input.Title" class="text-danger small"></span>
                    <small class="text-muted">Be specific and descriptive (3-200 characters)</small>
                </div>

                <!-- Description -->
                <div class="mb-3">
                    <label asp-for="Input.Description" class="form-label">Description *</label>
                    <textarea asp-for="Input.Description" class="form-control" rows="5"
                              placeholder="Provide details about the issue, when you noticed it, and any relevant information..."
                              maxlength="5000"></textarea>
                    <span asp-validation-for="Input.Description" class="text-danger small"></span>
                    <small class="text-muted">10-5000 characters | <span id="descriptionCount">0</span>/5000</small>
                </div>

                <!-- Location Section -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-geo-alt"></i> Location</h6>
                    </div>
                    <div class="card-body">
                        <!-- Address -->
                        <div class="mb-3">
                            <label asp-for="Input.Address" class="form-label">Address (Optional)</label>
                            <input asp-for="Input.Address" class="form-control" 
                                   placeholder="e.g., 123 Main St, Downtown" />
                            <small class="text-muted">Help others locate the exact spot</small>
                        </div>

                        <!-- Map -->
                        <div class="mb-3">
                            <label class="form-label">Select Location on Map *</label>
                            <div id="map" style="height: 400px; border: 1px solid #dee2e6; border-radius: 0.375rem; margin-bottom: 10px;"></div>
                            <input type="hidden" asp-for="Input.Latitude" id="latitude" />
                            <input type="hidden" asp-for="Input.Longitude" id="longitude" />
                            <small class="text-muted d-block mt-2">
                                Coordinates: <span id="coordsDisplay">Click on the map</span>
                            </small>
                        </div>

                        <!-- City & Neighborhood -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.CityId" class="form-label">City *</label>
                                <select asp-for="Input.CityId" class="form-select" id="citySelect">
                                    <option value="">Select a city...</option>
                                    @* Populated by JavaScript *@
                                </select>
                                <span asp-validation-for="Input.CityId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.NeighborhoodId" class="form-label">Neighborhood *</label>
                                <select asp-for="Input.NeighborhoodId" class="form-select" id="neighborhoodSelect">
                                    <option value="">Select a neighborhood...</option>
                                    @* Populated by JavaScript *@
                                </select>
                                <span asp-validation-for="Input.NeighborhoodId" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Photos Section -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-image"></i> Photos (Optional)</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Upload Photos</label>
                            <div class="upload-area border-2 border-dashed rounded p-4 text-center cursor-pointer" 
                                 id="uploadArea" style="border-color: #dee2e6; cursor: pointer; transition: all 0.3s;">
                                <i class="bi bi-cloud-upload" style="font-size: 2rem; color: #6c757d;"></i>
                                <p class="mb-0 text-muted">Drag and drop photos here or click to select</p>
                                <small class="text-muted">Max 5 photos, 5MB each (JPG, PNG)</small>
                                <input type="file" id="photoInput" multiple accept="image/*" style="display: none;" />
                            </div>
                            <div id="photoPreview" class="row mt-3"></div>
                        </div>
                    </div>
                </div>

                <!-- Tags Section -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-tags"></i> Categories (Optional)</h6>
                    </div>
                    <div class="card-body">
                        <label class="form-label">Select relevant categories</label>
                        <div id="tagsContainer" class="mb-3">
                            @* Populated by JavaScript *@
                        </div>
                        <small class="text-muted">Help others find similar issues</small>
                    </div>
                </div>

                <!-- Actions -->
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle"></i> Report Issue
                    </button>
                    <a href="/issues" class="btn btn-outline-secondary btn-lg">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <script>
        // Initialize map
        let map;
        let markerLayer;
        let selectedLat = 40.7128;
        let selectedLng = -74.0060;

        document.addEventListener('DOMContentLoaded', function() {
            // Map initialization
            map = L.map('map').setView([selectedLat, selectedLng], 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

            map.on('click', function(e) {
                selectedLat = e.latlng.lat;
                selectedLng = e.latlng.lng;
                updateMarker();
            });

            // Character counter
            const descInput = document.getElementById('Input_Description');
            if (descInput) {
                descInput.addEventListener('input', function() {
                    document.getElementById('descriptionCount').textContent = this.value.length;
                });
            }

            // Photo upload
            setupPhotoUpload();
            setupTags();
        });

        function updateMarker() {
            document.getElementById('latitude').value = selectedLat;
            document.getElementById('longitude').value = selectedLng;
            document.getElementById('coordsDisplay').textContent = `${selectedLat.toFixed(4)}, ${selectedLng.toFixed(4)}`;

            if (markerLayer) {
                map.removeLayer(markerLayer);
            }
            markerLayer = L.marker([selectedLat, selectedLng]).addTo(map);
        }

        function setupPhotoUpload() {
            const uploadArea = document.getElementById('uploadArea');
            const photoInput = document.getElementById('photoInput');
            const photoPreview = document.getElementById('photoPreview');

            uploadArea.addEventListener('click', () => photoInput.click());
            uploadArea.addEventListener('dragover', (e) => {
                e.preventDefault();
                uploadArea.style.backgroundColor = '#f8f9fa';
            });
            uploadArea.addEventListener('dragleave', () => {
                uploadArea.style.backgroundColor = 'transparent';
            });
            uploadArea.addEventListener('drop', (e) => {
                e.preventDefault();
                photoInput.files = e.dataTransfer.files;
                displayPhotos();
            });

            photoInput.addEventListener('change', displayPhotos);
        }

        function displayPhotos() {
            const photoInput = document.getElementById('photoInput');
            const photoPreview = document.getElementById('photoPreview');
            photoPreview.innerHTML = '';

            Array.from(photoInput.files).slice(0, 5).forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const col = document.createElement('div');
                    col.className = 'col-6 col-md-4 mb-3';
                    col.innerHTML = `
                        <div class="position-relative">
                            <img src="${e.target.result}" class="img-fluid rounded" alt="Photo">
                            <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0" 
                                    onclick="removePhoto(${index})">×</button>
                        </div>
                    `;
                    photoPreview.appendChild(col);
                };
                reader.readAsDataURL(file);
            });
        }

        function removePhoto(index) {
            const photoInput = document.getElementById('photoInput');
            const files = Array.from(photoInput.files);
            files.splice(index, 1);
            // Note: Can't directly modify FileList, would need to reselect
            const dataTransfer = new DataTransfer();
            files.forEach(file => dataTransfer.items.add(file));
            photoInput.files = dataTransfer.files;
            displayPhotos();
        }

        function setupTags() {
            // TODO: Fetch tags from API and populate
            const tagsContainer = document.getElementById('tagsContainer');
            const tags = ['Infrastructure', 'Safety', 'Environment', 'Traffic', 'Maintenance'];
            
            tags.forEach(tag => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'btn btn-outline-primary btn-sm me-2 mb-2';
                btn.textContent = tag;
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    btn.classList.toggle('active');
                    btn.classList.toggle('btn-primary');
                });
                tagsContainer.appendChild(btn);
            });
        }
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />
}
