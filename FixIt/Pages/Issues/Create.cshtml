@page "/issues/create"
@model CreateIssueModel
@{
    ViewData["Title"] = "Report an Issue";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <!-- Header -->
            <div class="text-center mb-5">
                <div class="mb-3">
                    <i class="bi bi-exclamation-circle text-gradient" style="font-size: 3.5rem;"></i>
                </div>
                <h1 class="h2 mb-2">Report a New Issue</h1>
                <p class="lead text-muted">Help improve your community by reporting civic problems</p>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Warning"] != null)
            {
                <div class="alert alert-warning alert-dismissible fade show">
                    @TempData["Warning"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Form -->
            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                <!-- Basic Info Card -->
                <div class="card mb-4" style="border: none;">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-info-circle"></i> Basic Information</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Input.Title" class="form-label">Issue Title *</label>
                            <input asp-for="Input.Title" class="form-control form-control-lg" 
                                   placeholder="e.g., Pothole on Main Street near the library" />
                            <span asp-validation-for="Input.Title" class="text-danger small"></span>
                            <small class="text-muted">Be specific and descriptive (3-200 characters)</small>
                        </div>

                        <div class="mb-0">
                            <label asp-for="Input.Description" class="form-label">Description *</label>
                            <textarea asp-for="Input.Description" class="form-control" rows="6" id="descriptionInput"
                                      placeholder="Provide details about the issue, when you noticed it, severity, and any relevant information..."
                                      maxlength="5000"></textarea>
                            <span asp-validation-for="Input.Description" class="text-danger small"></span>
                            <div class="d-flex justify-content-between mt-1">
                                <small class="text-muted">10-5000 characters</small>
                                <small class="text-muted"><span id="descriptionCount">0</span>/5000</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Location Card -->
                <div class="card mb-4" style="border: none;">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-geo-alt"></i> Location</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Input.Address" class="form-label">Address (Optional)</label>
                            <input asp-for="Input.Address" class="form-control" 
                                   placeholder="e.g., 123 Main St, Downtown" />
                            <small class="text-muted">Help others locate the exact spot</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Select Location on Map *</label>
                            <div id="map" style="height: 400px; border: 2px solid var(--gray-300); border-radius: 0.75rem;"></div>
                            <input type="hidden" asp-for="Input.Latitude" id="latitude" />
                            <input type="hidden" asp-for="Input.Longitude" id="longitude" />
                            <span asp-validation-for="Input.Latitude" class="text-danger small"></span>
                            <span asp-validation-for="Input.Longitude" class="text-danger small"></span>
                            <div class="mt-2 p-2" style="background: var(--gray-100); border-radius: 0.5rem;">
                                <small class="text-muted">
                                    <i class="bi bi-cursor"></i> Coordinates: <span id="coordsDisplay" class="text-primary fw-bold">Click on the map</span>
                                </small>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.CityId" class="form-label">City *</label>
                            <select asp-for="Input.CityId" asp-items="Model.Cities" class="form-select" id="citySelect">
                                <option value="">Select a city...</option>
                            </select>
                            <span asp-validation-for="Input.CityId" class="text-danger small"></span>
                            <small class="text-muted">Select the city where the issue is located</small>
                        </div>
                    </div>
                </div>

                <!-- Photos Card -->
                <div class="card mb-4" style="border: none;">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-image"></i> Photos (Optional)</h6>
                    </div>
                    <div class="card-body">
                        <div class="upload-area p-5 text-center" id="uploadArea" 
                             style="border: 2px dashed var(--gray-400); border-radius: 0.75rem; cursor: pointer; transition: all 0.3s;">
                            <i class="bi bi-cloud-upload" style="font-size: 3rem; color: var(--primary);"></i>
                            <p class="mb-2 fw-bold">Drag and drop photos here or click to select</p>
                            <small class="text-muted">Max 5 photos, 5MB each (JPG, PNG, WEBP, GIF)</small>
                            <input type="file" asp-for="Input.Photos" id="photoInput" multiple accept="image/*" style="display: none;" />
                        </div>
                        <div id="photoPreview" class="row mt-3"></div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="card" style="border: none; background: var(--gray-100);">
                    <div class="card-body">
                        <div class="d-flex gap-3 justify-content-between align-items-center flex-wrap">
                            <small class="text-muted">
                                <i class="bi bi-shield-check"></i> Your report will be visible to the public and city officials
                            </small>
                            <div class="d-flex gap-2">
                                <a href="/issues" class="btn btn-outline-secondary">
                                    <i class="bi bi-x-circle"></i> Cancel
                                </a>
                                <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
                                    <i class="bi bi-check-circle"></i> Report Issue
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <script>
        let map, markerLayer;
        let selectedLat = 42.6977, selectedLng = 23.3219; // Default to Sofia
        let selectedFiles = [];

        document.addEventListener('DOMContentLoaded', function() {
            // Map initialization
            map = L.map('map').setView([selectedLat, selectedLng], 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);

            map.on('click', function(e) {
                selectedLat = e.latlng.lat;
                selectedLng = e.latlng.lng;
                updateMarker();
            });

            // Character counter
            const descInput = document.getElementById('descriptionInput');
            if (descInput) {
                descInput.addEventListener('input', function() {
                    document.getElementById('descriptionCount').textContent = this.value.length;
                });
                // Initialize counter
                document.getElementById('descriptionCount').textContent = descInput.value.length;
            }

            // Photo upload
            setupPhotoUpload();
            
            // Initial marker
            updateMarker();
        });

        function updateMarker() {
            document.getElementById('latitude').value = selectedLat;
            document.getElementById('longitude').value = selectedLng;
            document.getElementById('coordsDisplay').textContent = `${selectedLat.toFixed(5)}, ${selectedLng.toFixed(5)}`;

            if (markerLayer) {
                map.removeLayer(markerLayer);
            }
            markerLayer = L.marker([selectedLat, selectedLng]).addTo(map);
        }

        function setupPhotoUpload() {
            const uploadArea = document.getElementById('uploadArea');
            const photoInput = document.getElementById('photoInput');

            uploadArea.addEventListener('click', () => photoInput.click());
            
            uploadArea.addEventListener('dragover', (e) => {
                e.preventDefault();
                uploadArea.style.borderColor = 'var(--primary)';
                uploadArea.style.backgroundColor = 'var(--primary-light)';
            });
            
            uploadArea.addEventListener('dragleave', () => {
                uploadArea.style.borderColor = 'var(--gray-400)';
                uploadArea.style.backgroundColor = 'transparent';
            });
            
            uploadArea.addEventListener('drop', (e) => {
                e.preventDefault();
                uploadArea.style.borderColor = 'var(--gray-400)';
                uploadArea.style.backgroundColor = 'transparent';
                
                const dt = new DataTransfer();
                for (let file of e.dataTransfer.files) {
                    dt.items.add(file);
                }
                photoInput.files = dt.files;
                displayPhotos();
            });

            photoInput.addEventListener('change', displayPhotos);
        }

        function displayPhotos() {
            const photoInput = document.getElementById('photoInput');
            const photoPreview = document.getElementById('photoPreview');
            photoPreview.innerHTML = '';

            if (!photoInput.files || photoInput.files.length === 0) {
                return;
            }

            const files = Array.from(photoInput.files).slice(0, 5); // Max 5 photos

            files.forEach((file, index) => {
                // Validate file
                if (!file.type.startsWith('image/')) {
                    alert(`${file.name} is not an image file`);
                    return;
                }

                if (file.size > 5 * 1024 * 1024) {
                    alert(`${file.name} is larger than 5MB`);
                    return;
                }

                const reader = new FileReader();
                reader.onload = (e) => {
                    const col = document.createElement('div');
                    col.className = 'col-6 col-md-4 mb-3';
                    col.innerHTML = `
                        <div class="position-relative">
                            <img src="${e.target.result}" class="img-fluid rounded shadow-sm" 
                                 style="width: 100%; height: 200px; object-fit: cover;">
                            <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 m-2" 
                                    onclick="removePhoto(${index})" style="padding: 0.25rem 0.5rem;">
                                <i class="bi bi-x"></i>
                            </button>
                            <div class="position-absolute bottom-0 start-0 m-2">
                                <span class="badge bg-dark">${formatFileSize(file.size)}</span>
                            </div>
                        </div>
                    `;
                    photoPreview.appendChild(col);
                };
                reader.readAsDataURL(file);
            });

            if (photoInput.files.length > 5) {
                alert('Only the first 5 photos will be uploaded');
            }
        }

        function removePhoto(index) {
            const photoInput = document.getElementById('photoInput');
            const dataTransfer = new DataTransfer();
            
            Array.from(photoInput.files).forEach((file, i) => {
                if (i !== index) {
                    dataTransfer.items.add(file);
                }
            });
            
            photoInput.files = dataTransfer.files;
            displayPhotos();
        }

        function formatFileSize(bytes) {
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
            return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
        }
    </script>
}