@page "/issues/create"
@using FixIt.Models.AI
@using FixIt.Models.Enums
@model CreateIssueModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["CreateAnIssue"];
    ViewData["RequiresMap"] = true;
    ViewData["BodyClass"] = "page-issue-create";
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/issues-shared.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/issue-create.css" asp-append-version="true" />
}

<div class="issue-page issue-create-page" id="issueCreateRoot"
     data-default-lat="42.6977"
     data-default-lng="23.3219"
     data-title-too-short="@Localizer["CreateTitleValidation"]"
     data-description-too-short="@Localizer["CreateDescriptionValidation"]"
     data-city-required="@Localizer["PleaseSelectACity"]"
     data-invalid-file-type="@Localizer["InvalidFileType"]"
     data-image-limit="@Localizer["ImageUploadLimit"]"
     data-video-limit="@Localizer["VideoUploadLimit"]"
     data-only-first-files="@Localizer["OnlyFirstTenFiles"]"
     data-no-suggestions="@Localizer["NoSuggestionsAvailableYet"]"
     data-not-started="@Localizer["NotStarted"]"
     data-location-pending="@Localizer["LocationPending"]"
     data-no-media="@Localizer["NoMediaSelected"]"
     data-files-selected-label="@Localizer["FilesSelectedLabel"]"
     data-submit-label="@Localizer["SubmitReport"]"
     data-submitting-label="@Localizer["SubmittingReport"]"
     data-ai-suggestion-loading="Analyzing issue draft..."
     data-ai-suggestion-ready="AI suggestions are ready. You can accept or override them."
     data-ai-suggestion-unavailable="AI suggestions are temporarily unavailable."
     data-ai-suggestion-idle="AI suggestions will appear after you add enough details."
     data-ai-generated-label="AI-generated"
     data-fallback-label="Rule-based suggestion"
     data-confidence-label="Confidence"
     data-apply-suggestion-label="Suggestions applied">
    <header class="issue-page-header">
        <div class="issue-page-header__content">
            <span class="issue-page-header__eyebrow">
                <i class="bi bi-send-plus"></i>
                @Localizer["ReportIssue"]
            </span>
            <h1 class="issue-page-header__title">@Localizer["CreateAnIssue"]</h1>
            <p class="issue-page-header__copy">@Localizer["ReportAndTrackInfrastructure"]</p>
        </div>

        <div class="issue-page-actions">
            <a asp-page="/Issues/Index" class="app-link-btn">
                <i class="bi bi-list-check"></i>
                <span>@Localizer["BrowseIssues"]</span>
            </a>
        </div>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning rounded-4 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Warning"]
        </div>
    }
    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
    {
        <div asp-validation-summary="All" class="alert alert-danger rounded-4 mb-4" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
        </div>
    }

    <div class="create-layout">
        <form method="post" enctype="multipart/form-data" id="issueForm" class="create-main" novalidate>
            <div id="createLiveRegion" class="visually-hidden" aria-live="polite"></div>

            <section class="issue-surface create-stepper">
                <div class="create-stepper__item is-active" data-step-item="details">
                    <span class="create-stepper__bubble">1</span>
                    <div>
                        <strong>@Localizer["Details"]</strong>
                        <span>@Localizer["BasicInformation"]</span>
                    </div>
                </div>
                <div class="create-stepper__item" data-step-item="location">
                    <span class="create-stepper__bubble">2</span>
                    <div>
                        <strong>@Localizer["Location"]</strong>
                        <span>@Localizer["PinTheExactSpotOnTheMap"]</span>
                    </div>
                </div>
                <div class="create-stepper__item" data-step-item="media">
                    <span class="create-stepper__bubble">3</span>
                    <div>
                        <strong>@Localizer["Media"]</strong>
                        <span>@Localizer["PhotosAndVideos"]</span>
                    </div>
                </div>
            </section>

            <section class="issue-surface create-card">
                <div class="create-card__header">
                    <div>
                        <span class="create-card__eyebrow">01</span>
                        <h2>@Localizer["BasicInformation"]</h2>
                        <p>@Localizer["GiveThemeAClearTitleAndDescription"]</p>
                    </div>
                </div>

                <div class="create-card__body">
                    <div class="create-field">
                        <label for="issueTitle" class="create-label">@Localizer["IssueTitle"]</label>
                        <input asp-for="Input.Title"
                               class="create-input create-input--lg"
                               id="issueTitle"
                               maxlength="200"
                               placeholder="@Localizer["ExamplePotholeOnMainStreet"]" />
                        <div class="create-field__meta">
                            <span class="create-field__hint">@Localizer["SpecificAndDescriptive"]</span>
                            <span class="create-counter" id="titleCounter"></span>
                        </div>
                        <span asp-validation-for="Input.Title" class="create-validation" id="titleValidation"></span>
                    </div>

                    <div class="create-field">
                        <label for="issueDescription" class="create-label">@Localizer["Description"]</label>
                        <textarea asp-for="Input.Description"
                                  class="create-textarea"
                                  id="issueDescription"
                                  rows="7"
                                  maxlength="5000"
                                  placeholder="@Localizer["DescribeTheIssueInDetail"]"></textarea>
                        <div class="create-field__meta">
                            <span class="create-field__hint">@Localizer["MinimumTenCharacters"]</span>
                            <span class="create-counter" id="descriptionCounter"></span>
                        </div>
                        <span asp-validation-for="Input.Description" class="create-validation" id="descriptionValidation"></span>
                    </div>

                    <div class="create-field">
                        <label asp-for="Input.TagNames" class="create-label">
                            @Localizer["TagsLabel"]
                            <span class="create-label__optional">@Localizer["Optional"]</span>
                        </label>
                        <input asp-for="Input.TagNames"
                               class="create-input"
                               id="tagInput"
                               placeholder="@Localizer["TagsPlaceholder"]"
                               aria-label="@Localizer["TagsLabel"]" />
                        <span class="create-field__hint">@Localizer["TagsHint"]</span>
                    </div>

                    <div class="create-field">
                        <div class="create-suggestions__header">
                            <span class="create-label">@Localizer["SuggestedTagsLabel"]</span>
                            <span class="create-field__hint">@Localizer["SuggestedTagsHint"]</span>
                        </div>
                        <div id="suggestedTags" class="create-suggestions"></div>
                    </div>

                    <section class="create-field create-field--ai">
                        <div class="create-ai-panel" id="aiIssueSuggestionPanel" aria-live="polite">
                            <div class="create-ai-panel__header">
                                <span class="create-label">Smart Issue Classification</span>
                                <span class="create-ai-badge" id="aiSuggestionSourceBadge">AI-generated</span>
                            </div>
                            <div class="create-ai-skeleton d-none" id="aiSuggestionSkeleton" aria-hidden="true">
                                <span class="app-skeleton"></span>
                                <span class="app-skeleton"></span>
                            </div>
                            <p class="create-field__hint mb-2" id="aiSuggestionStatus">AI suggestions will appear after you add enough details.</p>
                            <div class="create-ai-confidence d-none" id="aiSuggestionConfidenceWrap">
                                <div class="create-ai-confidence__head">
                                    <span class="create-field__hint mb-0">Confidence</span>
                                    <strong id="aiSuggestionConfidenceText">0%</strong>
                                </div>
                                <div class="create-ai-confidence__track" aria-hidden="true">
                                    <span class="create-ai-confidence__fill" id="aiSuggestionConfidenceBar"></span>
                                </div>
                            </div>
                        </div>

                        <div class="create-ai-grid">
                            <div class="create-field">
                                <label asp-for="Input.Category" class="create-label">@Localizer["CategoryLabel"]</label>
                                <select asp-for="Input.Category" class="create-select" id="issueCategory">
                                    <option value="">Select category</option>
                                    @foreach (var category in Enum.GetValues<IssueCategory>())
                                    {
                                        <option value="@category">@category</option>
                                    }
                                </select>
                            </div>

                            <div class="create-field">
                                <label asp-for="Input.Priority" class="create-label">@Localizer["SeverityLabel"]</label>
                                <select asp-for="Input.Priority" class="create-select" id="issuePriority">
                                    <option value="">Select severity</option>
                                    @foreach (var priority in Enum.GetValues<IssuePriority>())
                                    {
                                        <option value="@priority">@priority</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="create-field">
                            <label asp-for="Input.Department" class="create-label">Department</label>
                            <input asp-for="Input.Department"
                                   class="create-input"
                                   id="issueDepartment"
                                   maxlength="120"
                                   placeholder="Suggested municipal department" />
                        </div>
                    </section>
                </div>
            </section>

            <section class="issue-surface create-card">
                <div class="create-card__header">
                    <div>
                        <span class="create-card__eyebrow">02</span>
                        <h2>@Localizer["Location"]</h2>
                        <p>@Localizer["PinTheExactSpotOnTheMapDescription"]</p>
                    </div>
                </div>

                <div class="create-card__body">
                    <div class="create-field">
                        <label for="issueAddress" class="create-label">
                            @Localizer["AddressLabel"]
                            <span class="create-label__optional">@Localizer["Optional"]</span>
                        </label>
                        <input asp-for="Input.Address"
                               class="create-input"
                               id="issueAddress"
                               placeholder="@Localizer["AddressAutoFilled"]" />
                        <span class="create-field__hint">@Localizer["ReverseGeocodedFromYourMapPin"]</span>
                    </div>

                    <div class="create-field">
                        <label class="create-label" for="map">@Localizer["PinOnMap"]</label>
                        <div class="create-map">
                            <div id="map" class="create-map__canvas" aria-label="@Localizer["PinOnMap"]"></div>
                            <div class="create-map__meta">
                                <div>
                                    <strong>@Localizer["Coordinates"]</strong>
                                    <span id="coordsDisplay">@Localizer["ClickTheMapToPlacePin"]</span>
                                </div>
                            </div>
                        </div>
                        <input asp-for="Input.Latitude" id="latitude" type="hidden" />
                        <input asp-for="Input.Longitude" id="longitude" type="hidden" />
                        <span asp-validation-for="Input.Latitude" class="create-validation"></span>
                    </div>

                    <div class="create-field">
                        <label for="baseCity" class="create-label">@Localizer["CityOrCities"]</label>
                        <select asp-for="Input.CityId" class="create-select" id="baseCity">
                            <option value="">@Localizer["SelectACity"]</option>
                            @foreach (var city in Model.Cities)
                            {
                                <option value="@city.Value">@city.Text</option>
                            }
                        </select>
                        <span class="create-field__hint">@Localizer["UsuallyAutoSelectedFromYourMapPin"]</span>
                        <span asp-validation-for="Input.CityId" class="create-validation" id="cityValidation"></span>
                    </div>
                </div>
            </section>

            <section class="issue-surface create-card">
                <div class="create-card__header create-card__header--split">
                    <div>
                        <span class="create-card__eyebrow">03</span>
                        <h2>@Localizer["PhotosAndVideos"]</h2>
                        <p>@Localizer["VisualEvidenceHelpsOfficials"]</p>
                    </div>
                    <span class="create-chip">@Localizer["Optional"]</span>
                </div>

                <div class="create-card__body">
                    <div class="create-upload" id="uploadZone" role="button" tabindex="0" aria-controls="mediaInput">
                        <div class="create-upload__icon">
                            <i class="bi bi-cloud-arrow-up-fill"></i>
                        </div>
                        <h3>@Localizer["DropFilesHereOrBrowseToUpload"]</h3>
                        <p>@Localizer["UploadFileInfo"]</p>
                        <div class="create-upload__types">
                            <span>JPG</span>
                            <span>PNG</span>
                            <span>WEBP</span>
                            <span>MP4</span>
                            <span>MOV</span>
                            <span>WEBM</span>
                        </div>
                        <input asp-for="Input.Photos"
                               id="mediaInput"
                               class="d-none"
                               type="file"
                               multiple
                               accept="image/*,video/*" />
                    </div>

                    <div class="media-preview-grid" id="mediaPreviewGrid"></div>
                </div>
            </section>

            <footer class="issue-surface create-submit">
                <div class="create-submit__meta">
                    <i class="bi bi-shield-check"></i>
                    <span>@Localizer["VisibleToPublicAndCityOfficials"]</span>
                </div>
                <div class="create-submit__actions">
                    <a href="/issues" class="app-link-btn">
                        <i class="bi bi-x-circle"></i>
                        <span>@Localizer["Cancel"]</span>
                    </a>
                    <button type="submit" class="nav-report-btn" id="baseSubmitBtn">
                        <i class="bi bi-send-fill"></i>
                        <span>@Localizer["SubmitReport"]</span>
                    </button>
                </div>
            </footer>
        </form>

        <aside class="create-sidebar">
            <section class="issue-surface create-sidebar-card">
                <h2>@Localizer["ProgressOverview"]</h2>
                <ul class="create-progress-list">
                    <li data-progress-item="details">
                        <span class="create-progress-list__dot"></span>
                        <div>
                            <strong>@Localizer["Details"]</strong>
                            <span>@Localizer["GiveThemeAClearTitleAndDescription"]</span>
                        </div>
                    </li>
                    <li data-progress-item="location">
                        <span class="create-progress-list__dot"></span>
                        <div>
                            <strong>@Localizer["Location"]</strong>
                            <span>@Localizer["PinTheExactSpotOnTheMapDescription"]</span>
                        </div>
                    </li>
                    <li data-progress-item="media">
                        <span class="create-progress-list__dot"></span>
                        <div>
                            <strong>@Localizer["Media"]</strong>
                            <span>@Localizer["UploadFileInfo"]</span>
                        </div>
                    </li>
                </ul>
            </section>

            <section class="issue-surface create-sidebar-card">
                <h2>@Localizer["ReportSnapshot"]</h2>
                <dl class="create-summary">
                    <div>
                        <dt>@Localizer["Title"]</dt>
                        <dd id="summaryTitleValue">@(string.IsNullOrWhiteSpace(Model.Input.Title) ? Localizer["NotStarted"] : Model.Input.Title)</dd>
                    </div>
                    <div>
                        <dt>@Localizer["CityOrCities"]</dt>
                        <dd id="summaryCityValue">@(string.IsNullOrWhiteSpace(Model.Input.CityId) ? Localizer["NotStarted"] : Model.Cities.FirstOrDefault(c => c.Value == Model.Input.CityId)?.Text ?? Localizer["NotStarted"])</dd>
                    </div>
                    <div>
                        <dt>@Localizer["Location"]</dt>
                        <dd id="summaryLocationValue">@Localizer["LocationPending"]</dd>
                    </div>
                    <div>
                        <dt>@Localizer["Media"]</dt>
                        <dd id="summaryMediaValue">@Localizer["NoMediaSelected"]</dd>
                    </div>
                </dl>
            </section>

            <section class="issue-surface create-sidebar-card">
                <h2>@Localizer["BeforeYouSubmit"]</h2>
                <ul class="create-checklist">
                    <li>@Localizer["BeAsSpecificAsPossible"]</li>
                    <li>@Localizer["ReverseGeocodedFromYourMapPin"]</li>
                    <li>@Localizer["VisualEvidenceHelpsOfficials"]</li>
                </ul>
            </section>
        </aside>
    </div>
</div>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/modules/issue-create.js" asp-append-version="true" defer></script>
}
