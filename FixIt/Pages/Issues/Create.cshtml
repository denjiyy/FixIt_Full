@page "/issues/create"
@using FixIt.Models.AI
@using FixIt.Models.Enums
@model CreateIssueModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["CreateAnIssue"];
    ViewData["RequiresMap"] = true;
    ViewData["BodyClass"] = "page-issue-create";

    // Design priority palette: Low = emerald, Medium = gold, High = amber, Critical = red.
    string SeverityColor(IssuePriority p) => p switch
    {
        IssuePriority.Low => "var(--success)",
        IssuePriority.Medium => "var(--warning)",
        IssuePriority.High => "var(--accent)",
        IssuePriority.Critical => "var(--danger)",
        _ => "var(--neutral-400)"
    };
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/issues-shared.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/issue-create.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/issue-report.css" asp-append-version="true" />
}

<div class="issue-page issue-report-page calm" id="issueCreateRoot"
     data-default-lat="42.6977"
     data-default-lng="23.3219"
     data-title-too-short="@Localizer["CreateTitleValidation"]"
     data-description-too-short="@Localizer["CreateDescriptionValidation"]"
     data-city-required="@Localizer["PleaseSelectACity"]"
     data-invalid-file-type="@Localizer["InvalidFileType"]"
     data-image-limit="@Localizer["ImageUploadLimit"]"
     data-video-limit="@Localizer["VideoUploadLimit"]"
     data-only-first-files="@Localizer["OnlyFirstTenFiles"]"
     data-no-suggestions="@Localizer["NoSuggestionsAvailableYet"]"
     data-not-started="@Localizer["NotStarted"]"
     data-location-pending="@Localizer["LocationPending"]"
     data-no-media="@Localizer["NoMediaSelected"]"
     data-files-selected-label="@Localizer["FilesSelectedLabel"]"
     data-submit-label="@Localizer["SubmitReport"]"
     data-submitting-label="@Localizer["SubmittingReport"]"
     data-ai-suggestion-loading="Analyzing issue draft..."
     data-ai-suggestion-ready="AI suggestions are ready. You can accept or override them."
     data-ai-suggestion-unavailable="AI suggestions are temporarily unavailable."
     data-ai-suggestion-idle="AI suggestions will appear after you add enough details."
     data-ai-generated-label="AI-generated"
     data-fallback-label="Rule-based suggestion"
     data-confidence-label="Confidence"
     data-apply-suggestion-label="Suggestions applied"
     data-duplicate-matches-label="@Localizer["DuplicateReminderMatchesLabel"]"
     data-duplicate-reminder-live="@Localizer["DuplicateReminderLive"]">

    <div class="report">
        <a href="/issues" class="backlink">
            <i class="bi bi-arrow-left"></i>
            <span>@Localizer["Cancel"]</span>
        </a>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success rounded-4 mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            </div>
        }
        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning rounded-4 mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Warning"]
            </div>
        }
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
        {
            <div asp-validation-summary="All" class="alert alert-danger rounded-4 mb-4" role="alert">
                <i class="bi bi-exclamation-circle-fill me-2"></i>
            </div>
        }

        <div class="report__grid">
            <form method="post" enctype="multipart/form-data" id="issueForm" class="report__form" novalidate>
                <div id="createLiveRegion" class="visually-hidden" aria-live="polite"></div>

                <div class="report__formhead">
                    <span class="eyebrow"><i class="bi bi-stars"></i>@Localizer["AiAssistedLabel"]</span>
                    <h1>@Localizer["CreateAnIssue"]</h1>
                    <p>@Localizer["ReportFlowSubtitle"]</p>
                </div>

                @* ---------- Photos ---------- *@
                <div class="fld">
                    <span class="fld__label">@Localizer["PhotosAndVideos"] <span class="fld__optional">@Localizer["Optional"]</span></span>
                    <div class="create-upload" id="uploadZone" role="button" tabindex="0" aria-controls="mediaInput">
                        <div class="create-upload__icon">
                            <i class="bi bi-camera-fill"></i>
                        </div>
                        <h3>@Localizer["DropFilesHereOrBrowseToUpload"]</h3>
                        <p>@Localizer["UploadFileInfo"]</p>
                        <div class="create-upload__types">
                            <span>JPG</span>
                            <span>PNG</span>
                            <span>WEBP</span>
                            <span>MP4</span>
                            <span>MOV</span>
                        </div>
                        <input asp-for="Input.Photos"
                               id="mediaInput"
                               class="d-none"
                               type="file"
                               multiple
                               accept="image/*,video/*" />
                    </div>
                    <div class="media-preview-grid" id="mediaPreviewGrid"></div>
                </div>

                @* ---------- Title ---------- *@
                <div class="fld">
                    <label class="fld__label" for="issueTitle">@Localizer["IssueTitle"]</label>
                    <input asp-for="Input.Title"
                           class="rinput"
                           id="issueTitle"
                           maxlength="200"
                           placeholder="@Localizer["ExamplePotholeOnMainStreet"]" />
                    <div class="fld__meta">
                        <span asp-validation-for="Input.Title" class="create-validation" id="titleValidation"></span>
                        <span class="create-counter" id="titleCounter"></span>
                    </div>
                </div>

                @* ---------- Description (with AI hint) ---------- *@
                <div class="fld">
                    <label class="fld__label" for="issueDescription">@Localizer["Description"]</label>
                    <div class="rinput--area-wrap">
                        <textarea asp-for="Input.Description"
                                  class="rinput rinput--area"
                                  id="issueDescription"
                                  rows="5"
                                  maxlength="5000"
                                  placeholder="@Localizer["DescribeTheIssueInDetail"]"></textarea>
                    </div>
                    <div class="fld__meta">
                        <span asp-validation-for="Input.Description" class="create-validation" id="descriptionValidation"></span>
                        <span class="create-counter" id="descriptionCounter"></span>
                    </div>
                </div>

                @* ---------- AI suggestion panel ---------- *@
                <div class="create-ai-panel" id="aiIssueSuggestionPanel" aria-live="polite">
                    <div class="create-ai-panel__header">
                        <span class="fld__label"><i class="bi bi-magic"></i> @Localizer["SmartClassificationLabel"]</span>
                        <span class="create-ai-badge" id="aiSuggestionSourceBadge">AI-generated</span>
                    </div>
                    <div class="create-ai-skeleton d-none" id="aiSuggestionSkeleton" aria-hidden="true">
                        <span class="app-skeleton"></span>
                        <span class="app-skeleton"></span>
                    </div>
                    <p class="create-field__hint mb-2" id="aiSuggestionStatus">AI suggestions will appear after you add enough details.</p>
                    <div class="create-ai-confidence d-none" id="aiSuggestionConfidenceWrap">
                        <div class="create-ai-confidence__head">
                            <span class="create-field__hint mb-0">Confidence</span>
                            <strong id="aiSuggestionConfidenceText">0%</strong>
                        </div>
                        <div class="create-ai-confidence__track" aria-hidden="true">
                            <span class="create-ai-confidence__fill" id="aiSuggestionConfidenceBar"></span>
                        </div>
                    </div>
                </div>

                @* ---------- Possible-duplicate reminder (advisory, never blocks submit) ---------- *@
                <div class="alert alert-warning d-none mt-3" id="duplicateWarningPanel" role="status" aria-live="polite">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-exclamation-triangle-fill me-2 mt-1" aria-hidden="true"></i>
                        <div class="flex-grow-1">
                            <strong>@Localizer["DuplicateReminderHeading"]</strong>
                            <p class="mb-2 small">@Localizer["DuplicateReminderIntro"]</p>
                            <ul class="mb-0 ps-3" id="duplicateWarningList"></ul>
                        </div>
                    </div>
                </div>

                @* ---------- Category pick-grid (synced to bound select) ---------- *@
                <div class="fld">
                    <span class="fld__label">@Localizer["CategoryLabel"]</span>
                    <div class="pickgrid" id="categoryPick" role="group" aria-label="@Localizer["CategoryLabel"]">
                        @foreach (var category in Enum.GetValues<IssueCategory>())
                        {
                            <button type="button" class="pick" data-value="@category">@category</button>
                        }
                    </div>
                    <select asp-for="Input.Category" class="report-bound-select" id="issueCategory" tabindex="-1" aria-hidden="true">
                        <option value="">@Localizer["SelectCategoryOption"]</option>
                        @foreach (var category in Enum.GetValues<IssueCategory>())
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>

                @* ---------- Severity segmented control (synced to bound select) ---------- *@
                <div class="fld">
                    <span class="fld__label">@Localizer["SeverityLabel"]</span>
                    <div class="seg" id="severitySeg" role="group" aria-label="@Localizer["SeverityLabel"]">
                        @foreach (var priority in Enum.GetValues<IssuePriority>())
                        {
                            <button type="button" data-value="@priority">
                                <span class="seg__dot" style="background:@SeverityColor(priority)"></span>@priority
                            </button>
                        }
                    </div>
                    <select asp-for="Input.Priority" class="report-bound-select" id="issuePriority" tabindex="-1" aria-hidden="true">
                        <option value="">@Localizer["SelectSeverityOption"]</option>
                        @foreach (var priority in Enum.GetValues<IssuePriority>())
                        {
                            <option value="@priority">@priority</option>
                        }
                    </select>
                </div>

                @* ---------- Department (AI-suggested) ---------- *@
                <div class="fld">
                    <label class="fld__label" for="issueDepartment">@Localizer["DepartmentLabel"] <span class="fld__optional">@Localizer["Optional"]</span></label>
                    <input asp-for="Input.Department"
                           class="rinput"
                           id="issueDepartment"
                           maxlength="120"
                           placeholder="@Localizer["SuggestedDepartmentPlaceholder"]" />
                </div>

                @* ---------- Tags ---------- *@
                <div class="fld">
                    <label class="fld__label" for="tagInput">@Localizer["TagsLabel"] <span class="fld__optional">@Localizer["Optional"]</span></label>
                    <input asp-for="Input.TagNames"
                           class="rinput"
                           id="tagInput"
                           placeholder="@Localizer["TagsPlaceholder"]"
                           aria-label="@Localizer["TagsLabel"]" />
                    <div id="suggestedTags" class="report-suggestions"></div>
                </div>

                @* ---------- Address + City ---------- *@
                <div class="fld">
                    <label class="fld__label" for="issueAddress">@Localizer["AddressLabel"] <span class="fld__optional">@Localizer["Optional"]</span></label>
                    <input asp-for="Input.Address"
                           class="rinput"
                           id="issueAddress"
                           placeholder="@Localizer["AddressAutoFilled"]" />
                </div>

                <div class="fld">
                    <label class="fld__label" for="baseCity">@Localizer["CityOrCities"]</label>
                    <select asp-for="Input.CityId" class="rinput rselect" id="baseCity">
                        <option value="">@Localizer["SelectACity"]</option>
                        @foreach (var city in Model.Cities)
                        {
                            <option value="@city.Value">@city.Text</option>
                        }
                    </select>
                    <span asp-validation-for="Input.CityId" class="create-validation" id="cityValidation"></span>
                </div>

                <input asp-for="Input.Latitude" id="latitude" type="hidden" />
                <input asp-for="Input.Longitude" id="longitude" type="hidden" />

                @* ---------- Submit row ---------- *@
                <div class="report__submit">
                    <label class="anon">
                        <input asp-for="Input.IsAnonymous" type="checkbox" />
                        <span>@Localizer["ReportAnonymouslyLabel"]</span>
                    </label>
                    <button type="submit" class="nav-report-btn" id="baseSubmitBtn">
                        <i class="bi bi-send-plus"></i>
                        <span>@Localizer["SubmitReport"]</span>
                    </button>
                </div>
            </form>

            <aside class="report__map">
                <div class="report__maptop glass">
                    <i class="bi bi-geo-alt-fill"></i>
                    <div>
                        <strong>@Localizer["PinnedLocation"]</strong>
                        <small id="coordsDisplay">@Localizer["ClickTheMapToPlacePin"]</small>
                    </div>
                </div>
                <div id="map" class="report__mapcanvas" aria-label="@Localizer["PinOnMap"]"></div>
            </aside>
        </div>
    </div>
</div>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/modules/issue-create.js" asp-append-version="true" defer></script>
    <script src="~/js/pages/report-controls.js" asp-append-version="true" defer></script>
}
