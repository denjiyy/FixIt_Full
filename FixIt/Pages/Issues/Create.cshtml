@page "/issues/create"
@model CreateIssueModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["CreateAnIssue"];
}

<link rel="stylesheet" href="~/css/pages/issue-create.css" />

<div class="container mt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">

            <!-- ── Hero Header ───────────────────────────── -->
            <div class="create-hero anim-1">
                <div class="create-hero-icon">
                    <i class="bi bi-plus-circle-fill"></i>
                </div>
                <h1>@Localizer["CreateAnIssue"]</h1>
                <p>@Localizer["ReportAndTrackInfrastructure"]</p>
            </div>

            <!-- ── Step Tracker ──────────────────────────── -->
            <div class="step-tracker anim-1">
                <div class="step-item">
                    <div class="step-bubble active" id="step1Bubble">1</div>
                    <span class="step-label active" id="step1Label">@Localizer["Details"]</span>
                </div>
                <div class="step-connector" id="conn1"></div>
                <div class="step-item">
                    <div class="step-bubble" id="step2Bubble">2</div>
                    <span class="step-label" id="step2Label">@Localizer["Location"]</span>
                </div>
                <div class="step-connector" id="conn2"></div>
                <div class="step-item">
                    <div class="step-bubble" id="step3Bubble">3</div>
                    <span class="step-label" id="step3Label">@Localizer["Media"]</span>
                </div>
            </div>

            <!-- ── Alerts ────────────────────────────────── -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Warning"] != null)
            {
                <div class="alert alert-warning alert-dismissible fade show rounded-3 mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Warning"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- ── Info Banner ───────────────────────────── -->
            <div class="info-banner anim-2">
                <i class="bi bi-shield-check-fill"></i>
                <div>
                        <strong>@Localizer["YourReportWillBeReviewed"]</strong>
                        @Localizer["BeAsSpecificAsPossible"]
            <!-- ── Form ──────────────────────────────────── -->
            <form method="post" enctype="multipart/form-data" id="issueForm" novalidate>

                <!-- Hidden master fields for ASP.NET model binding -->
                <input type="hidden" asp-for="Input.Title"       id="masterTitle" />
                <input type="hidden" asp-for="Input.Description" id="masterDescription" />
                <input type="hidden" asp-for="Input.CityId"      id="masterCity" />
                <input type="hidden" asp-for="Input.Latitude"    id="masterLat" />
                <input type="hidden" asp-for="Input.Longitude"   id="masterLng" />

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
                {
                    <div asp-validation-summary="All" class="alert alert-danger rounded-3 mb-4" role="alert">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                    </div>
                }

                <!-- ── STEP 1 · Basic Info ─────────────────────── -->
                <div class="create-card anim-2">
                    <div class="create-card-header">
                        <div class="create-card-step-num">1</div>
                        <div class="create-card-header-text">
                            <h6>@Localizer["BasicInformation"]</h6>
                            <small>@Localizer["GiveThemeAClearTitleAndDescription"]</small>
                        </div>
                    </div>
                    <div class="create-card-body">

                        <!-- Title -->
                        <div class="mb-5">
                            <label for="baseTitle" class="create-label">
                                @Localizer["IssueTitle"] <span class="required-star">*</span>
                            </label>
                            <input type="text"
                                   class="create-input input-lg"
                                   id="baseTitle"
                                   name="baseTitle"
                                   placeholder="@Localizer["ExamplePotholeOnMainStreet"]"
                                   maxlength="200" />
                            <span asp-validation-for="Input.Title" class="text-danger" style="font-size: var(--text-xs);"></span>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="input-hint">
                                    <i class="bi bi-pencil"></i>
                                    @Localizer["SpecificAndDescriptive"]
                                </span>
                                <span class="char-counter" id="titleCounterDisplay">0 / 200</span>
                            </div>
                        </div>

                        <!-- Description -->
                        <div class="mb-0">
                            <label for="baseDescription" class="create-label">
                                @Localizer["Description"] <span class="required-star">*</span>
                            </label>
                            <textarea class="create-textarea"
                                      id="baseDescription"
                                      name="baseDescription"
                                      rows="6"
                                      maxlength="5000"
                                      placeholder="@Localizer["DescribeTheIssueInDetail"]"></textarea>
                            <span class="text-danger" style="font-size: var(--text-xs);"></span>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="input-hint">
                                    <i class="bi bi-chat-text"></i>
                                    @Localizer["MinimumTenCharacters"]
                                </span>
                                <span class="char-counter" id="descCounterDisplay">0 / 5000</span>
                            </div>
                        </div>

                        <!-- Tags input (manual + AI suggestions) -->
                        <div class="mb-5">
                            <label for="tagInput" class="create-label">
                                Tags <span class="optional-tag">Optional</span>
                            </label>
                            <input type="text"
                                   class="create-input"
                                   id="tagInput"
                                   placeholder="e.g. pothole, safety, street-light"
                                   aria-label="Tag names" />
                            <input type="hidden" asp-for="Input.TagNames" id="masterTags" />
                            <div class="input-hint"><i class="bi bi-tags"></i> Comma-separated tags (will attempt to map existing tags)</div>
                        </div>

                        <div class="mb-5">
                            <div style="font-size: var(--text-xs); font-weight: var(--font-semibold); text-transform: uppercase; color: var(--gray-400); margin-bottom: var(--space-2);">
                                <i class="bi bi-robot"></i> AI suggested tags
                            </div>
                            <div id="suggestedTags" class="d-flex flex-wrap gap-2"></div>
                        </div>

                    </div>
                </div>

                <!-- ── STEP 2 · Location ───────────────────────── -->
                <div class="create-card anim-3">
                    <div class="create-card-header">
                        <div class="create-card-step-num">2</div>
                        <div class="create-card-header-text">
                            <h6>@Localizer["LocationSectionHeading"]</h6>
                            <small>@Localizer["PinTheExactSpotOnTheMapDescription"]</small>
                        </div>
                    </div>
                    <div class="create-card-body">

                        <!-- Address -->
                        <div class="mb-5">
                            <label asp-for="Input.Address" class="create-label">
                                @Localizer["Address"] <span class="optional-tag">@Localizer["Optional"]</span>
                            </label>
                            <input asp-for="Input.Address"
                                   class="create-input"
                                   placeholder="@Localizer["AddressAutoFilled"]" />
                            <span class="input-hint"><i class="bi bi-magic"></i> @Localizer["ReverseGeocodedFromYourMapPin"]</span>
                        </div>

                        <!-- Map -->
                        <div class="mb-5">
                            <label class="create-label">
                                @Localizer["PinOnMap"] <span class="required-star">*</span>
                            </label>
                            <div class="map-container">
                                <div id="map"></div>
                                <div class="coords-pill">
                                    <i class="bi bi-crosshair"></i>
                                    <span>@Localizer["Coordinates"]</span>
                                    <strong id="coordsDisplay">@Localizer["ClickTheMapToPlacePin"]</strong>
                                </div>
                            </div>
                            <input type="hidden" asp-for="Input.Latitude"  id="latitude" />
                            <input type="hidden" asp-for="Input.Longitude" id="longitude" />
                            <span asp-validation-for="Input.Latitude"  class="text-danger" style="font-size: var(--text-xs);"></span>
                        </div>

                        <!-- City -->
                        <div class="mb-0">
                            <label for="baseCity" class="create-label">
                                @Localizer["CityOrCities"] <span class="required-star">*</span>
                            </label>
                            <select class="create-select" id="baseCity" name="baseCity">
                                <option value="">@Localizer["SelectACity"]</option>
                                @foreach (var city in Model.Cities)
                                {
                                    <option value="@city.Value">@city.Text</option>
                                }
                            </select>
                            <span class="input-hint"><i class="bi bi-building"></i> @Localizer["UsuallyAutoSelectedFromYourMapPin"]</span>
                        </div>

                    </div>
                </div>

                <!-- ── STEP 3 · Media ──────────────────────────── -->
                <div class="create-card anim-4">
                    <div class="create-card-header">
                        <div class="create-card-step-num">3</div>
                        <div class="create-card-header-text">
                            <h6>@Localizer["PhotosAndVideos"]</h6>
                            <small>@Localizer["VisualEvidenceHelpsOfficials"]</small>
                        </div>
                        <span class="badge" style="background: var(--gray-100); color: var(--gray-500); font-size: var(--text-xs); border: 1px solid var(--gray-200); font-weight: var(--font-semibold);">@Localizer["Optional"]</span>
                    </div>
                    <div class="create-card-body">

                        <div class="upload-zone" id="uploadZone">
                            <div class="upload-zone-icon">
                                <i class="bi bi-cloud-arrow-up-fill"></i>
                            </div>
                            <div class="upload-zone-title">
                                @Localizer["DropFilesHereOrBrowseToUpload"]
                            </div>
                            <div class="upload-zone-sub">
                                @Localizer["UploadFileInfo"]
                            </div>
                            <div class="upload-type-chips">
                                <span class="upload-chip"><i class="bi bi-image"></i> JPG</span>
                                <span class="upload-chip"><i class="bi bi-image"></i> PNG</span>
                                <span class="upload-chip"><i class="bi bi-image"></i> WEBP</span>
                                <span class="upload-chip"><i class="bi bi-play-circle"></i> MP4</span>
                                <span class="upload-chip"><i class="bi bi-play-circle"></i> MOV</span>
                                <span class="upload-chip"><i class="bi bi-play-circle"></i> WEBM</span>
                            </div>
                            <input type="file"
                                   asp-for="Input.Photos"
                                   id="mediaInput"
                                   multiple
                                   accept="image/*,video/*"
                                   style="display: none;" />
                        </div>

                        <div class="media-preview-grid" id="mediaPreviewGrid"></div>

                    </div>
                </div>

                <!-- ── Submit Footer ───────────────────────────── -->
                <div class="submit-footer anim-5">
                    <div class="submit-footer-meta">
                        <i class="bi bi-shield-check-fill"></i>
                        <span>@Localizer["VisibleToPublicAndCityOfficials"]</span>
                    </div>
                    <div class="submit-actions">
                        <a href="/issues" class="btn-cancel">
                            <i class="bi bi-x"></i> @Localizer["Cancel"]
                        </a>
                        <button type="submit" class="btn-submit" id="baseSubmitBtn">
                            <i class="bi bi-send-fill"></i>
                            @Localizer["SubmitReport"]
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
    /* ── State ───────────────────────────────────────── */
    let map, markerLayer;
    let selectedLat = 42.6977, selectedLng = 23.3219;
    let geocodingCache = {};
    let lastGeocodingRequest = 0;
    let selectedCityFromGeocode = null;
    const GEOCODING_THROTTLE_MS = 500;

    /* ── Init ────────────────────────────────────────── */
    document.addEventListener('DOMContentLoaded', () => {
        // Reset submit button (fixes "Processing..." stuck state on back-nav)
        const submitBtn = document.getElementById('baseSubmitBtn');
        if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="bi bi-send-fill"></i> Submit Report';
        }

        document.getElementById('latitude').value  = selectedLat;
        document.getElementById('longitude').value = selectedLng;

        initMap();
        initCharCounter('baseTitle',       'titleCounterDisplay', 200);
        initCharCounter('baseDescription', 'descCounterDisplay',  5000);
        initUploadZone();
        initStepTracker();
    });

    /* ── Step Tracker (progressive validation feedback) ─ */
    function initStepTracker() {
        const titleEl = document.getElementById('baseTitle');
        const descEl  = document.getElementById('baseDescription');
        const cityEl  = document.getElementById('baseCity');

        function updateSteps() {
            const step1Done = titleEl.value.trim().length >= 3 && descEl.value.trim().length >= 10;
            const step2Done = !!(cityEl.value && document.getElementById('latitude').value);

            setStepState(1, step1Done ? 'done' : 'active');
            setStepState(2, step1Done ? (step2Done ? 'done' : 'active') : 'idle');
            setStepState(3, step2Done ? 'active' : 'idle');

            document.getElementById('conn1').classList.toggle('done', step1Done);
            document.getElementById('conn2').classList.toggle('done', step2Done);
        }

        titleEl.addEventListener('input', updateSteps);
        descEl.addEventListener('input',  updateSteps);
        cityEl.addEventListener('change', updateSteps);
    }

    function setStepState(num, state) {
        const bubble = document.getElementById(`step${num}Bubble`);
        const label  = document.getElementById(`step${num}Label`);

        bubble.className = 'step-bubble';
        label.className  = 'step-label';

        if (state === 'done') {
            bubble.classList.add('done');
            bubble.innerHTML = '<i class="bi bi-check-lg" style="font-size:.75rem;"></i>';
            label.classList.add('done');
        } else if (state === 'active') {
            bubble.classList.add('active');
            bubble.textContent = num;
            label.classList.add('active');
        } else {
            bubble.textContent = num;
        }
    }

    /* ── Character Counter ───────────────────────────── */
    function initCharCounter(inputId, displayId, max) {
        const input   = document.getElementById(inputId);
        const display = document.getElementById(displayId);
        if (!input || !display) return;

        function update() {
            const len = input.value.length;
            display.textContent = `${len} / ${max}`;
            display.className = 'char-counter';
            if (len >= max)         display.classList.add('at-limit');
            else if (len >= max * .85) display.classList.add('near-limit');
        }

        input.addEventListener('input', update);
        update();
    }

    /* ── Map ─────────────────────────────────────────── */
    function initMap() {
        map = L.map('map').setView([selectedLat, selectedLng], 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        map.on('click', (e) => {
            selectedLat = e.latlng.lat;
            selectedLng = e.latlng.lng;
            updateMarker();
        });

        updateMarker();
    }

    function updateMarker() {
        document.getElementById('latitude').value  = selectedLat;
        document.getElementById('longitude').value = selectedLng;
        document.getElementById('coordsDisplay').textContent = `${selectedLat.toFixed(5)}, ${selectedLng.toFixed(5)}`;

        if (markerLayer) map.removeLayer(markerLayer);
        markerLayer = L.marker([selectedLat, selectedLng]).addTo(map);

        reverseGeocode(selectedLat, selectedLng);
    }

    async function reverseGeocode(lat, lng) {
        const key = `${lat.toFixed(4)},${lng.toFixed(4)}`;
        if (geocodingCache[key]) {
            applyGeocode(geocodingCache[key]);
            return;
        }

        const now = Date.now();
        if (now - lastGeocodingRequest < GEOCODING_THROTTLE_MS) return;
        lastGeocodingRequest = now;

        try {
            const res  = await fetch(`/api/geocoding/reverse?latitude=${lat}&longitude=${lng}`, {
                headers: { Accept: 'application/json' }
            });
            if (!res.ok) return;
            const data = await res.json();
            if (data?.address) {
                geocodingCache[key] = data;
                applyGeocode(data);
            }
        } catch (e) {
            console.error('Geocoding error:', e);
        }
    }

    function applyGeocode(data) {
        const addressInput = document.querySelector('input[name="Input.Address"]');
        if (addressInput) addressInput.value = data.address || '';

        if (data.cityId?.trim()) {
            const sel = document.getElementById('baseCity');
            if (sel) {
                sel.value = data.cityId;
                selectedCityFromGeocode = data.cityId;
            }
        }

        // Trigger step tracker update
        document.getElementById('baseCity').dispatchEvent(new Event('change'));
    }

    /* ── Upload Zone ─────────────────────────────────── */
    function initUploadZone() {
        const zone  = document.getElementById('uploadZone');
        const input = document.getElementById('mediaInput');

        zone.addEventListener('click', () => input.click());

        zone.addEventListener('dragover', (e) => {
            e.preventDefault();
            zone.classList.add('drag-over');
        });
        zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
        zone.addEventListener('drop', (e) => {
            e.preventDefault();
            zone.classList.remove('drag-over');
            const dt = new DataTransfer();
            for (const f of e.dataTransfer.files) dt.items.add(f);
            input.files = dt.files;
            renderPreviews();
        });

        input.addEventListener('change', renderPreviews);
    }

    function renderPreviews() {
        const input = document.getElementById('mediaInput');
        const grid  = document.getElementById('mediaPreviewGrid');
        grid.innerHTML = '';

        if (!input.files?.length) return;

        const files = Array.from(input.files).slice(0, 10);
        const MAX_IMG = 5  * 1024 * 1024;
        const MAX_VID = 100 * 1024 * 1024;

        files.forEach((file, idx) => {
            const isImg = file.type.startsWith('image/');
            const isVid = file.type.startsWith('video/');
            if (!isImg && !isVid) { alert(`${file.name} is not a valid file type`); return; }

            const maxSize = isImg ? MAX_IMG : MAX_VID;
            if (file.size > maxSize) {
                alert(`${file.name} exceeds the ${maxSize / 1024 / 1024} MB limit`);
                return;
            }

            const item = document.createElement('div');
            item.className = 'media-preview-item';

            const removeBtn = `<button type="button" class="media-preview-remove" onclick="removeMedia(${idx})" title="Remove">
                <i class="bi bi-x"></i>
            </button>`;
            const badge = `<span class="media-preview-badge">${formatFileSize(file.size)}</span>`;

            if (isImg) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    item.innerHTML = `<img src="${e.target.result}" alt="${file.name}">${removeBtn}${badge}`;
                };
                reader.readAsDataURL(file);
            } else {
                const ext = file.name.split('.').pop().toUpperCase();
                item.innerHTML = `
                    <div class="preview-video-placeholder">
                        <i class="bi bi-play-circle-fill"></i>
                        <span>${ext}</span>
                    </div>
                    ${removeBtn}${badge}`;
            }

            grid.appendChild(item);
        });

        if (input.files.length > 10) alert('Only the first 10 files will be uploaded.');
    }

    function removeMedia(index) {
        const input = document.getElementById('mediaInput');
        const dt    = new DataTransfer();
        Array.from(input.files).forEach((f, i) => { if (i !== index) dt.items.add(f); });
        input.files = dt.files;
        renderPreviews();
    }

    function formatFileSize(bytes) {
        if (bytes < 1024)        return bytes + ' B';
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function normalizeTags(tagString) {
        return Array.from(new Set(
            (tagString || '')
                .split(',')
                .map(t => t.trim().toLowerCase())
                .filter(t => t.length > 0)
        ));
    }

    function renderSuggestedTags(tags) {
        const container = document.getElementById('suggestedTags');
        if (!container) return;

        container.innerHTML = '';

        if (!tags || tags.length === 0) {
            container.innerHTML = '<small style="color: var(--gray-400);">No suggestions available yet.</small>';
            return;
        }

        tags.slice(0, 8).forEach(tag => {
            const pill = document.createElement('button');
            pill.type = 'button';
            pill.className = 'btn btn-sm btn-outline-primary';
            pill.textContent = tag;
            pill.style = 'text-transform:none; margin-bottom:0.25rem;';
            pill.addEventListener('click', () => {
                const input = document.getElementById('tagInput');
                if (!input) return;

                const current = normalizeTags(input.value);
                if (!current.includes(tag.toLowerCase())) {
                    current.push(tag.toLowerCase());
                    input.value = current.join(', ');
                }
            });
            container.appendChild(pill);
        });
    }

    let tagSuggestionTimer = null;
    function requestTagSuggestions() {
        const title = document.getElementById('baseTitle')?.value.trim() ?? '';
        const description = document.getElementById('baseDescription')?.value.trim() ?? '';

        if (tagSuggestionTimer) {
            clearTimeout(tagSuggestionTimer);
        }

        if (title.length < 3 && description.length < 10) {
            renderSuggestedTags([]);
            return;
        }

        tagSuggestionTimer = setTimeout(async () => {
            try {
                const response = await fetch('/api/analysis/suggest-tags', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ title, description })
                });

                if (!response.ok) {
                    renderSuggestedTags([]);
                    return;
                }

                const suggested = await response.json();
                renderSuggestedTags(Array.isArray(suggested) ? suggested : []);
            } catch (e) {
                console.error('Tag suggestion fetch failed', e);
                renderSuggestedTags([]);
            }
        }, 400);
    }

    const titleInput = document.getElementById('baseTitle');
    const descInput = document.getElementById('baseDescription');

    if (titleInput) titleInput.addEventListener('input', requestTagSuggestions);
    if (descInput)  descInput.addEventListener('input', requestTagSuggestions);

    /* ── Form Submit ─────────────────────────────────── */
    document.getElementById('issueForm').addEventListener('submit', function (e) {
        const title       = document.getElementById('baseTitle').value.trim();
        const description = document.getElementById('baseDescription').value.trim();
        let   city        = document.getElementById('baseCity').value;
        const latitude    = document.getElementById('latitude').value  || '42.6977';
        const longitude   = document.getElementById('longitude').value || '23.3219';

        if (!city && selectedCityFromGeocode) {
            city = selectedCityFromGeocode;
            document.getElementById('baseCity').value = city;
        }

        if (title.length < 3) {
            e.preventDefault();
            document.getElementById('baseTitle').focus();
            alert('Title must be at least 3 characters');
            return;
        }

        if (description.length < 10) {
            e.preventDefault();
            document.getElementById('baseDescription').focus();
            alert('Description must be at least 10 characters');
            return;
        }

        if (!city) {
            e.preventDefault();
                            alert('@Localizer["PleaseSelectACity"]');
            return;
        }

        // Sync hidden master fields for ASP.NET model binding
        document.getElementById('masterTitle').value       = title;
        document.getElementById('masterDescription').value = description;
        document.getElementById('masterCity').value        = city;
        document.getElementById('masterLat').value         = latitude;
        document.getElementById('masterLng').value         = longitude;
        document.getElementById('masterTags').value        = document.getElementById('tagInput').value.trim();

        const btn = document.getElementById('baseSubmitBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" style="width:14px;height:14px;"></span> Submitting…';
    });
    </script>
}
