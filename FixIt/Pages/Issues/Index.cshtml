@page "/issues"
@model IssueListModel
@{
    ViewData["Title"] = "Issues";
}

<div class="container-fluid mt-5">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h1 class="h2 mb-0">
                <i class="bi bi-exclamation-triangle"></i> City Issues
            </h1>
            <p class="text-muted">Report and track civic problems in your area</p>
        </div>
        <div class="col-md-6 text-end">
            @if (User?.Identity?.IsAuthenticated ?? false)
            {
                <a href="/issues/create" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-circle"></i> Report Issue
                </a>
            }
            else
            {
                <a href="/Identity/Account/Login" class="btn btn-primary btn-lg">
                    <i class="bi bi-box-arrow-in-right"></i> Login to Report
                </a>
            }
        </div>
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label for="searchQuery" class="form-label">Search</label>
                    <input type="text" class="form-control" id="searchQuery" name="searchQuery" 
                           placeholder="Search issues..." value="@Model.SearchQuery">
                </div>
                <div class="col-md-3">
                    <label for="status" class="form-label">Status</label>
                    <select class="form-select" id="status" name="status">
                        <option value="">All Statuses</option>
                        <option value="0" selected="@(Model.SelectedStatus == 0)">New</option>
                        <option value="1" selected="@(Model.SelectedStatus == 1)">Confirmed</option>
                        <option value="2" selected="@(Model.SelectedStatus == 2)">In Progress</option>
                        <option value="3" selected="@(Model.SelectedStatus == 3)">Fixed</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="priority" class="form-label">Priority</label>
                    <select class="form-select" id="priority" name="priority">
                        <option value="">All Priorities</option>
                        <option value="0" selected="@(Model.SelectedPriority == 0)">Low</option>
                        <option value="1" selected="@(Model.SelectedPriority == 1)">Medium</option>
                        <option value="2" selected="@(Model.SelectedPriority == 2)">High</option>
                        <option value="3" selected="@(Model.SelectedPriority == 3)">Critical</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-search"></i> Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Issues Grid -->
    @if (Model.Issues?.Any() == true)
    {
        <div class="row g-4">
            @foreach (var issue in Model.Issues)
            {
                <div class="col-md-6 col-lg-4">
                    <!-- FIXED: Use correct route -->
                    <a href="/issues/@issue.Id" class="card h-100 issue-card text-decoration-none">
                        <!-- Status Badge -->
                        <div class="position-absolute top-0 end-0 p-2">
                            @{
                                var statusColor = issue.Status switch
                                {
                                    FixIt.Models.Enums.IssueStatus.New => "warning",
                                    FixIt.Models.Enums.IssueStatus.Confirmed => "info",
                                    FixIt.Models.Enums.IssueStatus.InProgress => "primary",
                                    FixIt.Models.Enums.IssueStatus.Fixed => "success",
                                    _ => "secondary"
                                };
                                var statusText = issue.Status.ToString();
                            }
                            <span class="badge bg-@statusColor">@statusText</span>
                        </div>

                        <!-- Card Body -->
                        <div class="card-body">
                            <h5 class="card-title">@issue.Title</h5>
                            <p class="card-text text-muted text-truncate">@issue.Description</p>
                            
                            <!-- Tags -->
                            @if (issue.TagIds?.Any() == true)
                            {
                                <div class="mb-2">
                                    @foreach (var tagId in issue.TagIds.Take(3))
                                    {
                                        <span class="badge bg-light text-dark me-1">#tag</span>
                                    }
                                </div>
                            }

                            <!-- Priority -->
                            <div class="mb-2">
                                @{
                                    var priorityColor = issue.Priority switch
                                    {
                                        FixIt.Models.Enums.IssuePriority.Low => "text-success",
                                        FixIt.Models.Enums.IssuePriority.Medium => "text-warning",
                                        FixIt.Models.Enums.IssuePriority.High => "text-danger",
                                        FixIt.Models.Enums.IssuePriority.Critical => "text-danger fw-bold",
                                        _ => ""
                                    };
                                }
                                <span class="@priorityColor">
                                    <i class="bi bi-exclamation-circle"></i> @issue.Priority
                                </span>
                            </div>
                        </div>

                        <!-- Footer -->
                        <div class="card-footer bg-light">
                            <div class="d-flex justify-content-between align-items-center small">
                                <div>
                                    <span class="me-3">
                                        <i class="bi bi-eye"></i> @issue.ViewCount
                                    </span>
                                    <span class="me-3">
                                        <i class="bi bi-chat"></i> @issue.CommentCount
                                    </span>
                                    <span>
                                        <i class="bi bi-hand-thumbs-up"></i> @issue.Upvotes
                                    </span>
                                </div>
                                <small class="text-muted">@issue.CreatedAt.ToString("MMM d")</small>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-5">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="/issues?page=@(Model.CurrentPage - 1)">Previous</a>
                    </li>
                    
                    @for (int i = 1; i <= Math.Min(5, Model.TotalPages); i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="/issues?page=@i">@i</a>
                        </li>
                    }
                    
                    <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="/issues?page=@(Model.CurrentPage + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <h5>No issues found</h5>
            <p>Be the first to report an issue in your city!</p>
            @if (User?.Identity?.IsAuthenticated ?? false)
            {
                <a href="/issues/create" class="btn btn-primary mt-3">
                    <i class="bi bi-plus-circle"></i> Report Issue
                </a>
            }
        </div>
    }
</div>

<style>
.issue-card {
    transition: all 0.3s ease;
    border: 1px solid #dee2e6;
    color: inherit;
}

.issue-card:hover {
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    transform: translateY(-2px);
    color: inherit;
}

.issue-card:active {
    transform: translateY(0);
}
</style>