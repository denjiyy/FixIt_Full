@page "/issues"
@using FixIt.Models.Enums
@using FixIt.Models.Issues
@model IssueListModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["CommunityIssues"];
    ViewData["BodyClass"] = "page-issues-index";
    ViewData["RequiresMap"] = true;

    var hasFilters = !string.IsNullOrWhiteSpace(Model.SearchQuery)
                     || Model.SelectedStatus >= 0
                     || Model.SelectedPriority >= 0
                     || !string.IsNullOrWhiteSpace(Model.SelectedCategory)
                     || Model.SelectedFromUtc.HasValue
                     || Model.SelectedToUtc.HasValue;
    var currentSort = string.IsNullOrWhiteSpace(Model.Sort) ? "newest" : Model.Sort.ToLowerInvariant();
    var resultsOnPage = Model.Issues?.Count ?? 0;

    string GlyphFor(IssueStatus s) => s switch
    {
        IssueStatus.Fixed => "bi-check2-circle",
        IssueStatus.InProgress => "bi-tools",
        IssueStatus.Confirmed => "bi-hand-thumbs-up",
        IssueStatus.Rejected => "bi-x-circle",
        IssueStatus.Duplicate => "bi-files",
        _ => "bi-exclamation-circle"
    };
    string GradFor(string? id)
    {
        var h = 0;
        foreach (var ch in id ?? string.Empty) { h = (h + ch) % 9973; }
        return new[] { "grad-a", "grad-b", "grad-c", "grad-d" }[h % 4];
    }
    string AddrOf(Issue it) => string.IsNullOrWhiteSpace(it.Address) ? Localizer["CommunityIssues"].Value : it.Address!;

    // Coordinates for the Leaflet map view (only issues that carry a location).
    var mapPoints = (Model.Issues ?? new List<Issue>())
        .Where(i => i.Location?.Coordinates != null)
        .Select(i => new
        {
            id = i.Id,
            title = i.Title,
            lat = i.Location.Coordinates.Latitude,
            lng = i.Location.Coordinates.Longitude,
            status = i.Status.ToString(),
            address = AddrOf(i)
        })
        .ToList();
    var mapJson = System.Text.Json.JsonSerializer.Serialize(mapPoints);
}

@section PageCss {
    <link rel="stylesheet" href="~/css/pages/issues-shared.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/calm-civic.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/issues-index.css" asp-append-version="true" />
}

<div class="issue-page issues-index-page calm"
     id="issuesIndexRoot"
     data-ai-filter-loading="Interpreting your request with AI..."
     data-ai-filter-error="AI filter translation failed. Applying basic text search instead."
     data-ai-filter-applied="AI filters applied to the current view."
     data-ai-filter-label="AI-generated filters">
    <section class="issues-index-hero issue-surface issue-surface--glass">
        <div class="issue-page-header issues-index-hero__header">
            <div class="issue-page-header__content">
                <span class="issue-page-header__eyebrow">
                    <i class="bi bi-radar"></i>
                    @Localizer["FeaturedCommunityActivity"]
                </span>
                <h1 class="issue-page-header__title">@Localizer["CommunityIssues"]</h1>
                <p class="issue-page-header__copy">@Localizer["IssuesDiscoveryCopy"]</p>
            </div>

            <div class="issue-page-actions">
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <a asp-page="/Issues/Create" class="nav-report-btn">
                        <i class="bi bi-plus-circle-fill"></i>
                        <span>@Localizer["ReportIssueBtn"]</span>
                    </a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="app-link-btn">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>@Localizer["SignInToReport"]</span>
                    </a>
                }
            </div>
        </div>

        <div class="issue-kpi-grid">
            <article class="issue-kpi-card">
                <div class="issue-kpi-card__label">
                    <i class="bi bi-flag-fill"></i>
                    @Localizer["TotalIssues"]
                </div>
                <div class="issue-kpi-card__value">@Model.Overview.TotalIssues</div>
                <div class="issue-kpi-card__meta">@Localizer["FeaturedCommunityActivityCopy"]</div>
            </article>

            <article class="issue-kpi-card">
                <div class="issue-kpi-card__label">
                    <i class="bi bi-check2-circle"></i>
                    @Localizer["Resolved"]
                </div>
                <div class="issue-kpi-card__value">@Model.Overview.FixedIssues</div>
                <div class="issue-kpi-card__meta">@Model.Overview.ResolutionRatePercentage% @Localizer["ResolutionRate"]</div>
            </article>

            <article class="issue-kpi-card">
                <div class="issue-kpi-card__label">
                    <i class="bi bi-arrow-repeat"></i>
                    @Localizer["InProgress"]
                </div>
                <div class="issue-kpi-card__value">@Model.Overview.InProgressIssues</div>
                <div class="issue-kpi-card__meta">@Localizer["ActiveIssues"]</div>
            </article>

            <article class="issue-kpi-card">
                <div class="issue-kpi-card__label">
                    <i class="bi bi-buildings"></i>
                    @Localizer["CitiesCovered"]
                </div>
                <div class="issue-kpi-card__value">@Model.Overview.CitiesCovered</div>
                <div class="issue-kpi-card__meta">@Localizer["CommunityPoweredPlatform"]</div>
            </article>
        </div>
    </section>

    <section class="issues-toolbar issue-surface">
        <div class="issues-toolbar__top">
            <div>
                <h2 class="issues-toolbar__title">@Localizer["FiltersLabel"]</h2>
                <p class="issues-toolbar__copy">
                    @Localizer["Showing"] <strong>@resultsOnPage</strong> @Localizer["IssuePlural"] @Localizer["Of"] <strong>@Model.FilteredTotal</strong>
                    @if (hasFilters)
                    {
                        <text> · @Localizer["Active"]</text>
                    }
                </p>
            </div>

            <button type="button" class="app-link-btn issues-toolbar__toggle" data-filter-toggle>
                <i class="bi bi-sliders"></i>
                <span>@Localizer["FiltersLabel"]</span>
            </button>
        </div>

        <div class="issues-toolbar__ai" aria-label="Natural language search">
            <label for="naturalSearchQuery" class="issues-toolbar__ai-label">Natural language filter</label>
            <div class="issues-toolbar__ai-row">
                <input type="text"
                       id="naturalSearchQuery"
                       class="issues-toolbar__ai-input"
                       placeholder="Example: high priority potholes from last 30 days" />
                <button type="button" id="aiFilterButton" class="nav-report-btn nav-report-btn--compact">
                    <i class="bi bi-stars"></i>
                    <span>Apply with AI</span>
                </button>
            </div>
            <div id="aiFilterStatus" class="issues-toolbar__ai-status" aria-live="polite"></div>
        </div>

        <form method="get" id="issuesFilterForm" class="issues-toolbar__form" data-filter-panel>
            <input type="hidden" name="sort" id="sortInput" value="@currentSort" />
            <input type="hidden" name="category" id="categoryInput" value="@Model.SelectedCategory" />
            <input type="hidden" name="from" id="fromInput" value="@(Model.SelectedFromUtc?.ToString("yyyy-MM-dd") ?? string.Empty)" />
            <input type="hidden" name="to" id="toInput" value="@(Model.SelectedToUtc?.ToString("yyyy-MM-dd") ?? string.Empty)" />

            <div class="issues-toolbar__fields">
                <label class="issues-field">
                    <span>@Localizer["Search"]</span>
                    <div class="issues-search">
                        <i class="bi bi-search"></i>
                        <input type="text"
                               id="searchQuery"
                               name="searchQuery"
                               value="@Model.SearchQuery"
                               placeholder="@Localizer["SearchByTitle"]"
                               autocomplete="off" />
                    </div>
                </label>

                <label class="issues-field">
                    <span>@Localizer["Status"]</span>
                    <select id="status" name="status">
                        <option value="">@Localizer["AllStatuses"]</option>
                        @if (Model.SelectedStatus == 0)
                        {
                            <option value="0" selected>@Localizer["New"]</option>
                        }
                        else
                        {
                            <option value="0">@Localizer["New"]</option>
                        }
                        @if (Model.SelectedStatus == 1)
                        {
                            <option value="1" selected>@Localizer["Confirmed"]</option>
                        }
                        else
                        {
                            <option value="1">@Localizer["Confirmed"]</option>
                        }
                        @if (Model.SelectedStatus == 2)
                        {
                            <option value="2" selected>@Localizer["InProgress"]</option>
                        }
                        else
                        {
                            <option value="2">@Localizer["InProgress"]</option>
                        }
                        @if (Model.SelectedStatus == 3)
                        {
                            <option value="3" selected>@Localizer["Fixed"]</option>
                        }
                        else
                        {
                            <option value="3">@Localizer["Fixed"]</option>
                        }
                    </select>
                </label>

                <label class="issues-field">
                    <span>@Localizer["Priority"]</span>
                    <select id="priority" name="priority">
                        <option value="">@Localizer["AllPriorities"]</option>
                        @if (Model.SelectedPriority == 0)
                        {
                            <option value="0" selected>@Localizer["Low"]</option>
                        }
                        else
                        {
                            <option value="0">@Localizer["Low"]</option>
                        }
                        @if (Model.SelectedPriority == 1)
                        {
                            <option value="1" selected>@Localizer["Medium"]</option>
                        }
                        else
                        {
                            <option value="1">@Localizer["Medium"]</option>
                        }
                        @if (Model.SelectedPriority == 2)
                        {
                            <option value="2" selected>@Localizer["High"]</option>
                        }
                        else
                        {
                            <option value="2">@Localizer["High"]</option>
                        }
                        @if (Model.SelectedPriority == 3)
                        {
                            <option value="3" selected>@Localizer["Critical"]</option>
                        }
                        else
                        {
                            <option value="3">@Localizer["Critical"]</option>
                        }
                    </select>
                </label>
            </div>

            <div class="issues-toolbar__sort">
                <span class="issues-toolbar__sort-label">@Localizer["SortByLabel"]</span>
                <div class="issues-sort-group" role="group" aria-label="@Localizer["SortOptions"]">
                    <button type="button" class="issues-sort-btn @(currentSort == "newest" ? "is-active" : "")" data-sort-value="newest">
                        <i class="bi bi-clock-history"></i>
                        @Localizer["Newest"]
                    </button>
                    <button type="button" class="issues-sort-btn @(currentSort == "mostvoted" ? "is-active" : "")" data-sort-value="mostvoted">
                        <i class="bi bi-hand-thumbs-up"></i>
                        @Localizer["MostVoted"]
                    </button>
                    <button type="button" class="issues-sort-btn @(currentSort == "mostviewed" ? "is-active" : "")" data-sort-value="mostviewed">
                        <i class="bi bi-eye"></i>
                        @Localizer["MostViewed"]
                    </button>
                </div>
            </div>

            <div class="issues-toolbar__actions">
                <button type="submit" class="nav-report-btn nav-report-btn--compact">
                    <i class="bi bi-search"></i>
                    <span>@Localizer["Apply"]</span>
                </button>
                <a href="/issues" class="app-link-btn">
                    <i class="bi bi-arrow-counterclockwise"></i>
                    <span>@Localizer["ClearFilters"]</span>
                </a>
            </div>
        </form>

        @if (hasFilters)
        {
            <div class="issues-active-filters">
                <span class="issues-active-filters__label">@Localizer["Active"]</span>
                @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
                {
                    <span class="issues-active-filters__chip">
                        <i class="bi bi-search"></i>
                        @Model.SearchQuery
                    </span>
                }
                @if (Model.SelectedStatus >= 0)
                {
                    <span class="issues-active-filters__chip">
                        <i class="bi bi-circle-half"></i>
                        @(Model.SelectedStatus switch
                        {
                            0 => Localizer["New"],
                            1 => Localizer["Confirmed"],
                            2 => Localizer["InProgress"],
                            3 => Localizer["Fixed"],
                            _ => string.Empty
                        })
                    </span>
                }
                @if (Model.SelectedPriority >= 0)
                {
                    <span class="issues-active-filters__chip">
                        <i class="bi bi-flag"></i>
                        @(Model.SelectedPriority switch
                        {
                            0 => Localizer["Low"],
                            1 => Localizer["Medium"],
                            2 => Localizer["High"],
                            3 => Localizer["Critical"],
                            _ => string.Empty
                        })
                    </span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.SelectedCategory))
                {
                    <span class="issues-active-filters__chip">
                        <i class="bi bi-diagram-3"></i>
                        @Model.SelectedCategory
                    </span>
                }
                @if (Model.SelectedFromUtc.HasValue || Model.SelectedToUtc.HasValue)
                {
                    <span class="issues-active-filters__chip">
                        <i class="bi bi-calendar-range"></i>
                        @(Model.SelectedFromUtc?.ToString("yyyy-MM-dd") ?? "Any date")
                        –
                        @(Model.SelectedToUtc?.ToString("yyyy-MM-dd") ?? "Now")
                    </span>
                }
            </div>
        }
    </section>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
    {
        <div class="alert alert-danger rounded-4 mt-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    @if (Model.Issues?.Any() == true)
    {
        <section class="issues-results">
            <div class="browse-head">
                <h2 class="h-section browse-head__title">@Localizer["CommunityIssues"]</h2>
                <div class="toggle" role="group" aria-label="@Localizer["ViewMode"]" id="browseToggle">
                    <button type="button" class="on" data-view="gallery">
                        <i class="bi bi-grid-1x2-fill"></i><span>@Localizer["GalleryView"]</span>
                    </button>
                    <button type="button" data-view="map">
                        <i class="bi bi-map-fill"></i><span>@Localizer["MapView"]</span>
                    </button>
                </div>
            </div>

            <div id="browseGallery">
                <div class="gallery">
                    @foreach (var issue in Model.Issues)
                    {
                        <partial name="_GalleryCard" model="issue" />
                    }
                </div>

                @if (Model.TotalPages > 1)
                {
                    var baseUrl = $"/issues?searchQuery={Uri.EscapeDataString(Model.SearchQuery ?? "")}" +
                                  $"&status={Model.SelectedStatus}" +
                                  $"&priority={Model.SelectedPriority}" +
                                  $"&category={Uri.EscapeDataString(Model.SelectedCategory ?? string.Empty)}" +
                                  $"&from={Uri.EscapeDataString(Model.SelectedFromUtc?.ToString("yyyy-MM-dd") ?? string.Empty)}" +
                                  $"&to={Uri.EscapeDataString(Model.SelectedToUtc?.ToString("yyyy-MM-dd") ?? string.Empty)}" +
                                  $"&sort={Uri.EscapeDataString(currentSort)}";
                    var paginationModel = new FixIt.ViewModels.PaginationViewModel
                    {
                        CurrentPage = Model.CurrentPage,
                        TotalPages = Model.TotalPages,
                        BaseUrl = baseUrl
                    };

                    <partial name="_Pagination" model="paginationModel" />
                }
            </div>

            <div id="browseMap" class="browse-map" style="display:none">
                <div class="browse-map__list">
                    @foreach (var issue in Model.Issues)
                    {
                        <a href="/issues/@issue.Id" class="mini-issue" data-issue-id="@issue.Id">
                            <div class="mini-issue__photo @GradFor(issue.Id)"><i class="bi @GlyphFor(issue.Status)"></i></div>
                            <div class="mini-issue__b">
                                <partial name="_BadgeStatus" model="issue.Status" />
                                <h4>@issue.Title</h4>
                                <span class="gcard__loc"><i class="bi bi-geo-alt-fill"></i>@AddrOf(issue)</span>
                            </div>
                        </a>
                    }
                </div>
                <div class="browse-map__canvas">
                    <div id="issuesLeaflet" style="width:100%;height:100%"></div>
                </div>
            </div>

            <script id="issuesMapConfig" type="application/json">@Html.Raw(mapJson)</script>
        </section>
    }
    else
    {
        <section class="issue-surface issue-empty-state issues-empty">
            <div class="issue-empty-state__icon">
                <i class="bi bi-inbox"></i>
            </div>
            <h2 class="issue-empty-state__title">@Localizer["NoIssuesFoundEmptyState"]</h2>
            <p class="issue-empty-state__copy">
                @(hasFilters
                    ? Localizer["NoResultsMatchYourCurrentFilters"]
                    : $"{Localizer["NoIssuesReportedYet"]}. {Localizer["BeTheFirstToMakeYourCommunityBetter"]}")
            </p>
            <div class="issue-page-actions issues-empty__actions">
                @if (hasFilters)
                {
                    <a href="/issues" class="app-link-btn">
                        <i class="bi bi-arrow-counterclockwise"></i>
                        <span>@Localizer["ClearFilters"]</span>
                    </a>
                }
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <a asp-page="/Issues/Create" class="nav-report-btn">
                        <i class="bi bi-send-plus"></i>
                        <span>@Localizer["SubmitReport"]</span>
                    </a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="nav-report-btn">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>@Localizer["SignInToReport"]</span>
                    </a>
                }
            </div>
        </section>
    }
</div>

@section PageScripts {
    <script src="~/js/modules/issues-index.js" asp-append-version="true" defer></script>
    <script src="~/js/pages/issues-browse.js" asp-append-version="true" defer></script>
}
