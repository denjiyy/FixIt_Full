{
  "DetailedErrors": false,
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Security": "Information"
    }
  },
  "MongoDB": {
    "ConnectionString": "${MONGODB_CONNECTION_STRING}",
    "DatabaseName": "${MONGODB_DATABASE_NAME:fixit}"
  },
  "Security": {
    "RequireHttps": true,
    "RateLimiting": {
      "Enabled": true,
      "RequestsPerMinute": 60,
      "RequestsPerHour": 1000
    },
    "CorsAllowedOrigins": [ "${CORS_ALLOWED_ORIGINS:https://yourdomain.com}" ],
    "ContentSecurityPolicy": "default-src 'self'; script-src 'self' 'unsafe-inline' cdn.jsdelivr.net cdnjs.cloudflare.com unpkg.com; style-src 'self' 'unsafe-inline' cdn.jsdelivr.net cdnjs.cloudflare.com fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' cdn.jsdelivr.net fonts.gstatic.com; connect-src 'self' tile.openstreetmap.org;"
  },
  "AllowedHosts": "${ALLOWED_HOSTS:localhost}",
  "Media": {
    "StoragePath": "/app/uploads",
    "MaxFileSizeBytes": 5242880,
    "MaxFilesPerUpload": 5,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".gif", ".webp" ]
  },
  "Authentication": {
    "Google": {
      "ClientId": "${GOOGLE_CLIENT_ID}",
      "ClientSecret": "${GOOGLE_CLIENT_SECRET}"
    },
    "GitHub": {
      "ClientId": "${GITHUB_CLIENT_ID}",
      "ClientSecret": "${GITHUB_CLIENT_SECRET}"
    },
    "Facebook": {
      "AppId": "${FACEBOOK_APP_ID}",
      "AppSecret": "${FACEBOOK_APP_SECRET}"
    },
    "Microsoft": {
      "ClientId": "${MICROSOFT_CLIENT_ID}",
      "ClientSecret": "${MICROSOFT_CLIENT_SECRET}",
      "TenantId": "${MICROSOFT_TENANT_ID:common}"
    }
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "Enabled": true,
    "TimeoutSeconds": 30
  }
}
