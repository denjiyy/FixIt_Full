@page
@model FixIt.Pages.Settings.ConnectedAccountsModel
@{
    ViewData["Title"] = "Connected Accounts";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1>Connected Accounts</h1>
            <p class="text-muted">Manage your authentication methods and linked providers</p>

            @if (Model.SuccessMessage != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @Model.SuccessMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model.ErrorMessage != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @Model.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- OAuth Providers -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">OAuth Providers</h5>
                </div>
                <div class="card-body">
                    @if (Model.User?.ExternalIdentities.Count == 0)
                    {
                        <p class="text-muted mb-0">No OAuth providers linked</p>
                    }
                    else
                    {
                        @foreach (var identity in Model.User!.ExternalIdentities.OrderByDescending(e => e.ConnectedAt))
                        {
                            <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                                <div>
                                    <h6 class="mb-1">
                                        @if (identity.Provider == "Google")
                                        {
                                            <i class="fab fa-google text-danger"></i>
                                        }
                                        else if (identity.Provider == "GitHub")
                                        {
                                            <i class="fab fa-github"></i>
                                        }
                                        else if (identity.Provider == "Microsoft")
                                        {
                                            <i class="fab fa-microsoft text-primary"></i>
                                        }
                                        @identity.Provider
                                    </h6>
                                    <p class="mb-0 text-muted small">
                                        @if (!string.IsNullOrEmpty(identity.ProviderDisplayName))
                                        {
                                            <span>@identity.ProviderDisplayName</span>
                                        }
                                    </p>
                                    <p class="mb-0 text-muted small">
                                        Linked: @identity.ConnectedAt.ToString("yyyy-MM-dd HH:mm")
                                    </p>
                                    @if (identity.LastSignInAt.HasValue)
                                    {
                                        <p class="mb-0 text-muted small">
                                            Last sign-in: @identity.LastSignInAt.Value.ToString("yyyy-MM-dd HH:mm")
                                        </p>
                                    }
                                </div>
                                <form method="post" asp-page-handler="Unlink" 
                                      onsubmit="return confirm('Are you sure?');" 
                                      style="display: inline;">
                                    <input type="hidden" name="provider" value="@identity.Provider" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Unlink
                                    </button>
                                </form>
                            </div>
                        }
                    }

                    <div class="mt-3">
                        <h6>Link more providers:</h6>
                        <form method="post" action="/api/auth/link-provider/google" style="display: inline;">
                            @if (Model.User?.ExternalIdentities.Any(e => e.Provider == "Google") != true)
                            {
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fab fa-google"></i> Link Google
                                </button>
                            }
                        </form>
                        <form method="post" action="/api/auth/link-provider/github" style="display: inline;">
                            @if (Model.User?.ExternalIdentities.Any(e => e.Provider == "GitHub") != true)
                            {
                                <button type="submit" class="btn btn-sm btn-outline-dark">
                                    <i class="fab fa-github"></i> Link GitHub
                                </button>
                            }
                        </form>
                        <form method="post" action="/api/auth/link-provider/microsoft" style="display: inline;">
                            @if (Model.User?.ExternalIdentities.Any(e => e.Provider == "Microsoft") != true)
                            {
                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                    <i class="fab fa-microsoft"></i> Link Microsoft
                                </button>
                            }
                        </form>
                    </div>
                </div>
            </div>

            <!-- Password Authentication -->
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Password Authentication</h5>
                </div>
                <div class="card-body">
                    @if (Model.User?.HasPasswordAuth == true)
                    {
                        <p><span class="badge bg-success">Enabled</span></p>
                        <p class="text-muted">You can sign in with email and password</p>
                        <a href="/Account/Manage/ChangePassword" class="btn btn-sm btn-primary">
                            Change Password
                        </a>
                    }
                    else
                    {
                        <p><span class="badge bg-secondary">Disabled</span></p>
                        <p class="text-muted">You're using OAuth providers to sign in</p>
                        <a href="/Account/Register" class="btn btn-sm btn-primary">
                            Set up Password
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
