@page
@model FixIt.Pages.LoginModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h1 class="card-title text-center mb-4">Welcome to FixIt</h1>
                    
                    @if (Model.ErrorMessage != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            @Model.ErrorMessage
                        </div>
                    }

                    <!-- OAuth Sign-In Options -->
                    <div class="mb-4">
                        <h5 class="text-center text-muted mb-3">Sign in with</h5>
                        
                        <form method="post" action="/api/auth/login/google" class="mb-2">
                            <button type="submit" class="btn btn-outline-danger w-100">
                                <i class="fab fa-google me-2"></i>
                                Continue with Google
                            </button>
                        </form>

                        <form method="post" action="/api/auth/login/github" class="mb-2">
                            <button type="submit" class="btn btn-outline-dark w-100">
                                <i class="fab fa-github me-2"></i>
                                Continue with GitHub
                            </button>
                        </form>

                        <form method="post" action="/api/auth/login/microsoft" class="mb-3">
                            <button type="submit" class="btn btn-outline-primary w-100">
                                <i class="fab fa-microsoft me-2"></i>
                                Continue with Microsoft
                            </button>
                        </form>
                    </div>

                    <div class="text-center mb-4">
                        <div class="divider">
                            <span class="divider-text">or</span>
                        </div>
                    </div>

                    <!-- Email/Password Sign-In -->
                    <form method="post" class="needs-validation" novalidate>
                        <div class="mb-3">
                            <label for="input-email" class="form-label">Email</label>
                            <input asp-for="Input.Email" 
                                   class="form-control" 
                                   id="input-email"
                                   placeholder="you@example.com"
                                   required />
                            <span asp-validation-for="Input.Email" class="invalid-feedback"></span>
                        </div>

                        <div class="mb-3">
                            <label for="input-password" class="form-label">Password</label>
                            <input asp-for="Input.Password" 
                                   type="password" 
                                   class="form-control" 
                                   id="input-password"
                                   required />
                            <span asp-validation-for="Input.Password" class="invalid-feedback"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="Input.RememberMe" 
                                   type="checkbox" 
                                   class="form-check-input" 
                                   id="input-remember" />
                            <label class="form-check-label" for="input-remember">
                                Remember me
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-3">Sign In</button>
                    </form>

                    <div class="text-center">
                        <p class="mb-0">Don't have an account? <a asp-page="Register" class="text-decoration-none">Create one</a></p>
                        <p><a asp-page="ForgotPassword" class="text-decoration-none">Forgot password?</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.divider {
    display: flex;
    align-items: center;
    margin: 20px 0;
}

.divider-text {
    flex: 1;
    text-align: center;
    color: #6c757d;
}

.divider::before,
.divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background-color: #e9ecef;
}

.divider::before {
    margin-right: 10px;
}

.divider::after {
    margin-left: 10px;
}
</style>

@section Scripts {
    <script>
        // Bootstrap form validation
        (function() {
            'use strict';
            const forms = document.querySelectorAll('.needs-validation');
            Array.prototype.slice.call(forms).forEach(function(form) {
                form.addEventListener('submit', function(event) {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        })();
    </script>
}
