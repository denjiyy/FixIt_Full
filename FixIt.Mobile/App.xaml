<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:FixIt.Mobile.Converters"
             x:Class="FixIt.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
            <converters:DateTimeToRelativeConverter x:Key="DateTimeToRelativeConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:PriorityToColorConverter x:Key="PriorityToColorConverter" />
            <converters:CategoryToBrushConverter x:Key="CategoryToBrushConverter" />
            <converters:CategoryToIconConverter x:Key="CategoryToIconConverter" />
            <converters:HashtagConverter x:Key="HashtagConverter" />
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <converters:FractionToStarConverter x:Key="FractionToStarConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
