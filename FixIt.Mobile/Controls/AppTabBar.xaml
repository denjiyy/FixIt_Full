<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="FixIt.Mobile.Controls.AppTabBar"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Name="Root">

    <ContentView.Resources>
        <LinearGradientBrush x:Key="FabBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimaryStrong}}" Offset="0" />
            <GradientStop Color="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" Offset="1" />
        </LinearGradientBrush>
    </ContentView.Resources>

    <VerticalStackLayout Spacing="0"
                         BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}">

        <BoxView HeightRequest="1"
                 Color="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}" />

        <Grid ColumnDefinitions="*,*,*,*,*"
              Padding="{OnPlatform iOS='6,8,6,8', Android='6,8,6,12', Default='6,8,6,12'}">

            <!-- Home -->
            <VerticalStackLayout Grid.Column="0" Spacing="3" Padding="0,4" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="home.png" WidthRequest="23" HeightRequest="23" HorizontalOptions="Center">
                    <Image.Triggers>
                        <DataTrigger TargetType="Image" Binding="{Binding Source={x:Reference Root}, Path=Active}" Value="home">
                            <Setter Property="Source" Value="home_selected.png" />
                        </DataTrigger>
                    </Image.Triggers>
                </Image>
                <Label Text="{local:Localize Key=Tab_Home}" FontSize="10" FontAttributes="Bold" HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding Source={x:Reference Root}, Path=Active}" Value="home">
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimary}}" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </VerticalStackLayout>

            <!-- Explore -->
            <VerticalStackLayout Grid.Column="1" Spacing="3" Padding="0,4" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnExploreTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="issues.png" WidthRequest="23" HeightRequest="23" HorizontalOptions="Center">
                    <Image.Triggers>
                        <DataTrigger TargetType="Image" Binding="{Binding Source={x:Reference Root}, Path=Active}" Value="explore">
                            <Setter Property="Source" Value="issues_selected.png" />
                        </DataTrigger>
                    </Image.Triggers>
                </Image>
                <Label Text="{local:Localize Key=Tab_Issues}" FontSize="10" FontAttributes="Bold" HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding Source={x:Reference Root}, Path=Active}" Value="explore">
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimary}}" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </VerticalStackLayout>

            <!-- Report FAB (elevated) -->
            <Border Grid.Column="2"
                    WidthRequest="56" HeightRequest="48"
                    StrokeThickness="0" StrokeShape="RoundRectangle 16"
                    Background="{StaticResource FabBrush}"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    TranslationY="-6"
                    SemanticProperties.Description="{local:Localize Key=Tab_Report}">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource PrimaryBrush}" Opacity="0.45" Offset="0,8" Radius="14" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportTapped" />
                </Border.GestureRecognizers>
                <Image Source="feed_plus.png" WidthRequest="24" HeightRequest="24"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Image.Behaviors>
                        <toolkit:IconTintColorBehavior TintColor="White" />
                    </Image.Behaviors>
                </Image>
            </Border>

            <!-- Alerts -->
            <VerticalStackLayout Grid.Column="3" Spacing="3" Padding="0,4" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAlertsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="alerts.png" WidthRequest="23" HeightRequest="23" HorizontalOptions="Center">
                    <Image.Triggers>
                        <DataTrigger TargetType="Image" Binding="{Binding Source={x:Reference Root}, Path=Active}" Value="alerts">
                            <Setter Property="Source" Value="alerts_selected.png" />
                        </DataTrigger>
                    </Image.Triggers>
                </Image>
                <Label Text="{local:Localize Key=Tab_Alerts}" FontSize="10" FontAttributes="Bold" HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding Source={x:Reference Root}, Path=Active}" Value="alerts">
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimary}}" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </VerticalStackLayout>

            <!-- You -->
            <VerticalStackLayout Grid.Column="4" Spacing="3" Padding="0,4" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnYouTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="profile.png" WidthRequest="23" HeightRequest="23" HorizontalOptions="Center">
                    <Image.Triggers>
                        <DataTrigger TargetType="Image" Binding="{Binding Source={x:Reference Root}, Path=Active}" Value="you">
                            <Setter Property="Source" Value="profile_selected.png" />
                        </DataTrigger>
                    </Image.Triggers>
                </Image>
                <Label Text="{local:Localize Key=Tab_Profile}" FontSize="10" FontAttributes="Bold" HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding Source={x:Reference Root}, Path=Active}" Value="you">
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimary}}" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </VerticalStackLayout>
        </Grid>
    </VerticalStackLayout>
</ContentView>
