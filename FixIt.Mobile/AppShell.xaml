<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="FixIt.Mobile.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:FixIt.Mobile.Localization"
       xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
       BackgroundColor="{StaticResource Background}"
       Style="{StaticResource AppShellStyle}"
       x:DataType="viewModels:ShellViewModel"
       Title="FixIt">

    <Shell.TitleView>
        <Border x:Name="OfflineBanner"
                BackgroundColor="{StaticResource Error}"
                Padding="12,8"
                StrokeThickness="0"
                Opacity="0"
                IsVisible="{Binding IsOffline}">
            <Label Text="{local:Localize Key=Common_NoInternet}"
                   TextColor="{StaticResource White}"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   SemanticProperties.Description="{local:Localize Key=Common_NoInternet}" />
        </Border>
    </Shell.TitleView>

    <TabBar>
        <Tab x:Name="HomeTab" Title="Home" Route="home" Icon="home.svg">
            <ShellContent x:Name="HomeContent" Route="home-page" Icon="home.svg" />
        </Tab>

        <Tab x:Name="IssuesTab" Title="Issues" Route="issues" Icon="issues.svg">
            <ShellContent x:Name="IssuesContent" Route="issues-page" Icon="issues.svg" />
        </Tab>

        <Tab x:Name="AlertsTab" Title="Alerts" Route="alerts" Icon="alerts.svg">
            <ShellContent x:Name="AlertsContent" Route="alerts-page" Icon="alerts.svg" />
        </Tab>

        <Tab x:Name="ReportIssueTab" Title="Report Issue" Route="report-issue-tab" Icon="report_locked.svg">
            <ShellContent x:Name="ReportIssueContent" Route="report-issue-page" Icon="report_locked.svg" />
        </Tab>

        <Tab x:Name="AccountTab" Title="Sign In" Route="sign-in-tab" Icon="profile.svg">
            <ShellContent x:Name="AccountContent" Route="account-page" Icon="profile.svg" />
        </Tab>
    </TabBar>
</Shell>
