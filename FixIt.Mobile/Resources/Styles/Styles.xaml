<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="HeadlineLarge" TargetType="Label">
        <Setter Property="FontSize" Value="Title" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="-0.5" />
        <Setter Property="TextColor" Value="{StaticResource OnBackground}" />
    </Style>

    <Style x:Key="HeadlineMedium" TargetType="Label">
        <Setter Property="FontSize" Value="Header" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource OnBackground}" />
    </Style>

    <Style x:Key="TitleMedium" TargetType="Label">
        <Setter Property="FontSize" Value="Subtitle" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource OnBackground}" />
    </Style>

    <Style x:Key="BodyMedium" TargetType="Label">
        <Setter Property="FontSize" Value="Body" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="LineHeight" Value="1.5" />
    </Style>

    <Style x:Key="LabelSmall" TargetType="Label">
        <Setter Property="FontSize" Value="Caption" />
        <Setter Property="TextColor" Value="{StaticResource OnSurfaceMuted}" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="Body" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Shadow">
            <Shadow Brush="{StaticResource Primary}"
                    Opacity="0.4"
                    Offset="0,4"
                    Radius="12" />
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="TextColor" Value="{StaticResource OnBackground}" />
        <Setter Property="BorderColor" Value="{StaticResource Surface2}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="Body" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>

    <Style x:Key="CompactPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Stroke" Value="{StaticResource Surface2}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Shadow">
            <Shadow Brush="{StaticResource ShadowBlack}"
                    Opacity="0.3"
                    Offset="0,4"
                    Radius="16" />
        </Setter>
    </Style>

    <Style x:Key="StatCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="EntryCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Stroke" Value="{StaticResource Surface2}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="Padding" Value="14,0" />
    </Style>

    <Style x:Key="EditorCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Stroke" Value="{StaticResource Surface2}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="Padding" Value="14,12" />
    </Style>

    <Style x:Key="AppShellStyle" TargetType="Shell">
        <Setter Property="BackgroundColor" Value="{StaticResource Background}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource OnBackground}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource OnBackground}" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource Background}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TabBarUnselected}" />
    </Style>

</ResourceDictionary>
