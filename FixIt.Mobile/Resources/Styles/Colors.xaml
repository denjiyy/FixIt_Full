<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        Mobile design tokens — aligned with the web design-system on
        2026-05-26 per spec §5.3. Any hardcoded hex in screens should be
        migrated to these keys.
    -->

    <!-- Backgrounds -->
    <Color x:Key="Background">#0F172A</Color>
    <Color x:Key="Surface">#1E293B</Color>
    <Color x:Key="Surface2">#334155</Color>
    <Color x:Key="Surface3">#475569</Color>

    <!-- Brand (web parity) -->
    <Color x:Key="Primary">#0ea5e9</Color>
    <Color x:Key="PrimaryDark">#0284c7</Color>
    <Color x:Key="PrimaryLight">#38bdf8</Color>
    <Color x:Key="Accent">#f97316</Color>
    <Color x:Key="AccentDark">#ea580c</Color>

    <!-- Text -->
    <Color x:Key="OnBackground">#F8FAFC</Color>
    <Color x:Key="OnSurface">#CBD5E1</Color>
    <Color x:Key="OnSurfaceMuted">#64748B</Color>
    <Color x:Key="OnPrimary">#FFFFFF</Color>

    <!-- Semantic (web parity) -->
    <Color x:Key="Success">#10b981</Color>
    <Color x:Key="Warning">#f59e0b</Color>
    <Color x:Key="Error">#ef4444</Color>
    <Color x:Key="Danger">#ef4444</Color>
    <Color x:Key="Info">#38bdf8</Color>

    <!-- Priority (matches web heatmap legend: red=critical, orange=high, yellow=medium, green=low) -->
    <Color x:Key="PriorityCritical">#ef4444</Color>
    <Color x:Key="PriorityHigh">#f97316</Color>
    <Color x:Key="PriorityMedium">#f59e0b</Color>
    <Color x:Key="PriorityLow">#10b981</Color>

    <!-- Status -->
    <Color x:Key="StatusNew">#0ea5e9</Color>
    <Color x:Key="StatusInProgress">#f59e0b</Color>
    <Color x:Key="StatusResolved">#10b981</Color>
    <Color x:Key="StatusCritical">#ef4444</Color>

    <!-- Borders -->
    <Color x:Key="Border">#1E293B</Color>
    <Color x:Key="DividerColor">#334155</Color>

    <!-- Tab bar -->
    <Color x:Key="TabBarBackground">#0F172A</Color>
    <Color x:Key="TabBarSelected">#0ea5e9</Color>
    <Color x:Key="TabBarUnselected">#475569</Color>

    <!-- Misc -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="ShadowBlack">#000000</Color>

    <!-- Radius scale (dp) -->
    <x:Double x:Key="RadiusSm">8</x:Double>
    <x:Double x:Key="RadiusMd">12</x:Double>
    <x:Double x:Key="RadiusLg">16</x:Double>
    <x:Double x:Key="RadiusXl">20</x:Double>
    <x:Double x:Key="Radius2xl">24</x:Double>
    <x:Double x:Key="RadiusFull">9999</x:Double>

</ResourceDictionary>
