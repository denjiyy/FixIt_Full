<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Background">#0F172A</Color>
    <Color x:Key="Surface">#1E293B</Color>
    <Color x:Key="Surface2">#334155</Color>
    <Color x:Key="Surface3">#475569</Color>

    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryDark">#1D4ED8</Color>
    <Color x:Key="PrimaryLight">#3B82F6</Color>
    <Color x:Key="Accent">#38BDF8</Color>

    <Color x:Key="OnBackground">#F8FAFC</Color>
    <Color x:Key="OnSurface">#E2E8F0</Color>
    <Color x:Key="OnSurfaceMuted">#94A3B8</Color>

    <Color x:Key="Success">#15803D</Color>
    <Color x:Key="Warning">#B45309</Color>
    <Color x:Key="Error">#B91C1C</Color>
    <Color x:Key="Info">#0284C7</Color>

    <Color x:Key="StatusNew">#1D4ED8</Color>
    <Color x:Key="StatusInProgress">#B45309</Color>
    <Color x:Key="StatusResolved">#15803D</Color>
    <Color x:Key="StatusCritical">#B91C1C</Color>

    <Color x:Key="DividerColor">#334155</Color>
    <Color x:Key="TabBarUnselected">#64748B</Color>
    <Color x:Key="ShadowBlack">#000000</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
</ResourceDictionary>
