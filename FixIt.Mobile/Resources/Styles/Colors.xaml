<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Backgrounds -->
    <Color x:Key="Background">#0F172A</Color>
    <Color x:Key="Surface">#1E293B</Color>
    <Color x:Key="Surface2">#334155</Color>
    <Color x:Key="Surface3">#475569</Color>

    <!-- Brand -->
    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryDark">#1D4ED8</Color>
    <Color x:Key="PrimaryLight">#3B82F6</Color>
    <Color x:Key="Accent">#38BDF8</Color>

    <!-- Text -->
    <Color x:Key="OnBackground">#F8FAFC</Color>
    <Color x:Key="OnSurface">#CBD5E1</Color>
    <Color x:Key="OnSurfaceMuted">#64748B</Color>
    <Color x:Key="OnPrimary">#FFFFFF</Color>

    <!-- Semantic -->
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Error">#EF4444</Color>
    <Color x:Key="Info">#38BDF8</Color>

    <!-- Status -->
    <Color x:Key="StatusNew">#3B82F6</Color>
    <Color x:Key="StatusInProgress">#F59E0B</Color>
    <Color x:Key="StatusResolved">#22C55E</Color>
    <Color x:Key="StatusCritical">#EF4444</Color>

    <!-- Borders -->
    <Color x:Key="Border">#1E293B</Color>
    <Color x:Key="DividerColor">#334155</Color>

    <!-- Tab bar -->
    <Color x:Key="TabBarBackground">#0F172A</Color>
    <Color x:Key="TabBarSelected">#2563EB</Color>
    <Color x:Key="TabBarUnselected">#475569</Color>

    <!-- Misc -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="ShadowBlack">#000000</Color>

</ResourceDictionary>
