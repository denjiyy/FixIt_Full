<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.ForgotPasswordPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:ForgotPasswordViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=ForgotPassword_Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20,40,20,40" Spacing="20"
                             VerticalOptions="Center">

            <Label Text="{local:Localize Key=ForgotPassword_Title}"
                   Style="{StaticResource HeadlineMedium}"
                   HorizontalTextAlignment="Center" />

            <Label Text="{local:Localize Key=ForgotPassword_Description}"
                   Style="{StaticResource BodyMedium}"
                   HorizontalTextAlignment="Center" />

            <!-- Form (hidden after success) -->
            <VerticalStackLayout Spacing="16"
                                 IsVisible="{Binding IsSent, Converter={StaticResource InverseBoolConverter}}">
                <Border Style="{StaticResource EntryCard}">
                    <Entry Placeholder="{local:Localize Key=Login_EmailPlaceholder}"
                           Text="{Binding Email}"
                           Keyboard="Email" />
                </Border>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="{AppThemeBinding Light={StaticResource LightDanger}, Dark={StaticResource DarkDanger}}"
                       FontSize="Caption"
                       IsVisible="{Binding HasError}" />

                <Button Text="{local:Localize Key=ForgotPassword_Send}"
                        Style="{StaticResource CompactPrimaryButton}"
                        Command="{Binding SendResetLinkCommand}"
                        IsEnabled="{Binding IsSending, Converter={StaticResource InverseBoolConverter}}" />

                <ActivityIndicator IsRunning="{Binding IsSending}"
                                   IsVisible="{Binding IsSending}"
                                   Color="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
            </VerticalStackLayout>

            <!-- Success message -->
            <Border Style="{StaticResource Card}"
                    IsVisible="{Binding IsSent}">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Label Text="{local:Localize Key=ForgotPassword_Success}"
                           Style="{StaticResource BodyMedium}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
