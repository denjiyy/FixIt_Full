<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="FixIt.Mobile.Views.SkeletonCardView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Border x:Name="SkeletonRoot"
            BackgroundColor="{StaticResource LightSurface}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 16"
            Padding="20"
            Margin="0,0,0,12">
        <VerticalStackLayout Spacing="12">
            <BoxView HeightRequest="16"
                     WidthRequest="140"
                     HorizontalOptions="Start"
                     CornerRadius="4"
                     Color="{StaticResource LightSurfaceStrong}" />
            <BoxView HeightRequest="12"
                     CornerRadius="4"
                     Color="{StaticResource LightSurfaceStrong}" />
            <BoxView HeightRequest="12"
                     WidthRequest="200"
                     HorizontalOptions="Start"
                     CornerRadius="4"
                     Color="{StaticResource LightSurfaceStrong}" />
        </VerticalStackLayout>
    </Border>
</ContentView>