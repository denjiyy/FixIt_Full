<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.HomePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:HomeViewModel"
             BackgroundColor="{StaticResource Background}"
             NavigationPage.HasNavigationBar="False"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Home_Title}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0,0,0,40">

            <!-- Hero Card -->
            <VerticalStackLayout x:Name="HeroBanner" Opacity="0" TranslationY="30">
                <Border Margin="20,28,20,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24"
                        Padding="24,28,24,28">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2563EB" Offset="0" />
                            <GradientStop Color="#1E3A8A" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Spacing="0">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                            <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                <Label Text="{local:Localize Key=Home_Platform}"
                                       TextTransform="Uppercase"
                                       CharacterSpacing="1.5"
                                       FontSize="Caption"
                                       TextColor="#93C5FD" />
                                <Label Text="{Binding Title}"
                                       FontSize="Title"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource White}"
                                       CharacterSpacing="-0.5"
                                       SemanticProperties.HeadingLevel="Level1" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    WidthRequest="48" HeightRequest="48"
                                    MaximumWidthRequest="80"
                                    BackgroundColor="#FFFFFF28"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 24"
                                    VerticalOptions="Start">
                                <Label Text="F"
                                       FontSize="Header"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource White}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <Label Text="{Binding WelcomeMessage}"
                               FontSize="Body"
                               TextColor="#BFDBFE"
                               LineHeight="1.45"
                               Margin="0,0,0,20"
                               SemanticProperties.Description="{Binding WelcomeMessage}" />

                        <Button Text="{local:Localize Key=Home_ReportCTA}"
                                BackgroundColor="{StaticResource White}"
                                TextColor="{StaticResource Primary}"
                                FontAttributes="Bold"
                                FontSize="Body"
                                HeightRequest="52"
                                CornerRadius="14"
                                Command="{Binding ReportIssueCommand}"
                                SemanticProperties.Description="{local:Localize Key=Home_ReportCTA}" />
                        <Button Text="{local:Localize Key=Health_Title}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,12,0,0"
                                Command="{Binding GoToHealthReportCommand}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- Stats Section -->
            <VerticalStackLayout x:Name="StatsSection" Opacity="0" TranslationY="30"
                                 Padding="20,28,20,0" Spacing="14">
                <Label Style="{StaticResource TitleMedium}"
                       Text="{local:Localize Key=Home_LivePulse}"
                       SemanticProperties.HeadingLevel="Level2" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="12" RowSpacing="12">
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StatCard}">
                        <VerticalStackLayout Spacing="6">
                            <Label Style="{StaticResource LabelSmall}"
                                   Text="{local:Localize Key=Home_TotalIssues}" />
                            <Label FontSize="Title" FontAttributes="Bold"
                                   TextColor="{StaticResource Accent}"
                                   Text="{Binding TotalIssues}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource StatCard}">
                        <VerticalStackLayout Spacing="6">
                            <Label Style="{StaticResource LabelSmall}"
                                   Text="{local:Localize Key=Home_Resolved}" />
                            <Label FontSize="Title" FontAttributes="Bold"
                                   TextColor="{StaticResource Success}"
                                   Text="{Binding ResolvedIssues}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource StatCard}">
                        <VerticalStackLayout Spacing="6">
                            <Label Style="{StaticResource LabelSmall}"
                                   Text="{local:Localize Key=Home_InProgress}" />
                            <Label FontSize="Title" FontAttributes="Bold"
                                   TextColor="{StaticResource Warning}"
                                   Text="{Binding InProgressIssues}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource StatCard}">
                        <VerticalStackLayout Spacing="6">
                            <Label Style="{StaticResource LabelSmall}"
                                   Text="{local:Localize Key=Home_Critical}" />
                            <Label FontSize="Title" FontAttributes="Bold"
                                   TextColor="{StaticResource Error}"
                                   Text="{Binding CriticalIssues}" />
                        </VerticalStackLayout>
                    </Border>

                    <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                            Text="Leaderboard"
                            Margin="0"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding GoToLeaderboardCommand}" />
                </Grid>
            </VerticalStackLayout>

            <!-- Quick Actions Section -->
            <VerticalStackLayout x:Name="QuickActionsSection" Opacity="0" TranslationY="30"
                                 Padding="20,28,20,0" Spacing="14">
                <Label Style="{StaticResource TitleMedium}"
                       Text="{local:Localize Key=QuickActions}"
                       SemanticProperties.HeadingLevel="Level2" />

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Border Grid.Column="0" Style="{StaticResource Card}" Padding="14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToHazardMapCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="🗺" FontSize="28" HorizontalOptions="Center" />
                            <Label Text="{local:Localize Key=HazardMap_Title}"
                                   FontSize="Caption"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource OnBackground}"
                                   HorizontalTextAlignment="Center"
                                   MaxLines="2" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToHealthReportCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="📊" FontSize="28" HorizontalOptions="Center" />
                            <Label Text="{local:Localize Key=Health_Title}"
                                   FontSize="Caption"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource OnBackground}"
                                   HorizontalTextAlignment="Center"
                                   MaxLines="2" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}" Padding="14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToLeaderboardCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="🏆" FontSize="28" HorizontalOptions="Center" />
                            <Label Text="{local:Localize Key=Leaderboard_Title}"
                                   FontSize="Caption"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource OnBackground}"
                                   HorizontalTextAlignment="Center"
                                   MaxLines="2" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>

            <!-- Recent Activity Section -->
            <VerticalStackLayout x:Name="RecentSection" Opacity="0" TranslationY="30"
                                 Padding="20,28,20,0" Spacing="14">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Style="{StaticResource TitleMedium}"
                           Text="{local:Localize Key=Home_Recent}"
                           SemanticProperties.HeadingLevel="Level2" />
                    <Label Grid.Column="1"
                           Text="{local:Localize Key=Home_SeeAll}"
                           FontSize="Caption"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Accent}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToIssuesCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <CollectionView ItemsSource="{Binding RecentIssues}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Spacing="0">
                            <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0">
                                <views:SkeletonCardView />
                                <views:SkeletonCardView />
                                <views:SkeletonCardView />
                            </VerticalStackLayout>
                            <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                                 Padding="0,40" Spacing="10"
                                                 HorizontalOptions="Center">
                                <Label Text="📋" FontSize="44" HorizontalOptions="Center" />
                                <Label Text="{local:Localize Key=Home_NoRecent}"
                                       Style="{StaticResource BodyMedium}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Issue">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnIssueTapped" CommandParameter="{Binding Id}" />
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label Grid.Column="0"
                                               Style="{StaticResource TitleMedium}"
                                               Text="{Binding Title}"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation"
                                               SemanticProperties.Description="{Binding Title}" />
                                        <Border Grid.Column="1"
                                                BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                StrokeThickness="0"
                                                Padding="8,4"
                                                StrokeShape="RoundRectangle 8"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding Status}"
                                                   FontSize="Caption"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource White}" />
                                        </Border>
                                    </Grid>
                                    <Label Grid.Row="1"
                                           Style="{StaticResource BodyMedium}"
                                           Text="{Binding Description}"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />
                                    <HorizontalStackLayout Grid.Row="2" Spacing="4">
                                        <Label Text="📍" FontSize="Caption" />
                                        <Label Text="{Binding CityName}" Style="{StaticResource LabelSmall}" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
