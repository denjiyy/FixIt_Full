<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.HomePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:FixIt.Mobile.Controls"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:HomeViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}"
             NavigationPage.HasNavigationBar="False"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Home_Title}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0,0,0,40">

            <!-- Hero Card -->
            <VerticalStackLayout x:Name="HeroBanner" Opacity="0" TranslationY="30">
                <Border Margin="20,28,20,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        Padding="24,26"
                        Background="{StaticResource PrimaryBrush}">
                    <VerticalStackLayout Spacing="0">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                            <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                <Label Text="{local:Localize Key=Home_Platform}"
                                       CharacterSpacing="0.6"
                                       FontSize="Caption"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource White}"
                                       Opacity="0.8" />
                                <Label Text="{Binding Title}"
                                       FontSize="Title"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource White}"
                                       CharacterSpacing="-0.5"
                                       SemanticProperties.HeadingLevel="Level1" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    WidthRequest="48" HeightRequest="48"
                                    MaximumWidthRequest="80"
                                    BackgroundColor="#33FFFFFF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 24"
                                    VerticalOptions="Start">
                                <Label Text="F"
                                       FontSize="Header"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource White}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <Label Text="{Binding WelcomeMessage}"
                               FontSize="Body"
                               TextColor="{StaticResource White}"
                               Opacity="0.9"
                               LineHeight="1.45"
                               Margin="0,0,0,20"
                               SemanticProperties.Description="{Binding WelcomeMessage}" />

                        <Button Text="{local:Localize Key=Home_ReportCTA}"
                                BackgroundColor="{StaticResource White}"
                                TextColor="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimaryStrong}}"
                                FontAttributes="Bold"
                                FontSize="Body"
                                HeightRequest="52"
                                CornerRadius="14"
                                Command="{Binding ReportIssueCommand}"
                                SemanticProperties.Description="{local:Localize Key=Home_ReportCTA}" />
                        <Button Text="{local:Localize Key=Health_Title}"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource White}"
                                BorderColor="#80FFFFFF"
                                BorderWidth="1"
                                FontAttributes="Bold"
                                FontSize="Body"
                                HeightRequest="52"
                                CornerRadius="14"
                                Margin="0,12,0,0"
                                Command="{Binding GoToHealthReportCommand}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- Stats Section -->
            <VerticalStackLayout x:Name="StatsSection" Opacity="0" TranslationY="30"
                                 Padding="20,28,20,0" Spacing="14">
                <Label Style="{StaticResource TitleMedium}"
                       Text="{local:Localize Key=Home_LivePulse}"
                       SemanticProperties.HeadingLevel="Level2" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="12" RowSpacing="12">
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StatCard}">
                        <VerticalStackLayout Spacing="6">
                            <Label Style="{StaticResource LabelSmall}"
                                   Text="{local:Localize Key=Home_TotalIssues}" />
                            <Label FontSize="Title" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource DarkAccent}}"
                                   Text="{Binding TotalIssues}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource StatCard}">
                        <VerticalStackLayout Spacing="6">
                            <Label Style="{StaticResource LabelSmall}"
                                   Text="{local:Localize Key=Home_Resolved}" />
                            <Label FontSize="Title" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource LightSuccess}, Dark={StaticResource DarkSuccess}}"
                                   Text="{Binding ResolvedIssues}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource StatCard}">
                        <VerticalStackLayout Spacing="6">
                            <Label Style="{StaticResource LabelSmall}"
                                   Text="{local:Localize Key=Home_InProgress}" />
                            <Label FontSize="Title" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource LightWarning}, Dark={StaticResource DarkWarning}}"
                                   Text="{Binding InProgressIssues}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource StatCard}">
                        <VerticalStackLayout Spacing="6">
                            <Label Style="{StaticResource LabelSmall}"
                                   Text="{local:Localize Key=Home_Critical}" />
                            <Label FontSize="Title" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource LightDanger}, Dark={StaticResource DarkDanger}}"
                                   Text="{Binding CriticalIssues}" />
                        </VerticalStackLayout>
                    </Border>

                    <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                            Text="{local:Localize Key=Leaderboard_Title}"
                            Margin="0"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding GoToLeaderboardCommand}" />
                </Grid>
            </VerticalStackLayout>

            <!-- Quick Actions Section -->
            <VerticalStackLayout x:Name="QuickActionsSection" Opacity="0" TranslationY="30"
                                 Padding="20,28,20,0" Spacing="14">
                <Label Style="{StaticResource TitleMedium}"
                       Text="{local:Localize Key=QuickActions}"
                       SemanticProperties.HeadingLevel="Level2" />

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Border Grid.Column="0" Style="{StaticResource Card}" Padding="14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToHazardMapCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Image Source="map.png" WidthRequest="32" HeightRequest="32" HorizontalOptions="Center" />
                            <Label Text="{local:Localize Key=HazardMap_Title}"
                                   FontSize="Caption"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}"
                                   HorizontalTextAlignment="Center"
                                   MaxLines="2" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToHealthReportCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Image Source="chart.png" WidthRequest="32" HeightRequest="32" HorizontalOptions="Center" />
                            <Label Text="{local:Localize Key=Health_Title}"
                                   FontSize="Caption"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}"
                                   HorizontalTextAlignment="Center"
                                   MaxLines="2" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}" Padding="14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToLeaderboardCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Image Source="trophy.png" WidthRequest="32" HeightRequest="32" HorizontalOptions="Center" />
                            <Label Text="{local:Localize Key=Leaderboard_Title}"
                                   FontSize="Caption"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}"
                                   HorizontalTextAlignment="Center"
                                   MaxLines="2" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>

            <!-- Recent Activity Section -->
            <VerticalStackLayout x:Name="RecentSection" Opacity="0" TranslationY="30"
                                 Padding="20,28,20,0" Spacing="14">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Style="{StaticResource TitleMedium}"
                           Text="{local:Localize Key=Home_Recent}"
                           SemanticProperties.HeadingLevel="Level2" />
                    <Label Grid.Column="1"
                           Text="{local:Localize Key=Home_SeeAll}"
                           FontSize="Caption"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource DarkAccent}}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToIssuesCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <CollectionView ItemsSource="{Binding RecentIssues}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Spacing="0">
                            <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0">
                                <views:SkeletonCardView />
                                <views:SkeletonCardView />
                                <views:SkeletonCardView />
                            </VerticalStackLayout>
                            <controls:EmptyStateView IsVisible="{Binding IsEmpty}"
                                                     IconSource="checklist.png"
                                                     Title="{local:Localize Key=Home_NoRecent}" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Issue">
                            <Border Style="{StaticResource IssueCardBorder}" Margin="0,0,0,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnIssueTapped" CommandParameter="{Binding Id}" />
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label Grid.Column="0"
                                               Style="{StaticResource TitleMedium}"
                                               Text="{Binding Title}"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation"
                                               SemanticProperties.Description="{Binding Title}" />
                                        <Border Grid.Column="1"
                                                Style="{StaticResource StatusBadge}"
                                                BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                            <Label Text="{Binding Status}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   CharacterSpacing="0.2"
                                                   TextColor="{StaticResource White}"
                                                   VerticalTextAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Label Grid.Row="1"
                                           Style="{StaticResource BodyMedium}"
                                           Text="{Binding Description}"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />
                                    <HorizontalStackLayout Grid.Row="2" Spacing="6">
                                        <Image Source="pin.png" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                                        <Label Text="{Binding CityName}" Style="{StaticResource LabelSmall}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
