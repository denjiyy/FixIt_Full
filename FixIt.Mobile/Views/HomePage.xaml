<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.HomePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:FixIt.Mobile.Controls"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Name="PageRoot"
             x:DataType="viewModels:HomeViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Home_Title}">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="AvatarBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" Offset="0" />
            <GradientStop Color="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimaryStrong}}" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="LogoBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimaryStrong}}" Offset="0" />
            <GradientStop Color="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" Offset="1" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ============ Top bar ============ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}">
            <Grid ColumnDefinitions="Auto,*,Auto" Padding="18,6,10,10" ColumnSpacing="9" VerticalOptions="Center">
                <Border Grid.Column="0"
                        WidthRequest="30" HeightRequest="30"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 9"
                        Background="{StaticResource LogoBrush}"
                        VerticalOptions="Center">
                    <Label Text="F" FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource White}"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Grid.Column="1"
                       Text="{local:Localize Key=Home_Title}"
                       FontSize="21" FontAttributes="Bold"
                       CharacterSpacing="-0.5"
                       TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}"
                       VerticalOptions="Center"
                       SemanticProperties.HeadingLevel="Level1" />
                <HorizontalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Center">
                    <ImageButton Source="map.png" WidthRequest="42" HeightRequest="42"
                                 Padding="9" BackgroundColor="Transparent"
                                 Command="{Binding GoToHazardMapCommand}"
                                 SemanticProperties.Description="{local:Localize Key=HazardMode_Title}">
                        <ImageButton.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource LightOnSurface}, Dark={StaticResource DarkOnSurface}}" />
                        </ImageButton.Behaviors>
                    </ImageButton>
                    <ImageButton Source="trophy.png" WidthRequest="42" HeightRequest="42"
                                 Padding="9" BackgroundColor="Transparent"
                                 Command="{Binding GoToLeaderboardCommand}"
                                 SemanticProperties.Description="{local:Localize Key=Leaderboard_Title}">
                        <ImageButton.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource LightOnSurface}, Dark={StaticResource DarkOnSurface}}" />
                        </ImageButton.Behaviors>
                    </ImageButton>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- ============ Feed ============ -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsLoading}"
                     RefreshColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}">
            <CollectionView ItemsSource="{Binding FeedIssues}"
                            SelectionMode="None">

                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="0" Padding="16,16,16,0">
                        <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0">
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                        </VerticalStackLayout>
                        <controls:EmptyStateView IsVisible="{Binding IsEmpty}"
                                                 IconSource="checklist.png"
                                                 Title="{local:Localize Key=Feed_Empty}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.Footer>
                    <BoxView HeightRequest="24" Color="Transparent" />
                </CollectionView.Footer>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Issue">
                        <Border Margin="16,14,16,0"
                                Padding="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                                Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 20">
                            <Border.Shadow>
                                <Shadow Brush="{StaticResource ShadowBrush}"
                                        Opacity="{AppThemeBinding Light=0.06, Dark=0.4}"
                                        Offset="0,2" Radius="12" />
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="0">

                                <!-- Head -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,16,12,12" ColumnSpacing="11">
                                    <Border Grid.Column="0"
                                            WidthRequest="40" HeightRequest="40"
                                            StrokeThickness="0"
                                            Background="{StaticResource AvatarBrush}"
                                            StrokeShape="RoundRectangle 999"
                                            VerticalOptions="Center">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.OpenProfileCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding AuthorInitials}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource White}"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                        <VerticalStackLayout.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.OpenProfileCommand}"
                                                CommandParameter="{Binding .}" />
                                        </VerticalStackLayout.GestureRecognizers>
                                        <Label Text="{Binding AuthorName}"
                                               FontSize="14.5" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}"
                                               LineBreakMode="TailTruncation" MaxLines="1" />
                                        <HorizontalStackLayout Spacing="5">
                                            <Image Source="feed_geo.png" WidthRequest="12" HeightRequest="12" VerticalOptions="Center" />
                                            <Label FontSize="12.5"
                                                   TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}"
                                                   LineBreakMode="TailTruncation" MaxLines="1" VerticalOptions="Center">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding PrimaryLocation}" />
                                                        <Span Text="  ·  " />
                                                        <Span Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelativeConverter}}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <Image Grid.Column="2" Source="feed_more.png"
                                           WidthRequest="18" HeightRequest="18"
                                           VerticalOptions="Center" />
                                </Grid>

                                <!-- Photo -->
                                <Grid HeightRequest="240">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.NavigateToIssueCommand}"
                                            CommandParameter="{Binding Id}" />
                                    </Grid.GestureRecognizers>

                                    <!-- placeholder (no photo) -->
                                    <Border IsVisible="{Binding HasPhoto, Converter={StaticResource InverseBoolConverter}}"
                                            StrokeThickness="0"
                                            Background="{Binding Category, Converter={StaticResource CategoryToBrushConverter}}">
                                        <Border IsVisible="{Binding Category, Converter={StaticResource StringNotEmptyConverter}}"
                                                StrokeThickness="0"
                                                BackgroundColor="#52000000"
                                                StrokeShape="RoundRectangle 999"
                                                Padding="11,5"
                                                HorizontalOptions="Center" VerticalOptions="Center">
                                            <Label Text="{Binding Category}"
                                                   FontSize="11" CharacterSpacing="0.6"
                                                   TextColor="#F2FFFFFF" />
                                        </Border>
                                    </Border>

                                    <!-- real photo -->
                                    <Image IsVisible="{Binding HasPhoto}"
                                           Source="{Binding PhotoUrl}"
                                           Aspect="AspectFill" />

                                    <!-- badges -->
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="12" VerticalOptions="Start">
                                        <Border Grid.Column="0"
                                                IsVisible="{Binding Priority, Converter={StaticResource StringNotEmptyConverter}}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 999"
                                                Padding="10,5"
                                                BackgroundColor="{Binding Priority, Converter={StaticResource PriorityToColorConverter}}">
                                            <Label Text="{Binding Priority}"
                                                   FontSize="11" FontAttributes="Bold"
                                                   CharacterSpacing="0.2"
                                                   TextColor="{StaticResource White}" />
                                        </Border>
                                        <Border Grid.Column="2"
                                                IsVisible="{Binding Status, Converter={StaticResource StringNotEmptyConverter}}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 999"
                                                Padding="10,5"
                                                BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                            <Label Text="{Binding Status}"
                                                   FontSize="11" FontAttributes="Bold"
                                                   CharacterSpacing="0.2"
                                                   TextColor="{StaticResource White}" />
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- Actions -->
                                <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto"
                                      Padding="12,10,12,2" ColumnSpacing="2">
                                    <Button Grid.Column="0"
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.UpvoteCommand}"
                                            CommandParameter="{Binding .}"
                                            ContentLayout="Left,6"
                                            BackgroundColor="Transparent"
                                            Padding="8,6"
                                            FontSize="13.5" FontAttributes="Bold"
                                            Text="{Binding VoteCount}"
                                            TextColor="{AppThemeBinding Light={StaticResource LightOnSurface}, Dark={StaticResource DarkOnSurface}}">
                                        <Button.ImageSource>
                                            <FileImageSource File="feed_upvote.png" />
                                        </Button.ImageSource>
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding UserHasUpvoted}" Value="True">
                                                <Setter Property="ImageSource" Value="feed_upvote_on.png" />
                                                <Setter Property="TextColor"
                                                        Value="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimary}}" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>

                                    <Button Grid.Column="1"
                                            Clicked="OnCommentClicked"
                                            BackgroundColor="Transparent"
                                            Padding="8,6">
                                        <Button.ImageSource>
                                            <FileImageSource File="feed_comment.png" />
                                        </Button.ImageSource>
                                    </Button>

                                    <Button Grid.Column="2"
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.ShareCommand}"
                                            CommandParameter="{Binding .}"
                                            ContentLayout="Left,6"
                                            BackgroundColor="Transparent"
                                            Padding="8,6"
                                            FontSize="13.5" FontAttributes="Bold"
                                            Text="{local:Localize Key=Feed_Share}"
                                            TextColor="{AppThemeBinding Light={StaticResource LightOnSurface}, Dark={StaticResource DarkOnSurface}}">
                                        <Button.ImageSource>
                                            <FileImageSource File="feed_share.png" />
                                        </Button.ImageSource>
                                    </Button>

                                    <Button Grid.Column="4"
                                            Clicked="OnSaveClicked"
                                            BackgroundColor="Transparent"
                                            Padding="8,6">
                                        <Button.ImageSource>
                                            <FileImageSource File="feed_save.png" />
                                        </Button.ImageSource>
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsSaved}" Value="True">
                                                <Setter Property="ImageSource" Value="feed_save_on.png" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                </Grid>

                                <!-- Body -->
                                <VerticalStackLayout Padding="16,4,16,16" Spacing="0">
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.NavigateToIssueCommand}"
                                            CommandParameter="{Binding Id}" />
                                    </VerticalStackLayout.GestureRecognizers>

                                    <Label Text="{Binding Title}"
                                           FontSize="16" FontAttributes="Bold"
                                           CharacterSpacing="-0.1" LineHeight="1.3"
                                           Margin="0,4,0,5"
                                           TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}"
                                           MaxLines="2" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Description}"
                                           FontSize="13.5" LineHeight="1.5"
                                           TextColor="{AppThemeBinding Light={StaticResource LightOnSurface}, Dark={StaticResource DarkOnSurface}}"
                                           MaxLines="3" LineBreakMode="TailTruncation" />

                                    <FlexLayout IsVisible="{Binding HasTags}"
                                                Wrap="Wrap" Margin="0,10,0,0"
                                                BindableLayout.ItemsSource="{Binding Tags}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Label Text="{Binding ., Converter={StaticResource HashtagConverter}}"
                                                       FontSize="12" FontAttributes="Bold"
                                                       Margin="0,0,8,0"
                                                       TextColor="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimary}}" />
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </FlexLayout>

                                    <BoxView HeightRequest="1" Margin="0,11,0,11"
                                             Color="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}" />

                                    <HorizontalStackLayout Spacing="14">
                                        <HorizontalStackLayout Spacing="5">
                                            <Image Source="feed_people.png" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                                            <Label FontSize="12" FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}"
                                                   VerticalOptions="Center">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding WatchersCount}" />
                                                        <Span Text=" " />
                                                        <Span Text="{local:Localize Key=Feed_Watching}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="5">
                                            <Image Source="feed_clock.png" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                                            <Label FontSize="12" FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}"
                                                   VerticalOptions="Center">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{local:Localize Key=Feed_Updated}" />
                                                        <Span Text=" " />
                                                        <Span Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelativeConverter}}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <controls:AppTabBar Grid.Row="2" Active="home" />
    </Grid>
</ContentPage>
