<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:SettingsViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Settings_Privacy_Title}">
    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="18">

            <!-- Appearance -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{local:Localize Key=Settings_Appearance_Title}"
                           Style="{StaticResource HeadlineMedium}" />
                    <Label Text="{local:Localize Key=Settings_Appearance_Description}"
                           Style="{StaticResource LabelSmall}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="{local:Localize Key=Settings_Appearance_System}"
                                Command="{Binding SelectThemeCommand}"
                                CommandParameter="system"
                                Style="{StaticResource OutlineToggleButton}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsThemeSystem}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                                    <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                                    <Setter Property="TextColor" Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="{local:Localize Key=Settings_Appearance_Light}"
                                Command="{Binding SelectThemeCommand}"
                                CommandParameter="light"
                                Style="{StaticResource OutlineToggleButton}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsThemeLight}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                                    <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                                    <Setter Property="TextColor" Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="{local:Localize Key=Settings_Appearance_Dark}"
                                Command="{Binding SelectThemeCommand}"
                                CommandParameter="dark"
                                Style="{StaticResource OutlineToggleButton}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsThemeDark}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                                    <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                                    <Setter Property="TextColor" Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Privacy -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{local:Localize Key=Settings_Privacy_Title}"
                           Style="{StaticResource HeadlineMedium}" />
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="{local:Localize Key=Settings_Privacy_AnonymousReporting}"
                               Style="{StaticResource BodyMedium}" />
                        <Label Grid.Row="1" Grid.Column="0"
                               Text="{local:Localize Key=Settings_Privacy_AnonymousReportingHint}"
                               Style="{StaticResource LabelSmall}" />
                        <Switch Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                IsToggled="{Binding AnonymousReporting}"
                                OnColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}"
                                ThumbColor="{StaticResource White}"
                                Toggled="OnAnonymousToggled"
                                VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Alerts -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{local:Localize Key=Settings_Alerts_Title}"
                           Style="{StaticResource HeadlineMedium}" />

                    <Grid ColumnDefinitions="*,Auto" RowSpacing="6">
                        <Label Text="{local:Localize Key=Settings_Alerts_Crime}" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding CrimeAlerts}"
                                OnColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" RowSpacing="6">
                        <Label Text="{local:Localize Key=Settings_Alerts_Accident}" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding AccidentAlerts}"
                                OnColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" RowSpacing="6">
                        <Label Text="{local:Localize Key=Settings_Alerts_Infrastructure}" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding InfrastructureAlerts}"
                                OnColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" RowSpacing="6">
                        <Label Text="{local:Localize Key=Settings_Alerts_Radius}" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding RadiusLabel}" Style="{StaticResource LabelSmall}" VerticalOptions="Center" />
                    </Grid>
                    <Slider Minimum="1" Maximum="20" Value="{Binding RadiusKm}"
                            MinimumTrackColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}"
                            ThumbColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />

                    <Label Text="{local:Localize Key=Settings_Alerts_Severity}" Style="{StaticResource BodyMedium}" />
                    <Picker ItemsSource="{Binding SeverityOptions}" SelectedItem="{Binding SeverityThreshold}"
                            TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}" />

                    <Button Text="{local:Localize Key=Settings_Alerts_Save}"
                            Command="{Binding SaveAlertsCommand}"
                            Style="{StaticResource PrimaryButton}" />
                </VerticalStackLayout>
            </Border>

            <!-- Profile visibility -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{local:Localize Key=Settings_ProfileVisibility_Title}"
                           Style="{StaticResource HeadlineMedium}" />
                    <Picker ItemsSource="{Binding VisibilityOptions}" SelectedItem="{Binding ProfileVisibility}"
                            TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}" />
                    <Button Text="{local:Localize Key=Settings_ProfileVisibility_Save}"
                            Command="{Binding SaveVisibilityCommand}"
                            Style="{StaticResource PrimaryButton}" />
                </VerticalStackLayout>
            </Border>

            <!-- City Preference -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{local:Localize Key=Settings_CityPreference}"
                           Style="{StaticResource HeadlineMedium}" />
                    <Picker ItemsSource="{Binding CityNames}"
                            SelectedItem="{Binding SelectedCityName}"
                            TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}" />
                    <Button Text="{local:Localize Key=Settings_Alerts_Save}"
                            Command="{Binding SaveCityPreferenceCommand}"
                            Style="{StaticResource PrimaryButton}" />
                </VerticalStackLayout>
            </Border>

            <!-- Email Preferences -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{local:Localize Key=Settings_EmailPreferences}"
                           Style="{StaticResource HeadlineMedium}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{local:Localize Key=Settings_EmailMaster}" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding EmailEnabled}"
                                OnColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding EmailEnabled}">
                        <Label Text="{local:Localize Key=Settings_WeeklyReports}" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding WeeklyReports}"
                                OnColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding EmailEnabled}">
                        <Label Text="{local:Localize Key=Settings_SafetyAlerts}" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding EmailSafetyAlerts}"
                                OnColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding EmailEnabled}">
                        <Label Text="{local:Localize Key=Settings_Reminders}" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding EmailReminders}"
                                OnColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                    </Grid>

                    <Button Text="{local:Localize Key=Settings_Alerts_Save}"
                            Command="{Binding SaveEmailPreferencesCommand}"
                            Style="{StaticResource PrimaryButton}"
                            IsVisible="{Binding EmailEnabled}" />
                </VerticalStackLayout>
            </Border>

            <!-- Connected Accounts -->
            <Button Text="{local:Localize Key=ConnectedAccounts_Title}"
                    Style="{StaticResource SecondaryButton}"
                    Clicked="OnConnectedAccountsClicked" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
