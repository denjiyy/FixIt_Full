<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.RegisterPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:RegisterViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}"
             NavigationPage.HasNavigationBar="False"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Register_SignUp}">

    <ScrollView>
        <Grid Padding="0,0,0,40" MinimumHeightRequest="700">
            <ContentView VerticalOptions="Center">
                <VerticalStackLayout Padding="28,0" Spacing="0">

                    <!-- Logo block -->
                    <VerticalStackLayout x:Name="LogoBlock"
                                         Scale="0.8" Opacity="0"
                                         HorizontalOptions="Center"
                                         Spacing="0"
                                         Margin="0,0,0,40">
                        <Border WidthRequest="72" HeightRequest="72"
                                BackgroundColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 36"
                                HorizontalOptions="Center"
                                Margin="0,0,0,20">
                            <Border.Shadow>
                                <Shadow Brush="{StaticResource PrimaryBrush}"
                                        Opacity="0.35"
                                        Offset="0,6"
                                        Radius="14" />
                            </Border.Shadow>
                            <Label Text="F"
                                   FontSize="Title"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource White}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <Label Text="{local:Localize Key=Register_Title}"
                               Style="{StaticResource HeadlineMedium}"
                               HorizontalTextAlignment="Center"
                               SemanticProperties.HeadingLevel="Level1" />
                        <Label Text="{local:Localize Key=Register_Subtitle}"
                               Style="{StaticResource BodyMedium}"
                               TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}"
                               HorizontalTextAlignment="Center"
                               Margin="0,8,0,0" />
                    </VerticalStackLayout>

                    <!-- Form block -->
                    <VerticalStackLayout x:Name="FormBlock" Opacity="0" TranslationY="20" Spacing="0">

                        <Border Style="{StaticResource EntryCard}" Margin="0,0,0,6">
                            <Entry Placeholder="{local:Localize Key=Register_FullNamePlaceholder}"
                                   Text="{Binding FullName}"
                                   SemanticProperties.Hint="{local:Localize Key=Register_FullNamePlaceholder}" />
                        </Border>
                        <Label Text="{Binding FullNameError}"
                               TextColor="{AppThemeBinding Light={StaticResource LightDanger}, Dark={StaticResource DarkDanger}}"
                               FontSize="Caption"
                               IsVisible="{Binding HasFullNameError}"
                               Margin="4,0,0,10" />

                        <Border Style="{StaticResource EntryCard}" Margin="0,0,0,6">
                            <Entry Keyboard="Email"
                                   Placeholder="{local:Localize Key=Register_EmailPlaceholder}"
                                   Text="{Binding Email}"
                                   SemanticProperties.Hint="{local:Localize Key=Register_EmailPlaceholder}" />
                        </Border>
                        <Label Text="{Binding EmailError}"
                               TextColor="{AppThemeBinding Light={StaticResource LightDanger}, Dark={StaticResource DarkDanger}}"
                               FontSize="Caption"
                               IsVisible="{Binding HasEmailError}"
                               Margin="4,0,0,10" />

                        <Border Style="{StaticResource EntryCard}" Margin="0,0,0,6">
                            <Entry IsPassword="True"
                                   Placeholder="{local:Localize Key=Register_PasswordPlaceholder}"
                                   Text="{Binding Password}"
                                   SemanticProperties.Hint="{local:Localize Key=Register_PasswordPlaceholder}" />
                        </Border>
                        <Label Text="{Binding PasswordError}"
                               TextColor="{AppThemeBinding Light={StaticResource LightDanger}, Dark={StaticResource DarkDanger}}"
                               FontSize="Caption"
                               IsVisible="{Binding HasPasswordError}"
                               Margin="4,0,0,10" />

                        <Border Style="{StaticResource EntryCard}" Margin="0,0,0,6">
                            <Entry IsPassword="True"
                                   Placeholder="{local:Localize Key=Register_ConfirmPasswordPlaceholder}"
                                   Text="{Binding ConfirmPassword}"
                                   SemanticProperties.Hint="{local:Localize Key=Register_ConfirmPasswordPlaceholder}" />
                        </Border>
                        <Label Text="{Binding ConfirmPasswordError}"
                               TextColor="{AppThemeBinding Light={StaticResource LightDanger}, Dark={StaticResource DarkDanger}}"
                               FontSize="Caption"
                               IsVisible="{Binding HasConfirmPasswordError}"
                               Margin="4,2,0,0" />

                        <Label Text="{Binding ErrorMessage}"
                               TextColor="{AppThemeBinding Light={StaticResource LightDanger}, Dark={StaticResource DarkDanger}}"
                               FontSize="Caption"
                               IsVisible="{Binding HasError}"
                               HorizontalTextAlignment="Center"
                               Margin="0,0,0,14" />

                        <Button Text="{local:Localize Key=Register_CreateAccount}"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding RegisterCommand}"
                                Margin="0,8,0,0"
                                SemanticProperties.Description="{local:Localize Key=Register_CreateAccount}" />

                        <ActivityIndicator IsRunning="{Binding IsLoading}"
                                           IsVisible="{Binding IsLoading}"
                                           Color="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}"
                                           Margin="0,20,0,0" />

                        <Label HorizontalOptions="Center" Margin="0,28,0,0">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{local:Localize Key=Register_AlreadyHaveAccount}"
                                          TextColor="{AppThemeBinding Light={StaticResource LightOnSurface}, Dark={StaticResource DarkOnSurface}}"
                                          FontSize="Caption" />
                                    <Span Text=" " />
                                    <Span Text="{local:Localize Key=Register_SignIn}"
                                          TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource DarkAccent}}"
                                          FontAttributes="Bold"
                                          FontSize="Caption" />
                                </FormattedString>
                            </Label.FormattedText>
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ContentView>
        </Grid>
    </ScrollView>
</ContentPage>
