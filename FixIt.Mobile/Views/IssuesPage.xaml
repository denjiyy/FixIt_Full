<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.IssuesPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:constants="clr-namespace:FixIt.Mobile.Constants"
             xmlns:controls="clr-namespace:FixIt.Mobile.Controls"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:IssuesViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Explore_Title}">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

        <!-- ============ Top bar ============ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}">
            <Grid ColumnDefinitions="*,Auto" Padding="18,6,10,10" VerticalOptions="Center">
                <Label Grid.Column="0"
                       Text="{local:Localize Key=Explore_Title}"
                       FontSize="21" FontAttributes="Bold"
                       CharacterSpacing="-0.5"
                       TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}"
                       VerticalOptions="Center"
                       SemanticProperties.HeadingLevel="Level1" />
                <ImageButton Grid.Column="1"
                             Source="map.png" WidthRequest="42" HeightRequest="42"
                             Padding="9" BackgroundColor="Transparent"
                             Command="{Binding GoToHazardMapCommand}"
                             SemanticProperties.Description="{local:Localize Key=HazardMode_Title}" />
            </Grid>
        </Border>

        <!-- ============ Search bar ============ -->
        <Border Grid.Row="1"
                Margin="16,12,16,0"
                HeightRequest="48"
                Padding="14,0"
                StrokeThickness="1"
                Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurfaceMuted}, Dark={StaticResource DarkSurface}}"
                StrokeShape="RoundRectangle 14">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="9">
                <Image Grid.Column="0" Source="feed_search.png" WidthRequest="17" HeightRequest="17" VerticalOptions="Center" />
                <Entry Grid.Column="1"
                       Placeholder="{local:Localize Key=Explore_SearchPlaceholder}"
                       Text="{Binding SearchText}"
                       ClearButtonVisibility="WhileEditing"
                       ReturnType="Search"
                       VerticalOptions="Center"
                       SemanticProperties.Hint="{local:Localize Key=Explore_SearchPlaceholder}" />
                <Image Grid.Column="2" Source="feed_sliders.png" WidthRequest="17" HeightRequest="17" VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- ============ Natural-language (AI) filter ============ -->
        <Grid Grid.Row="2"
              Margin="16,10,16,0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8">
            <Border Style="{StaticResource EntryCard}" HeightRequest="44">
                <Entry Placeholder="{local:Localize Key=Issues_AIFilter_Placeholder}"
                       Text="{Binding NaturalLanguageQuery}"
                       ReturnType="Search"
                       VerticalOptions="Center"
                       SemanticProperties.Hint="{local:Localize Key=Issues_AIFilter_Placeholder}" />
            </Border>
            <Button Grid.Column="1"
                    Text="{local:Localize Key=Issues_AIFilter_Button}"
                    Style="{StaticResource CompactPrimaryButton}"
                    Command="{Binding ApplyNaturalLanguageFilterCommand}" />
        </Grid>

        <!-- ============ Filter chips ============ -->
        <ScrollView Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,12,0,2"
                    HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Padding="16,0" Spacing="8">

                <Border Style="{StaticResource FilterChipBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetFilterCommand}"
                                              CommandParameter="{x:Static constants:AppConstants.FilterAll}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsAllFilterActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{local:Localize Key=Issues_Filter_All}"
                           FontSize="12.5" FontAttributes="Bold"
                           VerticalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsAllFilterActive}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <Border Style="{StaticResource FilterChipBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetFilterCommand}"
                                              CommandParameter="{x:Static constants:AppConstants.FilterNew}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsNewFilterActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{local:Localize Key=Issues_Filter_New}"
                           FontSize="12.5" FontAttributes="Bold"
                           VerticalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsNewFilterActive}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <Border Style="{StaticResource FilterChipBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetFilterCommand}"
                                              CommandParameter="{x:Static constants:AppConstants.FilterInProgress}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsInProgressFilterActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{local:Localize Key=Issues_Filter_InProgress}"
                           FontSize="12.5" FontAttributes="Bold"
                           VerticalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsInProgressFilterActive}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <Border Style="{StaticResource FilterChipBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetFilterCommand}"
                                              CommandParameter="{x:Static constants:AppConstants.FilterResolved}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsResolvedFilterActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{local:Localize Key=Issues_Filter_Resolved}"
                           FontSize="12.5" FontAttributes="Bold"
                           VerticalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsResolvedFilterActive}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- ============ Photo grid ============ -->
        <RefreshView Grid.Row="4"
                     Command="{Binding RefreshIssuesCommand}"
                     IsRefreshing="{Binding IsLoading}"
                     RefreshColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}"
                     Margin="0,10,0,0">
            <CollectionView x:Name="IssuesCollection"
                            ItemsSource="{Binding Issues}"
                            Margin="3,0"
                            Opacity="0"
                            TranslationY="40"
                            SelectionMode="None"
                            RemainingItemsThreshold="6"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreIssuesCommand}">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="3"
                                     HorizontalItemSpacing="3" VerticalItemSpacing="3" />
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="0" Padding="16,0">
                        <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0">
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                        </VerticalStackLayout>
                        <controls:EmptyStateView IsVisible="{Binding IsEmpty}"
                                                 IconSource="checklist.png"
                                                 Title="{local:Localize Key=Issues_Empty_Title}"
                                                 Subtitle="{local:Localize Key=Issues_Empty_Subtitle}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.Footer>
                    <ActivityIndicator IsRunning="{Binding IsLoadingMore}"
                                       IsVisible="{Binding IsLoadingMore}"
                                       Color="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}"
                                       Margin="0,12,0,32" />
                </CollectionView.Footer>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Issue">
                        <Grid HeightRequest="168">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnIssueTapped" CommandParameter="{Binding Id}" />
                            </Grid.GestureRecognizers>

                            <!-- category-tinted backdrop -->
                            <Border StrokeThickness="0"
                                    Background="{Binding Category, Converter={StaticResource CategoryToBrushConverter}}" />

                            <!-- category glyph (hidden once a real photo loads) -->
                            <Image Source="{Binding Category, Converter={StaticResource CategoryToIconConverter}}"
                                   WidthRequest="30" HeightRequest="30" Opacity="0.92"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   Margin="0,0,0,8">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="White" />
                                </Image.Behaviors>
                            </Image>

                            <!-- real photo -->
                            <Image IsVisible="{Binding HasPhoto}"
                                   Source="{Binding PhotoUrl}"
                                   Aspect="AspectFill" />

                            <!-- priority dot -->
                            <Border WidthRequest="16" HeightRequest="16"
                                    Margin="7"
                                    StrokeThickness="2"
                                    Stroke="{StaticResource White}"
                                    StrokeShape="RoundRectangle 999"
                                    HorizontalOptions="End" VerticalOptions="Start"
                                    IsVisible="{Binding Priority, Converter={StaticResource StringNotEmptyConverter}}"
                                    BackgroundColor="{Binding Priority, Converter={StaticResource PriorityToColorConverter}}" />

                            <!-- location overlay -->
                            <Border VerticalOptions="End" StrokeThickness="0" HeightRequest="40" InputTransparent="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#00000000" Offset="0.0" />
                                        <GradientStop Color="#99000000" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <HorizontalStackLayout VerticalOptions="End" Padding="7,0,7,6" Spacing="3" InputTransparent="True">
                                <Image Source="feed_geo.png" WidthRequest="11" HeightRequest="11" VerticalOptions="Center">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="White" />
                                    </Image.Behaviors>
                                </Image>
                                <Label Text="{Binding CityName}"
                                       FontSize="10.5" FontAttributes="Bold"
                                       TextColor="{StaticResource White}"
                                       LineBreakMode="TailTruncation" MaxLines="1"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <controls:AppTabBar Grid.Row="5" Active="explore" />
    </Grid>
</ContentPage>
