<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.IssuesPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:constants="clr-namespace:FixIt.Mobile.Constants"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:IssuesViewModel"
             BackgroundColor="{StaticResource Background}"
             NavigationPage.HasNavigationBar="False"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Issues_Title}">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Header -->
        <Label Grid.Row="0"
               Text="{local:Localize Key=Issues_Title}"
               Style="{StaticResource HeadlineLarge}"
               Margin="24,28,24,16"
               SemanticProperties.HeadingLevel="Level1" />

        <!-- Search Bar -->
        <Border Grid.Row="1"
                Margin="20,0,20,0"
                Style="{StaticResource EntryCard}">
            <Entry Placeholder="{local:Localize Key=Issues_SearchPlaceholder}"
                   PlaceholderColor="{StaticResource OnSurfaceMuted}"
                   TextColor="{StaticResource OnBackground}"
                   Text="{Binding SearchText}"
                   ClearButtonVisibility="WhileEditing"
                   ReturnType="Search"
                   SemanticProperties.Hint="{local:Localize Key=Issues_SearchPlaceholder}" />
        </Border>

        <!-- Filter Chips -->
        <ScrollView Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,14,0,0"
                    HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Padding="20,0" Spacing="8">

                <Border StrokeShape="RoundRectangle 20" Padding="16,9"
                        MinimumHeightRequest="44"
                        BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource Surface2}" StrokeThickness="1">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetFilterCommand}"
                                              CommandParameter="{x:Static constants:AppConstants.FilterAll}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsAllFilterActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="Stroke" Value="{StaticResource Primary}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{local:Localize Key=Issues_Filter_All}"
                           FontSize="Caption" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceMuted}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsAllFilterActive}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Padding="16,9"
                        MinimumHeightRequest="44"
                        BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource Surface2}" StrokeThickness="1">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetFilterCommand}"
                                              CommandParameter="{x:Static constants:AppConstants.FilterNew}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsNewFilterActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="Stroke" Value="{StaticResource Primary}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{local:Localize Key=Issues_Filter_New}"
                           FontSize="Caption" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceMuted}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsNewFilterActive}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Padding="16,9"
                        MinimumHeightRequest="44"
                        BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource Surface2}" StrokeThickness="1">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetFilterCommand}"
                                              CommandParameter="{x:Static constants:AppConstants.FilterInProgress}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsInProgressFilterActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="Stroke" Value="{StaticResource Primary}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{local:Localize Key=Issues_Filter_InProgress}"
                           FontSize="Caption" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceMuted}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsInProgressFilterActive}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Padding="16,9"
                        MinimumHeightRequest="44"
                        BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource Surface2}" StrokeThickness="1">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetFilterCommand}"
                                              CommandParameter="{x:Static constants:AppConstants.FilterResolved}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsResolvedFilterActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="Stroke" Value="{StaticResource Primary}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{local:Localize Key=Issues_Filter_Resolved}"
                           FontSize="Caption" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceMuted}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsResolvedFilterActive}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Issues List -->
        <RefreshView Grid.Row="3"
                     Command="{Binding RefreshIssuesCommand}"
                     IsRefreshing="{Binding IsLoading}"
                     Margin="0,14,0,0">
            <CollectionView x:Name="IssuesCollection"
                            ItemsSource="{Binding Issues}"
                            Margin="20,0,20,0"
                            Opacity="0"
                            TranslationY="40"
                            SelectionMode="None"
                            RemainingItemsThreshold="3"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreIssuesCommand}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="0">
                        <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0">
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                        </VerticalStackLayout>
                        <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                             Padding="0,64" Spacing="10"
                                             HorizontalOptions="Center">
                            <Label Text="📋" FontSize="44" HorizontalOptions="Center" />
                            <Label Text="{local:Localize Key=Issues_Empty_Title}"
                                   Style="{StaticResource TitleMedium}"
                                   HorizontalOptions="Center"
                                   SemanticProperties.HeadingLevel="Level2" />
                            <Label Text="{local:Localize Key=Issues_Empty_Subtitle}"
                                   Style="{StaticResource LabelSmall}"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.Footer>
                    <ActivityIndicator IsRunning="{Binding IsLoadingMore}"
                                       IsVisible="{Binding IsLoadingMore}"
                                       Color="{StaticResource Primary}"
                                       Margin="0,8,0,32" />
                </CollectionView.Footer>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Issue">
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnIssueTapped" CommandParameter="{Binding Id}" />
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <Label Grid.Column="0"
                                           Style="{StaticResource TitleMedium}"
                                           Text="{Binding Title}"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           SemanticProperties.Description="{Binding Title}" />
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="8,4"
                                            VerticalOptions="Center"
                                            BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                        <Label Text="{Binding Status}"
                                               TextColor="{StaticResource White}"
                                               FontSize="Caption"
                                               FontAttributes="Bold" />
                                    </Border>
                                </Grid>
                                <Label Grid.Row="1"
                                       Style="{StaticResource BodyMedium}"
                                       Text="{Binding Description}"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation" />
                                <HorizontalStackLayout Grid.Row="2" Spacing="4">
                                    <Label Text="📍" FontSize="Caption" />
                                    <Label Text="{Binding CityName}" Style="{StaticResource LabelSmall}" />
                                    <Label Text="·" Style="{StaticResource LabelSmall}" />
                                    <Label Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelativeConverter}}"
                                           Style="{StaticResource LabelSmall}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>