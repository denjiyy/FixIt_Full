<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.IssuesPage"
            
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:constants="clr-namespace:FixIt.Mobile.Constants"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:IssuesViewModel"
             BackgroundColor="{StaticResource Background}"
             NavigationPage.HasNavigationBar="True"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Issues_Title}">

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0"
                Margin="24,16,24,0"
                Style="{StaticResource EntryCard}">
            <Entry
                   Placeholder="{local:Localize Key=Issues_SearchPlaceholder}"
                   PlaceholderColor="{StaticResource OnSurfaceMuted}"
                   TextColor="{StaticResource OnBackground}"
                   Text="{Binding SearchText}"
                   ClearButtonVisibility="WhileEditing"
                   ReturnType="Search"
                   SemanticProperties.Hint="{local:Localize Key=Issues_SearchPlaceholder}" />
        </Border>

        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,12,0,0"
                    HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Padding="24,0,24,0" Spacing="8">
                <Border StrokeShape="RoundRectangle 20"
                        Padding="14,8"
                        MinimumHeightRequest="44"
                        BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource Surface2}"
                        StrokeThickness="1"
                        SemanticProperties.Description="Filter by All issues">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetFilterCommand}"
                                              CommandParameter="{x:Static constants:AppConstants.FilterAll}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsAllFilterActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="StrokeThickness" Value="0" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{local:Localize Key=Issues_Filter_All}" FontSize="Caption" TextColor="{StaticResource OnSurface}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsAllFilterActive}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                                <Setter Property="FontAttributes" Value="Bold" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <Border StrokeShape="RoundRectangle 20"
                        Padding="14,8"
                        MinimumHeightRequest="44"
                        BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource Surface2}"
                        StrokeThickness="1"
                        SemanticProperties.Description="Filter by New issues">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetFilterCommand}"
                                              CommandParameter="{x:Static constants:AppConstants.FilterNew}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsNewFilterActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="StrokeThickness" Value="0" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{local:Localize Key=Issues_Filter_New}" FontSize="Caption" TextColor="{StaticResource OnSurface}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsNewFilterActive}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                                <Setter Property="FontAttributes" Value="Bold" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <Border StrokeShape="RoundRectangle 20"
                        Padding="14,8"
                        MinimumHeightRequest="44"
                        BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource Surface2}"
                        StrokeThickness="1"
                        SemanticProperties.Description="Filter by In Progress issues">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetFilterCommand}"
                                              CommandParameter="{x:Static constants:AppConstants.FilterInProgress}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsInProgressFilterActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="StrokeThickness" Value="0" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{local:Localize Key=Issues_Filter_InProgress}" FontSize="Caption" TextColor="{StaticResource OnSurface}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsInProgressFilterActive}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                                <Setter Property="FontAttributes" Value="Bold" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <Border StrokeShape="RoundRectangle 20"
                        Padding="14,8"
                        MinimumHeightRequest="44"
                        BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource Surface2}"
                        StrokeThickness="1"
                        SemanticProperties.Description="Filter by Resolved issues">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetFilterCommand}"
                                              CommandParameter="{x:Static constants:AppConstants.FilterResolved}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsResolvedFilterActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="StrokeThickness" Value="0" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{local:Localize Key=Issues_Filter_Resolved}" FontSize="Caption" TextColor="{StaticResource OnSurface}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsResolvedFilterActive}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                                <Setter Property="FontAttributes" Value="Bold" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>
            </HorizontalStackLayout>
        </ScrollView>

        <RefreshView Grid.Row="2"
                     Command="{Binding RefreshIssuesCommand}"
                     IsRefreshing="{Binding IsLoading}"
                     SemanticProperties.Description="Pull to refresh issues">
            <CollectionView x:Name="IssuesCollection"
                            ItemsSource="{Binding Issues}"
                            Margin="24,12,24,0"
                            Opacity="0"
                            TranslationY="40"
                            SelectionMode="None"
                            RemainingItemsThreshold="3"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreIssuesCommand}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="8">
                        <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0">
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                        </VerticalStackLayout>
                        <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                             Padding="0,64,0,0"
                                             Spacing="8"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Label Text="📋" FontSize="48" HorizontalOptions="Center" />
                            <Label Text="{local:Localize Key=Issues_Empty_Title}"
                                   Style="{StaticResource TitleMedium}"
                                   HorizontalOptions="Center"
                                   SemanticProperties.HeadingLevel="Level2" />
                            <Label Text="{local:Localize Key=Issues_Empty_Subtitle}"
                                   Style="{StaticResource LabelSmall}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.Footer>
                    <ActivityIndicator IsRunning="{Binding IsLoadingMore}"
                                       IsVisible="{Binding IsLoadingMore}"
                                       Color="{StaticResource Primary}"
                                       Margin="0,8,0,24" />
                </CollectionView.Footer>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Issue">
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnIssueTapped" CommandParameter="{Binding Id}" />
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <Label Grid.Column="0"
                                           Style="{StaticResource TitleMedium}"
                                           Text="{Binding Title}"
                                           SemanticProperties.Description="{Binding Title}" />

                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="8,4"
                                            BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                            SemanticProperties.Description="{Binding StatusDescription}">
                                        <Label Text="{Binding Status}"
                                               TextColor="{StaticResource White}"
                                               FontSize="Caption"
                                               FontAttributes="Bold"
                                               CharacterSpacing="2" />
                                    </Border>
                                </Grid>

                                <Label Grid.Row="1"
                                       Style="{StaticResource BodyMedium}"
                                       Text="{Binding Description}"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"
                                       SemanticProperties.Description="{Binding Description}" />

                                <HorizontalStackLayout Grid.Row="2" Spacing="4">
                                    <Label Text="📍" Style="{StaticResource LabelSmall}" />
                                    <Label Text="{Binding CityName}" Style="{StaticResource LabelSmall}" />
                                    <Label Text=" • " Style="{StaticResource LabelSmall}" />
                                    <Label Text="🕐" Style="{StaticResource LabelSmall}" />
                                    <Label Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelativeConverter}}" Style="{StaticResource LabelSmall}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
