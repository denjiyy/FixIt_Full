<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.HazardMapPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:FixIt.Mobile.Controls"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:HazardMapViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}"
             NavigationPage.HasNavigationBar="True"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=HazardMap_Title}">

    <Grid x:Name="HazardMapRoot"
          RowDefinitions="Auto,260,*"
          RowSpacing="14"
          Padding="20,20,20,0"
          Opacity="0"
          TranslationY="24">
        <Label Grid.Row="0"
               Text="{local:Localize Key=HazardMap_Title}"
               Style="{StaticResource HeadlineLarge}"
               SemanticProperties.HeadingLevel="Level1" />

        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                Padding="0">
            <Grid>
                <WebView Source="{Binding MapSource}" />
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
            </Grid>
        </Border>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Hazards}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="10" Padding="0,40">
                    <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0">
                        <views:SkeletonCardView />
                        <views:SkeletonCardView />
                    </VerticalStackLayout>
                    <controls:EmptyStateView IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                             IconSource="bell.png"
                                             Title="{local:Localize Key=HazardMap_Empty}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SafetyHazard">
                    <Border Style="{StaticResource IssueCardBorder}" Margin="0,0,0,12">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Label Text="{Binding Title}"
                                       Style="{StaticResource TitleMedium}"
                                       SemanticProperties.Description="{Binding Title}" />
                                <Border Grid.Column="1"
                                        Style="{StaticResource StatusBadge}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource LightDanger}, Dark={StaticResource DarkDanger}}">
                                    <Label Text="{Binding Severity}"
                                           TextColor="{StaticResource White}"
                                           FontAttributes="Bold"
                                           FontSize="11"
                                           CharacterSpacing="0.2"
                                           VerticalTextAlignment="Center" />
                                </Border>
                            </Grid>
                            <Label Grid.Row="1"
                                   Text="{Binding Description}"
                                   Style="{StaticResource BodyMedium}"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation" />
                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                                    <Label Text="{Binding Confirmations}" Style="{StaticResource LabelSmall}" />
                                    <Label Text="{local:Localize Key=HazardMap_Confirmations}" Style="{StaticResource LabelSmall}" />
                                </HorizontalStackLayout>
                                <Button Grid.Column="1"
                                        Text="{local:Localize Key=HazardMap_Confirm}"
                                        Style="{StaticResource CompactPrimaryButton}"
                                        IsVisible="{Binding CanConfirm}"
                                        CommandParameter="{Binding Id}"
                                        Clicked="OnConfirmClicked" />
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
