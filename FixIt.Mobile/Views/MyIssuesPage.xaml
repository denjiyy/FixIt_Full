<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.MyIssuesPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:FixIt.Mobile.Controls"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:MyIssuesViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}"
             NavigationPage.HasNavigationBar="False"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=MyIssues_Title}">

    <Grid RowDefinitions="Auto,*">

        <Label Grid.Row="0"
               Text="{local:Localize Key=MyIssues_Title}"
               Style="{StaticResource HeadlineLarge}"
               Margin="24,28,24,16"
               SemanticProperties.HeadingLevel="Level1" />

        <RefreshView Grid.Row="1"
                     Command="{Binding LoadIssuesCommand}"
                     IsRefreshing="{Binding IsLoading}"
                     RefreshColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}">
            <CollectionView x:Name="MyIssuesCollection"
                            ItemsSource="{Binding Issues}"
                            SelectionMode="None"
                            Margin="20,0,20,0"
                            RemainingItemsThreshold="3"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreIssuesCommand}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="0">
                        <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0">
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                        </VerticalStackLayout>
                        <controls:EmptyStateView IsVisible="{Binding IsEmpty}"
                                                 IconSource="checklist.png"
                                                 Title="{local:Localize Key=MyIssues_Empty_Title}"
                                                 Subtitle="{local:Localize Key=MyIssues_Empty_Subtitle}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.Footer>
                    <ActivityIndicator IsRunning="{Binding IsLoadingMore}"
                                       IsVisible="{Binding IsLoadingMore}"
                                       Color="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}"
                                       Margin="0,8,0,32" />
                </CollectionView.Footer>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Issue">
                        <SwipeView Margin="0,0,0,12">
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItem Text="{local:Localize Key=MyIssues_Delete}"
                                               BackgroundColor="{AppThemeBinding Light={StaticResource LightDanger}, Dark={StaticResource DarkDanger}}"
                                               CommandParameter="{Binding Id}"
                                               Invoked="OnDeleteIssueInvoked" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Style="{StaticResource IssueCardBorder}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnIssueTapped" CommandParameter="{Binding Id}" />
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label Grid.Column="0"
                                               Style="{StaticResource TitleMedium}"
                                               Text="{Binding Title}"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation" />
                                        <Border Grid.Column="1"
                                                Style="{StaticResource StatusBadge}"
                                                BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                            <Label Text="{Binding Status}"
                                                   TextColor="{StaticResource White}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   CharacterSpacing="0.2"
                                                   VerticalTextAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Label Grid.Row="1"
                                           Style="{StaticResource BodyMedium}"
                                           Text="{Binding Description}"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />
                                    <HorizontalStackLayout Grid.Row="2" Spacing="6">
                                        <Image Source="pin.png" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                                        <Label Text="{Binding CityName}" Style="{StaticResource LabelSmall}" VerticalOptions="Center" />
                                        <Label Text="·" Style="{StaticResource LabelSmall}" VerticalOptions="Center" />
                                        <Label Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelativeConverter}}"
                                               Style="{StaticResource LabelSmall}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
