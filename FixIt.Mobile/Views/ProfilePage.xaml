<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.ProfilePage"
             x:Name="ProfilePageRoot"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:FixIt.Mobile.Controls"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:ProfileViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Profile_Title}">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="AvatarBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" Offset="0" />
            <GradientStop Color="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimaryStrong}}" Offset="1" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ============ Top bar ============ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}">
            <Grid ColumnDefinitions="*,Auto" Padding="18,6,10,10" VerticalOptions="Center">
                <Label Grid.Column="0" Text="{local:Localize Key=Profile_Title}"
                       FontSize="21" FontAttributes="Bold" CharacterSpacing="-0.5"
                       TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}"
                       VerticalOptions="Center" SemanticProperties.HeadingLevel="Level1" />
                <ImageButton Grid.Column="1" Source="feed_settings.png" WidthRequest="22" HeightRequest="22"
                             Padding="9" BackgroundColor="Transparent"
                             Command="{Binding OpenSettingsCommand}"
                             SemanticProperties.Description="{local:Localize Key=Profile_Settings}" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ProfileRoot" Opacity="0" TranslationY="25" Spacing="0" Padding="0,0,0,40">

                <!-- ============ Hero ============ -->
                <VerticalStackLayout Padding="20,22,20,8" Spacing="0" HorizontalOptions="Center">
                    <Border WidthRequest="84" HeightRequest="84" StrokeThickness="0"
                            Background="{StaticResource AvatarBrush}" StrokeShape="RoundRectangle 999"
                            HorizontalOptions="Center">
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource PrimaryBrush}" Opacity="0.3" Offset="0,6" Radius="16" />
                        </Border.Shadow>
                        <Label Text="{Binding Initials}" FontSize="30" FontAttributes="Bold"
                               TextColor="{StaticResource White}" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <Label Text="{Binding DisplayName}" FontSize="20" FontAttributes="Bold" CharacterSpacing="-0.2"
                           Margin="0,12,0,0" HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}" />
                    <Label Text="{Binding Email}" FontSize="13" Margin="0,2,0,0" HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}" />

                    <Border Margin="0,10,0,0" StrokeThickness="0" StrokeShape="RoundRectangle 999" Padding="13,6"
                            HorizontalOptions="Center"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightPrimarySoft}, Dark={StaticResource DarkPrimarySoft}}">
                        <HorizontalStackLayout Spacing="6">
                            <Image Source="trophy.png" WidthRequest="14" HeightRequest="14" VerticalOptions="Center">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimary}}" />
                                </Image.Behaviors>
                            </Image>
                            <Label FontSize="12.5" FontAttributes="Bold" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimary}}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding ReputationPoints}" />
                                        <Span Text=" pts · " />
                                        <Span Text="{Binding TrustLevel}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ============ Stats card ============ -->
                <Border Margin="16,18,16,0" StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                        StrokeShape="RoundRectangle 18">
                    <Grid ColumnDefinitions="*,1,*,1,*" Padding="0,14">
                        <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                            <Label Text="{Binding IssuesReported}" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}" />
                            <Label Text="{local:Localize Key=Profile_Reports}" FontSize="11" FontAttributes="Bold" CharacterSpacing="0.4"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}" />
                        </VerticalStackLayout>
                        <BoxView Grid.Column="1" WidthRequest="1" Color="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}" />
                        <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                            <Label Text="{Binding IssuesResolved}" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource LightSuccess}, Dark={StaticResource DarkSuccess}}" />
                            <Label Text="{local:Localize Key=Profile_Resolved}" FontSize="11" FontAttributes="Bold" CharacterSpacing="0.4"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}" />
                        </VerticalStackLayout>
                        <BoxView Grid.Column="3" WidthRequest="1" Color="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}" />
                        <VerticalStackLayout Grid.Column="4" Spacing="2" HorizontalOptions="Center">
                            <Label Text="{Binding FixRate, StringFormat='{0}%'}" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}" />
                            <Label Text="{local:Localize Key=Profile_FixRate}" FontSize="11" FontAttributes="Bold" CharacterSpacing="0.4"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ============ Action buttons ============ -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="16,14,16,0">
                    <Button Grid.Column="0" Text="{local:Localize Key=Profile_Settings}"
                            Style="{StaticResource SecondaryButton}" HeightRequest="46"
                            Command="{Binding OpenSettingsCommand}" />
                    <Button Grid.Column="1" Text="{local:Localize Key=Health_Title}"
                            Style="{StaticResource SecondaryButton}" HeightRequest="46"
                            Command="{Binding ViewHealthReportCommand}" />
                </Grid>

                <!-- ============ Tabs ============ -->
                <Grid ColumnDefinitions="*,*,*" Margin="16,18,16,0">
                    <VerticalStackLayout Grid.Column="0" Spacing="8">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectProfileTabCommand}" CommandParameter="reports" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label Text="{local:Localize Key=Profile_Reports}" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsReportsTab}" Value="True">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimary}}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <BoxView HeightRequest="2" Color="Transparent">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding IsReportsTab}" Value="True">
                                    <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectProfileTabCommand}" CommandParameter="saved" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label Text="{local:Localize Key=Profile_Saved}" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsSavedTab}" Value="True">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimary}}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <BoxView HeightRequest="2" Color="Transparent">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding IsSavedTab}" Value="True">
                                    <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" Spacing="8">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectProfileTabCommand}" CommandParameter="badges" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label Text="{local:Localize Key=Profile_Badges}" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsBadgesTab}" Value="True">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightPrimaryStrong}, Dark={StaticResource DarkPrimary}}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <BoxView HeightRequest="2" Color="Transparent">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding IsBadgesTab}" Value="True">
                                    <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>
                    </VerticalStackLayout>
                </Grid>
                <BoxView HeightRequest="1" Margin="16,0,16,0"
                         Color="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}" />

                <!-- ============ Reports tab ============ -->
                <Grid IsVisible="{Binding IsReportsTab}" Padding="14,14,14,0">
                    <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0" Padding="2,0">
                        <views:SkeletonCardView />
                        <views:SkeletonCardView />
                    </VerticalStackLayout>

                    <controls:EmptyStateView IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                             IconSource="checklist.png"
                                             Title="{local:Localize Key=Profile_NoIssues}" />

                    <FlexLayout BindableLayout.ItemsSource="{Binding MyIssues}" Wrap="Wrap" JustifyContent="Start">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:Issue">
                                <Grid WidthRequest="104" HeightRequest="104" Margin="0,0,4,4">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={x:Reference ProfilePageRoot}, Path=BindingContext.OpenIssueCommand}"
                                                              CommandParameter="{Binding Id}" />
                                    </Grid.GestureRecognizers>
                                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                            Background="{Binding Category, Converter={StaticResource CategoryToBrushConverter}}" />
                                    <Image Source="{Binding Category, Converter={StaticResource CategoryToIconConverter}}"
                                           WidthRequest="26" HeightRequest="26" Opacity="0.92" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Image.Behaviors>
                                            <toolkit:IconTintColorBehavior TintColor="White" />
                                        </Image.Behaviors>
                                    </Image>
                                    <Border IsVisible="{Binding HasPhoto}" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                                        <Image Source="{Binding PhotoUrl}" Aspect="AspectFill" />
                                    </Border>
                                    <Border WidthRequest="14" HeightRequest="14" Margin="6" StrokeThickness="2"
                                            Stroke="{StaticResource White}" StrokeShape="RoundRectangle 999"
                                            HorizontalOptions="End" VerticalOptions="Start"
                                            IsVisible="{Binding Priority, Converter={StaticResource StringNotEmptyConverter}}"
                                            BackgroundColor="{Binding Priority, Converter={StaticResource PriorityToColorConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </Grid>

                <!-- ============ Saved tab ============ -->
                <controls:EmptyStateView IsVisible="{Binding IsSavedTab}"
                                         IconSource="feed_save.png"
                                         Title="{local:Localize Key=Profile_SavedEmpty}" />

                <!-- ============ Badges tab ============ -->
                <FlexLayout IsVisible="{Binding IsBadgesTab}" Wrap="Wrap" JustifyContent="SpaceBetween" Padding="20,14,20,0">
                    <VerticalStackLayout WidthRequest="96" Spacing="7" Margin="0,0,0,16">
                        <Border WidthRequest="64" HeightRequest="64" StrokeThickness="0" StrokeShape="RoundRectangle 18"
                                HorizontalOptions="Center" BackgroundColor="{StaticResource Accent}">
                            <Image Source="cat_road.png" WidthRequest="26" HeightRequest="26" HorizontalOptions="Center" VerticalOptions="Center">
                                <Image.Behaviors><toolkit:IconTintColorBehavior TintColor="White" /></Image.Behaviors>
                            </Image>
                        </Border>
                        <Label Text="Pothole Pro" FontSize="11.5" FontAttributes="Bold" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource LightOnSurface}, Dark={StaticResource DarkOnSurface}}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout WidthRequest="96" Spacing="7" Margin="0,0,0,16">
                        <Border WidthRequest="64" HeightRequest="64" StrokeThickness="0" StrokeShape="RoundRectangle 18"
                                HorizontalOptions="Center" BackgroundColor="{StaticResource Warning}">
                            <Image Source="cat_light.png" WidthRequest="26" HeightRequest="26" HorizontalOptions="Center" VerticalOptions="Center">
                                <Image.Behaviors><toolkit:IconTintColorBehavior TintColor="White" /></Image.Behaviors>
                            </Image>
                        </Border>
                        <Label Text="Night Watch" FontSize="11.5" FontAttributes="Bold" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource LightOnSurface}, Dark={StaticResource DarkOnSurface}}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout WidthRequest="96" Spacing="7" Margin="0,0,0,16">
                        <Border WidthRequest="64" HeightRequest="64" StrokeThickness="0" StrokeShape="RoundRectangle 18"
                                HorizontalOptions="Center" BackgroundColor="{StaticResource Primary}">
                            <Image Source="cat_water.png" WidthRequest="26" HeightRequest="26" HorizontalOptions="Center" VerticalOptions="Center">
                                <Image.Behaviors><toolkit:IconTintColorBehavior TintColor="White" /></Image.Behaviors>
                            </Image>
                        </Border>
                        <Label Text="Leak Hunter" FontSize="11.5" FontAttributes="Bold" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource LightOnSurface}, Dark={StaticResource DarkOnSurface}}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout WidthRequest="96" Spacing="7" Margin="0,0,0,16">
                        <Border WidthRequest="64" HeightRequest="64" StrokeThickness="0" StrokeShape="RoundRectangle 18"
                                HorizontalOptions="Center" BackgroundColor="{StaticResource Success}">
                            <Image Source="feed_people.png" WidthRequest="26" HeightRequest="26" HorizontalOptions="Center" VerticalOptions="Center">
                                <Image.Behaviors><toolkit:IconTintColorBehavior TintColor="White" /></Image.Behaviors>
                            </Image>
                        </Border>
                        <Label Text="Mobilizer" FontSize="11.5" FontAttributes="Bold" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource LightOnSurface}, Dark={StaticResource DarkOnSurface}}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout WidthRequest="96" Spacing="7" Margin="0,0,0,16">
                        <Border WidthRequest="64" HeightRequest="64" StrokeThickness="0" StrokeShape="RoundRectangle 18"
                                HorizontalOptions="Center" BackgroundColor="{StaticResource PrimaryDark}">
                            <Image Source="feed_verified.png" WidthRequest="26" HeightRequest="26" HorizontalOptions="Center" VerticalOptions="Center">
                                <Image.Behaviors><toolkit:IconTintColorBehavior TintColor="White" /></Image.Behaviors>
                            </Image>
                        </Border>
                        <Label Text="First Reporter" FontSize="11.5" FontAttributes="Bold" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource LightOnSurface}, Dark={StaticResource DarkOnSurface}}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout WidthRequest="96" Spacing="7" Margin="0,0,0,16">
                        <Border WidthRequest="64" HeightRequest="64" StrokeThickness="0" StrokeShape="RoundRectangle 18"
                                HorizontalOptions="Center" BackgroundColor="{StaticResource AccentDark}">
                            <Image Source="trophy.png" WidthRequest="26" HeightRequest="26" HorizontalOptions="Center" VerticalOptions="Center">
                                <Image.Behaviors><toolkit:IconTintColorBehavior TintColor="White" /></Image.Behaviors>
                            </Image>
                        </Border>
                        <Label Text="Civic Leader" FontSize="11.5" FontAttributes="Bold" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource LightOnSurface}, Dark={StaticResource DarkOnSurface}}" />
                    </VerticalStackLayout>
                </FlexLayout>

                <Label IsVisible="{Binding IsBadgesTab}" Text="{local:Localize Key=Profile_BadgesEmpty}"
                       FontSize="12" HorizontalTextAlignment="Center" Margin="24,0,24,0"
                       TextColor="{AppThemeBinding Light={StaticResource LightOnSurfaceMuted}, Dark={StaticResource DarkOnSurfaceMuted}}" />

                <!-- ============ Language + sign out ============ -->
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="16,22,16,0">
                    <Label Grid.Column="0" Text="{local:Localize Key=Profile_Language}" VerticalOptions="Center"
                           FontSize="14" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}" />
                    <Button Grid.Column="1" Text="EN" Command="{Binding SwitchLanguageCommand}" CommandParameter="en-US"
                            Style="{StaticResource OutlineToggleButton}" WidthRequest="54">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsEnglish}" Value="True">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                                <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button Grid.Column="2" Text="BG" Command="{Binding SwitchLanguageCommand}" CommandParameter="bg-BG"
                            Style="{StaticResource OutlineToggleButton}" WidthRequest="54">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsBulgarian}" Value="True">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                                <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>

                <Button Text="{local:Localize Key=Profile_SignOut}" Style="{StaticResource SecondaryButton}"
                        TextColor="{AppThemeBinding Light={StaticResource LightDanger}, Dark={StaticResource DarkDanger}}"
                        BorderColor="{AppThemeBinding Light={StaticResource LightDanger}, Dark={StaticResource DarkDanger}}"
                        Command="{Binding LogoutCommand}" Margin="16,12,16,0"
                        SemanticProperties.Description="{local:Localize Key=Profile_SignOut}" />

                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                   Color="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}"
                                   Margin="0,12,0,0" />
            </VerticalStackLayout>
        </ScrollView>

        <controls:AppTabBar Grid.Row="2" Active="you" />
    </Grid>
</ContentPage>
