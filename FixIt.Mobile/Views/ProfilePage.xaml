<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.ProfilePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:FixIt.Mobile.Controls"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:ProfileViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}"
             NavigationPage.HasNavigationBar="False"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Profile_Title}">

    <ScrollView>
        <VerticalStackLayout x:Name="ProfileRoot"
                             Padding="20,28,20,40"
                             Spacing="16"
                             Opacity="0"
                             TranslationY="25">

            <!-- Identity Card -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Border WidthRequest="88" HeightRequest="88"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 44"
                            HorizontalOptions="Center">
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource PrimaryBrush}"
                                    Opacity="0.3" Offset="0,4" Radius="14" />
                        </Border.Shadow>
                        <Label Text="{Binding Initials}"
                               TextColor="{StaticResource White}"
                               FontSize="Title"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="{Binding DisplayName}"
                               Style="{StaticResource HeadlineMedium}"
                               HorizontalTextAlignment="Center"
                               SemanticProperties.HeadingLevel="Level1" />
                        <Label Text="{Binding Email}"
                               Style="{StaticResource LabelSmall}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}"
                            StrokeThickness="0"
                            Padding="12,5"
                            StrokeShape="RoundRectangle 10"
                            HorizontalOptions="Center">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="{local:Localize Key=Common_Trust}"
                                   FontSize="Caption"
                                   FontAttributes="Bold"
                                   CharacterSpacing="0.4"
                                   TextColor="{StaticResource White}" />
                            <Label Text="{Binding TrustLevel}"
                                   FontSize="Caption"
                                   FontAttributes="Bold"
                                   CharacterSpacing="0.4"
                                   TextColor="{StaticResource White}" />
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Language Switcher -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0"
                           Text="{local:Localize Key=Profile_Language}"
                           Style="{StaticResource TitleMedium}"
                           VerticalOptions="Center"
                           SemanticProperties.HeadingLevel="Level2" />
                    <Button Grid.Column="1" Text="EN"
                            Command="{Binding SwitchLanguageCommand}"
                            CommandParameter="en-US"
                            Style="{StaticResource OutlineToggleButton}"
                            WidthRequest="56">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsEnglish}" Value="True">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                                <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button Grid.Column="2" Text="BG"
                            Command="{Binding SwitchLanguageCommand}"
                            CommandParameter="bg-BG"
                            Style="{StaticResource OutlineToggleButton}"
                            WidthRequest="56">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsBulgarian}" Value="True">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                                <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
            </Border>

            <!-- Stats Row -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Style="{StaticResource LabelSmall}"
                               Text="{local:Localize Key=Profile_Reputation}" />
                        <Label FontSize="Title" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource DarkAccent}}"
                               Text="{Binding ReputationPoints}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Style="{StaticResource LabelSmall}"
                               Text="{local:Localize Key=Profile_Reported}" />
                        <Label FontSize="Title" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource LightOnBackground}, Dark={StaticResource DarkOnBackground}}"
                               Text="{Binding IssuesReported}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Style="{StaticResource LabelSmall}"
                               Text="{local:Localize Key=Profile_Resolved}" />
                        <Label FontSize="Title" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource LightSuccess}, Dark={StaticResource DarkSuccess}}"
                               Text="{Binding IssuesResolved}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="{local:Localize Key=Health_Title}"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ViewHealthReportCommand}" />
                <Button Grid.Column="1"
                        Text="{local:Localize Key=HazardMap_Title}"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ViewHazardMapCommand}" />
            </Grid>

            <!-- My Issues -->
            <VerticalStackLayout Spacing="14">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Style="{StaticResource TitleMedium}"
                           Text="{local:Localize Key=Profile_MyIssues}"
                           SemanticProperties.HeadingLevel="Level2" />
                    <Label Grid.Column="1"
                           Text="{local:Localize Key=Profile_ViewAll}"
                           TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource DarkAccent}}"
                           FontSize="Caption"
                           FontAttributes="Bold"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ViewAllIssuesCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <CollectionView ItemsSource="{Binding MyIssues}"
                                SelectionMode="None"
                                VerticalOptions="Start">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Spacing="0">
                            <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0">
                                <views:SkeletonCardView />
                                <views:SkeletonCardView />
                                <views:SkeletonCardView />
                            </VerticalStackLayout>
                            <controls:EmptyStateView IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                                     IconSource="checklist.png"
                                                     Title="{local:Localize Key=Profile_NoIssues}" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Issue">
                            <Border Style="{StaticResource IssueCardBorder}" Margin="0,0,0,12">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label Grid.Column="0"
                                               Style="{StaticResource TitleMedium}"
                                               Text="{Binding Title}"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation" />
                                        <Border Grid.Column="1"
                                                Style="{StaticResource StatusBadge}"
                                                BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                            <Label Text="{Binding Status}"
                                                   TextColor="{StaticResource White}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   CharacterSpacing="0.2"
                                                   VerticalTextAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <HorizontalStackLayout Grid.Row="1" Spacing="6">
                                        <Image Source="pin.png" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                                        <Label Text="{Binding CityName}" Style="{StaticResource LabelSmall}" VerticalOptions="Center" />
                                        <Label Text="·" Style="{StaticResource LabelSmall}" VerticalOptions="Center" />
                                        <Label Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelativeConverter}}"
                                               Style="{StaticResource LabelSmall}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Sign Out -->
            <Button Text="{local:Localize Key=Profile_SignOut}"
                    Style="{StaticResource SecondaryButton}"
                    TextColor="{AppThemeBinding Light={StaticResource LightDanger}, Dark={StaticResource DarkDanger}}"
                    BorderColor="{AppThemeBinding Light={StaticResource LightDanger}, Dark={StaticResource DarkDanger}}"
                    Command="{Binding LogoutCommand}"
                    Margin="0,8,0,0"
                    SemanticProperties.Description="{local:Localize Key=Profile_SignOut}" />

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
