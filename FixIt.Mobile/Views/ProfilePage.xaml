<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.ProfilePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:ProfileViewModel"
             BackgroundColor="{StaticResource Background}"
             NavigationPage.HasNavigationBar="False"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Profile_Title}">

    <ScrollView>
        <VerticalStackLayout x:Name="ProfileRoot"
                             Padding="24,56,24,34"
                             Spacing="24"
                             Opacity="0"
                             TranslationY="25">
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Border WidthRequest="96"
                            HeightRequest="96"
                            BackgroundColor="{StaticResource Primary}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 48"
                            HorizontalOptions="Center">
                        <Label Text="{Binding Initials}"
                               TextColor="{StaticResource White}"
                               FontSize="Title"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <Label Text="{Binding DisplayName}"
                           Style="{StaticResource HeadlineMedium}"
                           HorizontalTextAlignment="Center"
                           SemanticProperties.HeadingLevel="Level1" />

                    <Label Text="{Binding Email}"
                           Style="{StaticResource BodyMedium}"
                           TextColor="{StaticResource OnSurfaceMuted}"
                           HorizontalTextAlignment="Center" />

                    <Border BackgroundColor="{StaticResource StatusNew}"
                            StrokeThickness="0"
                            Padding="10,4"
                            StrokeShape="RoundRectangle 8"
                            HorizontalOptions="Center"
                            SemanticProperties.Description="{Binding TrustLevel, StringFormat='Trust level: {0}'}">
                        <Label Text="{Binding TrustLevel, StringFormat='TRUST: {0}'}"
                               FontSize="Caption"
                               FontAttributes="Bold"
                               CharacterSpacing="2"
                               TextColor="{StaticResource White}" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0"
                           Text="{local:Localize Key=Profile_Language}"
                           Style="{StaticResource TitleMedium}"
                           VerticalOptions="Center"
                           SemanticProperties.HeadingLevel="Level2" />
                    <Button Grid.Column="1"
                            Text="EN"
                            Command="{Binding SwitchLanguageCommand}"
                            CommandParameter="en-US"
                            Style="{StaticResource SecondaryButton}"
                            HeightRequest="44">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsEnglish}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button Grid.Column="2"
                            Text="BG"
                            Command="{Binding SwitchLanguageCommand}"
                            CommandParameter="bg-BG"
                            Style="{StaticResource SecondaryButton}"
                            HeightRequest="44">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsBulgarian}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                <Setter Property="TextColor" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{local:Localize Key=Profile_Reputation}" Style="{StaticResource LabelSmall}" />
                        <Label Text="{Binding ReputationPoints}" Style="{StaticResource HeadlineMedium}" TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{local:Localize Key=Profile_Reported}" Style="{StaticResource LabelSmall}" />
                        <Label Text="{Binding IssuesReported}" Style="{StaticResource HeadlineMedium}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{local:Localize Key=Profile_Resolved}" Style="{StaticResource LabelSmall}" />
                        <Label Text="{Binding IssuesResolved}" Style="{StaticResource HeadlineMedium}" TextColor="{StaticResource Success}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <VerticalStackLayout Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="{local:Localize Key=Profile_MyIssues}"
                           Style="{StaticResource TitleMedium}"
                           SemanticProperties.HeadingLevel="Level2" />
                    <Label Grid.Column="1"
                           Text="{local:Localize Key=Profile_ViewAll}"
                           TextColor="{StaticResource Accent}"
                           FontSize="Caption"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ViewAllIssuesCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <CollectionView ItemsSource="{Binding MyIssues}"
                                SelectionMode="None"
                                VerticalOptions="Start">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Spacing="8">
                            <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0">
                                <views:SkeletonCardView />
                                <views:SkeletonCardView />
                                <views:SkeletonCardView />
                                <views:SkeletonCardView />
                            </VerticalStackLayout>
                            <Label Text="{local:Localize Key=Profile_NoIssues}"
                                   IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                   Style="{StaticResource BodyMedium}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Issue">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label Grid.Column="0" Style="{StaticResource TitleMedium}" Text="{Binding Title}" />
                                        <Border Grid.Column="1"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                Padding="8,4"
                                                BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                SemanticProperties.Description="{Binding StatusDescription}">
                                            <Label Text="{Binding Status}" TextColor="{StaticResource White}" FontSize="Caption" FontAttributes="Bold" CharacterSpacing="2" />
                                        </Border>
                                    </Grid>

                                    <Label Grid.Row="1" Style="{StaticResource BodyMedium}" Text="{Binding Description}" MaxLines="2" LineBreakMode="TailTruncation" />

                                    <HorizontalStackLayout Grid.Row="2" Spacing="4">
                                        <Label Text="📍" Style="{StaticResource LabelSmall}" />
                                        <Label Text="{Binding CityName}" Style="{StaticResource LabelSmall}" />
                                        <Label Text=" • " Style="{StaticResource LabelSmall}" />
                                        <Label Text="🕐" Style="{StaticResource LabelSmall}" />
                                        <Label Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelativeConverter}}" Style="{StaticResource LabelSmall}" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <Button Text="{local:Localize Key=Profile_SignOut}"
                    Style="{StaticResource SecondaryButton}"
                    TextColor="{StaticResource Error}"
                    BorderColor="{StaticResource Error}"
                    Command="{Binding LogoutCommand}"
                    SemanticProperties.Description="Sign out of your account" />

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
