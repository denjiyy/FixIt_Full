<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.IssueDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:IssueDetailViewModel"
             BackgroundColor="{StaticResource Background}"
             NavigationPage.HasNavigationBar="True"
             ios:Page.UseSafeArea="True"
             Title="{Binding Issue.Title}">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout x:Name="DetailRoot"
                                 Opacity="0"
                                 TranslationY="24"
                                 Padding="0,0,0,34"
                                 Spacing="0">
                <Grid HeightRequest="260">
                    <Border IsVisible="{Binding HasIssuePhoto, Converter={StaticResource InverseBoolConverter}}"
                            StrokeThickness="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource Primary}" Offset="0" />
                                <GradientStop Color="{StaticResource PrimaryDark}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Label Text="FixIt"
                               FontSize="Title"
                               FontAttributes="Bold"
                               TextColor="{StaticResource White}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <Image Aspect="AspectFill"
                           IsVisible="{Binding HasIssuePhoto}"
                           SemanticProperties.Description="Issue photo">
                        <Image.Source>
                            <UriImageSource Uri="{Binding Issue.PhotoUrl}"
                                            CacheValidity="1.00:00:00"
                                            CachingEnabled="True" />
                        </Image.Source>
                    </Image>
                </Grid>

                <VerticalStackLayout Padding="24" Spacing="16">
                    <HorizontalStackLayout Spacing="8">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                Padding="8,4"
                                BackgroundColor="{Binding Issue.Status, Converter={StaticResource StatusToColorConverter}}"
                                SemanticProperties.Description="{Binding Issue.StatusDescription}">
                            <Label Text="{Binding Issue.Status}"
                                   TextColor="{StaticResource White}"
                                   FontSize="Caption"
                                   FontAttributes="Bold"
                                   CharacterSpacing="2" />
                        </Border>
                        <Border Stroke="{StaticResource Surface2}"
                                StrokeShape="RoundRectangle 8"
                                Padding="8,4"
                                BackgroundColor="{StaticResource Surface}">
                            <Label Text="{Binding Issue.Category}"
                                   TextColor="{StaticResource OnSurface}"
                                   FontSize="Caption" />
                        </Border>
                    </HorizontalStackLayout>

                    <Label Text="{Binding Issue.Title}"
                           Style="{StaticResource HeadlineMedium}"
                           SemanticProperties.HeadingLevel="Level1" />

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Border WidthRequest="24"
                                HeightRequest="24"
                                BackgroundColor="{StaticResource Primary}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12">
                            <Label Text="{Binding Issue.AuthorInitials}"
                                   TextColor="{StaticResource White}"
                                   FontSize="Caption"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <HorizontalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="{Binding Issue.AuthorName}" Style="{StaticResource LabelSmall}" />
                            <Label Text=" • " Style="{StaticResource LabelSmall}" />
                            <Label Text="{Binding Issue.CityName}" Style="{StaticResource LabelSmall}" />
                            <Label Text=" • " Style="{StaticResource LabelSmall}" />
                            <Label Text="{Binding Issue.CreatedAt, Converter={StaticResource DateTimeToRelativeConverter}}" Style="{StaticResource LabelSmall}" />
                        </HorizontalStackLayout>
                        <Label Grid.Column="2"
                               Text="{Binding Issue.VoteCount, StringFormat='▲ {0}'}"
                               Style="{StaticResource LabelSmall}"
                               TextColor="{StaticResource Accent}" />
                    </Grid>

                    <HorizontalStackLayout Spacing="12">
                        <Button x:Name="UpvoteButton"
                                Text="▲"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnUpvoteClicked"
                                SemanticProperties.Description="Upvote this issue" />
                        <Button x:Name="DownvoteButton"
                                Text="▼"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnDownvoteClicked"
                                SemanticProperties.Description="Downvote this issue" />
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource DividerColor}" />

                    <Label Text="{Binding Issue.Description}"
                           Style="{StaticResource BodyMedium}"
                           SemanticProperties.Description="{Binding Issue.Description}" />

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource DividerColor}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="{local:Localize Key=Detail_Comments}"
                               Style="{StaticResource TitleMedium}"
                               SemanticProperties.HeadingLevel="Level2" />
                        <Label Grid.Column="1"
                               Text="{Binding Comments.Count}"
                               Style="{StaticResource LabelSmall}"
                               VerticalOptions="Center" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding Comments}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout IsVisible="{Binding HasNoComments}"
                                                 Padding="0,48"
                                                 Spacing="8"
                                                 HorizontalOptions="Center">
                                <Label Text="💬" FontSize="48" HorizontalOptions="Center" />
                                <Label Text="{local:Localize Key=Detail_NoComments}"
                                       Style="{StaticResource BodyMedium}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Comment">
                                <Grid ColumnDefinitions="36,*" ColumnSpacing="12" Padding="0,10">
                                    <Border WidthRequest="36"
                                            HeightRequest="36"
                                            BackgroundColor="{StaticResource Surface2}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18">
                                        <Label Text="{Binding AuthorInitials}"
                                               TextColor="{StaticResource White}"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" Text="{Binding AuthorName}" Style="{StaticResource TitleMedium}" />
                                            <Label Grid.Column="1" Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelativeConverter}}" Style="{StaticResource LabelSmall}" />
                                        </Grid>
                                        <Label Text="{Binding Text}" Style="{StaticResource BodyMedium}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                IsVisible="{Binding IsLoggedIn}"
                BackgroundColor="{StaticResource Background}"
                Stroke="{StaticResource DividerColor}"
                StrokeThickness="1"
                Padding="16,10,16,24">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Border Style="{StaticResource EntryCard}">
                        <Entry Placeholder="{local:Localize Key=Detail_CommentPlaceholder}"
                               Text="{Binding CommentText}"
                               PlaceholderColor="{StaticResource OnSurfaceMuted}"
                               TextColor="{StaticResource OnBackground}"
                               SemanticProperties.Hint="{local:Localize Key=Detail_CommentPlaceholder}" />
                    </Border>
                    <Label Text="{Binding CommentError}"
                           TextColor="{StaticResource Error}"
                           FontSize="Caption"
                           IsVisible="{Binding HasCommentError}" />
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="{local:Localize Key=Detail_Send}"
                        Style="{StaticResource CompactPrimaryButton}"
                        Command="{Binding AddCommentCommand}"
                        SemanticProperties.Description="Send comment" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
