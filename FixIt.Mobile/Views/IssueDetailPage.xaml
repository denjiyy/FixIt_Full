<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.IssueDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:IssueDetailViewModel"
             BackgroundColor="{StaticResource Background}"
             NavigationPage.HasNavigationBar="True"
             ios:Page.UseSafeArea="True"
             Title="{Binding Issue.Title}">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout x:Name="DetailRoot"
                                 Opacity="0" TranslationY="24"
                                 Spacing="0">

                <!-- Hero Image -->
                <Grid HeightRequest="240">
                    <Border IsVisible="{Binding HasIssuePhoto, Converter={StaticResource InverseBoolConverter}}"
                            StrokeThickness="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2563EB" Offset="0" />
                                <GradientStop Color="#1E3A8A" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Label Text="FixIt"
                               FontSize="Title"
                               FontAttributes="Bold"
                               TextColor="{StaticResource White}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Image Aspect="AspectFill"
                           IsVisible="{Binding HasIssuePhoto}"
                           SemanticProperties.Description="Issue photo">
                        <Image.Source>
                            <UriImageSource Uri="{Binding Issue.PhotoUrl}"
                                            CacheValidity="1.00:00:00"
                                            CachingEnabled="True" />
                        </Image.Source>
                    </Image>
                </Grid>

                <!-- Content -->
                <VerticalStackLayout Padding="20,20,20,0" Spacing="16">

                    <!-- Status & Category -->
                    <HorizontalStackLayout Spacing="8">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                Padding="8,4"
                                BackgroundColor="{Binding Issue.Status, Converter={StaticResource StatusToColorConverter}}">
                            <Label Text="{Binding Issue.Status}"
                                   TextColor="{StaticResource White}"
                                   FontSize="Caption"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1" />
                        </Border>
                        <Border Stroke="{StaticResource Surface2}"
                                StrokeShape="RoundRectangle 8"
                                Padding="8,4"
                                BackgroundColor="{StaticResource Surface}">
                            <Label Text="{Binding Issue.Category}"
                                   TextColor="{StaticResource OnSurface}"
                                   FontSize="Caption" />
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Title -->
                    <Label Text="{Binding Issue.Title}"
                           Style="{StaticResource HeadlineMedium}"
                           SemanticProperties.HeadingLevel="Level1" />

                    <!-- Author row -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Border WidthRequest="32" HeightRequest="32"
                                BackgroundColor="{StaticResource Primary}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                            <Label Text="{Binding Issue.AuthorInitials}"
                                   TextColor="{StaticResource White}"
                                   FontSize="Caption"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="{Binding Issue.AuthorName}" Style="{StaticResource LabelSmall}" />
                            <Label Text="·" Style="{StaticResource LabelSmall}" />
                            <Label Text="{Binding Issue.CityName}" Style="{StaticResource LabelSmall}" />
                            <Label Text="·" Style="{StaticResource LabelSmall}" />
                            <Label Text="{Binding Issue.CreatedAt, Converter={StaticResource DateTimeToRelativeConverter}}"
                                   Style="{StaticResource LabelSmall}" />
                        </HorizontalStackLayout>
                        <Label Grid.Column="2"
                               Text="{Binding Issue.VoteCount, StringFormat='▲ {0}'}"
                               Style="{StaticResource LabelSmall}"
                               TextColor="{StaticResource Accent}"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- Vote Buttons -->
                    <HorizontalStackLayout Spacing="10">
                        <Button x:Name="UpvoteButton"
                                Text="▲  Upvote"
                                Style="{StaticResource SecondaryButton}"
                                HeightRequest="44"
                                Clicked="OnUpvoteClicked"
                                SemanticProperties.Description="Upvote this issue" />
                        <Button x:Name="DownvoteButton"
                                Text="▼  Downvote"
                                Style="{StaticResource SecondaryButton}"
                                HeightRequest="44"
                                Clicked="OnDownvoteClicked"
                                SemanticProperties.Description="Downvote this issue" />
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource DividerColor}" />

                    <!-- Description -->
                    <Label Text="{Binding Issue.Description}"
                           Style="{StaticResource BodyMedium}"
                           SemanticProperties.Description="{Binding Issue.Description}" />

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource DividerColor}" />

                    <!-- Comments Header -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="{local:Localize Key=Detail_Comments}"
                               Style="{StaticResource TitleMedium}"
                               SemanticProperties.HeadingLevel="Level2" />
                        <Label Grid.Column="1"
                               Text="{Binding Comments.Count}"
                               Style="{StaticResource LabelSmall}"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- Comments List -->
                    <CollectionView ItemsSource="{Binding Comments}"
                                    SelectionMode="None"
                                    Margin="0,0,0,20">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout IsVisible="{Binding HasNoComments}"
                                                 Padding="0,36" Spacing="10"
                                                 HorizontalOptions="Center">
                                <Label Text="💬" FontSize="44" HorizontalOptions="Center" />
                                <Label Text="{local:Localize Key=Detail_NoComments}"
                                       Style="{StaticResource BodyMedium}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Comment">
                                <Grid ColumnDefinitions="36,*" ColumnSpacing="12"
                                      Padding="0,12,0,0">
                                    <Border WidthRequest="36" HeightRequest="36"
                                            BackgroundColor="{StaticResource Surface2}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18">
                                        <Label Text="{Binding AuthorInitials}"
                                               TextColor="{StaticResource White}"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0"
                                                   Text="{Binding AuthorName}"
                                                   Style="{StaticResource TitleMedium}" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelativeConverter}}"
                                                   Style="{StaticResource LabelSmall}" />
                                        </Grid>
                                        <Label Text="{Binding Text}" Style="{StaticResource BodyMedium}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Comment Input -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsLoggedIn}"
                BackgroundColor="{StaticResource Background}"
                Stroke="{StaticResource DividerColor}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 0"
                Padding="16,12,16,24">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Border Style="{StaticResource EntryCard}">
                        <Entry Placeholder="{local:Localize Key=Detail_CommentPlaceholder}"
                               Text="{Binding CommentText}"
                               PlaceholderColor="{StaticResource OnSurfaceMuted}"
                               TextColor="{StaticResource OnBackground}"
                               SemanticProperties.Hint="{local:Localize Key=Detail_CommentPlaceholder}" />
                    </Border>
                    <Label Text="{Binding CommentError}"
                           TextColor="{StaticResource Error}"
                           FontSize="Caption"
                           IsVisible="{Binding HasCommentError}"
                           Margin="4,0,0,0" />
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="{local:Localize Key=Detail_Send}"
                        Style="{StaticResource CompactPrimaryButton}"
                        Command="{Binding AddCommentCommand}"
                        SemanticProperties.Description="Send comment" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>