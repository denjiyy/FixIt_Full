<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.LeaderboardPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:LeaderboardViewModel"
             BackgroundColor="{StaticResource Background}"
             NavigationPage.HasNavigationBar="False"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Leaderboard_Title}">

    <Grid x:Name="LeaderboardRoot"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="16"
          Padding="20,28,20,0"
          Opacity="0"
          TranslationY="24">
        <Label Text="{local:Localize Key=Leaderboard_Title}"
               Style="{StaticResource HeadlineLarge}"
               SemanticProperties.HeadingLevel="Level1" />

        <HorizontalStackLayout Grid.Row="1" Spacing="8">
            <Border StrokeShape="RoundRectangle 18" Padding="14,8" BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Surface2}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectPeriodCommand}" CommandParameter="weekly" />
                </Border.GestureRecognizers>
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsWeekly}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                        <Setter Property="Stroke" Value="{StaticResource Primary}" />
                    </DataTrigger>
                </Border.Triggers>
                <Label Text="{local:Localize Key=Leaderboard_Weekly}" FontSize="Caption" FontAttributes="Bold" TextColor="{StaticResource OnSurface}" />
            </Border>
            <Border StrokeShape="RoundRectangle 18" Padding="14,8" BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Surface2}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectPeriodCommand}" CommandParameter="monthly" />
                </Border.GestureRecognizers>
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsMonthly}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                        <Setter Property="Stroke" Value="{StaticResource Primary}" />
                    </DataTrigger>
                </Border.Triggers>
                <Label Text="{local:Localize Key=Leaderboard_Monthly}" FontSize="Caption" FontAttributes="Bold" TextColor="{StaticResource OnSurface}" />
            </Border>
            <Border StrokeShape="RoundRectangle 18" Padding="14,8" BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Surface2}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectPeriodCommand}" CommandParameter="alltime" />
                </Border.GestureRecognizers>
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsAllTime}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                        <Setter Property="Stroke" Value="{StaticResource Primary}" />
                    </DataTrigger>
                </Border.Triggers>
                <Label Text="{local:Localize Key=Leaderboard_AllTime}" FontSize="Caption" FontAttributes="Bold" TextColor="{StaticResource OnSurface}" />
            </Border>
        </HorizontalStackLayout>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Entries}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="10" Padding="0,56" HorizontalOptions="Center">
                    <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0">
                        <views:SkeletonCardView />
                        <views:SkeletonCardView />
                        <views:SkeletonCardView />
                    </VerticalStackLayout>
                    <Label Text="🏆" FontSize="44" HorizontalOptions="Center" />
                    <Label Text="{local:Localize Key=Leaderboard_Empty}"
                           Style="{StaticResource BodyMedium}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:LeaderboardEntry">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                            <Label Text="{Binding MedalPrefix}" Style="{StaticResource TitleMedium}" VerticalOptions="Center" />
                            <Border Grid.Column="1" WidthRequest="42" HeightRequest="42"
                                    StrokeThickness="0"
                                    BackgroundColor="{StaticResource Surface2}"
                                    StrokeShape="RoundRectangle 21">
                                <Label Text="{Binding Initials}"
                                       TextColor="{StaticResource White}"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding UserDisplayName}" Style="{StaticResource TitleMedium}" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{local:Localize Key=Common_Trust}" Style="{StaticResource LabelSmall}" />
                                    <Label Text="{Binding TrustLevel}" Style="{StaticResource LabelSmall}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Border Grid.Column="3"
                                    BackgroundColor="{StaticResource Surface2}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="10,6"
                                    VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{Binding Points}"
                                           TextColor="{StaticResource Accent}"
                                           FontAttributes="Bold"
                                           FontSize="Caption" />
                                    <Label Text="{local:Localize Key=Leaderboard_Points}"
                                           TextColor="{StaticResource Accent}"
                                           FontAttributes="Bold"
                                           FontSize="Caption" />
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
