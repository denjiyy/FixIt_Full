<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.LeaderboardPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:FixIt.Mobile.Controls"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:LeaderboardViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}"
             NavigationPage.HasNavigationBar="False"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Leaderboard_Title}">

    <Grid x:Name="LeaderboardRoot"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="16"
          Padding="20,28,20,0"
          Opacity="0"
          TranslationY="24">
        <Label Text="{local:Localize Key=Leaderboard_Title}"
               Style="{StaticResource HeadlineLarge}"
               SemanticProperties.HeadingLevel="Level1" />

        <HorizontalStackLayout Grid.Row="1" Spacing="8">
            <Button Text="{local:Localize Key=Leaderboard_Weekly}"
                    Command="{Binding SelectPeriodCommand}"
                    CommandParameter="weekly"
                    Style="{StaticResource OutlineToggleButton}"
                    SemanticProperties.Description="Select weekly leaderboard">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsWeekly}" Value="True">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                        <Setter Property="TextColor" Value="{StaticResource White}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            <Button Text="{local:Localize Key=Leaderboard_Monthly}"
                    Command="{Binding SelectPeriodCommand}"
                    CommandParameter="monthly"
                    Style="{StaticResource OutlineToggleButton}"
                    SemanticProperties.Description="Select monthly leaderboard">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsMonthly}" Value="True">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                        <Setter Property="TextColor" Value="{StaticResource White}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            <Button Text="{local:Localize Key=Leaderboard_AllTime}"
                    Command="{Binding SelectPeriodCommand}"
                    CommandParameter="alltime"
                    Style="{StaticResource OutlineToggleButton}"
                    SemanticProperties.Description="Select all-time leaderboard">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsAllTime}" Value="True">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}" />
                        <Setter Property="TextColor" Value="{StaticResource White}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </HorizontalStackLayout>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Entries}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="10" Padding="0,40">
                    <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0">
                        <views:SkeletonCardView />
                        <views:SkeletonCardView />
                        <views:SkeletonCardView />
                    </VerticalStackLayout>
                    <controls:EmptyStateView IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                             IconSource="trophy.png"
                                             Title="{local:Localize Key=Leaderboard_Empty}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:LeaderboardEntry">
                    <Border Style="{StaticResource IssueCardBorder}" Margin="0,0,0,12">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                            <Label Text="{Binding MedalPrefix}" Style="{StaticResource TitleMedium}" VerticalOptions="Center" />
                            <Border Grid.Column="1" WidthRequest="42" HeightRequest="42"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkPrimary}}"
                                    StrokeShape="RoundRectangle 21">
                                <Label Text="{Binding Initials}"
                                       TextColor="{StaticResource White}"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding UserDisplayName}" Style="{StaticResource TitleMedium}" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{local:Localize Key=Common_Trust}" Style="{StaticResource LabelSmall}" />
                                    <Label Text="{Binding TrustLevel}" Style="{StaticResource LabelSmall}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Border Grid.Column="3"
                                    Style="{StaticResource StatusBadge}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightAccentSoft}, Dark={StaticResource DarkAccentSoft}}">
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{Binding Points}"
                                           TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource DarkAccent}}"
                                           FontAttributes="Bold"
                                           FontSize="Caption"
                                           VerticalTextAlignment="Center" />
                                    <Label Text="{local:Localize Key=Leaderboard_Points}"
                                           TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource DarkAccent}}"
                                           FontAttributes="Bold"
                                           FontSize="Caption"
                                           VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
