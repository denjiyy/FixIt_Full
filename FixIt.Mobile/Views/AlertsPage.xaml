<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.AlertsPage"
            
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:models="clr-namespace:FixIt.Mobile.Models"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:views="clr-namespace:FixIt.Mobile.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:AlertsViewModel"
             BackgroundColor="{StaticResource Background}"
             NavigationPage.HasNavigationBar="True"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Alerts_Title}">

    <Grid RowDefinitions="Auto,*" Padding="24,16,24,0">
        <Label Grid.Row="0"
               Text="{local:Localize Key=Alerts_Title}"
               Style="{StaticResource HeadlineMedium}"
               SemanticProperties.HeadingLevel="Level1" />

        <RefreshView Grid.Row="1"
                     Command="{Binding LoadAlertsCommand}"
                     IsRefreshing="{Binding IsLoading}">
            <CollectionView x:Name="AlertsCollection"
                            ItemsSource="{Binding Alerts}"
                            SelectionMode="None"
                            Margin="0,16,0,0">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="8">
                        <VerticalStackLayout IsVisible="{Binding IsLoading}" Spacing="0">
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                            <views:SkeletonCardView />
                        </VerticalStackLayout>
                        <VerticalStackLayout IsVisible="{Binding IsEmpty}" Padding="0,64" Spacing="8" HorizontalOptions="Center">
                            <Label Text="🔔" FontSize="48" HorizontalOptions="Center" />
                            <Label Text="{local:Localize Key=Alerts_Empty_Title}" Style="{StaticResource TitleMedium}" HorizontalTextAlignment="Center" />
                            <Label Text="{local:Localize Key=Alerts_Empty_Subtitle}" Style="{StaticResource LabelSmall}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SafetyHazard">
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Border BackgroundColor="{StaticResource Error}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="8,4"
                                            SemanticProperties.Description="{Binding Severity, StringFormat='Severity: {0}'}">
                                        <Label Text="{Binding Severity}" TextColor="{StaticResource White}" FontSize="Caption" FontAttributes="Bold" />
                                    </Border>
                                    <Label Grid.Column="1" Text="{Binding Title}" Style="{StaticResource TitleMedium}" />
                                </Grid>
                                <Label Grid.Row="1" Text="{Binding Description}" Style="{StaticResource BodyMedium}" MaxLines="2" LineBreakMode="TailTruncation" />
                                <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="📍" Style="{StaticResource LabelSmall}" />
                                        <Label Text="{Binding Address}" Style="{StaticResource LabelSmall}" />
                                        <Label Text=" • " Style="{StaticResource LabelSmall}" />
                                        <Label Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelativeConverter}}" Style="{StaticResource LabelSmall}" />
                                    </HorizontalStackLayout>
                                    <Button Grid.Column="1"
                                            Text="{local:Localize Key=Alerts_Confirm}"
                                            Style="{StaticResource CompactPrimaryButton}"
                                            IsVisible="{Binding CanConfirm}"
                                            CommandParameter="{Binding Id}"
                                            Clicked="OnConfirmClicked" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
