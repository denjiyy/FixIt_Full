<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FixIt.Mobile.Views.ReportIssuePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FixIt.Mobile.Localization"
             xmlns:viewModels="clr-namespace:FixIt.Mobile.ViewModels"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:DataType="viewModels:ReportIssueViewModel"
             BackgroundColor="{StaticResource Background}"
             NavigationPage.HasNavigationBar="True"
             ios:Page.UseSafeArea="True"
             Title="{local:Localize Key=Report_Title}">

    <ScrollView>
        <VerticalStackLayout x:Name="FormRoot"
                             Opacity="0" TranslationY="25"
                             Padding="20,20,20,40"
                             Spacing="16">

            <!-- Photo Area -->
            <Border x:Name="PhotoBorder"
                    HeightRequest="220"
                    BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource Surface2}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20"
                    SemanticProperties.Description="{local:Localize Key=Report_PhotoTap}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding TakePhotoCommand}" />
                </Border.GestureRecognizers>
                <Grid>
                    <VerticalStackLayout IsVisible="{Binding HasPhoto, Converter={StaticResource InverseBoolConverter}}"
                                         Spacing="10"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">
                        <Label Text="📷" FontSize="44" HorizontalOptions="Center" />
                        <Label Text="{local:Localize Key=Report_PhotoPlaceholder}"
                               Style="{StaticResource TitleMedium}"
                               HorizontalOptions="Center" />
                        <Label Text="{local:Localize Key=Report_PhotoTap}"
                               Style="{StaticResource LabelSmall}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <Image x:Name="PhotoPreview"
                           Aspect="AspectFill"
                           IsVisible="{Binding HasPhoto}"
                           Source="{Binding CapturedPhotoSource}"
                           SemanticProperties.Description="{local:Localize Key=Detail_IssuePhoto}" />

                    <Border IsVisible="{Binding HasPhoto}"
                            BackgroundColor="#000000AA"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Padding="10,5"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="12">
                        <Label Text="{local:Localize Key=Report_Retake}"
                               FontSize="Caption"
                               FontAttributes="Bold"
                               TextColor="{StaticResource White}" />
                    </Border>
                </Grid>
            </Border>
            <Label Text="{Binding PhotoError}"
                   TextColor="{StaticResource Error}"
                   FontSize="Caption"
                   IsVisible="{Binding HasPhotoError}"
                   Margin="4,0,0,0" />

            <!-- Details Section -->
            <Label Text="{local:Localize Key=Report_Details}"
                   Style="{StaticResource LabelSmall}"
                   CharacterSpacing="1.5"
                   TextTransform="Uppercase"
                   Margin="0,8,0,0"
                   SemanticProperties.HeadingLevel="Level2" />

            <Border Style="{StaticResource EntryCard}">
                <Entry Placeholder="{local:Localize Key=Report_TitlePlaceholder}"
                       PlaceholderColor="{StaticResource OnSurfaceMuted}"
                       TextColor="{StaticResource OnBackground}"
                       Text="{Binding Title}"
                       MaxLength="200"
                       SemanticProperties.Hint="{local:Localize Key=Report_TitlePlaceholder}" />
            </Border>
            <Label Text="{Binding TitleError}"
                   TextColor="{StaticResource Error}"
                   FontSize="Caption"
                   IsVisible="{Binding HasTitleError}"
                   Margin="4,0,0,0" />

            <Border Style="{StaticResource EditorCard}" MinimumHeightRequest="110">
                <Editor Placeholder="{local:Localize Key=Report_DescPlaceholder}"
                        PlaceholderColor="{StaticResource OnSurfaceMuted}"
                        TextColor="{StaticResource OnBackground}"
                        AutoSize="TextChanges"
                        MaxLength="2000"
                        Text="{Binding Description}"
                        SemanticProperties.Hint="{local:Localize Key=Report_DescPlaceholder}" />
            </Border>
            <Label Text="{Binding DescriptionError}"
                   TextColor="{StaticResource Error}"
                   FontSize="Caption"
                   IsVisible="{Binding HasDescriptionError}"
                   Margin="4,0,0,0" />

            <!-- Location Section -->
            <Label Text="{local:Localize Key=Report_Location}"
                   Style="{StaticResource LabelSmall}"
                   CharacterSpacing="1.5"
                   TextTransform="Uppercase"
                   Margin="0,8,0,0"
                   SemanticProperties.HeadingLevel="Level2" />

            <Border Style="{StaticResource EntryCard}">
                <Entry Placeholder="{local:Localize Key=Report_LocationPlaceholder}"
                       PlaceholderColor="{StaticResource OnSurfaceMuted}"
                       TextColor="{StaticResource OnBackground}"
                       MaxLength="500"
                       Text="{Binding Location}"
                       SemanticProperties.Hint="{local:Localize Key=Report_LocationPlaceholder}" />
            </Border>
            <Label Text="{Binding LocationError}"
                   TextColor="{StaticResource Error}"
                   FontSize="Caption"
                   IsVisible="{Binding HasLocationError}"
                   Margin="4,0,0,0" />

            <!-- Submit -->
            <Button Text="{local:Localize Key=Report_Submit}"
                    Style="{StaticResource PrimaryButton}"
                    Opacity="{Binding CanSubmit, Converter={StaticResource BoolToOpacityConverter}}"
                    Command="{Binding SubmitCommand}"
                    Margin="0,8,0,0"
                    SemanticProperties.Description="{local:Localize Key=Report_Submit}" />

            <Label Text="{Binding SubmitError}"
                   TextColor="{StaticResource Error}"
                   FontSize="Caption"
                   IsVisible="{Binding HasSubmitError}"
                   HorizontalTextAlignment="Center" />

            <Label x:Name="SuccessCheckLabel"
                   Text="✅"
                   FontSize="48"
                   Scale="0" Opacity="0"
                   HorizontalOptions="Center"
                   IsVisible="{Binding SubmissionSucceeded}"
                   SemanticProperties.Description="{local:Localize Key=Report_Success}" />

            <ActivityIndicator IsRunning="{Binding IsSubmitting}"
                               IsVisible="{Binding IsSubmitting}"
                               Color="{StaticResource Primary}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
